@page "/payroll/periods"
@inject NavigationManager Navigation
@using System.Linq

<div class="card card-flush">
    <div class="card-header align-items-center py-5 gap-2 gap-md-5">
        <div class="card-title">
            <div class="d-flex align-items-center position-relative my-1">
                <i class="ki-outline ki-magnifier fs-3 position-absolute ms-4"></i>
                <input type="text" data-kt-ecommerce-order-filter="search" class="form-control form-control-solid w-250px ps-12" placeholder="Search Payroll">
            </div>
        </div>
        <div class="card-toolbar">
            <button type="button" class="btn btn-primary" @onclick="CreateNewPeriod">
                <i class="ki-outline ki-plus fs-2"></i> Generate Payroll
            </button>
        </div>
    </div>
    <div class="card-body pt-0">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5">
                <thead>
                    <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-100px">Period Name</th>
                        <th class="min-w-100px">Month/Year</th>
                        <th class="min-w-100px">Status</th>
                        <th class="min-w-100px">Total Payout</th>
                        <th class="text-end min-w-100px">Actions</th>
                    </tr>
                </thead>
                <tbody class="fw-semibold text-gray-600">
                    @foreach (var period in Periods)
                    {
                        <tr>
                            <td>
                                <a href="javascript:void(0)" @onclick="() => ViewDetail(period.Name)" class="text-gray-800 text-hover-primary fw-bold">@period.Name</a>
                            </td>
                            <td>
                                <span class="fw-bold">@period.Month/@period.Year</span>
                            </td>
                            <td>
                                <div class="badge badge-light-@(period.Status == "Closed" ? "success" : "warning") fw-bold">@period.Status</div>
                            </td>
                            <td>
                                <span class="fw-bold">@period.TotalAmount.ToString("N0") VND</span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-icon btn-active-light-primary w-30px h-30px me-3" title="View Details" @onclick="() => ViewDetail(period.Name)">
                                    <i class="ki-outline ki-eye fs-3"></i>
                                </button>
                                <button class="btn btn-icon btn-active-light-danger w-30px h-30px" title="Delete" @onclick="() => DeletePeriod(period)">
                                    <i class="ki-outline ki-trash fs-3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<PayrollPeriodViewModel> Periods = new();

    protected override void OnInitialized()
    {
        Periods = new List<PayrollPeriodViewModel>
        {
            new PayrollPeriodViewModel { Name = "Payroll Jan 2026", Month = 1, Year = 2026, Status = "Closed", TotalAmount = 500000000 },
            new PayrollPeriodViewModel { Name = "Payroll Feb 2026", Month = 2, Year = 2026, Status = "Draft", TotalAmount = 520000000 }
        };
    }

    private void CreateNewPeriod() 
    { 
        // Mock logic: Add a new period
        var lastPeriod = Periods.OrderByDescending(p => p.Year).ThenByDescending(p => p.Month).FirstOrDefault();
        var nextMonth = 1;
        var nextYear = 2026;

        if (lastPeriod != null)
        {
            if (lastPeriod.Month == 12)
            {
                nextMonth = 1;
                nextYear = lastPeriod.Year + 1;
            }
            else
            {
                nextMonth = lastPeriod.Month + 1;
                nextYear = lastPeriod.Year;
            }
        }

        Periods.Add(new PayrollPeriodViewModel 
        { 
            Name = $"Payroll {System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(nextMonth)} {nextYear}", 
            Month = nextMonth, 
            Year = nextYear, 
            Status = "Draft", 
            TotalAmount = 0 
        });
    }

    private void DeletePeriod(PayrollPeriodViewModel period)
    {
        Periods.Remove(period);
    }

    private void ViewDetail(string periodName)
    {
        // For demo, passing periodName as ID
        Navigation.NavigateTo($"/payroll/period/{periodName}");
    }

    public class PayrollPeriodViewModel
    {
        public string Name { get; set; }
        public int Month { get; set; }
        public int Year { get; set; }
        public string Status { get; set; }
        public decimal TotalAmount { get; set; }
    }
}
