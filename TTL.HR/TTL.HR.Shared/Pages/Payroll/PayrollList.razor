    private class PayrollItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Code { get; set; } = "";
        public string Department { get; set; } = "";
        public string Avatar { get; set; } = "";
        public string AvatarBg { get; set; } = "";
        public decimal BaseSalary { get; set; }
        public decimal Allowances { get; set; }
        public string WorkingDays { get; set; } = "";
        public decimal Deductions { get; set; }
        public decimal NetPay { get; set; }
        public string Status { get; set; } = "";
        public List<DetailItem> IncomeDetails { get; set; } = new();
        public List<DetailItem> DeductionDetails { get; set; } = new();
        public WorkSummaryData WorkSummary { get; set; } = new();
    }

    private class DetailItem
    {
        public string Title { get; set; }
        public decimal Amount { get; set; }
        public DetailItem(string title, decimal amount) { Title = title; Amount = amount; }
    }

    private class WorkSummaryData
    {
        public string Standard { get; set; } = "";
        public string Overtime { get; set; } = "";
        public string LateEarly { get; set; } = "";
    }

    private HashSet<int> _selectedIds = new();

    private void ToggleSelectAll(object? checkedValue)
    {
        if (checkedValue is bool isChecked && isChecked)
        {
            _selectedIds = _payrolls.Select(x => x.Id).ToHashSet();
        }
        else
        {
            _selectedIds.Clear();
        }
    }

    private void ToggleSelect(int id, object? checkedValue)
    {
        if (checkedValue is bool isChecked && isChecked)
        {
            _selectedIds.Add(id);
        }
        else
        {
            _selectedIds.Remove(id);
        }
    }

    private bool IsSelected(int id) => _selectedIds.Contains(id);

    private void FinalizePayroll()
    {
        if (_selectedIds.Any())
        {
            var itemsToUpdate = _payrolls.Where(p => _selectedIds.Contains(p.Id)).ToList();
            foreach (var item in itemsToUpdate)
            {
                item.Status = "Đã chốt";
            }
        }
    }

    private void FinalizeAll()
    {
        foreach (var item in _payrolls)
        {
            item.Status = "Đã chốt";
        }
    }

