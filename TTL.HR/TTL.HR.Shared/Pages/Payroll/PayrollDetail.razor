@page "/payroll/period/{Year:int}/{Month:int}"
@using TTL.HR.Shared.Components.Common

<PageTitle>Chi tiết bảng lương tháng @Month/@Year - TTL.HR</PageTitle>

<div class="card card-flush shadow-sm border-0">
    <!--begin::Header-->
    <div class="card-header align-items-center py-5 gap-2 gap-md-5 border-0">
        <div class="card-title">
            <div class="d-flex align-items-center position-relative my-1">
                <i class="ki-outline ki-magnifier fs-3 position-absolute ms-4 text-gray-500"></i>
                <input type="text" class="form-control form-control-solid w-250px ps-12" placeholder="Tìm theo tên, mã NV..." @bind="SearchTerm" @bind:event="oninput">
            </div>
            
            <div class="ms-3 d-none d-md-block">
                <div class="p-3 bg-light rounded fw-bold text-gray-700">
                    Kỳ lương tháng @Month/@Year
                </div>
            </div>
        </div>
        
        <div class="card-toolbar d-flex gap-2">
            <button type="button" class="btn btn-light-primary fw-bold"><i class="ki-outline ki-file-up fs-2 me-1"></i> Xuất Excel</button>
            <button type="button" class="btn btn-primary fw-bold" @onclick="FinalizePayroll"><i class="ki-outline ki-check-circle fs-2 me-1"></i> Chốt lương tháng này</button>
        </div>
    </div>
    <!--end::Header-->

    <div class="card-body pt-0">
        <div class="mb-5 mt-2 d-flex align-items-center justify-content-between">
            <div class="form-check form-check-custom form-check-solid">
                <input class="form-check-input" type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected" />
                <label class="form-check-label fw-bold text-gray-700 ms-3">Chọn tất cả (@FilteredPayslips.Count() nhân viên)</label>
            </div>
            <div class="text-muted fs-7">
                <i class="ki-outline ki-information-5 fs-5 me-1"></i> Nhấn vào tên nhân viên để điều chỉnh lương chi tiết.
            </div>
        </div>

        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10">
            <div class="table-responsive">
                <table class="table align-middle table-row-dashed fs-6 gy-5">
                    <thead class="bg-light">
                        <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                            <th class="w-10px pe-2 ps-4"></th>
                            <th class="min-w-250px">NHÂN VIÊN</th>
                            <th class="min-w-125px text-end">LƯƠNG CƠ BẢN</th>
                            <th class="min-w-125px text-end">PHỤ CẤP</th>
                            <th class="min-w-125px text-center">NGÀY CÔNG</th>
                            <th class="min-w-125px text-end text-danger">GIẢM TRỪ</th>
                            <th class="min-w-125px text-end text-primary">THỰC LĨNH</th>
                            <th class="min-w-100px text-center">TRẠNG THÁI</th>
                        </tr>
                    </thead>
                    <tbody class="fw-semibold text-gray-700">
                        @if (FilteredPayslips.Any())
                        {
                            @foreach (var slip in FilteredPayslips)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="form-check form-check-custom form-check-solid">
                                            <input class="form-check-input" type="checkbox" @bind="slip.IsSelected" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center cursor-pointer" @onclick="() => OpenDetailDrawer(slip)">
                                            <div class="symbol symbol-circle symbol-40px overflow-hidden me-3 border border-gray-300">
                                                @if (!string.IsNullOrEmpty(slip.AvatarUrl))
                                                {
                                                    <img src="@slip.AvatarUrl" alt="" />
                                                }
                                                else
                                                {
                                                    <span class="symbol-label bg-light-primary text-primary fw-bold">@slip.EmployeeName.Substring(0, 1)</span>
                                                }
                                            </div>
                                            <div class="d-flex flex-column">
                                                <a href="javascript:void(0)" class="text-gray-800 text-hover-primary fs-6 fw-bold">@slip.EmployeeName</a>
                                                <span class="text-muted fs-7">@slip.EmployeeCode • @slip.Department</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold">@slip.BasicSalary.ToString("N0") đ</td>
                                    <td class="text-end text-success fw-bold">+@slip.TotalAllowances.ToString("N0") đ</td>
                                    <td class="text-center">
                                        <span class="fw-bold">@slip.ActualWorkDays</span>/@slip.StandardWorkDays
                                    </td>
                                    <td class="text-end text-danger fw-bold">-@slip.TotalDeductions.ToString("N0") đ</td>
                                    <td class="text-end fw-bolder text-primary fs-5">@slip.NetSalary.ToString("N0") đ</td>
                                    <td class="text-center">
                                        <span class="badge @(slip.Status == "Đã chốt" ? "badge-light-success" : "badge-light-warning") fw-bold py-2 px-3">@slip.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-10">Không tìm thấy dữ liệu nhân viên.</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-light-primary bg-opacity-10">
                        <tr class="fw-bolder fs-6 text-gray-800">
                            <td colspan="2" class="ps-10 py-5">TỔNG CỘNG (@FilteredPayslips.Count() nhân viên)</td>
                            <td class="text-end">@Payslips.Sum(p => p.BasicSalary).ToString("N0") đ</td>
                            <td class="text-end text-success">+@Payslips.Sum(p => p.TotalAllowances).ToString("N0") đ</td>
                            <td class="text-center">--</td>
                            <td class="text-end text-danger">-@Payslips.Sum(p => p.TotalDeductions).ToString("N0") đ</td>
                            <td class="text-end text-primary fs-4">@Payslips.Sum(p => p.NetSalary).ToString("N0") đ</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </SkeletonLoading>
    </div>
</div>

<!-- PAYSLIP DETAIL DRAWER -->
<div class="drawer drawer-end @(IsDrawerOpen ? "drawer-on" : "")" style="width: 500px; max-width: 100vw; z-index: 1060; transition: transform 0.3s ease-in-out; position: fixed; right: 0; top: 0; bottom: 0; background: white; box-shadow: -10px 0 30px rgba(0,0,0,0.1); transform: @(IsDrawerOpen ? "translateX(0)" : "translateX(100%)")">
    @if (SelectedSlip != null)
    {
        <div class="card w-100 rounded-0 border-0 h-100 shadow-lg">
            <div class="card-header border-0 pt-7 mb-2 ms-2">
                <h3 class="card-title fw-bolder text-gray-900 fs-2">Điều chỉnh Phiếu lương</h3>
                <div class="card-toolbar">
                    <button class="btn btn-sm btn-icon btn-active-light-primary" @onclick="CloseDrawer">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </button>
                </div>
            </div>
            <div class="card-body p-9 scroll-y">
                <!-- User Info -->
                <div class="d-flex align-items-center mb-8 bg-light p-6 rounded">
                    <div class="symbol symbol-70px symbol-circle me-5 border border-white border-4 shadow-sm">
                         <img src="@SelectedSlip.AvatarUrl" alt="" />
                    </div>
                    <div class="d-flex flex-column">
                        <span class="fs-4 fw-bold text-gray-900 mb-1">@SelectedSlip.EmployeeName</span>
                        <span class="fs-7 fw-semibold text-gray-500">Mã NV: @SelectedSlip.EmployeeCode</span>
                        <span class="fs-7 fw-semibold text-gray-500">@SelectedSlip.Department</span>
                    </div>
                </div>

                <div class="mb-10">
                    <h4 class="fw-bold mb-5 fs-6 text-uppercase text-gray-500 border-bottom pb-2">Các khoản điều chỉnh</h4>
                    
                    <div class="mb-6">
                        <label class="form-label fw-bold">Lương cơ bản (VND)</label>
                        <input type="number" class="form-control form-control-solid fw-bold text-primary fs-5" @bind="SelectedSlip.BasicSalary" />
                    </div>

                    <div class="mb-6">
                        <label class="form-label fw-bold">Các khoản Phụ cấp (+)</label>
                        <input type="number" class="form-control form-control-solid fw-bold text-success fs-5" @bind="SelectedSlip.TotalAllowances" />
                    </div>

                    <div class="mb-6">
                        <label class="form-label fw-bold">Các khoản Giảm trừ (-)</label>
                        <input type="number" class="form-control form-control-solid fw-bold text-danger fs-5" @bind="SelectedSlip.TotalDeductions" />
                    </div>
                </div>

                <div class="bg-dark rounded p-8 d-flex flex-stack shadow">
                    <div class="d-flex flex-column">
                        <span class="text-white fw-bold fs-6">THỰC LĨNH SAU ĐIỀU CHỈNH</span>
                        <span class="text-gray-500 fs-8">Tính toán tự động theo công thức</span>
                    </div>
                    <span class="text-primary fw-bolder fs-1">@((SelectedSlip.BasicSalary + SelectedSlip.TotalAllowances - SelectedSlip.TotalDeductions).ToString("N0")) đ</span>
                </div>
            </div>
            <div class="card-footer border-0 py-8 px-9 d-flex gap-3">
                <button type="button" class="btn btn-light fw-bold flex-grow-1" @onclick="CloseDrawer">Hủy bỏ</button>
                <button type="button" class="btn btn-primary fw-bold flex-grow-1" @onclick="SaveAdjustments">Lưu thay đổi</button>
            </div>
        </div>
    }
</div>

@if (IsDrawerOpen)
{
    <div class="modal-backdrop fade show" @onclick="CloseDrawer" style="z-index: 1050"></div>
}
