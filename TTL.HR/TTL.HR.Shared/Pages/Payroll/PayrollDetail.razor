@page "/payroll/period/{Id}"
@page "/payroll/period/{Year:int}/{Month:int}"
@using TTL.HR.Shared.Components.Common
@inject IFormatService FormatService



<PageTitle>Chi tiết bảng lương - TTL.HR</PageTitle>

@using TTL.HR.Application.Modules.Payroll.Models
@using TTL.HR.Application.Modules.Organization.Models

<PageTitle>@PeriodName - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">

        <!-- Unified Filters Bar -->
        <EmployeeToolbar 
            SearchQuery="@SearchTerm"
            Departments="@_departments"
            OnSearchChanged="OnSearchChange"
            OnDepartmentChanged="OnDepartmentChange"
            OnRefresh="LoadData"
            ShowExport="true">
            <ExtraFilters>
                <div class="d-flex align-items-center me-4 my-1 bg-light px-4 py-2 rounded border border-gray-200">
                    <i class="ki-outline ki-calendar-8 fs-4 me-2 text-primary"></i>
                    <span class="fw-bold text-gray-700 fs-7">@PeriodName</span>
                    @if (SelectedPeriod != null)
                    {
                        <span class="badge badge-light-@GetStatusColor(SelectedPeriod.StatusColor, SelectedPeriod.Status) fw-bold px-3 py-1 ms-2">
                             @(string.IsNullOrEmpty(SelectedPeriod.StatusName) ? SelectedPeriod.Status : SelectedPeriod.StatusName)
                        </span>
                    }
                </div>
            </ExtraFilters>
            <CustomActions>
                @if (SelectedPeriod != null && !SelectedPeriod.Id.StartsWith("VIRTUAL"))
                {
                    <button type="button" class="btn btn-primary fw-bold fs-7 px-6" @onclick="FinalizePayroll">
                        <i class="ki-outline ki-check-circle fs-3 me-1"></i> Chốt lương tháng này
                    </button>
                    <button type="button" class="btn btn-light-success fw-bold fs-7 px-6 ms-2" @onclick="ReCalculatePayroll">
                        <i class="ki-outline ki-arrows-loop fs-3 me-1"></i> Tính toán lại (Live)
                    </button>
                }
                else if (SelectedPeriod != null && SelectedPeriod.Id.StartsWith("VIRTUAL"))
                {
                    <button type="button" class="btn btn-primary fw-bold fs-7 px-6" @onclick="ReCalculatePayroll">
                        <i class="ki-outline ki-plus fs-3 me-1"></i> Khởi tạo bảng lương chính thức
                    </button>
                }
            </CustomActions>
        </EmployeeToolbar>

        @if (SelectedPeriod != null)
        {
            <!-- Dashboard Summary -->
            <div class="row g-5 mb-8 mt-1 px-5">
                <!-- TỔNG THỰC LĨNH -->
                <div class="col-md-3">
                    <div class="card card-flush bg-@GetStatusBg(SelectedPeriod.StatusColor, SelectedPeriod.Status) h-100 shadow-sm border border-white border-opacity-10 rounded-3">
                        <div class="card-header pt-5 overflow-hidden position-relative min-h-125px">
                            <div class="card-title d-flex flex-column z-index-1">
                                 <span class="fs-2hx fw-bold text-white me-2 lh-1 ls-n2">@FormatService.FormatCurrency(SelectedPeriod.TotalNetSalary)</span>
                                 <span class="text-white text-opacity-70 pt-1 fw-semibold fs-6 text-uppercase">TỔNG THỰC LĨNH</span>
                            </div>
                            <i class="ki-outline ki-wallet fs-4tx text-white opacity-20 position-absolute end-0 bottom-0 mb-n5 me-n5"></i>
                        </div>
                    </div>
                </div>

                <!-- TỔNG THUẾ -->
                <div class="col-md-3">
                    <div class="card card-flush bg-light-danger h-100 shadow-sm border border-danger border-opacity-10 rounded-3">
                        <div class="card-header pt-5 overflow-hidden position-relative min-h-125px">
                            <div class="card-title d-flex flex-column z-index-1">
                                 <span class="fs-2hx fw-bold text-danger me-2 lh-1 ls-n2">@FormatService.FormatCurrency(SelectedPeriod.TotalTax)</span>
                                 <span class="text-danger text-opacity-70 pt-1 fw-semibold fs-6 text-uppercase">TỔNG THUẾ TNCN</span>
                            </div>
                            <i class="ki-outline ki-book-open fs-4tx text-danger opacity-10 position-absolute end-0 bottom-0 mb-n5 me-n5"></i>
                        </div>
                    </div>
                </div>

                <!-- TỔNG BẢO HIỂM -->
                <div class="col-md-3">
                    <div class="card card-flush bg-light-success h-100 shadow-sm border border-success border-opacity-10 rounded-3">
                        <div class="card-header pt-5 overflow-hidden position-relative min-h-125px">
                            <div class="card-title d-flex flex-column z-index-1">
                                 <span class="fs-2hx fw-bold text-success me-2 lh-1 ls-n2">@FormatService.FormatCurrency(SelectedPeriod.TotalInsurance)</span>
                                 <span class="text-success text-opacity-70 pt-1 fw-semibold fs-6 text-uppercase">TỔNG BẢO HIỂM</span>
                            </div>
                            <i class="ki-outline ki-shield-tick fs-4tx text-success opacity-10 position-absolute end-0 bottom-0 mb-n5 me-n5"></i>
                        </div>
                    </div>
                </div>

                <!-- TỔNG NHÂN SỰ -->
                <div class="col-md-3">
                    <div class="card card-flush h-100 shadow-sm border border-gray-200 rounded-3">
                        <div class="card-header pt-5 overflow-hidden position-relative min-h-125px">
                            <div class="card-title d-flex flex-column z-index-1">
                                 <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@SelectedPeriod.EmployeeCount</span>
                                 <span class="text-gray-500 pt-1 fw-semibold fs-6 text-uppercase">TỔNG NHÂN SỰ</span>
                            </div>
                            <i class="ki-outline ki-profile-user fs-4tx text-gray-200 opacity-50 position-absolute end-0 bottom-0 mb-n5 me-n5"></i>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Selection & Summary Bar -->
        <div class="d-flex flex-stack mb-6 mt-4">
            <div class="d-flex align-items-center">
                <div class="form-check form-check-sm form-check-custom form-check-solid me-5">
                    <input class="form-check-input" type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected" id="check_all_payroll" />
                    <label class="form-check-label fw-bold text-gray-700 fs-7 ms-2 text-nowrap" for="check_all_payroll">
                        Chọn tất cả (@FilteredPayslips.Count() nhân viên)
                    </label>
                </div>
                <div class="text-muted fs-8 fw-semibold ms-2">
                    <i class="ki-outline ki-information-5 fs-7 me-1 text-primary"></i> 
                    Mapping Status: <span class="badge badge-light-success fw-bold">Live Data</span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-gray-500 fs-7">Công thức mapping:</span>
                <code class="bg-light-dark text-dark px-3 py-1 rounded fs-9 fw-bold ms-1">(Lương CB / @(Payslips.FirstOrDefault()?.StandardWorkDays ?? 22)) * Công + OT + Phụ cấp - BH - Thuế</code>
            </div>
        </div>

        <!-- Standardized Data Grid -->
        <EmployeeDataGrid 
            TItem="PayslipViewModel"
            Items="FilteredPayslips"
            IsLoading="_isLoading"
            TotalCount="_totalCount"
            PageSize="_pageSize"
            CurrentPage="_page"
            OnPageChanged="OnPageChanged"
            Rows="10"
            Columns="8">
            <HeaderTemplate>
                <th class="w-10px pe-2 ps-4"></th>
                <th class="min-w-250px">NHÂN VIÊN</th>
                <th class="min-w-120px text-end">LƯƠNG CƠ BẢN</th>
                <th class="min-w-120px text-end text-success">PHỤ CẤP</th>
                <th class="min-w-100px text-center">NGÀY CÔNG</th>
                <th class="min-w-120px text-end text-danger">GIẢM TRỪ</th>
                <th class="min-w-120px text-end text-primary">THỰC LĨNH</th>
                <th class="min-w-100px text-center">TRẠNG THÁI</th>
            </HeaderTemplate>
            <RowTemplate Context="slip">
                <td class="ps-4">
                    <div class="form-check form-check-custom form-check-solid">
                        <input class="form-check-input" type="checkbox" @bind="slip.IsSelected" @onclick:stopPropagation />
                    </div>
                </td>
                <td class="d-flex align-items-center">
                    <div class="symbol symbol-circle symbol-50px overflow-hidden me-3 shadow-xs">
                        <a href="javascript:;" class="kt_drawer_employee_detail_toggle" @onclick="() => OpenDetailDrawer(slip)">
                            @if (!string.IsNullOrEmpty(slip.AvatarUrl))
                            {
                                <div class="symbol-label"><img src="@slip.AvatarUrl" alt="" class="w-100" /></div>
                            }
                            else
                            {
                                <div class="symbol-label bg-light-primary text-primary fw-bolder">@(slip.EmployeeName?.Length > 0 ? slip.EmployeeName.Substring(0, 1) : "P")</div>
                            }
                        </a>
                    </div>
                    <div class="d-flex flex-column">
                        <a href="javascript:;" class="kt_drawer_employee_detail_toggle text-gray-900 fw-bold text-hover-primary mb-1 fs-6" @onclick="() => OpenDetailDrawer(slip)">@slip.EmployeeName</a>
                        <span class="text-muted fw-semibold fs-7">@slip.EmployeeCode • @slip.Department</span>
                        @if (!string.IsNullOrEmpty(slip.WarningMessage))
                        {
                            <span class="text-danger fs-9 fw-bold mt-1">
                                <i class="ki-outline ki-information-5 fs-9 text-danger me-1"></i>
                                @slip.WarningMessage
                            </span>
                        }
                    </div>
                </td>
                <td class="text-end fw-bold">@FormatService.FormatCurrency(slip.BasicSalary)</td>
                <td class="text-end text-success fw-bold">
                    <div class="d-flex flex-column align-items-end">
                        <span>+@FormatService.FormatCurrency(slip.TotalAllowances)</span>
                        @if (slip.Bonus > 0)
                        {
                            <span class="fs-9 text-dark">Thưởng: @FormatService.FormatCurrency(slip.Bonus)</span>
                        }
                    </div>
                </td>
                <td class="text-center">
                    <div class="d-flex flex-column">
                        <span class="fw-bolder">@slip.ActualWorkDays/@slip.StandardWorkDays</span>
                        <div class="progress h-4px w-100 mt-1 bg-light-success">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @(slip.StandardWorkDays > 0 ? (slip.ActualWorkDays * 100 / slip.StandardWorkDays) : 0)%"></div>
                        </div>
                    </div>
                </td>
                <td class="text-end text-danger fw-bold">-@FormatService.FormatCurrency(slip.GrandTotalDeductions)</td>
                <td class="text-end text-primary fs-5 fw-bolder">@FormatService.FormatCurrency(slip.NetSalary)</td>
                <td class="text-center">
                    <span class="badge badge-light-@GetStatusColor(slip.StatusColor, slip.Status) fw-bold px-4 py-2 rounded-pill">
                        @(string.IsNullOrEmpty(slip.StatusName) ? slip.Status : slip.StatusName)
                    </span>
                </td>
            </RowTemplate>
            <FooterTemplate>
                <tr class="bg-light-primary bg-opacity-5">
                    <td></td>
                    <td class="py-5 ps-0 fw-bolder text-gray-800">TỔNG CỘNG (@_totalCount NS):</td>
                    <td class="text-end fw-bolder">@FormatService.FormatCurrency(Payslips.Sum(p => p.BasicSalary))</td>
                    <td class="text-end fw-bolder text-success">@FormatService.FormatCurrency(Payslips.Sum(p => p.TotalAllowances + p.Bonus))</td>
                    <td class="text-center">--</td>
                    <td class="text-end fw-bolder text-danger">@FormatService.FormatCurrency(Payslips.Sum(p => p.GrandTotalDeductions))</td>
                    <td class="text-end fw-bolder text-primary fs-4">@FormatService.FormatCurrency(Payslips.Sum(p => p.NetSalary))</td>
                    <td></td>
                </tr>
            </FooterTemplate>
        </EmployeeDataGrid>

    </div>
</div>

<!-- PAYSLIP DETAIL DRAWER -->
<div class="drawer drawer-end @(IsDrawerOpen ? "drawer-on" : "")" style="width: 800px; max-width: 100vw; z-index: 1060; transition: transform 0.3s ease-in-out; position: fixed; right: 0; top: 0; bottom: 0; background: white; box-shadow: -10px 0 30px rgba(0,0,0,0.1); transform: @(IsDrawerOpen ? "translateX(0)" : "translateX(100%)")">
    @if (SelectedSlip != null)
    {
        <div class="card w-100 rounded-0 border-0 h-100 shadow-lg">
            <div class="card-header border-0 pt-7 mb-2 ms-2">
                <h3 class="card-title fw-bolder text-gray-900 fs-2">Điều chỉnh Phiếu lương</h3>
                <div class="card-toolbar">
                    <button class="btn btn-sm btn-icon btn-active-light-primary" @onclick="CloseDrawer">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </button>
                </div>
            </div>
            <div class="card-body p-9 scroll-y">
                <!-- User Info Header (Black as circled in frame) -->
                <div class="d-flex align-items-center mb-8 bg-gray-900 p-6 rounded shadow-sm text-white">
                    <div class="symbol symbol-70px symbol-circle me-5 border border-white border-opacity-10 shadow-sm">
                         <img src="@SelectedSlip.AvatarUrl" alt="" />
                    </div>
                    <div class="d-flex flex-column">
                        <span class="fs-4 fw-bold text-white mb-1">@SelectedSlip.EmployeeName</span>
                        <div class="d-flex align-items-center">
                            <span class="fs-7 fw-semibold text-gray-500">Mã NV: @SelectedSlip.EmployeeCode</span>
                            <span class="bullet bullet-dot bg-success h-6px w-6px ms-2 me-2"></span>
                            <span class="fs-7 fw-semibold text-gray-500">@SelectedSlip.Department</span>
                        </div>
                    </div>
                </div>

                <!-- Dynamic Formula Mapping Section -->
                <div class="mb-10">
                    <div class="d-flex flex-stack mb-5 border-bottom pb-2">
                        <h4 class="fw-bold fs-6 text-uppercase text-gray-500 mb-0">Công thức & Mapping động</h4>
                        <span class="badge badge-light-primary fw-bold">Live Calc</span>
                    </div>
                    
                    <div class="bg-gray-50 rounded p-5 mb-8 border border-dashed border-gray-300">
                        <div class="d-flex flex-stack mb-3">
                            <span class="text-gray-600 fs-7">Lương cơ bản mapping từ HĐ:</span>
                            <span class="text-gray-900 fw-bold">@FormatService.FormatCurrency(SelectedSlip.BasicSalary)</span>
                        </div>
                        <div class="d-flex flex-stack mb-3">
                            <span class="text-gray-600 fs-7">Số ngày công chuẩn (Tháng @Month):</span>
                            <span class="text-gray-900 fw-bold">@SelectedSlip.StandardWorkDays ngày</span>
                        </div>
                        <div class="separator separator-dashed my-3"></div>
                        <div class="d-flex flex-stack mb-1">
                            <span class="text-primary fw-bold fs-7">Lương tính từng ngày (Mặc định):</span>
                            <span class="text-primary fw-bolder">@FormatService.FormatCurrency(SelectedSlip.StandardWorkDays > 0 ? SelectedSlip.BasicSalary / (decimal)SelectedSlip.StandardWorkDays : 0)</span>
                        </div>
                        <div class="text-muted fs-9 italic">*(Công thức: BasicSalary / StandardDays)*</div>
                    </div>

                    <div class="row g-5 mb-8">
                        <div class="col-4">
                            <div class="card bg-light-success border-0 p-4">
                                <label class="form-label text-success fs-8 mb-1 fw-bolder text-uppercase">Công đi làm</label>
                                <div class="fw-bold fs-4 text-gray-800">@(SelectedSlip.ActualWorkDays - SelectedSlip.LeaveDays - SelectedSlip.HolidayDays) <span class="fs-7 fw-normal text-muted">ngày</span></div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card bg-light-info border-0 p-4">
                                <label class="form-label text-info fs-8 mb-1 fw-bolder text-uppercase">Nghỉ phép/Lễ</label>
                                <div class="fw-bold fs-4 text-gray-800">@(SelectedSlip.LeaveDays + SelectedSlip.HolidayDays) <span class="fs-7 fw-normal text-muted">ngày</span></div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card bg-light-primary border-0 p-4">
                                <label class="form-label text-primary fs-8 mb-1 fw-bolder text-uppercase">Tổng công mapping</label>
                                <div class="fw-bold fs-4 text-gray-800">@SelectedSlip.ActualWorkDays <span class="fs-7 fw-normal text-muted">ngày</span></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-5 bg-light rounded p-4 border border-dashed border-gray-300">
                        <div class="d-flex flex-stack mb-2">
                             <div class="d-flex flex-column">
                                 <span class="text-gray-700 fw-bold">Thành tiền công ngày:</span>
                                 <span class="text-muted fs-8">(@SelectedSlip.ActualWorkDays ngày x <span class="text-primary fw-bold">@FormatService.FormatCurrency(SelectedSlip.StandardWorkDays > 0 ? SelectedSlip.BasicSalary / (decimal)SelectedSlip.StandardWorkDays : 0)</span>)</span>
                             </div>
                             <span class="text-dark fw-bolder">@FormatService.FormatCurrency(SelectedSlip.TotalWorkSalary)</span>
                        </div>
                        
                        @if (SelectedSlip.OvertimeHours > 0)
                        {
                            <div class="separator separator-dashed my-3"></div>
                            
                            var otNormal = Math.Max(0, SelectedSlip.OvertimeHours - SelectedSlip.OvertimeHoursWeekend - SelectedSlip.OvertimeHoursHoliday);
                            var hourlyRate = SelectedSlip.StandardWorkDays > 0 ? (SelectedSlip.BasicSalary / (decimal)SelectedSlip.StandardWorkDays / 8m) : 0;
                            
                            @if (otNormal > 0)
                            {
                                <div class="d-flex flex-stack mb-2">
                                     <div class="d-flex flex-column">
                                         <span class="text-gray-700 fw-bold">Tăng ca ngày thường (@((SelectedSlip.OtRateWeekday * 100).ToString("F0"))%):</span>
                                         <span class="text-muted fs-8">(@otNormal h x <span class="text-success fw-bold">@FormatService.FormatCurrency(hourlyRate * (decimal)SelectedSlip.OtRateWeekday)</span>)</span>
                                     </div>
                                     <span class="text-dark fw-bolder">@FormatService.FormatCurrency(Math.Round(hourlyRate * (decimal)otNormal * (decimal)SelectedSlip.OtRateWeekday, 0))</span>
                                </div>
                            }

                            @if (SelectedSlip.OvertimeHoursWeekend > 0)
                            {
                                <div class="d-flex flex-stack mb-2 @(otNormal > 0 ? "mt-3" : "")">
                                     <div class="d-flex flex-column">
                                         <span class="text-gray-700 fw-bold">Tăng ca Cuối tuần (@((SelectedSlip.OtRateWeekend * 100).ToString("F0"))%):</span>
                                         <span class="text-muted fs-8">(@SelectedSlip.OvertimeHoursWeekend h x <span class="text-primary fw-bold">@FormatService.FormatCurrency(hourlyRate * (decimal)SelectedSlip.OtRateWeekend)</span>)</span>
                                     </div>
                                     <span class="text-dark fw-bolder">@FormatService.FormatCurrency(SelectedSlip.OvertimeSalaryWeekend)</span>
                                </div>
                            }

                            @if (SelectedSlip.OvertimeHoursHoliday > 0)
                            {
                                <div class="d-flex flex-stack mb-2 @(otNormal > 0 || SelectedSlip.OvertimeHoursWeekend > 0 ? "mt-3" : "")">
                                     <div class="d-flex flex-column">
                                         <span class="text-gray-700 fw-bold">Tăng ca Lễ/Tết (@((SelectedSlip.OtRateHoliday * 100).ToString("F0"))%):</span>
                                         <span class="text-muted fs-8">(@SelectedSlip.OvertimeHoursHoliday h x <span class="text-danger fw-bold">@FormatService.FormatCurrency(hourlyRate * (decimal)SelectedSlip.OtRateHoliday)</span>)</span>
                                     </div>
                                     <span class="text-dark fw-bolder">@FormatService.FormatCurrency(SelectedSlip.OvertimeSalaryHoliday)</span>
                                </div>
                            }
                            
                            <div class="separator separator-dashed my-3"></div>
                            <div class="d-flex flex-stack">
                                <span class="text-gray-800 fw-bolder">Tổng tiền tăng ca:</span>
                                <span class="text-dark fw-bolder fs-5">@FormatService.FormatCurrency(SelectedSlip.OvertimeSalary)</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="mb-10">
                    <h4 class="fw-bold mb-5 fs-6 text-uppercase text-gray-500 border-bottom pb-2">Điều chỉnh Thông tin lương</h4>
                    <div class="row g-5 mb-5">
                        <div class="col-6">
                            <label class="form-label fs-7 fw-bold">Lương cơ bản (HĐ):</label>
                            <input type="number" class="form-control form-control-solid" @bind="SelectedSlip.BasicSalary" @bind:event="oninput" @onkeyup="SelectedSlip.CalculateNet" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fs-7 fw-bold">Tổng phụ cấp:</label>
                            <input type="number" class="form-control form-control-solid" @bind="SelectedSlip.TotalAllowances" @bind:event="oninput" @onkeyup="SelectedSlip.CalculateNet" />
                        </div>
                    </div>
                    @if (SelectedSlip.AllowanceDetails != null && SelectedSlip.AllowanceDetails.Any())
                    {
                        <div class="bg-light-success rounded p-4 border border-success border-dashed">
                            <div class="d-flex flex-stack mb-3">
                                <span class="fw-bold text-success fs-7 text-uppercase">Phụ cấp theo setup nhân viên</span>
                                <span class="badge badge-light-success fw-bold">@SelectedSlip.AllowanceDetails.Count khoản</span>
                            </div>
                            @foreach (var item in SelectedSlip.AllowanceDetails)
                            {
                                <div class="d-flex flex-stack mb-2 py-1 border-bottom border-dashed border-gray-200">
                                    <div class="d-flex align-items-center">
                                        <i class="ki-outline ki-gift fs-7 text-success me-2"></i>
                                        <span class="text-gray-700 fw-semibold fs-7">@item.Name</span>
                                    </div>
                                    <span class="text-success fw-bolder">+@FormatService.FormatCurrency(item.Amount)</span>
                                </div>
                            }
                            <div class="d-flex flex-stack pt-2 mt-1">
                                <span class="text-gray-700 fw-bolder">Tổng cộng:</span>
                                <span class="text-success fw-bolder fs-5">+@FormatService.FormatCurrency(SelectedSlip.AllowanceDetails.Sum(x => x.Amount))</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning fs-8 py-3">
                            <i class="ki-outline ki-information-5 fs-7 me-2"></i>
                            Nhân viên này chưa được thiết lập phụ cấp. Vui lòng cấu hình trong module Phú cấp & Phúc lợi.
                        </div>
                    }
                </div>

                <div class="mb-10">
                    <h4 class="fw-bold mb-5 fs-6 text-uppercase text-gray-500 border-bottom pb-2">Chi tiết lịch sử chấm công (Mapping)</h4>
                    <div style="zoom: 0.9">
                         <TTL.HR.Shared.Pages.User.Components.UserAttendanceHistory EmployeeId="@SelectedSlip.EmployeeId" />
                    </div>
                </div>

                <div class="mb-10">
                    <h4 class="fw-bold mb-5 fs-6 text-uppercase text-gray-500 border-bottom pb-2">Thu nhập khác & Tăng ca</h4>
                    
                    <div class="mb-5 bg-light-info p-5 rounded-3 border border-info border-dashed shadow-sm">
                        @if (SelectedSlip.OvertimeHours > 0)
                        {
                            <div class="d-flex flex-stack mb-2">
                                 <span class="text-gray-800 fw-bold">Tăng ca mapping (@SelectedSlip.OvertimeHours h):</span>
                                 <span class="text-gray-900 fw-bolder">@FormatService.FormatCurrency(SelectedSlip.OvertimeSalary)</span>
                            </div>
                        }
                        @if (SelectedSlip.AllowanceDetails != null && SelectedSlip.AllowanceDetails.Any())
                        {
                            @foreach (var item in SelectedSlip.AllowanceDetails)
                            {
                                <div class="d-flex flex-stack mb-2">
                                    <span class="text-gray-700 fw-semibold">
                                        <i class="ki-outline ki-check-circle fs-7 text-success me-1"></i>@item.Name:
                                    </span>
                                    <span class="text-gray-900 fw-bold">+@FormatService.FormatCurrency(item.Amount)</span>
                                </div>
                            }
                            <div class="separator separator-dashed border-info opacity-20 my-2"></div>
                        }
                        <div class="d-flex flex-stack mb-2">
                             <span class="text-gray-800 fw-bold">Tổng phụ cấp mapping:</span>
                             <span class="text-gray-900 fw-bolder">@FormatService.FormatCurrency(SelectedSlip.TotalAllowances)</span>
                        </div>
                        @if (SelectedSlip.Bonus > 0)
                        {
                            <div class="d-flex flex-stack mb-2">
                                 <span class="text-gray-800 fw-bold">Thưởng/KPI:</span>
                                 <span class="text-success fw-bolder">+@FormatService.FormatCurrency(SelectedSlip.Bonus)</span>
                            </div>
                        }
                        <div class="d-flex flex-stack border-top border-info border-opacity-50 pt-3 mt-3">
                             <span class="text-info-emphasis fw-bolder fs-5">TỔNG THU NHẬP (GROSS):</span>
                             <span class="text-info-emphasis fw-bolder fs-4">@FormatService.FormatCurrency(SelectedSlip.GrossSalary)</span>
                        </div>
                    </div>
                </div>

                <div class="mb-10">
                    <h4 class="fw-bold mb-5 fs-6 text-uppercase text-gray-500 border-bottom pb-2">Khấu trừ & Thuế</h4>
                    
                    <div class="mb-5 bg-light-danger p-5 rounded-3 border border-danger border-dashed shadow-sm">
                        <div class="d-flex flex-stack mb-2">
                             <div class="d-flex flex-column">
                                <span class="text-gray-800 fw-bold">Bảo hiểm (10.5%) mapping:</span>
                                <span class="fs-8 text-muted">Lương đóng BH: @FormatService.FormatCurrency(SelectedSlip.InsuranceSalary)</span>
                             </div>
                             <span class="text-danger fw-bolder">-@FormatService.FormatCurrency(SelectedSlip.TotalInsurance)</span>
                        </div>
                        
                        <div class="d-flex flex-stack mb-2">
                             <div class="d-flex flex-column">
                                <span class="text-gray-800 fw-bold">Thuế TNCN:</span>
                                <span class="fs-8 text-muted">Personal: 11M @(SelectedSlip.DependentDeduction > 0 ? $" | Dependent: {FormatService.FormatCurrency(SelectedSlip.DependentDeduction)}" : "")</span>
                             </div>
                             <span class="text-danger fw-bolder">-@FormatService.FormatCurrency(SelectedSlip.TaxAmount)</span>
                        </div>

                        @if (SelectedSlip.AdvanceAmount > 0)
                        {
                            <div class="d-flex flex-stack mb-2">
                                 <span class="text-gray-800 fw-bold">Tạm ứng lương:</span>
                                 <span class="text-danger fw-bolder">-@FormatService.FormatCurrency(SelectedSlip.AdvanceAmount)</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="bg-danger rounded p-8 d-flex flex-stack shadow-lg mb-5 overflow-hidden position-relative border border-white border-opacity-10">
                    <div class="d-flex flex-column position-relative z-index-1">
                        <span class="text-white fw-bold fs-6">THỰC LĨNH CUỐI CÙNG</span>
                        <span class="text-white text-opacity-75 fs-8">Áp dụng công thức mapping động hàng ngày</span>
                    </div>
                    <span class="text-white fw-bolder fs-1 position-relative z-index-1">@FormatService.FormatCurrency(SelectedSlip.NetSalary)</span>
                    <i class="ki-outline ki-wallet fs-4tx text-white opacity-5 position-absolute end-0 bottom-0 mb-n5 me-n5"></i>
                </div>
            </div>
            <div class="card-footer border-0 py-8 px-9 d-flex gap-3">
                <button type="button" class="btn btn-light fw-bold flex-grow-1" @onclick="CloseDrawer">Hủy bỏ</button>
                <button type="button" class="btn btn-light-success fw-bold flex-grow-1" @onclick="() => DownloadPayslip(SelectedSlip)">
                    <i class="ki-outline ki-file-down fs-3"></i> In phiếu lương
                </button>
                <button type="button" class="btn btn-primary fw-bold flex-grow-1" @onclick="SaveAdjustments">Lưu thay đổi</button>
            </div>
        </div>
    }
</div>

@if (IsDrawerOpen)
{
    <div class="modal-backdrop fade show" @onclick="CloseDrawer" style="z-index: 1050"></div>
}
