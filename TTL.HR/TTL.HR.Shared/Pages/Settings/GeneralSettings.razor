@page "/settings/general"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        
        <!-- Header with Save Action -->
        <div class="d-flex flex-wrap flex-stack mb-6">
            <h3 class="fw-bolder my-2">Cài đặt hệ thống 
            <span class="fs-6 text-gray-400 fw-bold ms-1">Cấu hình chung toàn hệ thống HR</span></h3>
            <div class="d-flex my-2">
                <button class="btn btn-light-primary btn-sm me-3 fw-bolder px-5" @onclick="LoadData" disabled="@_isSaving">
                    <i class="bi bi-arrow-counterclockwise fs-5 me-1"></i>Hủy thay đổi
                </button>
                <button class="btn btn-primary btn-sm fw-bolder px-8" @onclick="SaveSettings" disabled="@(_isSaving || _isLoading)">
                    @if (_isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg fs-5 me-1"></i>
                    }
                    Lưu cấu hình
                </button>
            </div>
        </div>

        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card">

        <div class="row g-7">
            <!-- Sidebar Navigation (Optional or visual guide) -->
            <div class="col-lg-3">
                <div class="card card-flush shadow-sm border-0 mb-5">
                    <div class="card-body p-0">
                        <div class="menu menu-column menu-rounded menu-state-bg menu-state-title-primary menu-state-icon-primary menu-state-bullet-primary mb-10">
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "company_profile" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("company_profile")'>
                                    <span class="menu-icon"><i class="bi bi-building fs-3"></i></span>
                                    <span class="menu-title fw-bold">Thông tin công ty</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "localization" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("localization")'>
                                    <span class="menu-icon"><i class="bi bi-globe fs-3"></i></span>
                                    <span class="menu-title fw-bold">Vùng & Ngôn ngữ</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "working_policy" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("working_policy")'>
                                    <span class="menu-icon"><i class="bi bi-clock-history fs-3"></i></span>
                                    <span class="menu-title fw-bold">Chính sách làm việc</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "holidays" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("holidays")'>
                                    <span class="menu-icon"><i class="bi bi-calendar2-heart fs-3"></i></span>
                                    <span class="menu-title fw-bold">Ngày nghỉ lễ & Phép</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "recruitment_config" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("recruitment_config")'>
                                    <span class="menu-icon"><i class="bi bi-person-plus fs-3"></i></span>
                                    <span class="menu-title fw-bold">Cấu hình Tuyển dụng</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "training_config" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("training_config")'>
                                    <span class="menu-icon"><i class="bi bi-journal-check fs-3"></i></span>
                                    <span class="menu-title fw-bold">Cấu hình Đào tạo</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "payroll" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("payroll")'>
                                    <span class="menu-icon"><i class="bi bi-cash-stack fs-3"></i></span>
                                    <span class="menu-title fw-bold">Cấu hình Lương & Thuế</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "notifications" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("notifications")'>
                                    <span class="menu-icon"><i class="bi bi-bell fs-3"></i></span>
                                    <span class="menu-title fw-bold">Thông báo & Email</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "code_generator" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("code_generator")'>
                                    <span class="menu-icon"><i class="bi bi-upc-scan fs-3"></i></span>
                                    <span class="menu-title fw-bold">Cấu hình sinh mã định danh</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card bg-light-info border-0 shadow-none">
                    <div class="card-body p-6">
                        <h4 class="text-info fw-bolder mb-3">Lưu ý bảo mật</h4>
                        
                        <p class="text-gray-600 fs-7 mb-0">Các thay đổi tại đây sẽ áp dụng ngay lập tức cho toàn bộ nhân viên. Vui lòng kiểm tra kỹ trước khi lưu.</p>
                    </div>
                </div>
            </div>

            <!-- Settings Content -->
            <div class="col-lg-9">
                @if (activeTab == "company_profile")
                {
                    <!-- Company Profile -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="company_profile">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Thông tin doanh nghiệp</h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-7">
                                <label class="col-lg-3 fw-bold text-muted fs-7">Logo công ty</label>
                                <div class="col-lg-9">
                                    <div class="symbol symbol-200px symbol-lg-250px symbol-fixed position-relative border p-4 rounded shadow-xs overflow-hidden" 
                                         style="background-image: linear-gradient(45deg, #f5f8fa 25%, transparent 25%), linear-gradient(-45deg, #f5f8fa 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #f5f8fa 75%), linear-gradient(-45deg, transparent 75%, #f5f8fa 75%); background-size: 20px 20px; background-position: 0 0, 0 10px, 10px -10px, -10px 0px; background-color: #ffffff;">
                                        @if (!string.IsNullOrEmpty(Model.LogoUrl))
                                        {
                                            <img src="@Model.LogoUrl" alt="Logo" style="object-fit: contain; width: 200px; max-height: 120px;" />
                                        }
                                        else
                                        {
                                            <img src="assets/media/logos/demo42.svg" alt="image" class="opacity-25" style="width: 200px;" />
                                        }

                                        
                                        <label for="logo-upload" class="position-absolute translate-middle bottom-0 start-100 mb-6 bg-body rounded-circle border border-secondary shadow-sm p-3 cursor-pointer hover-scale btn btn-icon btn-active-color-primary w-35px h-35px">
                                            <i class="bi bi-pencil-fill fs-6 text-muted"></i>
                                            <InputFile id="logo-upload" OnChange="HandleLogoUpload" class="d-none" accept=".jpg,.jpeg,.png,.svg" />
                                        </label>
                                    </div>
                                    <div class="form-text mt-4 fs-8">Định dạng hỗ trợ: <span class="fw-bold">png, jpg, svg</span>. Dung lượng tối đa <span class="fw-bold">2MB</span>.</div>
                                </div>
                            </div>

                            <div class="row mb-7">
                                <label class="col-lg-3 fw-bold text-muted fs-7">Favicon (Biểu tượng trình duyệt)</label>
                                <div class="col-lg-9">
                                    <div class="symbol symbol-50px symbol-fixed position-relative border p-2 rounded shadow-xs overflow-hidden"
                                         style="background-image: linear-gradient(45deg, #f5f8fa 25%, transparent 25%), linear-gradient(-45deg, #f5f8fa 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #f5f8fa 75%), linear-gradient(-45deg, transparent 75%, #f5f8fa 75%); background-size: 10px 10px; background-position: 0 0, 0 5px, 5px -5px, -5px 0px; background-color: #ffffff;">
                                         @if (!string.IsNullOrEmpty(Model.FaviconUrl))
                                         {
                                             <img src="@Model.FaviconUrl" alt="Favicon" style="object-fit: contain; width: 32px; height: 32px;" />
                                         }
                                         else
                                         {
                                             <img src="assets/media/logos/favicon.ico" alt="image" class="opacity-25" />
                                         }

                                        
                                        <label for="favicon-upload" class="position-absolute translate-middle bottom-0 start-100 mb-0 bg-body rounded-circle border border-secondary shadow-sm p-1 cursor-pointer hover-scale btn btn-icon btn-active-color-primary w-25px h-25px">
                                            <i class="bi bi-pencil-fill fs-9 text-muted"></i>
                                            <InputFile id="favicon-upload" OnChange="HandleFaviconUpload" class="d-none" accept=".ico,.png" />
                                        </label>
                                    </div>
                                    <div class="form-text mt-2 fs-9">Định dạng hỗ trợ: <span class="fw-bold">ico, png</span>. Kích thước khuyến nghị <span class="fw-bold">32x32px</span>.</div>
                                </div>
                            </div>

                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Tên công ty</label>
                                <div class="col-lg-9">
                                    <input type="text" class="form-control form-control-solid fs-7" @bind="Model.CompanyName" />
                                </div>
                            </div>
                            <div class="row mb-6">
                                <div class="col-md-6 row">
                                    <label class="col-lg-6 col-form-label fw-bold fs-7 ps-5">Mã số thuế</label>
                                    <div class="col-lg-6">
                                        <input type="text" class="form-control form-control-solid fs-7" @bind="Model.TaxCode" />
                                    </div>
                                </div>
                                <div class="col-md-6 row">
                                    <label class="col-lg-4 col-form-label fw-bold fs-7">Website</label>
                                    <div class="col-lg-8">
                                        <input type="text" class="form-control form-control-solid fs-7" @bind="Model.Website" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <div class="col-md-6 row">
                                    <label class="col-lg-6 col-form-label fw-bold fs-7 ps-5">Số điện thoại</label>
                                    <div class="col-lg-6">
                                        <input type="text" class="form-control form-control-solid fs-7" @bind="Model.CompanyPhone" />
                                    </div>
                                </div>
                                <div class="col-md-6 row">
                                    <label class="col-lg-4 col-form-label fw-bold fs-7">Email đại diện</label>
                                    <div class="col-lg-8">
                                        <input type="email" class="form-control form-control-solid fs-7" @bind="Model.CompanyEmail" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Địa chỉ trụ sở</label>
                                <div class="col-lg-9">
                                    <textarea class="form-control form-control-solid fs-7" rows="2" @bind="Model.CompanyAddress"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "localization")
                {
                    <!-- Localization & Formats -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="localization">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Vùng & Ngôn ngữ</h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Múi giờ hệ thống</label>
                                <div class="col-lg-9">
                                    <select class="form-select form-select-solid fs-7 fw-bold" @bind="Model.TimeZone">
                                        <option value="Asia/Ho_Chi_Minh">(GMT+07:00) Bangkok, Hanoi, Jakarta</option>
                                        <option value="SE Asia Standard Time">(GMT+07:00) SE Asia</option>
                                        <option value="UTC">Universal Coordinated Time (UTC)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <div class="col-md-6 row">
                                    <label class="col-lg-6 col-form-label fw-bold fs-7 ps-5">Ngôn ngữ mặc định</label>
                                    <div class="col-lg-6">
                                        <select class="form-select form-select-solid fs-7 fw-bold" @bind="Model.DefaultLanguage">
                                            <option value="vi-VN">Tiếng Việt</option>
                                            <option value="en-US">English</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6 row">
                                    <label class="col-lg-4 col-form-label fw-bold fs-7">Tiền tệ</label>
                                    <div class="col-lg-8">
                                        <select class="form-select form-select-solid fs-7 fw-bold" @bind="Model.Currency">
                                            <option value="VND">Việt Nam Đồng (VNĐ)</option>
                                            <option value="USD">US Dollar ($)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Định dạng ngày tháng</label>
                                <div class="col-lg-9 d-flex gap-4">
                                    <div class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="date_format" value="dd/MM/yyyy" checked="@(Model.DateFormat == "dd/MM/yyyy")" @onchange='() => Model.DateFormat = "dd/MM/yyyy"' />
                                        <label class="form-check-label fs-7 fw-bold">DD/MM/YYYY</label>
                                    </div>
                                    <div class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="date_format" value="MM/dd/yyyy" checked="@(Model.DateFormat == "MM/dd/yyyy")" @onchange='() => Model.DateFormat = "MM/dd/yyyy"' />
                                        <label class="form-check-label fs-7 fw-bold">MM/DD/YYYY</label>
                                    </div>
                                    <div class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="date_format" value="yyyy-MM-dd" checked="@(Model.DateFormat == "yyyy-MM-dd")" @onchange='() => Model.DateFormat = "yyyy-MM-dd"' />
                                        <label class="form-check-label fs-7 fw-bold">YYYY-MM-DD</label>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Định dạng số</label>
                                <div class="col-lg-9 row g-4">
                                    <div class="col-md-6">
                                        <span class="text-muted fs-8 d-block mb-2">Dấu phân cách hàng nghìn</span>
                                        <select class="form-select form-select-solid fs-7">
                                            <option value="comma">Dấu phẩy (,)</option>
                                            <option value="dot">Dấu chấm (.)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-muted fs-8 d-block mb-2">Dấu phân cách thập phân</span>
                                        <select class="form-select form-select-solid fs-7">
                                            <option value="dot">Dấu chấm (.)</option>
                                            <option value="comma">Dấu phẩy (,)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row mt-10">
                                <div class="col-12 bg-light-info rounded p-5 border border-dashed border-info">
                                    <h5 class="fw-bolder text-info mb-3">Xem trước định dạng</h5>
                                    <div class="d-flex flex-wrap gap-5">
                                        <div class="bg-white px-4 py-2 rounded shadow-xs fs-8">Ngày: <b>25/12/2024</b></div>
                                        <div class="bg-white px-4 py-2 rounded shadow-xs fs-8">Tiền tệ: <b>25,000,000 VNĐ</b></div>
                                        <div class="bg-white px-4 py-2 rounded shadow-xs fs-8">Múi giờ: <b>Asia/Ho_Chi_Minh (GMT+7)</b></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "working_policy")
                {
                    <!-- Working Policy -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="working_policy">
                        <div class="card-header pt-7 d-flex justify-content-between">
                            <h3 class="card-title fw-bolder text-gray-800">Chính sách thời gian làm việc</h3>
                            <div class="card-toolbar">
                                <span class="badge badge-light-primary fw-bolder">Chính sách chuẩn</span>
                            </div>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Giờ làm việc</label>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Bắt đầu</span>
                                        <input type="time" class="form-control fs-7" value="@Model.WorkStartTime" @onchange="@(e => Model.WorkStartTime = e.Value?.ToString())" />
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Kết thúc</span>
                                        <input type="time" class="form-control fs-7" value="@Model.WorkEndTime" @onchange="@(e => Model.WorkEndTime = e.Value?.ToString())" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Giờ nghỉ trưa</label>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Bắt đầu</span>
                                        <input type="time" class="form-control fs-7" value="@Model.BreakStartTime" @onchange="@(e => Model.BreakStartTime = e.Value?.ToString())" />
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Kết thúc</span>
                                        <input type="time" class="form-control fs-7" value="@Model.BreakEndTime" @onchange="@(e => Model.BreakEndTime = e.Value?.ToString())" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Thời gian ân hạn đi muộn</label>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <input type="number" class="form-control fs-7" @bind="Model.LateGracePeriodMinutes" />
                                        <span class="input-group-text fs-8">Phút</span>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Các ngày làm việc</label>
                                <div class="col-lg-9 d-flex flex-wrap gap-3">
                                    @{
                                        var daysAr = new[] { ("Mon", "Thứ 2"), ("Tue", "Thứ 3"), ("Wed", "Thứ 4"), ("Thu", "Thứ 5"), ("Fri", "Thứ 6"), ("Sat", "Thứ 7"), ("Sun", "Chủ nhật") };
                                    }
                                    @foreach (var (key, label) in daysAr)
                                    {
                                        var isSelected = Model.WorkDays?.Contains(key) ?? false;
                                        <button type="button" class="btn btn-sm @(isSelected ? "btn-light-primary" : "btn-light") fw-bolder" 
                                                @onclick='() => { if(isSelected) Model.WorkDays.Remove(key); else Model.WorkDays.Add(key); }'>
                                            @label
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="row">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Thời gian linh hoạt</label>
                                <div class="col-lg-9">
                                    <label class="form-check form-switch form-check-custom form-check-solid">
                                        <input class="form-check-input w-45px h-25px" type="checkbox" @bind="Model.AllowFlexibleHours" />
                                        <span class="form-check-label fs-7 fw-bold text-gray-600">Cho phép nhân viên tự sắp xếp thời gian làm việc (Flexible)</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "holidays")
                {
                    <!-- Holidays Configuration -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="holidays">
                        <div class="card-header pt-7">
                            <div class="d-flex align-items-center gap-4">
                                <h3 class="card-title fw-bolder text-gray-800 mb-0">Cấu hình Ngày nghỉ lễ</h3>
                                <select class="form-select form-select-solid form-select-sm fw-bold w-125px" @bind="SelectedYear">
                                    @for (int yy = DateTime.Now.Year - 1; yy <= DateTime.Now.Year + 2; yy++)
                                    {
                                        <option value="@yy">Năm @yy</option>
                                    }
                                </select>
                            </div>
                            <div class="card-toolbar d-flex gap-3">
                                <button type="button" class="btn btn-sm btn-light-info fw-bolder" @onclick="HandleAccrueLeave" disabled="@_isAccruing">
                                    @if (_isAccruing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-plus-circle-dotted me-2"></i>
                                    }
                                    Cộng phép tháng @DateTime.Now.Month
                                </button>
                                <button type="button" class="btn btn-sm btn-primary fw-bolder" @onclick="AddHoliday">
                                    <i class="bi bi-plus-lg me-2"></i>Thêm ngày nghỉ
                                </button>
                            </div>
                        </div>
                        <div class="card-body pt-5">
                            @{
                                var filteredHolidays = Model.Holidays?.Where(h => h.IsRecurring || h.StartDate.Year == SelectedYear || h.EndDate.Year == SelectedYear).ToList(); 
                            }
                            @if (filteredHolidays == null || !filteredHolidays.Any())
                            {
                                <div class="text-center py-10">
                                    <i class="ki-outline ki-calendar-remove fs-4x text-muted mb-4"></i>
                                    <div class="fs-5 fw-bold text-gray-600">Chưa có ngày nghỉ lễ nào được cấu hình</div>
                                    <div class="fs-7 text-muted mt-2">Bấm vào nút "Thêm ngày nghỉ" để bắt đầu cấu hình. Các ngày nghỉ lễ này sẽ được áp dụng trong tính toán chấm công, làm thêm giờ và xếp ca.</div>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-4">
                                        <thead>
                                            <tr class="fw-bolder text-muted bg-light text-uppercase fs-9">
