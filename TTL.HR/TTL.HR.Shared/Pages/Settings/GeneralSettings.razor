@page "/settings/general"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        
        <!-- Header with Save Action -->
        <div class="d-flex flex-wrap flex-stack mb-6">
            <h3 class="fw-bolder my-2">Cài đặt hệ thống 
            <span class="fs-6 text-gray-400 fw-bold ms-1">Cấu hình chung toàn hệ thống HR</span></h3>
            <div class="d-flex my-2">
                <button class="btn btn-light-primary btn-sm me-3 fw-bolder px-5" @onclick="LoadData" disabled="@_isSaving">
                    <i class="bi bi-arrow-counterclockwise fs-5 me-1"></i>Hủy thay đổi
                </button>
                <button class="btn btn-primary btn-sm fw-bolder px-8" @onclick="SaveSettings" disabled="@(_isSaving || _isLoading)">
                    @if (_isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg fs-5 me-1"></i>
                    }
                    Lưu cấu hình
                </button>
            </div>
        </div>

        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card">

        <div class="row g-7">
            <!-- Sidebar Navigation (Optional or visual guide) -->
            <div class="col-lg-3">
                <div class="card card-flush shadow-sm border-0 mb-5">
                    <div class="card-body p-0">
                        <div class="menu menu-column menu-rounded menu-state-bg menu-state-title-primary menu-state-icon-primary menu-state-bullet-primary mb-10">
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "company_profile" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("company_profile")'>
                                    <span class="menu-icon"><i class="bi bi-building fs-3"></i></span>
                                    <span class="menu-title fw-bold">Thông tin công ty</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "localization" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("localization")'>
                                    <span class="menu-icon"><i class="bi bi-globe fs-3"></i></span>
                                    <span class="menu-title fw-bold">Vùng & Ngôn ngữ</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "working_policy" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("working_policy")'>
                                    <span class="menu-icon"><i class="bi bi-clock-history fs-3"></i></span>
                                    <span class="menu-title fw-bold">Chính sách làm việc</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "recruitment_config" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("recruitment_config")'>
                                    <span class="menu-icon"><i class="bi bi-person-plus fs-3"></i></span>
                                    <span class="menu-title fw-bold">Cấu hình Tuyển dụng</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "training_config" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("training_config")'>
                                    <span class="menu-icon"><i class="bi bi-journal-check fs-3"></i></span>
                                    <span class="menu-title fw-bold">Cấu hình Đào tạo</span>
                                </a>
                            </div>
                            <div class="menu-item">
                                <a class="menu-link py-4 @(activeTab == "notifications" ? "active" : "")" href="javascript:;" @onclick='() => SetActiveTab("notifications")'>
                                    <span class="menu-icon"><i class="bi bi-bell fs-3"></i></span>
                                    <span class="menu-title fw-bold">Thông báo & Email</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card bg-light-info border-0 shadow-none">
                    <div class="card-body p-6">
                        <h4 class="text-info fw-bolder mb-3">Lưu ý bảo mật</h4>
                        <p class="text-gray-600 fs-7 mb-0">Các thay đổi tại đây sẽ áp dụng ngay lập tức cho toàn bộ nhân viên. Vui lòng kiểm tra kỹ trước khi lưu.</p>
                    </div>
                </div>
            </div>

            <!-- Settings Content -->
            <div class="col-lg-9">
                @if (activeTab == "company_profile")
                {
                    <!-- Company Profile -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="company_profile">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Thông tin doanh nghiệp</h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-7">
                                <label class="col-lg-3 fw-bold text-muted fs-7">Logo công ty</label>
                                <div class="col-lg-9">
                                    <div class="symbol symbol-100px symbol-lg-160px symbol-fixed position-relative">
                                        <img src="assets/media/logos/demo42.svg" alt="image" class="border p-4 bg-light" />
                                        <div class="position-absolute translate-middle bottom-0 start-100 mb-6 bg-body rounded-circle border border-secondary shadow-sm p-2 cursor-pointer hover-scale">
                                            <i class="bi bi-pencil-fill fs-8 text-muted"></i>
                                        </div>
                                    </div>
                                    <div class="form-text mt-2 fs-8">Định dạng hỗ trợ: png, jpg, svg. Dung lượng tối đa 2MB.</div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Tên công ty</label>
                                <div class="col-lg-9">
                                    <input type="text" class="form-control form-control-solid fs-7" @bind="Model.CompanyName" />
                                </div>
                            </div>
                            <div class="row mb-6">
                                <div class="col-md-6 row">
                                    <label class="col-lg-6 col-form-label fw-bold fs-7 ps-5">Mã số thuế</label>
                                    <div class="col-lg-6">
                                        <input type="text" class="form-control form-control-solid fs-7" @bind="Model.TaxCode" />
                                    </div>
                                </div>
                                <div class="col-md-6 row">
                                    <label class="col-lg-4 col-form-label fw-bold fs-7">Website</label>
                                    <div class="col-lg-8">
                                        <input type="text" class="form-control form-control-solid fs-7" @bind="Model.Website" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <div class="col-md-6 row">
                                    <label class="col-lg-6 col-form-label fw-bold fs-7 ps-5">Số điện thoại</label>
                                    <div class="col-lg-6">
                                        <input type="text" class="form-control form-control-solid fs-7" @bind="Model.CompanyPhone" />
                                    </div>
                                </div>
                                <div class="col-md-6 row">
                                    <label class="col-lg-4 col-form-label fw-bold fs-7">Email đại diện</label>
                                    <div class="col-lg-8">
                                        <input type="email" class="form-control form-control-solid fs-7" @bind="Model.CompanyEmail" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Địa chỉ trụ sở</label>
                                <div class="col-lg-9">
                                    <textarea class="form-control form-control-solid fs-7" rows="2" @bind="Model.CompanyAddress"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "localization")
                {
                    <!-- Localization & Formats -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="localization">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Vùng & Ngôn ngữ</h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Múi giờ hệ thống</label>
                                <div class="col-lg-9">
                                    <select class="form-select form-select-solid fs-7 fw-bold" @bind="Model.TimeZone">
                                        <option value="Asia/Ho_Chi_Minh">(GMT+07:00) Bangkok, Hanoi, Jakarta</option>
                                        <option value="SE Asia Standard Time">(GMT+07:00) SE Asia</option>
                                        <option value="UTC">Universal Coordinated Time (UTC)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <div class="col-md-6 row">
                                    <label class="col-lg-6 col-form-label fw-bold fs-7 ps-5">Ngôn ngữ mặc định</label>
                                    <div class="col-lg-6">
                                        <select class="form-select form-select-solid fs-7 fw-bold" @bind="Model.DefaultLanguage">
                                            <option value="vi-VN">Tiếng Việt</option>
                                            <option value="en-US">English</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6 row">
                                    <label class="col-lg-4 col-form-label fw-bold fs-7">Tiền tệ</label>
                                    <div class="col-lg-8">
                                        <select class="form-select form-select-solid fs-7 fw-bold" @bind="Model.Currency">
                                            <option value="VND">Việt Nam Đồng (VNĐ)</option>
                                            <option value="USD">US Dollar ($)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Định dạng ngày tháng</label>
                                <div class="col-lg-9 d-flex gap-4">
                                    <div class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="date_format" value="dd/MM/yyyy" checked="@(Model.DateFormat == "dd/MM/yyyy")" @onchange='() => Model.DateFormat = "dd/MM/yyyy"' />
                                        <label class="form-check-label fs-7 fw-bold">DD/MM/YYYY</label>
                                    </div>
                                    <div class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="date_format" value="MM/dd/yyyy" checked="@(Model.DateFormat == "MM/dd/yyyy")" @onchange='() => Model.DateFormat = "MM/dd/yyyy"' />
                                        <label class="form-check-label fs-7 fw-bold">MM/DD/YYYY</label>
                                    </div>
                                    <div class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="date_format" value="yyyy-MM-dd" checked="@(Model.DateFormat == "yyyy-MM-dd")" @onchange='() => Model.DateFormat = "yyyy-MM-dd"' />
                                        <label class="form-check-label fs-7 fw-bold">YYYY-MM-DD</label>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Định dạng số</label>
                                <div class="col-lg-9 row g-4">
                                    <div class="col-md-6">
                                        <span class="text-muted fs-8 d-block mb-2">Dấu phân cách hàng nghìn</span>
                                        <select class="form-select form-select-solid fs-7">
                                            <option value="comma">Dấu phẩy (,)</option>
                                            <option value="dot">Dấu chấm (.)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-muted fs-8 d-block mb-2">Dấu phân cách thập phân</span>
                                        <select class="form-select form-select-solid fs-7">
                                            <option value="dot">Dấu chấm (.)</option>
                                            <option value="comma">Dấu phẩy (,)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row mt-10">
                                <div class="col-12 bg-light-info rounded p-5 border border-dashed border-info">
                                    <h5 class="fw-bolder text-info mb-3">Xem trước định dạng</h5>
                                    <div class="d-flex flex-wrap gap-5">
                                        <div class="bg-white px-4 py-2 rounded shadow-xs fs-8">Ngày: <b>25/12/2024</b></div>
                                        <div class="bg-white px-4 py-2 rounded shadow-xs fs-8">Tiền tệ: <b>25,000,000 VNĐ</b></div>
                                        <div class="bg-white px-4 py-2 rounded shadow-xs fs-8">Múi giờ: <b>Asia/Ho_Chi_Minh (GMT+7)</b></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "working_policy")
                {
                    <!-- Working Policy -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="working_policy">
                        <div class="card-header pt-7 d-flex justify-content-between">
                            <h3 class="card-title fw-bolder text-gray-800">Chính sách thời gian làm việc</h3>
                            <div class="card-toolbar">
                                <span class="badge badge-light-primary fw-bolder">Chính sách chuẩn</span>
                            </div>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Giờ làm việc</label>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Bắt đầu</span>
                                        <input type="time" class="form-control fs-7" @bind="Model.WorkStartTime" />
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Kết thúc</span>
                                        <input type="time" class="form-control fs-7" @bind="Model.WorkEndTime" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Giờ nghỉ trưa</label>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Bắt đầu</span>
                                        <input type="time" class="form-control fs-7" @bind="Model.BreakStartTime" />
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Kết thúc</span>
                                        <input type="time" class="form-control fs-7" @bind="Model.BreakEndTime" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Thời gian ân hạn đi muộn</label>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <input type="number" class="form-control fs-7" @bind="Model.LateGracePeriodMinutes" />
                                        <span class="input-group-text fs-8">Phút</span>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Các ngày làm việc</label>
                                <div class="col-lg-9 d-flex flex-wrap gap-3">
                                    @{
                                        var days = new[] { ("Mon", "Thứ 2"), ("Tue", "Thứ 3"), ("Wed", "Thứ 4"), ("Thu", "Thứ 5"), ("Fri", "Thứ 6"), ("Sat", "Thứ 7"), ("Sun", "Chủ nhật") };
                                        var selectedDays = Model.WorkDays?.Split(';', StringSplitOptions.RemoveEmptyEntries).ToList() ?? new List<string>();
                                    }
                                    @foreach (var (key, label) in days)
                                    {
                                        var isSelected = selectedDays.Contains(key);
                                        <button type="button" class="btn btn-sm @(isSelected ? "btn-light-primary" : "btn-light") fw-bolder" 
                                                @onclick='() => { if(isSelected) selectedDays.Remove(key); else selectedDays.Add(key); Model.WorkDays = string.Join(";", selectedDays); }'>
                                            @label
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="row">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Thời gian linh hoạt</label>
                                <div class="col-lg-9">
                                    <label class="form-check form-switch form-check-custom form-check-solid">
                                        <input class="form-check-input w-45px h-25px" type="checkbox" @bind="Model.AllowFlexibleHours" />
                                        <span class="form-check-label fs-7 fw-bold text-gray-600">Cho phép nhân viên tự sắp xếp thời gian làm việc (Flexible)</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "recruitment_config")
                {
                    <!-- Recruitment Configuration -->
                    <div class="card card-flush shadow-sm border-0 mb-8">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Cấu hình Tuyển dụng</h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Địa điểm phỏng vấn mặc định</label>
                                <div class="col-lg-9">
                                    <input type="text" class="form-control form-control-solid fs-7" @bind="Model.DefaultInterviewLocation" placeholder="Tòa nhà TTL, Phòng họp 1..." />
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Thời gian lưu trữ hồ sơ</label>
                                <div class="col-lg-3">
                                    <div class="input-group input-group-solid">
                                        <input type="number" class="form-control fs-7" @bind="Model.ResumeRetentionDays" />
                                        <span class="input-group-text fs-8">Ngày</span>
                                    </div>
                                </div>
                            </div>
                            <div class="separator separator-dashed my-6"></div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Cài đặt tự động</label>
                                <div class="col-lg-9">
                                    <label class="form-check form-switch form-check-custom form-check-solid mb-3">
                                        <input class="form-check-input w-40px h-20px" type="checkbox" @bind="Model.AutoSendThankYouEmail" />
                                        <span class="form-check-label fs-7 fw-bold text-gray-700">Tự động gửi email cảm ơn khi nhận hồ sơ</span>
                                    </label>
                                    <label class="form-check form-switch form-check-custom form-check-solid mb-3">
                                        <input class="form-check-input w-40px h-20px" type="checkbox" @bind="Model.EnableExternalJobBoard" />
                                        <span class="form-check-label fs-7 fw-bold text-gray-700">Kích hoạt đăng tin tự động lên Job Board bên ngoài</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "training_config")
                {
                    <!-- Training Configuration -->
                    <div class="card card-flush shadow-sm border-0 mb-8">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Cấu hình Đào tạo</h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Ngân sách tối đa / nhân viên / năm</label>
                                <div class="col-lg-4">
                                    <div class="input-group input-group-solid">
                                        <input type="number" class="form-control fs-7" @bind="Model.MaxBudgetPerEmployee" />
                                        <span class="input-group-text fs-8">VNĐ</span>
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Thời gian đào tạo mặc định</label>
                                <div class="col-lg-3">
                                    <div class="input-group input-group-solid">
                                        <input type="number" class="form-control fs-7" @bind="Model.DefaultTrainingDurationHours" />
                                        <span class="input-group-text fs-8">Giờ</span>
                                    </div>
                                </div>
                            </div>
                            <div class="separator separator-dashed my-6"></div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Quy trình & Đánh giá</label>
                                <div class="col-lg-9">
                                    <label class="form-check form-switch form-check-custom form-check-solid mb-3">
                                        <input class="form-check-input w-40px h-20px" type="checkbox" @bind="Model.AutoEnrollOnboarding" />
                                        <span class="form-check-label fs-7 fw-bold text-gray-700">Tự động ghi danh khóa Onboarding cho nhân viên mới</span>
                                    </label>
                                    <label class="form-check form-switch form-check-custom form-check-solid mb-3">
                                        <input class="form-check-input w-40px h-20px" type="checkbox" @bind="Model.EnableFeedback" />
                                        <span class="form-check-label fs-7 fw-bold text-gray-700">Cho phép phản hồi/đánh giá sau khi hoàn thành khóa học</span>
                                    </label>
                                </div>
                            </div>
                            <div class="row mb-6">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Cảnh báo hết hạn chứng chỉ</label>
                                <div class="col-lg-3">
                                    <div class="input-group input-group-solid">
                                        <input type="number" class="form-control fs-7" @bind="Model.CertificateExpiryWarningDays" />
                                        <span class="input-group-text fs-8">Ngày</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "notifications")
                {
                    <!-- Notifications & Security -->
                    <div class="card card-flush shadow-sm border-0 mb-8" id="notifications">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Thông báo & Email</h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="row mb-7">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Máy chủ SMTP</label>
                                <div class="col-lg-6">
                                    <input type="text" class="form-control form-control-solid fs-7" @bind="Model.SmtpServer" placeholder="smtp.gmail.com" />
                                </div>
                                <div class="col-lg-3">
                                    <div class="input-group input-group-solid">
                                        <span class="input-group-text fs-8">Cổng</span>
                                        <input type="number" class="form-control fs-7" @bind="Model.SmtpPort" />
                                    </div>
                                </div>
                            </div>
                            <div class="row mb-7">
                                <label class="col-lg-3 col-form-label fw-bold fs-7">Tài khoản gửi tin</label>
                                <div class="col-lg-9">
                                    <input type="text" class="form-control form-control-solid fs-7" @bind="Model.SmtpUser" placeholder="noreply@tantanloc.com" />
                                </div>
                            </div>
                            <div class="row mb-7">
                                <div class="col-lg-3"></div>
                                <div class="col-lg-9">
                                    <label class="form-check form-switch form-check-custom form-check-solid mb-3">
                                        <input class="form-check-input w-40px h-20px" type="checkbox" @bind="Model.EnableEmailNotifications" />
                                        <span class="form-check-label fs-7 fw-bold text-gray-700">Kích hoạt gửi thông báo qua Email</span>
                                    </label>
                                </div>
                            </div>
                            
                            <h5 class="fw-bolder mb-5 mt-10">Tùy chọn thông báo hệ thống</h5>
                            <div class="table-responsive">
                                <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-4">
                                    <thead>
                                        <tr class="fw-bolder text-muted bg-light text-uppercase fs-9">
                                            <th class="ps-4">Sự kiện kích hoạt</th>
                                            <th class="text-center">Kích hoạt</th>
                                            <th class="text-center">Cấu hình thêm</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="ps-4"><span class="text-dark fw-bold fs-7">Yêu cầu nghỉ phép/đi công tác</span></td>
                                            <td class="text-center"><div class="form-check form-check-custom form-check-solid justify-content-center"><input class="form-check-input" type="checkbox" @bind="Model.NotifyOnLeaveRequest" /></div></td>
                                            <td><span class="text-muted fs-8">Thông báo cho quản lý trực tiếp</span></td>
                                        </tr>
                                        <tr>
                                            <td class="ps-4"><span class="text-dark fw-bold fs-7">Phê duyệt nghỉ phép/đi công tác</span></td>
                                            <td class="text-center"><div class="form-check form-check-custom form-check-solid justify-content-center"><input class="form-check-input" type="checkbox" @bind="Model.NotifyOnLeaveApproval" /></div></td>
                                            <td><span class="text-muted fs-8">Thông báo cho nhân viên yêu cầu</span></td>
                                        </tr>
                                        <tr>
                                            <td class="ps-4"><span class="text-dark fw-bold fs-7">Hợp đồng sắp hết hạn</span></td>
                                            <td class="text-center"><div class="form-check form-check-custom form-check-solid justify-content-center"><input class="form-check-input" type="checkbox" @bind="Model.NotifyOnContractExpiry" /></div></td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <span class="fs-8 text-muted me-2">Thông báo trước</span>
                                                    <input type="number" class="form-control form-control-solid w-60px h-25px fs-8" @bind="Model.ContractExpiryWarningDays" />
                                                    <span class="fs-8 text-muted ms-2">ngày</span>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="ps-4"><span class="text-dark fw-bold fs-7">Kết thúc thử việc</span></td>
                                            <td class="text-center"><div class="form-check form-check-custom form-check-solid justify-content-center"><input class="form-check-input" type="checkbox" @bind="Model.NotifyOnProbationEnd" /></div></td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <span class="fs-8 text-muted me-2">Thông báo trước</span>
                                                    <input type="number" class="form-control form-control-solid w-60px h-25px fs-8" @bind="Model.ProbationEndWarningDays" />
                                                    <span class="fs-8 text-muted ms-2">ngày</span>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="ps-4"><span class="text-dark fw-bold fs-7">Sinh nhật & Kỷ niệm</span></td>
                                            <td class="text-center">
                                                <div class="d-flex gap-5 justify-content-center">
                                                    <label class="form-check form-check-custom form-check-solid"><input class="form-check-input w-15px h-15px" type="checkbox" @bind="Model.NotifyOnBirthday" /><span class="ms-2 fs-8">Sinh nhật</span></label>
                                                    <label class="form-check form-check-custom form-check-solid"><input class="form-check-input w-15px h-15px" type="checkbox" @bind="Model.NotifyOnWorkAnniversary" /><span class="ms-2 fs-8">Kỷ niệm</span></label>
                                                </div>
                                            </td>
                                            <td><span class="text-muted fs-8">Thông báo chung toàn hệ thống</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        </SkeletonLoading>
    </div>
</div>
