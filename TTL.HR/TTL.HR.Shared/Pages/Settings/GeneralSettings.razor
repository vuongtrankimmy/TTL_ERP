                                                        <div class="input-group input-group-solid input-group-sm">
                                                            <input type="number" class="form-control" @bind="step.Rate" step="0.01" />
                                                            <span class="input-group-text fs-9">%</span>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="input-group input-group-solid input-group-sm">
                                                            <input type="number" class="form-control" @bind="step.Deduction" />
                                                            <span class="input-group-text fs-9">VNĐ</span>
                                                        </div>
                                                    </td>
