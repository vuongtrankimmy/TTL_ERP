@page "/settings/localization"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        
        <!-- Header -->
        <div class="d-flex flex-wrap flex-stack mb-6">
            <h3 class="fw-bolder my-2">Vùng & Ngôn ngữ
            <span class="fs-6 text-gray-400 fw-bold ms-1">Tùy chỉnh hiển thị và định dạng cho hệ thống</span></h3>
            <div class="d-flex my-2">
                <button class="btn btn-light-primary btn-sm me-3 fw-bolder px-5" @onclick="ResetToDefault" disabled="@_isSaving">
                    <i class="bi bi-arrow-counterclockwise fs-5 me-1"></i>Mặc định
                </button>
                <button class="btn btn-primary btn-sm fw-bolder px-8" @onclick="SaveSettings" disabled="@(_isSaving || _isLoading)">
                    @if (_isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg fs-5 me-1"></i>
                    }
                    Lưu thay đổi
                </button>
            </div>
        </div>

        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card">

        <div class="row g-7">
            <!-- Left Column: Language & Region Settings -->
            <div class="col-lg-8">
                <!-- Language Card -->
                <div class="card card-flush shadow-sm border-0 mb-8">
                    <div class="card-header pt-7">
                        <h3 class="card-title align-items-start flex-column">
                            <span class="card-label fw-bolder text-gray-800">Ngôn ngữ hiển thị</span>
                            <span class="text-muted mt-1 fw-bold fs-7">Chọn ngôn ngữ mặc định cho giao diện người dùng</span>
                        </h3>
                    </div>
                    <div class="card-body pt-5">
                        <div class="row g-5">
                            <div class="col-md-6">
                                <label class="d-flex flex-stack cursor-pointer mb-5 p-4 border border-dashed rounded @(Model.DefaultLanguage == "vi-VN" ? "bg-light-primary border-primary" : "")">
                                    <span class="d-flex align-items-center me-2">
                                        <span class="symbol symbol-40px me-4">
                                            <img src="assets/media/flags/vietnam.svg" alt="VN" class="w-30px" />
                                        </span>
                                        <span class="d-flex flex-column">
                                            <span class="fw-bolder text-gray-800 fs-6">Tiếng Việt</span>
                                            <span class="text-muted fs-8">Ngôn ngữ chính thức</span>
                                        </span>
                                    </span>
                                    <span class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="language" value="vi-VN" checked="@(Model.DefaultLanguage == "vi-VN")" @onchange='() => Model.DefaultLanguage = "vi-VN"' />
                                    </span>
                                </label>
                            </div>
                            <div class="col-md-6">
                                <label class="d-flex flex-stack cursor-pointer mb-5 p-4 border border-dashed rounded @(Model.DefaultLanguage == "en-US" ? "bg-light-primary border-primary" : "hover-bg-light")">
                                    <span class="d-flex align-items-center me-2">
                                        <span class="symbol symbol-40px me-4">
                                            <img src="assets/media/flags/united-states.svg" alt="US" class="w-30px" />
                                        </span>
                                        <span class="d-flex flex-column">
                                            <span class="fw-bolder text-gray-800 fs-6">English (US)</span>
                                            <span class="text-muted fs-8">Global Standard</span>
                                        </span>
                                    </span>
                                    <span class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input" type="radio" name="language" value="en-US" checked="@(Model.DefaultLanguage == "en-US")" @onchange='() => Model.DefaultLanguage = "en-US"' />
                                    </span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Region & Format Card -->
                <div class="card card-flush shadow-sm border-0 mb-8">
                    <div class="card-header pt-7">
                        <h3 class="card-title align-items-start flex-column">
                            <span class="card-label fw-bolder text-gray-800">Định dạng & Vùng</span>
                            <span class="text-muted mt-1 fw-bold fs-7">Cấu hình thời gian, tiền tệ và định dạng số</span>
                        </h3>
                    </div>
                    <div class="card-body pt-5">
                        <div class="row mb-8">
                            <label class="col-lg-4 col-form-label fw-bold fs-7">Múi giờ (Timezone)</label>
                            <div class="col-lg-8">
                                <select class="form-select form-select-solid fs-7" @bind="Model.TimeZone">
                                    <option value="Asia/Ho_Chi_Minh">(GMT+07:00) Bangkok, Hanoi, Jakarta</option>
                                    <option value="SE Asia Standard Time">(GMT+07:00) SE Asia</option>
                                    <option value="Asia/Tokyo">(GMT+09:00) Tokyo, Seoul</option>
                                    <option value="America/New_York">(GMT-05:00) Eastern Time (US & Canada)</option>
                                    <option value="Europe/London">(GMT+00:00) London, Lisbon</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mb-8">
                            <label class="col-lg-4 col-form-label fw-bold fs-7">Đơn vị tiền tệ</label>
                            <div class="col-lg-8">
                                <div class="d-flex flex-wrap gap-3">
                                    <label class="btn btn-outline btn-outline-dashed btn-active-light-primary d-flex align-items-center px-5 @(Model.Currency == "VND" ? "active" : "")">
                                        <span class="form-check form-check-custom form-check-solid me-3">
                                            <input class="form-check-input" type="radio" name="currency" value="VND" checked="@(Model.Currency == "VND")" @onchange='() => Model.Currency = "VND"' />
                                        </span>
                                        <span class="d-flex flex-column text-start">
                                            <span class="fw-bolder fs-6">VNĐ</span>
                                            <span class="fs-8">Việt Nam Đồng</span>
                                        </span>
                                    </label>
                                    <label class="btn btn-outline btn-outline-dashed btn-active-light-primary d-flex align-items-center px-5 @(Model.Currency == "USD" ? "active" : "")">
                                        <span class="form-check form-check-custom form-check-solid me-3">
                                            <input class="form-check-input" type="radio" name="currency" value="USD" checked="@(Model.Currency == "USD")" @onchange='() => Model.Currency = "USD"' />
                                        </span>
                                        <span class="d-flex flex-column text-start">
                                            <span class="fw-bolder fs-6">USD</span>
                                            <span class="fs-8">US Dollar</span>
                                        </span>
                                    </label>
                                </div>

                            </div>
                        </div>

                        <div class="row mb-8">
                            <label class="col-lg-4 col-form-label fw-bold fs-7">Định dạng ngày tháng</label>
                            <div class="col-lg-8">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-check form-check-custom form-check-solid border p-3 rounded cursor-pointer @(Model.DateFormat == "dd/MM/yyyy" ? "bg-light" : "")">
                                            <input class="form-check-input" type="radio" name="date_format" checked="@(Model.DateFormat == "dd/MM/yyyy")" @onchange='() => Model.DateFormat = "dd/MM/yyyy"' />
                                            <span class="ms-3 fs-7 fw-bold">DD/MM/YYYY</span>
                                        </label>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-check form-check-custom form-check-solid border p-3 rounded cursor-pointer @(Model.DateFormat == "MM/dd/yyyy" ? "bg-light" : "")">
                                            <input class="form-check-input" type="radio" name="date_format" checked="@(Model.DateFormat == "MM/dd/yyyy")" @onchange='() => Model.DateFormat = "MM/dd/yyyy"' />
                                            <span class="ms-3 fs-7 fw-bold">MM/DD/YYYY</span>
                                        </label>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-check form-check-custom form-check-solid border p-3 rounded cursor-pointer @(Model.DateFormat == "yyyy-MM-dd" ? "bg-light" : "")">
                                            <input class="form-check-input" type="radio" name="date_format" checked="@(Model.DateFormat == "yyyy-MM-dd")" @onchange='() => Model.DateFormat = "yyyy-MM-dd"' />
                                            <span class="ms-3 fs-7 fw-bold">YYYY-MM-DD</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <label class="col-lg-4 col-form-label fw-bold fs-7">Định dạng số</label>
                            <div class="col-lg-8 row g-4">
                                <div class="col-md-6">
                                    <span class="text-muted fs-8 d-block mb-2">Dấu phân cách hàng nghìn</span>
                                    <select class="form-select form-select-solid fs-7">
                                        <option value="comma">Dấu phẩy (,)</option>
                                        <option value="dot">Dấu chấm (.)</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <span class="text-muted fs-8 d-block mb-2">Dấu phân cách thập phân</span>
                                    <select class="form-select form-select-solid fs-7">
                                        <option value="dot">Dấu chấm (.)</option>
                                        <option value="comma">Dấu phẩy (,)</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Preview & Help -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 bg-light-info mb-8">
                    <div class="card-body p-8">
                        <h4 class="fw-bolder text-info mb-5">Xem trước hiển thị</h4>
                        <div class="bg-white rounded p-6 shadow-xs">
                            <div class="d-flex flex-column gap-4">
                                <div class="d-flex justify-content-between border-bottom pb-2">
                                    <span class="text-gray-600 fs-8">Ngày hôm nay:</span>
                                    <span class="fw-bolder fs-7">@DateTime.Now.ToString(Model.DateFormat)</span>
                                </div>
                                <div class="d-flex justify-content-between border-bottom pb-2">
                                    <span class="text-gray-600 fs-8">Múi giờ:</span>
                                    <span class="fw-bolder fs-7">@Model.TimeZone</span>
                                </div>
                                <div class="d-flex justify-content-between border-bottom pb-2">
                                    <span class="text-gray-600 fs-8">Tiền lương mẫu:</span>
                                    <span class="fw-bolder fs-7">@(string.Format(Model.Currency == "VND" ? "{0:N0} VNĐ" : "${0:N2}", 25500000))</span>
                                </div>
                                <div class="d-flex justify-content-between border-bottom pb-2">
                                    <span class="text-gray-600 fs-8">Ngôn ngữ:</span>
                                    <span class="fw-bolder fs-7">@(Model.DefaultLanguage == "vi-VN" ? "Tiếng Việt" : "English")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-8">
                        <div class="d-flex align-items-center mb-5">
                            <i class="bi bi-question-circle-fill fs-1 text-primary me-3"></i>
                            <h4 class="fw-bolder text-gray-800 mb-0">Hỗ trợ</h4>
                        </div>
                        <p class="text-gray-600 fs-7 mb-6">
                            Các cài đặt vùng và ngôn ngữ ảnh hưởng trực tiếp đến cách dữ liệu được trích xuất trong các báo cáo Excel và PDF.
                        </p>
                        <div class="separator separator-dashed mb-6"></div>
                        <div class="d-flex flex-column gap-3">
                            <a href="#" class="text-primary fw-bold fs-7 hover-underline">HDSD định dạng báo cáo</a>
                            <a href="#" class="text-primary fw-bold fs-7 hover-underline">Tải về bộ ngôn ngữ (JSON)</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </SkeletonLoading>
    </div>
</div>

