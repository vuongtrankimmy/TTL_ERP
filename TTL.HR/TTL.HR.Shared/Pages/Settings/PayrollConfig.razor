@page "/settings/payroll-config"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <!-- Header with Actions -->
        <div class="d-flex flex-wrap flex-stack mb-6">
            <h3 class="fw-bolder my-2">Cấu hình lương & Bảo hiểm
            <span class="fs-6 text-gray-400 fw-bold ms-1">Tham số tính toán cho bảng lương hệ thống</span></h3>
            <div class="d-flex my-2">
                <button class="btn btn-sm btn-light-primary me-3 fw-bold px-10" @onclick="LoadData" disabled="@_isSaving">
                    <i class="bi bi-arrow-counterclockwise fs-4 me-1"></i>Hủy thay đổi
                </button>
                <button class="btn btn-sm btn-primary fw-bold px-10" @onclick="SaveSettings" disabled="@(_isSaving || _isLoading)">
                    @if (_isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg fs-4 me-1"></i>
                    }
                    Lưu tham số
                </button>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bolder mb-8">
            <li class="nav-item">
                <a class="nav-link py-4 px-8 me-4 @(activeTab == "insurance" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("insurance")'>
                    <i class="bi bi-shield-check me-2"></i>Tham số bảo hiểm
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-4 px-8 me-4 @(activeTab == "pit" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("pit")'>
                    <i class="bi bi-layout-text-window-reverse me-2"></i>Biểu thuế TNCN
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-4 px-8 me-4 @(activeTab == "allowances" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("allowances")'>
                    <i class="bi bi-gift me-2"></i>Phụ cấp & Phúc lợi
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-4 px-8 me-0 @(activeTab == "overtime" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("overtime")'>
                    <i class="bi bi-clock-history me-2"></i>Cấu hình Tăng ca
                </a>
            </li>
        </ul>

        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table">
        <div class="tab-content">
            @if (activeTab == "insurance")
            {
                <div class="tab-pane fade show active">
                <!-- Insurance Table -->
                <div class="card card-flush shadow-xs border mb-8">
                    <div class="card-header pt-7">
                        <h3 class="card-title align-items-start flex-column">
                            <span class="card-label fw-bolder text-gray-800">Danh mục tham số đóng bảo hiểm</span>
                        </h3>
                        <div class="card-toolbar">
                            <span class="text-muted fs-8 fw-bold fst-italic">
                                <i class="bi bi-info-circle me-1"></i>Các giá trị này được dùng để tự động tính toán lương hằng tháng.
                            </span>
                        </div>
                    </div>
                    <div class="card-body pt-5">
                        <div class="table-responsive">
                            <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-6">
                                <thead>
                                    <tr class="fw-bolder text-muted bg-light text-uppercase fs-9">
                                        <th class="ps-4 min-w-250px">Tên tham số</th>
                                        <th class="min-w-150px">NV Đóng (%)</th>
                                        <th class="min-w-150px">Công ty đóng (%)</th>
                                        <th class="min-w-150px">Giá trị cố định</th>
                                        <th class="min-w-150px">Ngày áp dụng</th>
                                        <th class="min-w-100px text-end pe-4">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex flex-column">
                                                <span class="text-dark fw-bolder fs-7">BHXH (Bảo hiểm xã hội)</span>
                                                <span class="text-muted fs-8 mt-1">Hưu trí, tử tuất, ốm đau...</span>
                                            </div>
                                        </td>
                                        <td><input type="number" step="0.1" class="form-control form-control-solid w-80px h-30px fs-7" @bind="Model.SocialInsurancePercentEmployee" /></td>
                                        <td><input type="number" step="0.1" class="form-control form-control-solid w-80px h-30px fs-7" @bind="Model.SocialInsurancePercentCompany" /></td>
                                        <td class="text-muted fs-7">--</td>
                                        <td class="fs-7 text-gray-600"><span class="badge badge-light fw-bold">01/01/2024</span></td>
                                        <td class="text-end pe-4"><span class="text-muted fs-8">Tự động áp dụng</span></td>
                                    </tr>
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex flex-column">
                                                <span class="text-dark fw-bolder fs-7">BHYT (Bảo hiểm y tế)</span>
                                                <span class="text-muted fs-8 mt-1">Chăm sóc sức khỏe cộng đồng</span>
                                            </div>
                                        </td>
                                        <td><input type="number" step="0.1" class="form-control form-control-solid w-80px h-30px fs-7" @bind="Model.HealthInsurancePercentEmployee" /></td>
                                        <td><input type="number" step="0.1" class="form-control form-control-solid w-80px h-30px fs-7" @bind="Model.HealthInsurancePercentCompany" /></td>
                                        <td class="text-muted fs-7">--</td>
                                        <td class="fs-7 text-gray-600"><span class="badge badge-light fw-bold">01/01/2024</span></td>
                                        <td class="text-end pe-4"><span class="text-muted fs-8">Tự động áp dụng</span></td>
                                    </tr>
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex flex-column">
                                                <span class="text-dark fw-bolder fs-7">BHTN (Bảo hiểm thất nghiệp)</span>
                                                <span class="text-muted fs-8 mt-1">Hỗ trợ khi mất việc làm</span>
                                            </div>
                                        </td>
                                        <td><input type="number" step="0.1" class="form-control form-control-solid w-80px h-30px fs-7" @bind="Model.UnemploymentInsurancePercentEmployee" /></td>
                                        <td><input type="number" step="0.1" class="form-control form-control-solid w-80px h-30px fs-7" @bind="Model.UnemploymentInsurancePercentCompany" /></td>
                                        <td class="text-muted fs-7">--</td>
                                        <td class="fs-7 text-gray-600"><span class="badge badge-light fw-bold">01/01/2024</span></td>
                                        <td class="text-end pe-4"><span class="text-muted fs-8">Tự động áp dụng</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Region Salary & Deductions -->
                <h3 class="fw-bolder text-gray-800 mb-6">Mức giảm trừ & Lương vùng</h3>
                <div class="row g-7 mb-8">
                    <div class="col-md-6">
                        <div class="card p-8 d-flex flex-row align-items-center justify-content-between border shadow-xs">
                            <div>
                                <span class="d-block text-gray-700 fw-bold fs-7 mb-1">Giảm trừ gia cảnh (Bản thân)</span>
                                <span class="text-muted fs-9 fst-italic mb-3 d-block">Áp dụng cho người nộp thuế TNCN</span>
                                <div class="d-flex align-items-end">
                                    <input type="number" class="form-control form-control-transparent fw-bolder fs-1 p-0 w-200px" @bind="Model.DefaultPersonalDeduction" />
                                    <span class="fs-9 fw-bold text-muted ms-1 mb-2">VNĐ / tháng</span>
                                </div>
                            </div>
                            <div class="btn btn-icon btn-light-primary btn-sm"><i class="bi bi-cash"></i></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card p-8 d-flex flex-row align-items-center justify-content-between border shadow-xs">
                            <div>
                                <span class="d-block text-gray-700 fw-bold fs-7 mb-1">Giảm trừ người phụ thuộc</span>
                                <span class="text-muted fs-9 fst-italic mb-3 d-block">Mỗi người phụ thuộc hợp lệ</span>
                                <div class="d-flex align-items-end">
                                    <input type="number" class="form-control form-control-transparent fw-bolder fs-1 p-0 w-150px" @bind="Model.DefaultDependentDeduction" />
                                    <span class="fs-9 fw-bold text-muted ms-1 mb-2">VNĐ / tháng</span>
                                </div>
                            </div>
                            <div class="btn btn-icon btn-light-primary btn-sm"><i class="bi bi-people"></i></div>
                        </div>
                </div>
            </div>
                
                <div class="row g-7 mb-8">
                    <div class="col-md-12">
                        <div class="card p-8 d-flex flex-row align-items-center justify-content-between border shadow-xs bg-light">
                            <div>
                                <span class="d-block text-gray-700 fw-bold fs-7 mb-1">Mức lương cơ sở (Toàn quốc)</span>
                                <span class="text-muted fs-9 fst-italic mb-3 d-block">Dùng để tính mức trần đóng BHXH/BHYT (20 lần lương cơ sở)</span>
                                <div class="d-flex align-items-end">
                                    <input type="number" class="form-control form-control-transparent fw-bolder fs-1 p-0 w-200px" @bind="Model.StatutoryPayRate" />
                                    <span class="fs-9 fw-bold text-muted ms-1 mb-2">VNĐ / tháng</span>
                                </div>
                            </div>
                            <div class="btn btn-icon btn-light-primary btn-sm"><i class="bi bi-bank"></i></div>
                        </div>
                    </div>
                </div>

                <div class="card card-flush shadow-xs border mb-8">
                    <div class="card-header">
                        <h3 class="card-title fw-bolder text-gray-800">Lương tối thiểu theo Vùng</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold fs-7 ps-4">Vùng I (Hà Nội, TP.HCM,...)</td>
                                        <td class="text-end pe-10">
                                            <div class="d-flex align-items-center justify-content-end">
                                                <input type="number" class="form-control form-control-solid w-150px h-30px fs-7 text-end" @bind="Model.Region1MinimumSalary" />
                                                <span class="fs-8 text-muted ms-2">VNĐ</span>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold fs-7 ps-4">Vùng II (Đà Nẵng, Cần Thơ,...)</td>
                                        <td class="text-end pe-10">
                                            <div class="d-flex align-items-center justify-content-end">
                                                <input type="number" class="form-control form-control-solid w-150px h-30px fs-7 text-end" @bind="Model.Region2MinimumSalary" />
                                                <span class="fs-8 text-muted ms-2">VNĐ</span>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold fs-7 ps-4">Vùng III (Bắc Ninh, Bình Dương,...)</td>
                                        <td class="text-end pe-10">
                                            <div class="d-flex align-items-center justify-content-end">
                                                <input type="number" class="form-control form-control-solid w-150px h-30px fs-7 text-end" @bind="Model.Region3MinimumSalary" />
                                                <span class="fs-8 text-muted ms-2">VNĐ</span>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold fs-7 ps-4">Vùng IV (Các khu vực còn lại)</td>
                                        <td class="text-end pe-10">
                                            <div class="d-flex align-items-center justify-content-end">
                                                <input type="number" class="form-control form-control-solid w-150px h-30px fs-7 text-end" @bind="Model.Region4MinimumSalary" />
                                                <span class="fs-8 text-muted ms-2">VNĐ</span>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                </div>
            }

            @if (activeTab == "pit")
            {
                <div class="tab-pane fade show active">
                    <div class="card card-flush shadow-xs border mb-8">
                        <div class="card-header pt-7">
                            <h3 class="card-title fw-bolder text-gray-800">Biểu thuế suất lũy tiến từng phần</h3>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5">
                                    <thead>
                                        <tr class="fw-bolder text-muted bg-light text-uppercase fs-9">
                                            <th>Bậc</th>
                                            <th>Thu nhập tính thuế (Triệu VNĐ/tháng)</th>
                                            <th class="text-center">Thuế suất (%)</th>
                                            <th class="text-end pe-4">Thành tiền tối đa bậc</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr><td>1</td><td>Đến 5</td><td class="text-center fw-bold">5%</td><td class="text-end pe-4">250,000</td></tr>
                                        <tr><td>2</td><td>Trên 5 đến 10</td><td class="text-center fw-bold">10%</td><td class="text-end pe-4">750,000</td></tr>
                                        <tr><td>3</td><td>Trên 10 đến 18</td><td class="text-center fw-bold">15%</td><td class="text-end pe-4">1,950,000</td></tr>
                                        <tr><td>4</td><td>Trên 18 đến 32</td><td class="text-center fw-bold">20%</td><td class="text-end pe-4">4,750,000</td></tr>
                                        <tr><td>5</td><td>Trên 32 đến 52</td><td class="text-center fw-bold">25%</td><td class="text-end pe-4">9,750,000</td></tr>
                                        <tr><td>6</td><td>Trên 52 đến 80</td><td class="text-center fw-bold">30%</td><td class="text-end pe-4">18,150,000</td></tr>
                                        <tr><td>7</td><td>Trên 80</td><td class="text-center fw-bold">35%</td><td class="text-end pe-4">--</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (activeTab == "allowances")
            {
                <div class="tab-pane fade show active">
                    <div class="card card-flush shadow-xs border mb-8">
                        <div class="card-body p-20 text-center">
                            <i class="bi bi-gift-fill fs-5x text-light-primary mb-5"></i>
                            <h3 class="fw-bolder text-gray-800">Quản lý Phụ cấp & Phúc lợi</h3>
                            <p class="text-muted fs-6">Vui lòng sử dụng mô-đun <a href="/payroll/allowances" class="fw-bold text-primary">Danh mục phụ cấp</a> để cấu hình chi tiết cho từng loại.</p>
                        </div>
                    </div>
                </div>
            }

            @if (activeTab == "overtime")
            {
                <div class="tab-pane fade show active">
                    <div class="row g-7 mb-8">
                        <div class="col-md-8">
                            <div class="card card-flush shadow-xs border h-100">
                                <div class="card-header pt-7">
                                    <h3 class="card-title align-items-start flex-column">
                                        <span class="card-label fw-bolder text-gray-800">Cấu hình & Công thức tính Tăng ca (OT)</span>
                                        <span class="text-muted mt-1 fw-bold fs-7">Thiết lập cách hệ thống tính toán tiền làm thêm giờ</span>
                                    </h3>
                                </div>
                                <div class="card-body pt-5">
                                    <div class="mb-10">
                                        <label class="form-label fw-bold fs-6 mb-2">Phương thức xác định giờ tăng ca</label>
                                        <div class="row g-9" data-kt-buttons="true" data-kt-buttons-target="[data-kt-button='true']">
                                            <div class="col-4">
                                                <label class="btn btn-outline btn-outline-dashed btn-active-light-primary d-flex text-start p-6 @(Model.OvertimeCalculationMethod == "Auto" ? "active" : "")" data-kt-button="true">
                                                    <span class="form-check form-check-custom form-check-solid form-check-sm align-items-start mt-1">
                                                        <input class="form-check-input" type="radio" name="ot_method" value="Auto" checked="@(Model.OvertimeCalculationMethod == "Auto")" @onchange='() => Model.OvertimeCalculationMethod = "Auto"' />
                                                    </span>
                                                    <span class="ms-5">
                                                        <span class="fs-6 fw-bold text-gray-800 d-block">Tự động (Auto)</span>
                                                        <span class="fw-semibold fs-8 text-muted">Dựa trên giờ ra/vào thực tế so với ca</span>
                                                    </span>
                                                </label>
                                            </div>
                                            <div class="col-4">
                                                <label class="btn btn-outline btn-outline-dashed btn-active-light-primary d-flex text-start p-6 @(Model.OvertimeCalculationMethod == "ApprovedOnly" ? "active" : "")" data-kt-button="true">
                                                    <span class="form-check form-check-custom form-check-solid form-check-sm align-items-start mt-1">
                                                        <input class="form-check-input" type="radio" name="ot_method" value="ApprovedOnly" checked="@(Model.OvertimeCalculationMethod == "ApprovedOnly")" @onchange='() => Model.OvertimeCalculationMethod = "ApprovedOnly"' />
                                                    </span>
                                                    <span class="ms-5">
                                                        <span class="fs-6 fw-bold text-gray-800 d-block">Chỉ từ Giấy phép</span>
                                                        <span class="fw-semibold fs-8 text-muted">Phải có đơn tăng ca được duyệt</span>
                                                    </span>
                                                </label>
                                            </div>
                                            <div class="col-4">
                                                <label class="btn btn-outline btn-outline-dashed btn-active-light-primary d-flex text-start p-6 @(Model.OvertimeCalculationMethod == "Hybrid" ? "active" : "")" data-kt-button="true">
                                                    <span class="form-check form-check-custom form-check-solid form-check-sm align-items-start mt-1">
                                                        <input class="form-check-input" type="radio" name="ot_method" value="Hybrid" checked="@(Model.OvertimeCalculationMethod == "Hybrid")" @onchange='() => Model.OvertimeCalculationMethod = "Hybrid"' />
                                                    </span>
                                                    <span class="ms-5">
                                                        <span class="fs-6 fw-bold text-gray-800 d-block">Kết hợp (Hybrid)</span>
                                                        <span class="fw-semibold fs-8 text-muted">Lấy giá trị nhỏ hơn giữa thực tế & đơn</span>
                                                    </span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="separator separator-dashed my-8"></div>

                                    <div class="mb-5">
                                        <label class="form-label fw-bold fs-6 text-gray-700 mb-3">Công thức áp dụng (Scripting)</label>
                                        <div class="bg-gray-900 rounded p-5 position-relative">
                                            <div class="d-flex position-absolute top-0 end-0 mt-3 me-3">
                                                <span class="badge badge-light-dark fs-9">C# Syntax</span>
                                            </div>
                                            <textarea class="form-control bg-transparent border-0 text-success fw-bold fs-7 font-monospace" rows="8" style="resize: none;" @bind="Model.OvertimeCode" placeholder="// Enter custom formula here..."></textarea>
                                        </div>
                                        <div class="text-muted fs-8 mt-3">
                                            <i class="bi bi-info-circle me-1"></i> Biến khả dụng: <code>ActualHours</code>, <code>ShiftHours</code>, <code>Rate</code>, <code>IsWeekend</code>, <code>IsHoliday</code>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card card-flush shadow-xs border mb-8">
                                <div class="card-header pt-7">
                                    <h3 class="card-title fw-bolder text-gray-800">Tham số Nhân hệ số</h3>
                                </div>
                                <div class="card-body">
                                    <div class="form-group mb-5">
                                        <label class="form-label fs-7 fw-bold">Ngày thường (Weekday)</label>
                                        <div class="input-group input-group-solid input-group-sm">
                                            <span class="input-group-text badge-light-primary">x</span>
                                            <input type="number" step="0.1" class="form-control" @bind="Model.OvertimeRateWeekday" />
                                        </div>
                                    </div>
                                    <div class="form-group mb-5">
                                        <label class="form-label fs-7 fw-bold">Cuối tuần (Weekend)</label>
                                        <div class="input-group input-group-solid input-group-sm">
                                            <span class="input-group-text badge-light-success">x</span>
                                            <input type="number" step="0.1" class="form-control" @bind="Model.OvertimeRateWeekend" />
                                        </div>
                                    </div>
                                    <div class="form-group mb-5">
                                        <label class="form-label fs-7 fw-bold">Ngày lễ (Holiday)</label>
                                        <div class="input-group input-group-solid input-group-sm">
                                            <span class="input-group-text badge-light-danger">x</span>
                                            <input type="number" step="0.1" class="form-control" @bind="Model.OvertimeRateHoliday" />
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label fs-7 fw-bold">Làm ca đêm (Overnight)</label>
                                        <div class="input-group input-group-solid input-group-sm">
                                            <span class="input-group-text badge-light-warning">x</span>
                                            <input type="number" step="0.1" class="form-control" @bind="Model.OvertimeOvernightRate" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card card-flush shadow-xs border">
                                <div class="card-header pt-7">
                                    <h3 class="card-title fw-bolder text-gray-800">Quy tắc bổ sung</h3>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex flex-stack mb-5">
                                        <div class="me-5">
                                            <label class="fs-7 fw-bold">Bắt buộc duyệt đơn</label>
                                            <div class="fs-9 text-muted italic">Yêu cầu workflow phê duyệt</div>
                                        </div>
                                        <div class="form-check form-switch form-check-custom form-check-solid">
                                            <input class="form-check-input h-20px w-35px" type="checkbox" @bind="Model.RequireOvertimeApproval" />
                                        </div>
                                    </div>
                                    
                                    <div class="separator separator-dashed my-5"></div>

                                    <div class="form-group">
                                        <label class="form-label fs-7 fw-bold">Số phút tối thiểu được tính OT</label>
                                        <div class="input-group input-group-solid input-group-sm">
                                            <input type="number" class="form-control" @bind="Model.MinOvertimeMinutes" />
                                            <span class="input-group-text">phút</span>
                                        </div>
                                        <span class="fs-9 text-muted mt-1 d-block">Làm dưới mức này sẽ không được tính OT.</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        </SkeletonLoading>
    </div>
</div>

