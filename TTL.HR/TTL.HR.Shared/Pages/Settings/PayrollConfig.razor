@page "/settings/payroll-config"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <!-- Tabs -->
        <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bolder mb-8">
            <li class="nav-item">
                <a class="nav-link active py-4 px-8 me-4" href="#">
                    <i class="bi bi-shield-check me-2"></i>Tham số bảo hiểm
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-4 px-8 me-4" href="#">
                    <i class="bi bi-layout-text-window-reverse me-2"></i>Biểu thuế TNCN
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-4 px-8 me-0" href="#">
                    <i class="bi bi-gift me-2"></i>Phụ cấp & Phúc lợi
                </a>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" role="tabpanel">
                <!-- Insurance Table -->
                <div class="card card-flush shadow-xs border mb-8">
                    <div class="card-header pt-7">
                        <h3 class="card-title align-items-start flex-column">
                            <span class="card-label fw-bolder text-gray-800">Danh mục tham số đóng bảo hiểm</span>
                        </h3>
                        <div class="card-toolbar">
                            <span class="text-muted fs-8 fw-bold fst-italic">
                                <i class="bi bi-info-circle me-1"></i>Các giá trị này được dùng để tự động tính toán lương hằng tháng.
                            </span>
                        </div>
                    </div>
                    <div class="card-body pt-5">
                        <div class="table-responsive">
                            <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-6">
                                <thead>
                                    <tr class="fw-bolder text-muted bg-light text-uppercase fs-9">
                                        <th class="ps-4 min-w-250px">Tên tham số</th>
                                        <th class="min-w-150px">NV Đóng (%)</th>
                                        <th class="min-w-150px">Công ty đóng (%)</th>
                                        <th class="min-w-150px">Giá trị cố định</th>
                                        <th class="min-w-150px">Ngày áp dụng</th>
                                        <th class="min-w-100px text-end pe-4">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex flex-column">
                                                <span class="text-dark fw-bolder fs-7">BHXH (Bảo hiểm xã hội)</span>
                                                <span class="text-muted fs-8 mt-1">Hưu trí, tử tuất, ốm đau...</span>
                                            </div>
                                        </td>
                                        <td class="fw-bold fs-7">8.0%</td>
                                        <td class="fw-bold fs-7">17.5%</td>
                                        <td class="text-muted fs-7">--</td>
                                        <td class="fs-7 text-gray-600"><span class="badge badge-light fw-bold">01/07/2023</span></td>
                                        <td class="text-end pe-4"><a href="#" class="btn btn-sm btn-link fw-bolder text-primary p-0">Chỉnh sửa</a></td>
                                    </tr>
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex flex-column">
                                                <span class="text-dark fw-bolder fs-7">BHYT (Bảo hiểm y tế)</span>
                                                <span class="text-muted fs-8 mt-1">Chăm sóc sức khỏe cộng đồng</span>
                                            </div>
                                        </td>
                                        <td class="fw-bold fs-7">1.5%</td>
                                        <td class="fw-bold fs-7">3.0%</td>
                                        <td class="text-muted fs-7">--</td>
                                        <td class="fs-7 text-gray-600"><span class="badge badge-light fw-bold">01/07/2023</span></td>
                                        <td class="text-end pe-4"><a href="#" class="btn btn-sm btn-link fw-bolder text-primary p-0">Chỉnh sửa</a></td>
                                    </tr>
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex flex-column">
                                                <span class="text-dark fw-bolder fs-7">BHTN (Bảo hiểm thất nghiệp)</span>
                                                <span class="text-muted fs-8 mt-1">Hỗ trợ khi mất việc làm</span>
                                            </div>
                                        </td>
                                        <td class="fw-bold fs-7">1.0%</td>
                                        <td class="fw-bold fs-7">1.0%</td>
                                        <td class="text-muted fs-7">--</td>
                                        <td class="fs-7 text-gray-600"><span class="badge badge-light fw-bold">01/07/2023</span></td>
                                        <td class="text-end pe-4"><a href="#" class="btn btn-sm btn-link fw-bolder text-primary p-0">Chỉnh sửa</a></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Region Salary & Deductions -->
                <h3 class="fw-bolder text-gray-800 mb-6">Mức giảm trừ & Lương vùng</h3>
                <div class="row g-7 mb-8">
                    <div class="col-md-6">
                        <div class="card p-8 d-flex flex-row align-items-center justify-content-between cursor-pointer border shadow-xs">
                            <div>
                                <span class="d-block text-gray-700 fw-bold fs-7 mb-1">Giảm trừ gia cảnh (Bản thân)</span>
                                <span class="text-muted fs-9 fst-italic mb-3 d-block">Áp dụng cho người nộp thuế TNCN</span>
                                <span class="fs-1 fw-bolder text-dark">11.000.000 <span class="fs-9 fw-bold text-muted ms-1">VNĐ / tháng</span></span>
                            </div>
                            <div class="btn btn-icon btn-light-primary btn-sm"><i class="bi bi-pencil-square"></i></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card p-8 d-flex flex-row align-items-center justify-content-between cursor-pointer border shadow-xs">
                            <div>
                                <span class="d-block text-gray-700 fw-bold fs-7 mb-1">Giảm trừ người phụ thuộc</span>
                                <span class="text-muted fs-9 fst-italic mb-3 d-block">Mỗi người phụ thuộc hợp lệ</span>
                                <span class="fs-1 fw-bolder text-dark">4.400.000 <span class="fs-9 fw-bold text-muted ms-1">VNĐ / tháng</span></span>
                            </div>
                            <div class="btn btn-icon btn-light-primary btn-sm"><i class="bi bi-pencil-square"></i></div>
                        </div>
                    </div>
                </div>

                <div class="card card-flush shadow-xs border mb-8">
                    <div class="card-header">
                        <h3 class="card-title fw-bolder text-gray-800">Lương tối thiểu theo Vùng</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold fs-7">Vùng I (Hà Nội, TP.HCM,...)</td>
                                        <td class="text-end fw-bolder fs-7 pe-10">4.680.000 VNĐ</td>
                                        <td class="text-end pe-7"><i class="bi bi-three-dots fs-3 cursor-pointer"></i></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold fs-7">Vùng II (Đà Nẵng, Cần Thơ,...)</td>
                                        <td class="text-end fw-bolder fs-7 pe-10">4.160.000 VNĐ</td>
                                        <td class="text-end pe-7"><i class="bi bi-three-dots fs-3 cursor-pointer"></i></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Info Boxes -->
                <div class="row g-5 mt-4">
                    <div class="col-md-4">
                        <div class="info-box bg-light-primary rounded-3 p-6 d-flex align-items-start gap-4 h-100">
                            <i class="bi bi-layout-text-sidebar-reverse fs-2x text-primary"></i>
                            <div>
                                <h4 class="fw-bolder fs-6 mb-2">Cơ sở pháp lý</h4>
                                <span class="fs-9 text-muted d-block">Theo Nghị định 24/2023/NĐ-CP và Nghị quyết về biểu thuế TNCN mới nhất.</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="warning-box bg-light-warning rounded-3 p-6 border border-dashed border-warning d-flex align-items-start gap-4 h-100">
                            <i class="bi bi-exclamation-triangle-fill fs-2x text-warning"></i>
                            <div>
                                <h4 class="fw-bolder fs-6 mb-2">Lưu ý quyết toán</h4>
                                <span class="fs-9 text-dark d-block">Việc thay đổi tham số sẽ ảnh hưởng đến các phiếu lương chưa chốt của kỳ hiện tại.</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="help-box bg-light-info rounded-3 p-6 border border-dashed border-info d-flex align-items-start gap-4 h-100">
                            <i class="bi bi-question-circle-fill fs-2x text-primary"></i>
                            <div>
                                <h4 class="fw-bolder fs-6 mb-2">Hỗ trợ nghiệp vụ</h4>
                                <span class="fs-9 text-muted d-block">Liên hệ bộ phận Kế toán - Thuế để được hướng dẫn về các định mức vùng mới nhất.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

