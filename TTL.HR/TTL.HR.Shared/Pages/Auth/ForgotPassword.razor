@page "/auth/forgot-password"
@layout AuthLayout

<PageTitle>Quên mật khẩu - TTL ERP</PageTitle>

<div class="text-center mb-11">
    <h1 class="text-dark fw-bolder mb-3">Quên mật khẩu?</h1>
    <div class="text-gray-500 fw-semibold fs-6">Nhập Email của bạn để nhận liên kết đặt lại mật khẩu.</div>
</div>

@if (_isSuccess)
{
    <div class="card shadow-sm mb-10 border-success border-dashed">
        <div class="card-body p-10 text-center">
            <div class="mb-5">
                <i class="bi bi-envelope-check-fill text-success fs-5x"></i>
            </div>
            <h2 class="fw-bolder mb-3">Kiểm tra Email của bạn!</h2>
            <p class="text-gray-600 fs-5">Chúng tôi đã gửi hướng dẫn đặt lại mật khẩu tới <strong>@_email</strong>.</p>
            <div class="mt-8">
                <a href="/auth/login" class="btn btn-primary fw-bold px-10">Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
}
else
{
    <form class="form w-100" @onsubmit="HandleSubmit">
        <div class="fv-row mb-8">
            <label class="form-label fs-6 fw-bolder text-dark text-uppercase">Email công việc / Cá nhân</label>
            <div class="position-relative">
                <i class="bi bi-envelope position-absolute translate-middle-y top-50 ms-4 text-gray-400 fs-3"></i>
                <input type="email" placeholder="Nhập địa chỉ email của bạn" 
                       class="form-control bg-transparent ps-12" 
                       @bind="_email" required />
            </div>
        </div>

        <div class="d-flex flex-stack gap-3">
            <button type="submit" class="btn btn-primary flex-grow-1" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Đang gửi...</span>
                }
                else
                {
                    <i class="bi bi-send-fill me-2"></i><span>Gửi yêu cầu</span>
                }
            </button>
            <a href="/auth/login" class="btn btn-light-primary fw-bold">Hủy</a>
        </div>
    </form>
}
