@page "/reset-password"
@page "/auth/reset-password"
@layout AuthLayout

<PageTitle>Thiết lập mật khẩu - TTL ERP</PageTitle>

<div class="text-center mb-11">
    <h1 class="text-dark fw-bolder mb-3">Thiết lập mật khẩu</h1>
    <div class="text-gray-500 fw-semibold fs-6">Vui lòng nhập mật khẩu mới cho tài khoản của bạn</div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger d-flex align-items-center p-5 mb-10 border-dashed">
        <i class="bi bi-exclamation-triangle-fill fs-2 text-danger me-4"></i>
        <div class="d-flex flex-column">
            <h4 class="mb-1 text-danger">Lỗi xác thực</h4>
            <span class="fs-7">@_errorMessage</span>
        </div>
    </div>
}

@if (_isSuccess)
{
    <div class="text-center py-5">
        <div class="mb-5 text-center">
            <i class="bi bi-check-circle-fill text-success fs-5x"></i>
        </div>
        <h2 class="fw-bolder mb-3">Thành công!</h2>
        <p class="text-gray-600 fs-5 mb-8">Mật khẩu của bạn đã được cập nhật thành công. Bạn có thể sử dụng mật khẩu mới để đăng nhập.</p>
        <div class="d-grid">
            <button type="button" class="btn btn-primary fw-bold" @onclick="GoToLogin">
                <i class="bi bi-box-arrow-in-right me-2"></i>ĐĂNG NHẬP NGAY
            </button>
        </div>
    </div>
}
else
{
    <form class="form w-100" @onsubmit="HandleResetPassword">
        <div class="fv-row mb-8">
            <label class="form-label fs-7 fw-bolder text-dark text-uppercase">Mật khẩu mới</label>
            <div class="position-relative mb-3">
                <i class="bi bi-key position-absolute translate-middle-y top-50 ms-4 text-gray-400 fs-3"></i>
                <input type="@(_showPassword ? "text" : "password")" placeholder="Nhập ít nhất 8 ký tự" 
                       class="form-control bg-transparent ps-12 pe-12" 
                       @bind="_newPassword" required />
                <button type="button" class="btn btn-sm btn-icon position-absolute translate-middle-y top-50 end-0 me-1" @onclick="TogglePasswordVisibility">
                    <i class="bi bi-@(_showPassword ? "eye-slash" : "eye") fs-2 text-gray-500"></i>
                </button>
            </div>
        </div>

        <div class="fv-row mb-10">
            <label class="form-label fs-7 fw-bolder text-dark text-uppercase">Xác nhận mật khẩu</label>
            <div class="position-relative mb-3">
                <i class="bi bi-shield-check position-absolute translate-middle-y top-50 ms-4 text-gray-400 fs-3"></i>
                <input type="@(_showConfirmPassword ? "text" : "password")" placeholder="Nhập lại mật khẩu mới" 
                       class="form-control bg-transparent ps-12 pe-12" 
                       @bind="_confirmPassword" required />
                <button type="button" class="btn btn-sm btn-icon position-absolute translate-middle-y top-50 end-0 me-1" @onclick="ToggleConfirmPasswordVisibility">
                    <i class="bi bi-@(_showConfirmPassword ? "eye-slash" : "eye") fs-2 text-gray-500"></i>
                </button>
            </div>
        </div>

        <div class="d-grid mb-10">
            <button type="submit" class="btn btn-primary" disabled="@(_isProcessing || string.IsNullOrEmpty(Token))">
                @if (_isProcessing)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>ĐANG XỬ LÝ...</span>
                }
                else
                {
                    <i class="bi bi-check-lg me-2"></i><span>CẬP NHẬT MẬT KHẨU</span>
                }
            </button>
        </div>
        
        <div class="text-center">
            <a href="/auth/login" class="link-primary fw-bold">Quay lại đăng nhập</a>
        </div>
    </form>
}
