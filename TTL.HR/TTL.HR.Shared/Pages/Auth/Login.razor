@page "/"
@page "/auth/login"
@layout AuthLayout

<PageTitle>Đăng nhập - OrgaX HR</PageTitle>

<!--begin::Form-->
<form class="form w-100" id="ttl_sign_in_form" @onsubmit="HandleLogin">
    <!--begin::Heading-->
    <div class="text-center mb-11">
        <!--begin::Title-->
        <h1 class="text-dark fw-bolder mb-3">Đăng nhập</h1>
        <!--end::Title-->
        <!--begin::Subtitle-->
        <div class="text-gray-500 fw-semibold fs-6">Hệ thống Quản trị Nhân sự TTL</div>
        <!--end::Subtitle=-->
    </div>
    <!--begin::Heading-->
    
    <!--begin::Input group=-->
    <div class="fv-row mb-8">
        <label class="form-label fs-6 fw-bolder text-dark">Tên đăng nhập</label>
        <input type="text" placeholder="Nhập tên đăng nhập" name="username" autocomplete="off" class="form-control bg-transparent" @bind="_username" />
    </div>
    <!--end::Input group=-->
    <div class="fv-row mb-3">
        <div class="d-flex flex-stack mb-2">
            <label class="form-label fw-bolder text-dark fs-6 mb-0">Mật khẩu</label>
            <a href="/auth/forgot-password" class="link-primary fs-6 fw-bolder">Quên mật khẩu?</a>
        </div>
        <div class="position-relative mb-3">
            <input type="@(_showPassword ? "text" : "password")" placeholder="Nhập mật khẩu" name="password" autocomplete="off" class="form-control bg-transparent" @bind="_password" />
            <span class="btn btn-sm btn-icon position-absolute translate-middle top-50 end-0 me-n2" @onclick="() => _showPassword = !_showPassword">
                <i class="ki-outline @(_showPassword ? "ki-eye-slash" : "ki-eye") fs-2"></i>
            </span>
        </div>
    </div>
    <!--end::Input group=-->
    
    <!--begin::Submit button-->
    <div class="d-grid mb-10 pt-5">
        <button type="submit" class="btn btn-primary" disabled="@_isLoading">
            @if (_isLoading)
            {
                <span class="indicator-progress" style="display: block;">
                    Vui lòng đợi...
                    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                </span>
            }
            else
            {
                <span class="indicator-label">Đăng nhập</span>
            }
        </button>
    </div>
    <!--end::Submit button-->
</form>
<!--end::Form-->


