@page "/organization/structure"
@using TTL.HR.Application.Modules.Organization.Models


<style>
    .org-container {
        position: relative;
        overflow: hidden;
        background: #f8f9fa;
        height: calc(100vh - 200px);
        cursor: grab;
        border-radius: 12px;
    }

    .org-tree {
        padding-top: 50px;
        position: relative;
        transition: transform 0.1s ease-out;
        display: inline-block;
        min-width: 100%;
        transform-origin: 0 0;
    }

    .org-tree ul {
        padding-top: 20px;
        position: relative;
        display: flex;
        justify-content: center;
    }

    .org-tree li {
        text-align: center;
        list-style-type: none;
        position: relative;
        padding: 20px 5px 0 5px;
    }

    /* Connectors */
    .org-tree li::before,
    .org-tree li::after {
        content: '';
        position: absolute;
        top: 0;
        right: 50%;
        border-top: 2px solid #ccc;
        width: 50%;
        height: 20px;
    }

    .org-tree li::after {
        right: auto;
        left: 50%;
        border-left: 2px solid #ccc;
    }

    .org-tree li:only-child::after,
    .org-tree li:only-child::before {
        display: none;
    }

    .org-tree li:only-child {
        padding-top: 0;
    }

    .org-tree li:first-child::before,
    .org-tree li:last-child::after {
        border: 0 none;
    }

    .org-tree li:last-child::before {
        border-right: 2px solid #ccc;
        border-radius: 0 5px 0 0;
    }

    .org-tree li:first-child::after {
        border-radius: 5px 0 0 0;
    }

    .org-tree ul ul::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        border-left: 2px solid #ccc;
        width: 0;
        height: 20px;
    }

    /* Card Nodes */
    .org-node {
        display: inline-block;
        padding: 15px;
        border: 1px solid #e4e6ef;
        background: #fff;
        border-radius: 10px;
        min-width: 220px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
        position: relative;
        z-index: 10;
        cursor: pointer;
        transition: all 0.3s;
    }

    .org-node:hover {
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
    }

    .org-node.is-manager {
        border: 2px solid #50cd89;
    }

    .org-node.is-department {
        border: 2px solid #009ef7;
        background: #f1faff;
    }

    .org-role {
        font-weight: 600;
        font-size: 1.1rem;
        color: #181c32;
    }

    .org-name {
        font-size: 0.95rem;
        color: #5e6278;
    }

    .avatar {
        width: 45px;
        height: 45px;
        border-radius: 8px;
        margin-right: 12px;
    }

    .dept-stats {
        font-size: 0.8rem;
        color: #a1a5b7;
        margin-top: 8px;
        display: flex;
        justify-content: space-between;
    }
@@media print {
    /* Reset layout for printing */
    #kt_app_sidebar, #kt_app_header, .toolbar, .node-tools {
        display: none !important;
    }
    
    .post, .container-fluid, .org-container {
        padding: 0 !important;
        margin: 0 !important;
        height: auto !important;
        overflow: visible !important;
        background: white !important;
    }

    .org-container {
        border: none !important;
    }

    .org-tree {
        transform: none !important; /* Reset zoom/pan for print */
        position: relative !important;
        display: block !important;
        width: 100% !important;
        padding: 20px 0 !important;
    }

    /* Ensure the legend is printed and positioned well */
    .card.position-fixed {
        position: static !important;
        margin-top: 50px !important;
        width: 250px !important;
        box-shadow: none !important;
        border: 1px solid #eee !important;
        background: white !important;
    }

    /* General clean up */
    .org-node {
        break-inside: avoid;
        border: 1px solid #ccc !important;
    }

    /* Keep connectors visible */
    .org-tree li::before, .org-tree li::after, .org-tree ul ul::before {
        border-color: #333 !important;
    }


}
</style>

<div class="toolbar py-5" id="kt_toolbar">
    <div id="kt_toolbar_container" class="container-fluid d-flex flex-stack flex-wrap">
        <div class="d-flex align-items-center gap-2">
            <div class="position-relative w-md-250px">
                <i class="bi bi-search position-absolute top-50 translate-middle-y ms-4 text-gray-400"></i>
                <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm bộ phận, nhân sự..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <div class="separator separator-dashed h-25px mx-2 opacity-50"></div>
            <div class="d-flex gap-1">
                <button class="btn btn-icon btn-sm btn-light" title="Phóng to" @onclick="() => ZoomIn()"><i class="bi bi-zoom-in fs-5"></i></button>
                <button class="btn btn-icon btn-sm btn-light" title="Thu nhỏ" @onclick="() => ZoomOut()"><i class="bi bi-zoom-out fs-5"></i></button>
                <button class="btn btn-icon btn-sm btn-light" title="Về trung tâm" @onclick="() => ResetPanZoom()"><i class="bi bi-fullscreen-exit fs-5"></i></button>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group">
                <button class="btn btn-sm btn-light-info fw-bolder px-4" @onclick="ExportDiagram"><i class="bi bi-download me-2"></i>Xuất sơ đồ</button>
            </div>
            <button class="btn btn-sm btn-primary fw-bolder px-5" @onclick="ToggleAddModal"><i class="bi bi-plus-lg me-1"></i>Thêm nút mới</button>
        </div>
    </div>
</div>

<div class="post d-flex flex-column-fluid" id="kt_post">
    <div class="container-fluid org-container" id="orgChartContainer">
        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card" Rows="3" Columns="2">
            <div class="org-tree" id="orgTreeExport">
                <ul>
                    @if (rootNode != null)
                    {
                        <OrgNodeView Node="rootNode" OnNodeClick="HandleNodeClick" />
                    }
                </ul>
            </div>
        </SkeletonLoading>
    </div>
</div>

<!-- MODAL: ADD NEW NODE -->
@if (showAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary py-4">
                    <h5 class="modal-title text-white">Thêm nút mới vào sơ đồ</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ToggleAddModal"></button>
                </div>
                <div class="modal-body p-8" style="max-height: 70vh; overflow-y: auto;">
                    <!-- Base Info -->
                    <div class="mb-8">
                        <h4 class="fs-6 fw-bold text-gray-800 mb-4 border-bottom pb-2">Thông tin cơ bản</h4>
                        <div class="row g-5">
                            <div class="col-md-6 mb-5">
                                <label class="form-label fw-bold">Tên nhân sự / Bộ phận</label>
                                <input type="text" class="form-control form-control-solid" @bind="newNode.Name" placeholder="Nhập tên..." />
                            </div>
                            <div class="col-md-6 mb-5">
                                <label class="form-label fw-bold">Chức danh / Vai trò</label>
                                <input type="text" class="form-control form-control-solid" @bind="newNode.Role" placeholder="Nhập chức danh..." />
                            </div>
                            <div class="col-md-6 mb-5">
                                <label class="form-label fw-bold">Loại nút</label>
                                <select class="form-select form-select-solid" @bind="newNode.Type">
                                    <option value="Employee">Nhân viên</option>
                                    <option value="Department">Bộ phận</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-5">
                                <label class="form-label fw-bold">Nút cấp trên</label>
                                <select class="form-select form-select-solid" @bind="newNodeParentId">
                                    @foreach (var node in flatNodeList)
                                    {
                                        <option value="@node.Id">@node.Role - @node.Name</option>
                                    }
                                </select>
                            </div>
                            @if (newNode.Type == "Employee")
                            {
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Số CCCD / CMND</label>
                                    <input type="text" class="form-control form-control-solid" @bind="newNode.CccdNumber" />
                                </div>
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Ngày sinh</label>
                                    <input type="date" class="form-control form-control-solid" @bind="newNode.DateOfBirth" />
                                </div>
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Giới tính</label>
                                    <select class="form-select form-select-solid" @bind="newNode.Gender">
                                        <option value="Nam">Nam</option>
                                        <option value="Nữ">Nữ</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Quốc tịch</label>
                                    <input type="text" class="form-control form-control-solid" @bind="newNode.Nationality" />
                                </div>
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Dân tộc</label>
                                    <input type="text" class="form-control form-control-solid" @bind="newNode.Ethnicity" />
                                </div>
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Tôn giáo</label>
                                    <input type="text" class="form-control form-control-solid" @bind="newNode.Religion" />
                                </div>
                                <div class="col-md-12 mb-5">
                                    <label class="form-label fw-bold">Quê quán</label>
                                    <input type="text" class="form-control form-control-solid" @bind="newNode.PlaceOfOrigin" />
                                </div>
                                <div class="col-md-12 mb-5">
                                    <label class="form-label fw-bold">Nơi thường trú</label>
                                    <textarea class="form-control form-control-solid" rows="1" @bind="newNode.Residence"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Quản lý?</label>
                                    <div class="form-check form-switch form-check-custom form-check-solid mt-2">
                                        <input class="form-check-input" type="checkbox" @bind="newNode.IsManager" />
                                        <span class="form-check-label fw-bold ms-2">Có</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @if (newNode.Type == "Employee")
                    {


                        <!-- Contact Info -->
                        <div class="mb-8">
                            <h4 class="fs-6 fw-bold text-gray-800 mb-4 border-bottom pb-2">Thông tin liên lạc</h4>
                            <div class="row g-5">
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Số điện thoại</label>
                                    <input type="text" class="form-control form-control-solid" @bind="newNode.Phone" />
                                </div>
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Email cá nhân</label>
                                    <input type="email" class="form-control form-control-solid" @bind="newNode.PersonalEmail" />
                                </div>
                            </div>
                        </div>

                        <!-- Job Details -->
                        <div class="mb-8">
                            <h4 class="fs-6 fw-bold text-gray-800 mb-4 border-bottom pb-2">Thông tin công việc</h4>
                            <div class="row g-5">
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Mã nhân viên</label>
                                    <input type="text" class="form-control form-control-solid" @bind="newNode.EmployeeCode" />
                                </div>
                                <div class="col-md-6 mb-5">
                                    <label class="form-label fw-bold">Loại hợp đồng</label>
                                    <select class="form-select form-select-solid" @bind="newNode.ContractType">
                                        <option value="">Chọn...</option>
                                        <option value="Thử việc">Thử việc</option>
                                        <option value="Chính thức - Không thời hạn">Chính thức - Không thời hạn</option>
                                        <option value="Hợp đồng 1 năm">Hợp đồng 1 năm</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-light" @onclick="ToggleAddModal">Hủy</button>
                    <button type="button" class="btn btn-primary px-8" @onclick="SaveNewNode">
                        <i class="bi bi-check-lg me-1"></i>Lưu thay đổi
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- DRAWER: EMPLOYEE DETAIL -->
<div id="kt_drawer_employee_detail" class="bg-white" data-kt-drawer="true" data-kt-drawer-name="employee-detail"
     data-kt-drawer-activate="true" data-kt-drawer-overlay="true"
     data-kt-drawer-width="{default:'300px', 'md': '650px'}" data-kt-drawer-direction="end"
     data-kt-drawer-close="#kt_drawer_employee_detail_close">

    <div class="card shadow-none rounded-0 w-100 h-100">
        <!-- Header Section -->
        <div class="card-header border-0 pt-7 pb-5">
            <div class="d-flex align-items-center">
                <div class="symbol symbol-70px symbol-2by3 me-5">
                    <img src="@selectedNode?.Avatar" alt="@selectedNode?.Name" class="rounded-3" />
                </div>
                <div class="d-flex flex-column">
                    <h2 class="fs-1 fw-bolder text-gray-900 mb-1">@selectedNode?.Name</h2>
                    <div class="text-primary fw-bold fs-6 mb-2">@selectedNode?.Role</div>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge badge-light-secondary text-gray-600 fw-bold px-3 py-2">
                            Mã NV:
                            NV001
                        </span>
                        <span class="badge badge-light-secondary text-gray-600 fw-bold px-3 py-2">Ban TGĐ</span>
                    </div>
                </div>
            </div>
            <div class="card-toolbar">
                <button type="button" class="btn btn-sm btn-icon btn-active-light-primary"
                        id="kt_drawer_employee_detail_close">
                    <i class="bi bi-x-lg fs-2"></i>
                </button>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="px-10" id="empDetailTabContent">
                <div class="py-5">
                    <div class="d-flex flex-stack mb-5">
                        <h3 class="fw-bolder m-0 fs-5 text-uppercase">
                            <i class="bi bi-person-badge text-primary me-2"></i>Thông tin cá nhân
                        </h3>
                    </div>

                    <div class="row g-6 mb-8">
                        <div class="col-md-4">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Số CCCD / CMND</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.CccdNumber</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Ngày sinh</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.DateOfBirth?.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Giới tính</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.Gender</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Quốc tịch</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.Nationality</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Dân tộc</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.Ethnicity</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Tôn giáo</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.Religion</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Quê quán</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.PlaceOfOrigin</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Nơi thường trú</label>
                            <div class="fw-bold fs-6 text-gray-800">@selectedNode?.Residence</div>
                        </div>
                    </div>



                    <!-- Section: Contact & Personal -->
                    <div class="mb-8">
                        <h4 class="fs-6 fw-bold text-gray-800 mb-4 border-bottom pb-2 text-uppercase">Thông tin liên lạc</h4>
                        <div class="row g-6">
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Số điện thoại</label>
                                <div class="fw-bold fs-6 text-primary">@selectedNode?.Phone</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Email cá nhân</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.PersonalEmail</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Email công việc</label>
                                <div class="fw-bold fs-6 text-primary">@selectedNode?.WorkEmail</div>
                            </div>
                        </div>
                    </div>

                    <!-- Section: Job Information -->
                    <div class="mb-8 p-6 bg-light-primary rounded-3 border border-primary border-dashed">
                        <h4 class="fs-6 fw-bold text-gray-800 mb-4 border-bottom pb-2 text-uppercase">Thông tin công việc</h4>
                        <div class="row g-6 mb-5">
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Mã nhân viên</label>
                                <div class="fw-bolder fs-6 text-dark">#@selectedNode?.EmployeeCode</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Loại hợp đồng</label>
                                <div><span class="badge badge-light-info fw-bold">@selectedNode?.ContractType</span></div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Ngày chính thức</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.OfficialJoinDate?.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                        <div class="row g-6">
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Văn phòng</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.Workplace</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Phòng ban</label>
                                <div class="fw-bold fs-6 text-gray-800">Phòng Kỹ thuật</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Chức vụ</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.Role</div>
                            </div>
                        </div>
                    </div>

                    <!-- Section: Finance -->
                    <div class="mb-8">
                        <h4 class="fs-6 fw-bold text-gray-800 mb-4 border-bottom pb-2 text-uppercase">Tài chính & Bảo hiểm</h4>
                        <div class="row g-6">
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">MST cá nhân</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.TaxId</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Số BHXH</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.SocialInsuranceId</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Hôn nhân</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.MaritalStatus</div>
                            </div>
                        </div>
                    </div>

                    <!-- Section: Emergency Contact -->
                    <div class="mb-5">
                        <h4 class="fs-6 fw-bold text-gray-800 mb-4 border-bottom pb-2 text-uppercase">Liên hệ khẩn cấp</h4>
                        <div class="row g-6">
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Người liên hệ</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.EmergencyContactName</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">Mối quan hệ</label>
                                <div class="fw-bold fs-6 text-gray-800">@selectedNode?.EmergencyContactRelation</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fs-8 text-uppercase fw-bolder mb-1">SĐT khẩn cấp</label>
                                <div class="fw-bold fs-6 text-danger">@selectedNode?.EmergencyContactPhone</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer border-0 d-flex justify-content-end p-10">
            <button type="button" class="btn btn-light px-10"
                    id="kt_drawer_employee_detail_close">
                Đóng
            </button>
        </div>
    </div>
</div>


<!-- Legend Fixed -->
<div class="card position-fixed bottom-0 start-0 m-8 shadow-lg border-0" style="z-index: 100; width: 220px; background: rgba(255,255,255,0.9); backdrop-filter: blur(4px);">
    <div class="card-body p-5">
        <h6 class="fs-8 text-uppercase fw-bolder text-gray-400 mb-4 tracking-widest">Phân loại</h6>
        <div class="d-flex align-items-center mb-3">
            <span class="w-12px h-12px rounded-circle bg-primary me-3"></span>
            <span class="fs-7 fw-bold text-gray-700">Bộ phận / Khối</span>
        </div>
        <div class="d-flex align-items-center mb-3">
            <span class="w-12px h-12px rounded-circle bg-success me-3"></span>
            <span class="fs-7 fw-bold text-gray-700">Cấp quản lý (Manager)</span>
        </div>
        <div class="d-flex align-items-center mb-0">
            <span class="w-12px h-12px rounded-circle bg-gray-300 me-3"></span>
            <span class="fs-7 fw-bold text-gray-700">Nhân viên</span>
        </div>
        
        <div class="separator separator-dashed my-4"></div>
        <div class="fs-9 text-muted d-flex justify-content-between align-items-center">
            <span>Tổng nhân sự:</span>
            <span class="badge badge-light-dark fw-bolder">@AllEmployeesCount</span>
        </div>
    </div>
</div>



<script>
    let scale = 1, pointX = 0, pointY = 0, isDragging = false, startX = 0, startY = 0;
    
    window.zoomAtCenter = (zoomIn) => {
        const orgContainer = document.querySelector('.org-container');
        if (!orgContainer) return;
        const rect = orgContainer.getBoundingClientRect();
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const xs = (centerX - pointX) / scale;
        const ys = (centerY - pointY) / scale;
        if (zoomIn) scale *= 1.2; else scale /= 1.2;
        scale = Math.min(3, Math.max(0.2, scale));
        pointX = centerX - xs * scale;
        pointY = centerY - ys * scale;
        updateTransform();
    };

    window.resetPanZoom = () => {
        scale = 1; pointX = 0; pointY = 20;
        updateTransform();
    };
    
    window.openEmployeeDetail = () => {
        const drawerElement = document.querySelector('#kt_drawer_employee_detail');
        if (drawerElement && typeof KTDrawer !== 'undefined') {
            let drawerInstance = KTDrawer.getInstance(drawerElement);
            if (!drawerInstance) {
                drawerInstance = new KTDrawer(drawerElement);
            }
            if (drawerInstance) drawerInstance.show();
        }
    };

    function updateTransform() {
        const orgTree = document.querySelector('.org-tree');
        if (orgTree) {
            orgTree.style.transform = `translate(${pointX}px, ${pointY}px) scale(${scale})`;
        }
    }

    window.exportOrgChart = () => {
        const element = document.getElementById('orgTreeExport');
        if (!element) return;

        if (typeof html2canvas === 'undefined') {
            const script = document.createElement('script');
            script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
            script.onload = () => doExport(element);
            document.head.appendChild(script);
        } else {
            doExport(element);
        }

        function doExport(el) {
            const originalTransform = el.style.transform;
            el.style.transform = 'none';
            
            html2canvas(el, {
                backgroundColor: '#f8f9fa',
                scale: 2,
                logging: false,
                useCORS: true
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = `OrganizationStructure_${new Date().getTime()}.png`;
                link.href = canvas.toDataURL();
                link.click();
                el.style.transform = originalTransform;
            }).catch(err => {
                console.error('Export failed:', err);
                el.style.transform = originalTransform;
            });
        }
    };



    function initOrgChartPanZoom() {
        console.log("Initializing OrgChart Pan/Zoom...");
        const orgTree = document.querySelector('.org-tree');
        const orgContainer = document.querySelector('.org-container');
        
        if (!orgTree || !orgContainer) {
            console.warn("OrgChart elements not found. Retrying in 100ms...");
            setTimeout(initOrgChartPanZoom, 100);
            return;
        }

        // Remove old listeners if any to avoid duplicates
        // (Simplified by re-assigning or using clean logic)
        
        const handleWheel = (e) => {
            e.preventDefault();
            const rect = orgContainer.getBoundingClientRect();
            const mouseX = e.clientX - rect.left;
            const mouseY = e.clientY - rect.top;

            const xs = (mouseX - pointX) / scale;
            const ys = (mouseY - pointY) / scale;

            const delta = -e.deltaY;
            if (delta > 0) scale *= 1.1; else scale /= 1.1;
            scale = Math.min(Math.max(0.1, scale), 5);

            pointX = mouseX - xs * scale;
            pointY = mouseY - ys * scale;

            updateTransform();
        };

        orgContainer.removeEventListener('wheel', handleWheel);
        orgContainer.addEventListener('wheel', handleWheel, { passive: false });

        orgContainer.onmousedown = (e) => {
            if (e.target.closest('.org-node')) return;
            isDragging = true;
            orgContainer.style.cursor = 'grabbing';
            startX = e.clientX - pointX;
            startY = e.clientY - pointY;
        };

        const onMouseUp = () => {
            isDragging = false;
            orgContainer.style.cursor = 'grab';
        };

        const onMouseMove = (e) => {
            if (!isDragging) return;
            pointX = e.clientX - startX;
            pointY = e.clientY - startY;
            updateTransform();
        };

        window.removeEventListener('mouseup', onMouseUp);
        window.removeEventListener('mousemove', onMouseMove);
        window.addEventListener('mouseup', onMouseUp);
        window.addEventListener('mousemove', onMouseMove);
        
        // Center the chart initially if needed
        pointX = (orgContainer.offsetWidth / 2) - (orgTree.offsetWidth / 2);
        pointY = 50;
        
        updateTransform();
        console.log("OrgChart Pan/Zoom initialized.");
    }
</script>


