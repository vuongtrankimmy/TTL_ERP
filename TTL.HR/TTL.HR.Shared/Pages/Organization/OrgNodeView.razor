@using TTL.HR.Application.Modules.Organization.Models
@using System.Linq

<li>
    <div class="org-node @(Node.Type == "Department" ? "is-department" : "") @(Node.IsManager ? "is-manager" : "")" 
         @onclick="() => OnNodeClick.InvokeAsync(Node)" @onclick:stopPropagation="true">
        <div class="node-tools">
            <button class="btn btn-icon btn-xs btn-light-primary"><i class="bi bi-pencil fs-9"></i></button>
        </div>
        
        <div class="d-flex align-items-center">
            <img src="@Node.Avatar" class="avatar" alt="@Node.Name" />
            <div class="d-flex flex-column align-items-start">
                <div class="org-role">@Node.Role</div>
                <div class="org-name d-flex align-items-center">
                    @Node.Name
                    @if (!string.IsNullOrEmpty(Node.EmployeeCode))
                    {
                        <span class="text-gray-400 fs-9 ms-2">#@Node.EmployeeCode</span>
                    }
                </div>
                @if (Node.Type == "Employee" && !string.IsNullOrEmpty(Node.Status))
                {
                    <span class="badge badge-light-success fw-bolder fs-9 py-1 px-2 mt-1">@Node.Status</span>
                }
            </div>
        </div>

        @if (Node.Type == "Department")
        {
            <div class="dept-stats">
                <span><i class="bi bi-diagram-3 me-1"></i>@Node.Children.Count(c => c.Type == "Department")</span>
                <span><i class="bi bi-people me-1"></i>@Node.EmployeeCount</span>
            </div>
        }
    </div>

    @if (Node.Children != null && Node.Children.Any())
    {
        <ul>
            @foreach (var child in Node.Children)
            {
                <OrgNodeView Node="child" OnNodeClick="OnNodeClick" />
            }
        </ul>
    }
</li>


