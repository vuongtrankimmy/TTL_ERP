@page "/assets/allocation"
@using TTL.HR.Shared.Components.Common

<PageTitle>Cấp phát tài sản - TTL.HR</PageTitle>

<div class="card card-flush shadow-sm border-0 pt-8">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div class="d-flex align-items-center position-relative my-1">
                <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5 text-gray-500"></i>
                <input type="text" class="form-control form-control-solid w-250px ps-13" placeholder="Tìm kiếm cấp phát..." />
            </div>
        </div>
        <div class="card-toolbar">
            <button type="button" class="btn btn-primary fw-bold" @onclick="OpenAllocationModal">
                <i class="ki-outline ki-plus fs-2 me-1"></i> Cấp phát tài sản
            </button>
        </div>
    </div>
    
    <div class="card-body pt-0">
        <!-- Tabs -->
        <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold mb-8">
            <li class="nav-item">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 active" data-bs-toggle="tab" href="#kt_allocation_active">
                    Đang sử dụng <span class="badge badge-light-primary ms-2">@ActiveAllocations.Count</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-active-primary ms-0 me-10 py-5" data-bs-toggle="tab" href="#kt_allocation_history">
                    Lịch sử thu hồi <span class="badge badge-light-secondary ms-2">@HistoryAllocations.Count</span>
                </a>
            </li>
        </ul>

        <div class="tab-content" id="myTabContent">
            <!-- Active Allocations Tab -->
            <div class="tab-pane fade show active" id="kt_allocation_active" role="tabpanel">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="5">
                    <div class="table-responsive">
                        <table class="table align-middle table-row-dashed fs-6 gy-5">
                            <thead>
                                <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                                    <th class="min-w-200px">Tài sản</th>
                                    <th class="min-w-200px">Nhân viên</th>
                                    <th class="min-w-150px">Ngày cấp phát</th>
                                    <th class="min-w-120px text-center">Tình trạng</th>
                                    <th class="text-end min-w-100px pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody class="fw-semibold text-gray-700">
                                @if (ActiveAllocations.Any())
                                {
                                    @foreach (var item in ActiveAllocations)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-40px me-3">
                                                        <div class="symbol-label bg-light-primary">
                                                            <i class="@GetAssetIcon(item.AssetType) text-primary fs-2"></i>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex justify-content-start flex-column">
                                                        <a href="javascript:void(0)" class="text-gray-900 text-hover-primary mb-1 fs-6 fw-bold">@item.AssetName</a>
                                                        <span class="text-muted fw-semibold d-block fs-7">@item.AssetCode</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-35px symbol-circle me-3">
                                                        <div class="symbol-label bg-light-info text-info fw-bold">@item.EmployeeName.Substring(0, 1)</div>
                                                    </div>
                                                    <div class="d-flex justify-content-start flex-column">
                                                        <span class="text-gray-900 fw-bold fs-6">@item.EmployeeName</span>
                                                        <span class="text-muted fw-semibold d-block fs-7">@item.Department</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-gray-700">@item.AssignedDate?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-center">
                                                <span class="badge badge-light-success fw-bold px-4 py-3">@item.Condition</span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <button class="btn btn-sm btn-light-danger btn-active-danger fw-bold hover-scale" @onclick="() => OpenReturnModal(item)">
                                                    <i class="ki-outline ki-arrow-left fs-4 me-1"></i> Thu hồi
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-20">
                                            <div class="text-muted fs-5">Chưa có tài sản nào đang được cấp phát.</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </SkeletonLoading>
            </div>

            <!-- History Tab -->
            <div class="tab-pane fade" id="kt_allocation_history" role="tabpanel">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="5">
                    <div class="table-responsive">
                        <table class="table align-middle table-row-dashed fs-6 gy-5">
                             <thead>
                                <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                                    <th class="min-w-200px">Tài sản</th>
                                    <th class="min-w-200px">Nhân viên</th>
                                    <th class="min-w-150px">Ngày cấp</th>
                                    <th class="min-w-150px">Ngày thu hồi</th>
                                    <th class="min-w-150px text-center">Tình trạng thực tế</th>
                                </tr>
                            </thead>
                            <tbody class="fw-semibold text-gray-700">
                                @if (HistoryAllocations.Any())
                                {
                                    @foreach (var item in HistoryAllocations)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-40px me-3">
                                                        <div class="symbol-label bg-light-secondary">
                                                            <i class="@GetAssetIcon(item.AssetType) text-gray-600 fs-2"></i>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex justify-content-start flex-column">
                                                        <span class="text-gray-900 mb-1 fs-6">@item.AssetName</span>
                                                        <span class="text-muted d-block fs-7">@item.AssetCode</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <span class="text-gray-700">@item.EmployeeName</span>
                                                </div>
                                            </td>
                                            <td class="text-gray-600">@item.AssignedDate?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-gray-900 fw-bold">@item.ReturnedDate?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-center">
                                                <span class="badge @(item.ReturnCondition == "Hỏng" ? "badge-light-danger" : "badge-light-info") fw-bold px-4 py-3">@item.ReturnCondition</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-20">
                                            <div class="text-muted fs-5">Chưa có lịch sử thu hồi nào.</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </SkeletonLoading>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Cấp phát mới -->
@if (IsAllocationModalOpen)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header border-0 pt-7 px-9">
                    <h3 class="modal-title fw-bolder text-primary fs-2">Cấp phát tài sản mới</h3>
                    <div class="btn btn-icon btn-sm btn-active-light-primary" @onclick="CloseAllocationModal">
                         <i class="ki-outline ki-cross fs-1"></i>
                    </div>
                </div>
                <EditForm Model="@NewAllocation" OnValidSubmit="SaveAllocation">
                    <div class="modal-body py-5 px-9">
                        <DataAnnotationsValidator />
                        
                        <div class="row g-9 mb-8">
                            <div class="col-md-6 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Nhân viên tiếp nhận</label>
                                <InputSelect class="form-select form-select-solid" @bind-Value="NewAllocation.EmployeeId">
                                    <option value="">-- Chọn nhân viên --</option>
                                    @foreach (var emp in Employees)
                                    {
                                        <option value="@emp.Id">@emp.FullName (@emp.Code)</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => NewAllocation.EmployeeId)" class="text-danger mt-1 fs-8" />
                            </div>
                            <div class="col-md-6 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Tài sản (Sẵn dùng)</label>
                                <InputSelect class="form-select form-select-solid" @bind-Value="NewAllocation.AssetId">
                                    <option value="">-- Chọn tài sản --</option>
                                    @foreach (var asset in AvailableAssets)
                                    {
                                        <option value="@asset.Id">@asset.Name (@asset.Code)</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => NewAllocation.AssetId)" class="text-danger mt-1 fs-8" />
                            </div>
                        </div>

                        <div class="row g-9 mb-8">
                            <div class="col-md-6 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Ngày cấp phát</label>
                                <div class="position-relative d-flex align-items-center">
                                    <i class="ki-outline ki-calendar-8 fs-2 position-absolute mx-4"></i>
                                    <InputDate class="form-control form-control-solid ps-12" @bind-Value="NewAllocation.AssignedDate" />
                                </div>
                            </div>
                            <div class="col-md-6 fv-row">
                                <label class="fs-6 fw-bold mb-2">Tình trạng bàn giao</label>
                                <select class="form-select form-select-solid">
                                    <option value="Mới">Mới 100%</option>
                                    <option value="Tốt" selected>Đang dùng tốt</option>
                                    <option value="Cũ">Cũ / Xước nhẹ</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="fv-row mb-5">
                            <label class="fs-6 fw-bold mb-2">Ghi chú / Cam kết sử dụng</label>
                            <InputTextArea class="form-control form-control-solid" @bind-Value="NewAllocation.Note" rows="3" placeholder="Nhập ghi chú hoặc cam kết của nhân viên khi nhận máy..." />
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-10 px-9 gap-3">
                        <button type="button" class="btn btn-light fw-bold" @onclick="CloseAllocationModal">Hủy bỏ</button>
                        <button type="submit" class="btn btn-primary fw-bold px-10">Xác nhận cấp phát</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Modal: Thu hồi tài sản -->
@if (IsReturnModalOpen)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header border-0 pt-7 px-9">
                    <h3 class="modal-title fw-bolder text-danger fs-2">Tiến hành thu hồi tài sản</h3>
                    <div class="btn btn-icon btn-sm btn-active-light-primary" @onclick="CloseReturnModal">
                         <i class="ki-outline ki-cross fs-1"></i>
                    </div>
                </div>
                <div class="modal-body py-5 px-9">
                     <div class="d-flex align-items-center bg-light-danger rounded p-6 mb-8 border border-danger border-dashed">
                         <i class="ki-outline ki-information-5 text-danger fs-1 ms-1 me-4"></i>
                         <div class="text-gray-800 fw-bold">Xác nhận thu hồi tài sản từ nhân viên <span class="text-danger fw-bolder">@AllocationToReturn?.EmployeeName</span>?</div>
                     </div>

                     <div class="mb-8">
                        <label class="fs-7 fw-bold text-muted mb-2 text-uppercase">Tài sản thu hồi</label>
                        <div class="form-control form-control-solid fw-bolder text-gray-900 bg-light py-4 fs-6">@AllocationToReturn?.AssetName (@AllocationToReturn?.AssetCode)</div>
                    </div>

                    <div class="row g-9 mb-8">
                        <div class="col-md-6 fv-row">
                            <label class="required fs-6 fw-bold mb-2">Ngày thu hồi</label>
                            <input type="date" class="form-control form-control-solid" @bind="ReturnDate" />
                        </div>
                        <div class="col-md-6 fv-row">
                            <label class="required fs-6 fw-bold mb-2">Tình trạng thực tế</label>
                            <select class="form-select form-select-solid" @bind="ReturnCondition">
                                <option value="Available">Sẵn dùng (Tốt)</option>
                                <option value="Maintenance">Cần bảo trì</option>
                                <option value="Broken">Đã hỏng</option>
                                <option value="Lost">Đã mất</option>
                            </select>
                        </div>
                    </div>

                    <div class="fv-row mb-5">
                         <label class="fs-6 fw-bold mb-2">Lý do & Mô tả tình trạng</label>
                         <textarea class="form-control form-control-solid" @bind="ReturnNote" rows="3" placeholder="Lý do thu hồi (nghỉ việc, đổi máy...) và chi tiết tình trạng máy hiện tại..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-10 px-9 gap-3">
                    <button type="button" class="btn btn-light fw-bold" @onclick="CloseReturnModal">Hủy bỏ</button>
                    <button type="button" class="btn btn-danger fw-bold px-10 shadow-sm" @onclick="ConfirmReturn">Xác nhận thu hồi</button>
                </div>
            </div>
        </div>
    </div>
}
