@page "/assets/inventory"
@using TTL.HR.Shared.Components.Common

<PageTitle>Kho tài sản - TTL.HR</PageTitle>

<div class="card card-flush shadow-sm border-0">
    <div class="card-header align-items-center py-5 gap-2 gap-md-5 border-0">
        <div class="card-title">
            <div class="d-flex align-items-center position-relative my-1">
                <i class="ki-outline ki-magnifier fs-3 position-absolute ms-4 text-gray-500"></i>
                <input type="text" class="form-control form-control-solid w-250px ps-12" placeholder="Tìm kiếm tài sản..." 
                       @bind="_searchTerm" @bind:event="oninput">
            </div>
        </div>
        <div class="card-toolbar">
            <div class="d-flex justify-content-end gap-3">
                <button type="button" class="btn btn-light-primary fw-bold">
                    <i class="ki-outline ki-exit-up fs-2 me-1"></i> Xuất Excel
                </button>
                <button type="button" class="btn btn-primary fw-bold" @onclick="CreateNewAsset">
                    <i class="ki-outline ki-plus fs-2 me-1"></i> Thêm tài sản
                </button>
            </div>
        </div>
    </div>
    <div class="card-body pt-0">
        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10">
            <div class="table-responsive">
                <table class="table align-middle table-row-dashed fs-6 gy-5">
                    <thead class="bg-light">
                        <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                            <th class="min-w-250px ps-4">TÊN TÀI SẢN</th>
                            <th class="min-w-120px">MàTSCĐ</th>
                            <th class="min-w-150px">NGƯỜI SỬ DỤNG</th>
                            <th class="min-w-120px text-center">TRẠNG THÁI</th>
                            <th class="min-w-120px">NGÀY MUA</th>
                            <th class="text-end min-w-100px pe-4">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody class="fw-semibold text-gray-700">
                        @if (FilteredAssets.Any())
                        {
                            @foreach (var asset in FilteredAssets)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="symbol symbol-40px me-3">
                                                <div class="symbol-label bg-light-info text-info">
                                                    <i class="ki-outline ki-laptop fs-2"></i>
                                                </div>
                                            </div>
                                            <div class="d-flex flex-column">
                                                <a href="javascript:void(0)" @onclick="() => ViewDetail(asset.Id)" class="text-gray-800 text-hover-primary fs-6 fw-bold">@asset.Name</a>
                                                <span class="text-muted fw-semibold fs-7 text-uppercase">@asset.Category</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge badge-light fw-bold fs-7">@asset.Code</span></td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (asset.AssignedTo != "Chưa bàn giao")
                                            {
                                                <div class="symbol symbol-25px symbol-circle me-2">
                                                    <div class="symbol-label bg-light-primary text-primary fs-9 fw-bold">@asset.AssignedTo.Substring(0, 1)</div>
                                                </div>
                                            }
                                            <span class="fw-bold">@asset.AssignedTo</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="badge badge-light-@(GetStatusColor(asset.StatusKey)) fw-bold px-4 py-3">@asset.Status</div>
                                    </td>
                                    <td>@asset.PurchaseDate?.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-icon btn-light-primary btn-active-primary me-2 hover-scale" title="Xem chi tiết" @onclick="() => ViewDetail(asset.Id)">
                                            <i class="ki-outline ki-eye fs-2"></i>
                                        </button>
                                        <button class="btn btn-sm btn-icon btn-light-warning btn-active-warning me-2 hover-scale" title="Chỉnh sửa" @onclick="() => EditAsset(asset.Id)">
                                            <i class="ki-outline ki-pencil fs-2"></i>
                                        </button>
                                        <button class="btn btn-sm btn-icon btn-light-danger btn-active-danger hover-scale" title="Xóa" @onclick="() => PromptDeleteAsset(asset)">
                                            <i class="ki-outline ki-trash fs-2"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-20">
                                    <div class="text-muted fs-4">Không tìm thấy tài sản nào.</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </SkeletonLoading>
    </div>
</div>

<DeleteConfirmationModal 
    IsVisible="@IsDeleteModalOpen"
    Title="Xóa tài sản"
    Message="Bạn có chắc chắn muốn xóa tài sản này khỏi kho?"
    ItemName="@(AssetToDelete?.Name ?? "")"
    OnConfirmed="ConfirmDelete"
    OnCancelled="CloseDeleteModal" />
