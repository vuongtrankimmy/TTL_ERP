@page "/assets/detail/{Id}"

<div class="d-flex flex-column flex-xl-row">
    <!--begin::Sidebar-->
    <div class="flex-column flex-lg-row-auto w-100 w-xl-350px mb-10">
        <!--begin::Card-->
        <div class="card mb-5 mb-xl-8">
            <div class="card-body pt-15">
                <!--begin::Summary-->
                <div class="d-flex flex-center flex-column mb-5">
                    <div class="symbol symbol-100px symbol-circle mb-7">
                        <span class="symbol-label bg-light-primary text-primary fs-1 fw-bold">IT</span>
                    </div>
                    <a href="#" class="fs-3 text-gray-800 text-hover-primary fw-bold mb-1">
                        @Asset?.Name
                    </a>
                    <div class="fs-5 fw-semibold text-muted mb-6">@Asset?.Code</div>
                    <div class="d-flex flex-wrap flex-center">
                        <div class="border border-gray-300 border-dashed rounded py-3 px-3 mb-3">
                            <div class="fs-4 fw-bold text-gray-700">
                                <span class="w-75px">@Asset?.PurchasePrice.ToString("N0")</span>
                            </div>
                            <div class="fw-semibold text-muted">Purchase Price</div>
                        </div>
                         <div class="border border-gray-300 border-dashed rounded py-3 px-3 mb-3 ms-2">
                             <div class="fs-4 fw-bold text-gray-700">
                                <span class="w-50px">@Asset?.Status</span>
                            </div>
                            <div class="fw-semibold text-muted">Status</div>
                        </div>
                    </div>
                </div>
                <!--end::Summary-->
                <!--begin::Details toggle-->
                <div class="d-flex flex-stack fs-4 py-3">
                    <div class="fw-bold rotate collapsible" data-bs-toggle="collapse" href="#kt_customer_view_details" role="button" aria-expanded="false" aria-controls="kt_customer_view_details">Details
                    <span class="ms-2 rotate-180">
                        <i class="ki-outline ki-down fs-3"></i>
                    </span></div>
                </div>
                <!--end::Details toggle-->
                <div class="separator separator-dashed my-3"></div>
                <!--begin::Details content-->
                <div id="kt_customer_view_details" class="collapse show">
                    <div class="py-5 fs-6">
                        <div class="fw-bold mt-5">Asset Type</div>
                        <div class="text-gray-600">@Asset?.Type</div>
                        <div class="fw-bold mt-5">Serial Number</div>
                        <div class="text-gray-600">@Asset?.SerialNumber</div>
                        <div class="fw-bold mt-5">Purchase Date</div>
                        <div class="text-gray-600">@Asset?.PurchaseDate.ToShortDateString()</div>
                         <div class="fw-bold mt-5">Vendor</div>
                        <div class="text-gray-600">FPT Shop</div>
                    </div>
                </div>
                <!--end::Details content-->
            </div>
        </div>
        <!--end::Card-->
    </div>
    <!--end::Sidebar-->
    <!--begin::Content-->
    <div class="flex-lg-row-fluid ms-lg-15">
        <!--begin:::Tabs-->
        <ul class="nav nav-custom nav-tabs nav-line-tabs nav-line-tabs-2x border-0 fs-4 fw-semibold mb-8">
            <li class="nav-item">
                <a class="nav-link text-active-primary pb-4 active" data-bs-toggle="tab" href="#kt_customer_view_overview_tab">Overview</a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-active-primary pb-4" data-bs-toggle="tab" href="#kt_customer_view_general_tab">Assignment History</a>
            </li>
        </ul>
        <!--end:::Tabs-->
        <!--begin:::Tab content-->
        <div class="tab-content" id="myTabContent">
            <!--begin:::Tab pane-->
            <div class="tab-pane fade show active" id="kt_customer_view_overview_tab" role="tabpanel">
                <div class="card pt-4 mb-6 mb-xl-9">
                    <div class="card-header border-0">
                        <div class="card-title">
                            <h2>Current Assignment</h2>
                        </div>
                    </div>
                    <div class="card-body pt-0 pb-5">
                       
                        @if (Asset?.Status == "Assigned")
                        {
                            <div class="d-flex align-items-center mb-7">
                                <!--begin::Avatar-->
                                <div class="symbol symbol-50px me-5">
                                    <img src="assets/media/avatars/300-1.jpg" class="" alt="" />
                                </div>
                                <!--end::Avatar-->
                                <!--begin::Text-->
                                <div class="flex-grow-1">
                                    <a href="#" class="text-dark fw-bold text-hover-primary fs-6">@Asset.AssignedTo</a>
                                    <span class="text-muted d-block fw-bold">Software Engineer</span>
                                </div>
                                <!--end::Text-->
                            </div>
                             <div class="notice d-flex bg-light-primary rounded border-primary border border-dashed p-6">
                                <i class="ki-outline ki-shield-tick fs-2tx text-primary me-4"></i>
                                <div class="d-flex flex-stack flex-grow-1 flex-wrap flex-md-nowrap">
                                    <div class="mb-3 mb-md-0 fw-semibold">
                                        <h4 class="text-gray-900 fw-bold">Handover Condition</h4>
                                        <div class="fs-6 text-gray-700 pe-7">Given in good condition. Bag and Mouse included.</div>
                                    </div>
                                    <a href="#" class="btn btn-primary px-6 align-self-center text-nowrap">View Handover Protocol</a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-dismissible bg-light-success d-flex flex-center flex-column py-10 px-10 px-lg-20 mb-10">
                                <i class="ki-outline ki-check-circle fs-5tx text-success mb-5"></i>
                                <div class="text-center">
                                    <h1 class="fw-bold mb-5">Available for Assignment</h1>
                                    <div class="separator separator-dashed border-success opacity-25 mb-5"></div>
                                    <div class="mb-9 text-dark">
                                        This asset is currently in stock and ready to be assigned to an employee.
                                    </div>
                                    <div class="d-flex flex-center flex-wrap">
                                        <a href="#" class="btn btn-outline btn-outline-success btn-active-success m-2">Perform Maintenance</a>
                                        <a href="#" class="btn btn-success m-2">Assign to Employee</a>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
            <!--end:::Tab pane-->
             <!--begin:::Tab pane for History-->
            <div class="tab-pane fade" id="kt_customer_view_general_tab" role="tabpanel">
                <div class="card pt-4 mb-6 mb-xl-9">
                    <div class="card-header border-0">
                        <div class="card-title">
                            <h2>History</h2>
                        </div>
                    </div>
                    <div class="card-body pt-0 pb-5">
                        <div class="timeline-label">
                            @foreach(var history in AllocationHistory)
                            {
                                <div class="timeline-item">
                                    <div class="timeline-label fw-bold text-gray-800 fs-6">@history.Date.ToString("dd/MM")</div>
                                    <div class="timeline-badge">
                                        <i class="fa fa-genderless text-@(history.Action == "Returned" ? "warning" : "success") fs-1"></i>
                                    </div>
                                    <div class="timeline-content d-flex flex-column ps-3">
                                        <span class="fw-bold text-gray-800 fs-6">@history.Action</span>
                                        <span class="text-muted">@history.Description</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
             <!--end:::Tab pane-->
        </div>
        <!--end:::Tab content-->
    </div>
    <!--end::Content-->
</div>

@code {
    [Parameter]
    public string Id { get; set; }

    private AssetDetailViewModel Asset;
    private List<HistoryViewModel> AllocationHistory = new();

    protected override void OnInitialized()
    {
        // Mock data logic based on Id
        if (Id == "IT-001" || string.IsNullOrEmpty(Id)) // Check null for preview
        {
            Asset = new AssetDetailViewModel
            {
                Name = "Dell XPS 15",
                Code = "IT-001",
                Type = "Laptop",
                Status = "Assigned",
                PurchasePrice = 35000000,
                PurchaseDate = new DateTime(2025, 1, 15),
                SerialNumber = "DXP-998877",
                AssignedTo = "Phan Thanh Tùng"
            };

            AllocationHistory = new List<HistoryViewModel>
            {
                new HistoryViewModel { Date = new DateTime(2025, 1, 20), Action = "Assigned", Description = "Assigned to Phan Thanh Tùng by Admin" },
                new HistoryViewModel { Date = new DateTime(2025, 1, 15), Action = "Purchased", Description = "Purchased from Vendor" }
            };
        }
        else
        {
             Asset = new AssetDetailViewModel
            {
                Name = "LG Ultrawide",
                Code = "IT-003",
                Type = "Monitor",
                Status = "Available",
                PurchasePrice = 12000000,
                PurchaseDate = new DateTime(2024, 6, 10),
                SerialNumber = "LG-29-WK600",
                AssignedTo = null
            };
             AllocationHistory = new List<HistoryViewModel>
            {
                new HistoryViewModel { Date = new DateTime(2025, 2, 1), Action = "Returned", Description = "Returned by John Doe (Resigned)" },
                new HistoryViewModel { Date = new DateTime(2024, 6, 15), Action = "Assigned", Description = "Assigned to John Doe" }
            };
        }
    }

    public class AssetDetailViewModel
    {
        public string Name { get; set; }
        public string Code { get; set; }
        public string Type { get; set; }
        public string Status { get; set; }
        public decimal PurchasePrice { get; set; }
        public DateTime PurchaseDate { get; set; }
        public string SerialNumber { get; set; }
        public string AssignedTo { get; set; }
    }

    public class HistoryViewModel
    {
        public DateTime Date { get; set; }
        public string Action { get; set; }
        public string Description { get; set; }
    }
}
