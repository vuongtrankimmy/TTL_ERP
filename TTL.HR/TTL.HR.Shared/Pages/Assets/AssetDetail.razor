@page "/assets/detail/{Id}"
@using TTL.HR.Shared.Components.Common

<PageTitle>Chi tiết tài sản - TTL.HR</PageTitle>

<div class="d-flex flex-column flex-xl-row pt-8">
    <!--begin::Sidebar-->
    <div class="flex-column flex-lg-row-auto w-100 w-xl-350px mb-10">
        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card">
            @if (Asset != null)
            {
                <div class="card mb-5 mb-xl-8 shadow-sm border-0">
                    <div class="card-body pt-15">
                        <div class="d-flex flex-center flex-column mb-5">
                            <div class="symbol symbol-100px symbol-circle mb-7 shadow-sm">
                                <div class="symbol-label bg-light-primary">
                                    <i class="@(GetAssetIcon(Asset.Category)) fs-3x text-primary"></i>
                                </div>
                            </div>
                            <span class="fs-2 text-gray-900 fw-bolder mb-1 text-center">@Asset.Name</span>
                            <div class="fs-6 fw-semibold text-muted mb-6">Mã TSCĐ: @Asset.Code</div>
                            
                            <div class="d-flex flex-wrap flex-center">
                                <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3 mx-2 text-center">
                                    <div class="fs-5 fw-bolder text-gray-800">@Asset.PurchasePrice.ToString("N0")</div>
                                    <div class="fw-semibold text-muted fs-8">Giá mua (VND)</div>
                                </div>
                                <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3 mx-2 text-center">
                                    <div class="badge badge-light-@(GetStatusColor(Asset.Status, Asset.StatusId)) fw-bold fs-7">@TranslateStatus(Asset.Status, Asset.StatusId)</div>
                                    <div class="fw-semibold text-muted fs-8 mt-1">Trạng thái</div>
                                </div>
                            </div>
                        </div>

                        <div class="separator separator-dashed my-6"></div>

                        <div class="py-2">
                            <div class="d-flex flex-stack mb-4">
                                <span class="fw-bold text-gray-800 me-2">Loại tài sản:</span>
                                <span class="text-gray-600">@Asset.Category</span>
                            </div>
                            <div class="d-flex flex-stack mb-4">
                                <span class="fw-bold text-gray-800 me-2">Số Serial:</span>
                                <span class="text-gray-600">@Asset.SerialNumber</span>
                            </div>
                            <div class="d-flex flex-stack mb-4">
                                <span class="fw-bold text-gray-800 me-2">Ngày mua:</span>
                                <span class="text-gray-600">@Asset.PurchaseDate?.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="d-flex flex-stack mb-4">
                                <span class="fw-bold text-gray-800 me-2">Thông số KT:</span>
                                <span class="text-gray-600">@Asset.Specification</span>
                            </div>
                            <div class="d-flex flex-stack">
                                <span class="fw-bold text-gray-800 me-2">Bảo hành:</span>
                                <span class="text-gray-600">@Asset.WarrantyPeriod</span>
                            </div>
                        </div>
                        
                        <div class="mt-8">
                            <button class="btn btn-primary w-100 fw-bold" @onclick="EditAsset">
                                <i class="ki-outline ki-pencil fs-2 me-1"></i> Chỉnh sửa thông tin
                            </button>
                        </div>
                    </div>
                </div>
            }
        </SkeletonLoading>
    </div>

    <!--begin::Content-->
    <div class="flex-lg-row-fluid ms-lg-15">
        <div class="card shadow-sm border-0 mb-8">
            <div class="card-header border-0 pt-6">
                <div class="card-title">
                    <h3 class="fw-bolder">Tình trạng sử dụng</h3>
                </div>
            </div>
            <div class="card-body">
                @if (Asset?.Status == "Assigned" || Asset?.StatusId == 2)
                {
                    <div class="d-flex align-items-center mb-8 bg-light-primary rounded p-6 border border-primary border-dashed">
                        <div class="symbol symbol-60px symbol-circle me-5 shadow-sm border border-white border-2">
                            <div class="symbol-label bg-primary text-inverse-primary fs-2 fw-bold">@Asset.AssignedToName?.Substring(0, 1)</div>
                        </div>
                        <div class="flex-grow-1">
                            <span class="text-gray-900 fw-bold fs-4 d-block">@Asset.AssignedToName</span>
                            <span class="text-muted fw-semibold">Đang sử dụng tài sản</span>
                        </div>
                        <div>
                            <span class="badge badge-light-primary fw-bold px-4 py-2">ĐàBÀN GIAO</span>
                        </div>
                    </div>
                    
                    <div class="notice d-flex bg-light-info rounded border-info border border-dashed p-6">
                        <i class="ki-outline ki-information-5 fs-2tx text-info me-4"></i>
                        <div class="d-flex flex-stack flex-grow-1 flex-wrap flex-md-nowrap">
                            <div class="mb-3 mb-md-0 fw-semibold">
                                <h4 class="text-gray-900 fw-bold">Ghi chú bàn giao</h4>
                                <div class="fs-6 text-gray-700 pe-7">Tài sản đang được nhân viên bảo quản và sử dụng cho công việc.</div>
                            </div>
                            <div class="d-flex gap-3">
                                <button class="btn btn-warning px-6 align-self-center text-nowrap fw-bold" @onclick="RequestMaintenance">Bảo trì</button>
                                <button class="btn btn-danger px-6 align-self-center text-nowrap fw-bold" @onclick="RevokeAsset">Thu hồi</button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-dismissible bg-light-success d-flex flex-center flex-column py-15 px-10 mb-0 border border-success border-dashed">
                        <i class="ki-outline ki-check-circle fs-5tx text-success mb-5"></i>
                        <div class="text-center">
                            <h1 class="fw-bold mb-5">Sẵn sàng để bàn giao</h1>
                            <div class="mb-9 text-dark fs-6">
                                Tài sản này hiện đang trong kho và sẵn sàng để cấp phát cho nhân viên mới.
                            </div>
                            <div class="d-flex flex-center flex-wrap gap-2">
                                <button class="btn btn-outline btn-outline-success btn-active-success fw-bold" @onclick="RequestMaintenance">Bảo trì tài sản</button>
                                <button class="btn btn-success fw-bold" @onclick='() => Navigation.NavigateTo($"/assets/allocation?AssetId={Id}")'>Cấp phát ngay</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header border-0 pt-6">
                <div class="card-title">
                    <h3 class="fw-bolder">Lịch sử bàn giao & Bảo trì</h3>
                </div>
            </div>
            <div class="card-body pt-0">
                <div class="timeline-label py-10">
                    @foreach(var history in AllocationHistory)
                    {
                        <div class="timeline-item">
                            <div class="timeline-label fw-bold text-gray-600 fs-7">@history.Date.ToString("dd/MM/yyyy")</div>
                            <div class="timeline-badge">
                                <i class="fa fa-genderless text-primary fs-1"></i>
                            </div>
                            <div class="timeline-content d-flex flex-column ps-3">
                                <div class="d-flex align-items-center">
                                    <span class="fw-bold text-gray-800 fs-6 me-2">@history.Action</span>
                                    <span class="text-muted fs-8">bởi @history.Actor</span>
                                </div>
                                <span class="text-muted fs-7">@history.Description</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Revoke Confirmation Modal -->
<GenericActionModal 
    IsVisible="@IsRevokeModalVisible" 
    Title="Xác nhận thu hồi"
    Heading="Thu hồi tài sản?"
    Message="@($"Bạn có chắc chắn muốn thu hồi tài sản {Asset?.Name} từ nhân viên {Asset?.AssignedToName}?")"
    Color="danger"
    Icon="ki-outline ki-arrows-loop"
    ConfirmLabel="Xác nhận thu hồi"
    CancelLabel="Bỏ qua"
    ShowReasonInput="true"
    ReasonPlaceholder="Nhập lý do thu hồi (vd: Thu hồi định kỳ, Nhân viên nghỉ việc...)"
    OnConfirmed="HandleRevokeConfirmed"
    OnCancelled="() => IsRevokeModalVisible = false" />

<!-- Maintenance Confirmation Modal -->
<GenericActionModal 
    IsVisible="@IsMaintenanceModalVisible" 
    Title="Yêu cầu bảo trì"
    Heading="Báo hỏng/Bảo trì?"
    Message="@($"Gửi yêu cầu bảo trì cho tài sản {Asset?.Name}? Trạng thái tài sản sẽ chuyển sang 'Đang bảo trì'.")"
    Color="warning"
    Icon="ki-outline ki-setting-4"
    ConfirmLabel="Gửi yêu cầu"
    CancelLabel="Bỏ qua"
    ShowReasonInput="true"
    ReasonPlaceholder="Mô tả tình trạng hỏng hóc hoặc lý do bảo trì..."
    OnConfirmed="HandleMaintenanceConfirmed"
    OnCancelled="() => IsMaintenanceModalVisible = false" />
