@page "/assets/add"
@inject NavigationManager Navigation

<div class="card">
    <div class="card-header">
        <div class="card-title">
            <h2>Add New Asset</h2>
        </div>
    </div>
    <div class="card-body">
        <EditForm Model="@Asset" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row mb-5">
                <div class="col-md-6 mb-5">
                    <label class="required form-label">Asset Name</label>
                    <InputText class="form-control form-control-solid" @bind-Value="Asset.Name" placeholder="e.g. Dell XPS 15" />
                </div>
                <div class="col-md-6 mb-5">
                    <label class="required form-label">Asset Code</label>
                    <InputText class="form-control form-control-solid" @bind-Value="Asset.Code" placeholder="e.g. IT-001" />
                </div>
            
                <div class="col-md-6 mb-5">
                    <label class="required form-label">Type</label>
                    <InputSelect class="form-select form-select-solid" Value="Asset.Type" ValueExpression="@(() => Asset.Type)" ValueChanged="@((string value) => OnTypeChanged(value))">
                        <option value="">Select Type...</option>
                        <option value="Laptop">Laptop</option>
                        <option value="Desktop">Desktop</option>
                        <option value="Monitor">Monitor</option>
                        <option value="Phone">Phone</option>
                        <option value="Vehicle">Vehicle</option>
                        <option value="Furniture">Furniture</option>
                        <option value="Other">Other (Custom)</option>
                    </InputSelect>
                    
                    @if (IsOtherTypeSelected)
                    {
                        <div class="mt-3">
                            <input type="text" class="form-control form-control-solid" placeholder="Enter custom type..." @bind="CustomType" />
                        </div>
                    }
                </div>
                <div class="col-md-6 mb-5">
                    <label class="form-label">Serial Number</label>
                    <InputText class="form-control form-control-solid" @bind-Value="Asset.SerialNumber" placeholder="e.g. SN-123456789" />
                </div>
            
                <div class="col-md-6 mb-5">
                    <label class="required form-label">Purchase Date</label>
                    <InputDate class="form-control form-control-solid" @bind-Value="Asset.PurchaseDate" />
                </div>
                <div class="col-md-6 mb-5">
                    <label class="required form-label">Purchase Price (VND)</label>
                    <InputNumber class="form-control form-control-solid" @bind-Value="Asset.PurchasePrice" />
                </div>
                
                 <div class="col-md-6 mb-5">
                    <label class="required form-label">Status</label>
                    <InputSelect class="form-select form-select-solid" @bind-Value="Asset.Status">
                        <option value="Available">Available</option>
                        <option value="Assigned">Assigned</option>
                        <option value="In Maintenance">In Maintenance</option>
                        <option value="Broken">Broken</option>
                        <option value="Disposed">Disposed</option>
                    </InputSelect>
                </div>
            </div>

             <div class="mb-5">
                <label class="form-label">Description / Notes</label>
                <InputTextArea class="form-control form-control-solid" rows="3" @bind-Value="Asset.Description" />
            </div>

            <div class="d-flex justify-content-end">
                <a href="/assets/inventory" class="btn btn-light me-3">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <span class="indicator-label">Save Asset</span>
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private AssetCreateModel Asset = new();

    private bool IsOtherTypeSelected = false;
    private string CustomType = "";

    protected override void OnInitialized()
    {
        Asset.PurchaseDate = DateTime.Today;
        Asset.Status = "Available";
    }

    private void OnTypeChanged(string value)
    {
        Asset.Type = value;
        IsOtherTypeSelected = (value == "Other");
    }

    private void HandleValidSubmit()
    {
        // If Custom Type is selected, use the custom value
        if (IsOtherTypeSelected && !string.IsNullOrWhiteSpace(CustomType))
        {
            Asset.Type = CustomType;
        }

        // Logic to save asset (e.g., call API)
        // For now, just navigate back
        Navigation.NavigateTo("/assets/inventory");
    }

    public class AssetCreateModel
    {
        public string Name { get; set; }
        public string Code { get; set; }
        public string Type { get; set; }
        public string SerialNumber { get; set; }
        public DateTime PurchaseDate { get; set; }
        public decimal PurchasePrice { get; set; }
        public string Status { get; set; }
        public string Description { get; set; }
    }
}
