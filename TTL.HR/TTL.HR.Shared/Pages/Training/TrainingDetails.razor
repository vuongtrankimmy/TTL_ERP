@page "/training/details/{Id}"
@using TTL.HR.Shared.Components.Common

<PageTitle>Chi tiết khóa học - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card" Rows="5" Columns="3">
        @if (Course != null)
        {
            <!-- Header -->
            <div class="card mb-5 mb-xl-10 shadow-sm border-0">
                <div class="card-body pt-9 pb-0">
                    <div class="d-flex flex-wrap flex-sm-nowrap mb-3">
                        <!-- Image/Icon -->
                        <div class="me-7 mb-4">
                            <div class="symbol symbol-100px symbol-lg-160px symbol-fixed position-relative">
                                <span class="symbol-label bg-light-info text-info fs-2x fw-bolder">TRAIN</span>
                                <div class="position-absolute translate-middle bottom-0 start-100 mb-6 bg-success rounded-circle border border-4 border-white h-20px w-20px"></div>
                            </div>
                        </div>
                        <!-- Details -->
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
                                <div class="d-flex flex-column">
                                    <div class="d-flex align-items-center mb-2">
                                        <h3 class="text-gray-900 fs-2 fw-bolder me-1">@Course.Title</h3>
                                        <span class="badge badge-light-primary ms-2">@Course.Status</span>
                                    </div>
                                    <div class="d-flex flex-wrap fw-bold fs-6 mb-4 pe-2">
                                        <span class="d-flex align-items-center text-gray-400 me-5 mb-2">
                                            <i class="ki-outline ki-profile-user fs-4 me-1"></i>@Course.TrainerName
                                        </span>
                                        <span class="d-flex align-items-center text-gray-400 me-5 mb-2">
                                            <i class="ki-outline ki-geolocation fs-4 me-1"></i>@(string.IsNullOrEmpty(Course.Location) ? "Phòng đào tạo / Online" : Course.Location)
                                        </span>
                                        <span class="d-flex align-items-center text-gray-400 mb-2">
                                            <i class="ki-outline ki-calendar fs-4 me-1"></i>@Course.StartDate.ToString("dd/MM/yyyy") @(Course.EndDate.HasValue ? $" - {Course.EndDate.Value.ToString("dd/MM/yyyy")}" : "") (@Course.DurationHours giờ)
                                        </span>
                                    </div>
                                </div>
                                <div class="d-flex my-4">
                                    <button class="btn btn-sm btn-light-primary fw-bold me-2" @onclick="HandleEdit">
                                        <i class="ki-outline ki-pencil fs-4 me-1"></i> Sửa thông tin
                                    </button>
                                    <button class="btn btn-sm btn-primary fw-bold" @onclick="HandleRegisterAttendee">
                                        <i class="ki-outline ki-plus fs-4 me-1"></i> Đăng ký học viên
                                    </button>
                                </div>
                            </div>
                            <div class="d-flex flex-wrap flex-stack">
                                <div class="d-flex flex-column flex-grow-1 pe-8">
                                    <div class="d-flex flex-wrap">
                                        <div class="border border-gray-300 border-dashed rounded min-w-125px py-3 px-4 me-6 mb-3">
                                            <div class="fs-2 fw-bolder">@Attendees.Count</div>
                                            <div class="fw-bold fs-6 text-gray-400">Đã đăng ký</div>
                                        </div>
                                        <div class="border border-gray-300 border-dashed rounded min-w-125px py-3 px-4 me-6 mb-3">
                                            <div class="fs-2 fw-bolder">@Course.MaxParticipants</div>
                                            <div class="fw-bold fs-6 text-gray-400">Số lượng tối đa</div>
                                        </div>
                                        <div class="border border-gray-300 border-dashed rounded min-w-125px py-3 px-4 me-6 mb-3">
                                            <div class="fs-2 fw-bolder">@(Course.IsMandatory ? "Bắt buộc" : "Tự nguyện")</div>
                                            <div class="fw-bold fs-6 text-gray-400">Tính chất</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Content & Attendees -->
            <div class="row g-5 g-xl-8">
                <div class="col-xl-4">
                    <div class="card border-0 shadow-sm mb-5">
                        <div class="card-header border-0 pt-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label fw-bolder text-dark">Nội dung khóa học</span>
                            </h3>
                        </div>
                        <div class="card-body pt-5">
                            <div class="text-gray-700 fs-6 mb-5">
                                @Course.Description
                            </div>
                            <div class="separator separator-dashed my-5"></div>
                            <h4 class="fw-bold mb-4">Chương trình đào tạo</h4>
                            <div class="timeline-label">
                                @if (Course.Syllabus != null && Course.Syllabus.Any())
                                {
                                    @foreach (var item in Course.Syllabus.Select((value, index) => new { value, index }))
                                    {
                                        var timeStr = item.value.Contains(" | ") ? item.value.Split(" | ")[0] : $"P.{item.index + 1}";
                                        var contentStr = item.value.Contains(" | ") ? item.value.Split(" | ")[1] : item.value;
                                        <div class="timeline-item">
                                            <div class="timeline-label fw-bolder text-gray-800 fs-6">@timeStr</div>
                                            <div class="timeline-badge">
                                                <i class="fa fa-genderless @(item.index % 2 == 0 ? "text-primary" : "text-success") fs-1"></i>
                                            </div>
                                            <div class="timeline-content d-flex flex-column ps-3">
                                                <span class="fw-bolder text-gray-800 fs-6">@contentStr</span>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted fs-7 py-3">Chưa cập nhật chương trình chi tiết.</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-8">
                    <div class="card border-0 shadow-sm mb-5">
                        <div class="card-header border-0 pt-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label fw-bolder text-dark">Danh sách học viên</span>
                                <span class="text-muted mt-1 fw-bold fs-7">@Attendees.Count học viên đã đăng ký</span>
                            </h3>
                        </div>
                        <div class="card-body py-3">
                            <div class="table-responsive">
                                <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-4">
                                    <thead>
                                        <tr class="fw-bolder text-muted bg-light">
                                            <th class="ps-4 min-w-150px rounded-start">Học viên</th>
                                            <th class="min-w-140px">Phòng ban</th>
                                            <th class="min-w-120px">Trạng thái</th>
                                            <th class="min-w-100px text-center">Tiến độ (%)</th>
                                            <th class="min-w-100px text-end rounded-end pe-4">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Attendees.Any())
                                        {
                                            @foreach(var attendee in Attendees)
                                            {
                                                <tr>
                                                    <td class="ps-4">
                                                        <div class="d-flex align-items-center">
                                                            <div class="symbol symbol-45px me-5">
                                                                @if (!string.IsNullOrEmpty(attendee.AvatarUrl))
                                                                {
                                                                    <img src="@attendee.AvatarUrl" alt="" />
                                                                }
                                                                else
                                                                {
                                                                    <span class="symbol-label bg-light-primary text-primary fw-bold">@(attendee.FullName?.Length > 0 ? attendee.FullName.Substring(0, 1) : "?")</span>
                                                                }
                                                            </div>
                                                            <div class="d-flex justify-content-start flex-column">
                                                                <a href="#" class="text-dark fw-bolder text-hover-primary fs-6">@attendee.FullName</a>
                                                                <span class="text-muted fw-bold d-block fs-7">@attendee.EmployeeId</span>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <span class="text-gray-800 fw-bold d-block fs-6">@attendee.Department</span>
                                                        <span class="text-muted fw-semibold fs-7">@attendee.Position</span>
                                                    </td>
                                                    <td>
                                                        @{
                                                            var attendeeStatusClass = attendee.Status switch
                                                            {
                                                                "Completed" or "Hoàn thành" => "badge-light-success",
                                                                "In Progress" or "Đang học" => "badge-light-warning",
                                                                "Enrolled" or "Đã tham gia" => "badge-light-primary",
                                                                _ => "badge-light-secondary"
                                                            };
                                                        }
                                                        <span class="badge @attendeeStatusClass fs-7 fw-bolder">@attendee.Status</span>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="text-dark fw-bolder d-block fs-6">@attendee.Progress</span>
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <button class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm shadow-sm" 
                                                                title="Hủy đăng ký" 
                                                                @onclick="() => PromptRemoveAttendee(attendee)">
                                                            <i class="ki-outline ki-trash fs-3"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-10">
                                                    <div class="text-muted">Chưa có học viên nào.</div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        </SkeletonLoading>
    </div>
</div>

@using TTL.HR.Shared.Components.Training

<!-- Registration Selection Popup -->
<TrainingRegistrationPopup 
    IsVisible="@IsRegisterModalOpen"
    CourseTitle="@Course?.Title"
    AlreadyEnrolledEmployeeIds="@Attendees.Select(a => a.EmployeeId).ToList()"
    OnConfirm="ConfirmRegister"
    OnCancel="CloseRegisterModal" />

<!-- Delete Confirmation Modal (Standard Implementation) -->
@if (IsDeleteModalOpen && ItemToRemoveAttendee != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pt-7">
                    <h5 class="modal-title fw-bolder fs-3 text-gray-800">Hủy đăng ký học viên</h5>
                    <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" @onclick="CloseRemoveModal">
                        <i class="ki-outline ki-cross fs-2"></i>
                    </div>
                </div>
                <div class="modal-body py-5">
                    <div class="text-gray-600 mb-5">
                        Bạn có chắc chắn muốn hủy đăng ký cho học viên <strong class="text-gray-800">@ItemToRemoveAttendee.FullName</strong> (@ItemToRemoveAttendee.EmployeeId) khỏi khóa học này?
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-7">
                    <button type="button" class="btn btn-light fw-bold" @onclick="CloseRemoveModal">Quay lại</button>
                    <button type="button" class="btn btn-danger fw-bold" @onclick="ConfirmRemoveAttendee">Xác nhận hủy</button>
                </div>
            </div>
        </div>
    </div>
}
