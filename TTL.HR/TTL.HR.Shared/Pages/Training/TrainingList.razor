@page "/training"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <!-- Filter Card -->
        <div class="card mb-8 shadow-sm">
            <div class="card-body py-4 px-6">
                <div class="d-flex flex-wrap align-items-center">
                    <!-- Search -->
                    <div class="position-relative w-md-250px me-4 my-1">
                        <span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"></path>
                            </svg>
                        </span>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm kiếm khóa học..." />
                    </div>

                    <!-- Type Filter -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Loại hình: Tất cả</option>
                            <option>Nội bộ</option>
                            <option>Bên ngoài</option>
                            <option>Online</option>
                        </select>
                    </div>

                     <!-- Date Filter -->
                    <div class="w-md-175px me-4 my-1">
                         <input class="form-control form-control-solid" placeholder="Chọn ngày" id="kt_datepicker_1"/>
                    </div>

                    <!-- Action Button -->
                    <div class="ms-auto my-1">
                        <a href="/training/add" class="btn btn-primary fw-bold fs-7 px-6"><i class="bi bi-plus-lg me-1"></i>Thêm khóa đào tạo</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="card shadow-sm border-0">
             <div class="card-header border-0 pt-6">
                <div class="card-title">
                    <div class="d-flex align-items-center position-relative my-1">
                        <span class="fs-4 fw-bolder text-dark">Danh sách khóa đào tạo</span>
                         <span class="badge badge-light-primary fw-bolder fs-7 ms-2">@_courses.Count khóa</span>
                    </div>
                </div>
            </div>
            <div class="card-body py-4">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="5" Columns="7">
                <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-4">
                        <thead>
                            <tr class="fw-bolder text-muted bg-light">
                                <th class="ps-4 min-w-200px rounded-start">Tên khóa học</th>
                                <th class="min-w-150px">Giảng viên</th>
                                <th class="min-w-100px">Thời gian</th>
                                <th class="min-w-100px">Địa điểm</th>
                                <th class="min-w-100px text-center">Học viên</th>
                                <th class="min-w-100px text-center">Trạng thái</th>
                                <th class="min-w-100px text-end rounded-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var course in _courses)
                            {
                                <tr class="hover-elevate">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="d-flex justify-content-start flex-column">
                                                <a href="/training/details/@course.Id" class="text-dark fw-bolder text-hover-primary fs-6">@course.Title</a>
                                                <span class="text-muted fw-bold d-block fs-7">@course.Code</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-gray-800 fw-bold d-block fs-6">@course.Trainer</span>
                                        <span class="text-muted fw-bold d-block fs-7">@course.Type</span>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="text-gray-800 fw-bold fs-6">@course.StartDate.ToString("dd/MM/yyyy")</span>
                                            <span class="text-muted fs-7">@course.Duration</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-gray-800 fw-bold d-block fs-6">@course.Location</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex flex-column align-items-center">
                                            <span class="badge badge-light-primary fw-bold fs-7 mb-1">@course.ParticipantsCount registered</span>
                                            <span class="text-muted fs-8">Max: @course.MaxParticipants</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @course.StatusClass fw-bold fs-7">@course.Status</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/training/details/@course.Id" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1" title="Chi tiết">
                                            <i class="bi bi-eye-fill fs-3"></i>
                                        </a>
                                        <button class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1" title="Điểm danh">
                                           <i class="bi bi-person-check-fill fs-3"></i>
                                        </button>
                                        <button class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm" title="Hủy">
                                            <i class="bi bi-x-circle-fill fs-3"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                 <!-- Pagination -->
                <div class="d-flex flex-stack flex-wrap pt-10">
                    <div class="fs-6 fw-bold text-gray-700">Hiển thị 1 đến @_courses.Count của @_courses.Count bản ghi</div>
                    <ul class="pagination">
                        <li class="page-item previous disabled"><a href="#" class="page-link"><i class="previous"></i></a></li>
                        <li class="page-item active"><a href="#" class="page-link">1</a></li>
                        <li class="page-item next"><a href="#" class="page-link"><i class="next"></i></a></li>
                    </ul>
                </div>
                </SkeletonLoading>
            </div>
        </div>
    </div>
</div>


