@page "/training/courses"
@using TTL.HR.Shared.Components.Common

<PageTitle>Khóa đào tạo - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <div class="mb-10 text-center">
            <h1 class="text-dark fw-boldest fs-2qx mb-3">Trung tâm Đào tạo</h1>
            <div class="text-gray-400 fw-bold fs-5">Hãy tham gia các khóa học để nâng cao kỹ năng và phát triển nghề nghiệp</div>
        </div>

        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card" Rows="2" Columns="4">
            <div class="row g-6 g-xl-9">
                @if (Courses.Any())
                {
                    @foreach (var course in Courses)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="card h-100 shadow-sm border-0 hover-elevate">
                                <div class="card-body d-flex flex-column p-9">
                                    <div class="d-flex flex-stack mb-5">
                                        <div class="symbol symbol-50px">
                                            <span class="symbol-label bg-light-primary text-primary fw-boldest">TRAIN</span>
                                        </div>
                                        <span class="badge badge-light-primary fw-bold px-4 py-3">@course.Status</span>
                                    </div>

                                    <div class="mb-5">
                                        <a href="javascript:void(0)" @onclick="() => ViewDetail(course.Id)" class="fs-2 text-gray-800 text-hover-primary fw-bolder">@course.Title</a>
                                        <div class="fw-bold text-gray-400 mt-2 mb-4 fs-6">@course.Description</div>
                                    </div>

                                    <div class="d-flex flex-stack mt-auto">
                                        <div class="d-flex align-items-center me-3">
                                            <div class="symbol symbol-35px symbol-circle me-3">
                                                <span class="symbol-label bg-light-warning text-warning fw-bold">@course.TrainerName.Substring(0, 1)</span>
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="text-gray-800 fw-bolder fs-7">@course.TrainerName</span>
                                                <span class="text-muted fw-bold fs-9">Giảng viên</span>
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <div class="text-gray-800 fw-bolder fs-7">@course.DurationHours giờ</div>
                                            <div class="text-muted fw-bold fs-9">Thời lượng</div>
                                        </div>
                                    </div>
                                    
                                    <div class="separator separator-dashed my-6"></div>
                                    
                                    <div class="d-flex flex-stack">
                                        <div class="d-flex align-items-center">
                                            <i class="ki-outline ki-calendar fs-2 text-gray-400 me-2"></i>
                                            <span class="text-gray-800 fw-bolder fs-7">@course.StartDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <button class="btn btn-sm btn-primary fw-bold px-6" @onclick="() => ViewDetail(course.Id)">Chi tiết</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-20">
                        <div class="text-muted fs-4">Hiện không có khóa học nào mới.</div>
                    </div>
                }
            </div>
        </SkeletonLoading>
    </div>
</div>
