@page "/training/course/{CourseId}"
@inject NavigationManager Navigation

<div class="row g-5 g-xl-8">
    <div class="col-xl-4">
        <!--begin::Statistics Widget 5-->
        <a href="#" class="card bg-success hoverable card-xl-stretch mb-xl-8">
            <div class="card-body">
                <i class="ki-outline ki-basket text-white fs-2x ms-n1"></i>
                <div class="text-white fw-bold fs-2 mb-2 mt-5">@Course?.Title</div>
                <div class="fw-semibold text-white">@Course?.Trainer</div>
            </div>
        </a>
        <!--end::Statistics Widget 5-->
         <div class="card mb-5 mb-xl-8">
            <div class="card-body pt-15">
                <div class="d-flex flex-center flex-column mb-5">
                     <div class="d-flex flex-wrap flex-center">
                        <div class="border border-gray-300 border-dashed rounded py-3 px-3 mb-3">
                            <div class="fs-4 fw-bold text-gray-700">
                                <span class="w-75px">@Course?.Duration</span>
                            </div>
                            <div class="fw-semibold text-muted">Duration</div>
                        </div>
                         <div class="border border-gray-300 border-dashed rounded py-3 px-3 mb-3 ms-2">
                             <div class="fs-4 fw-bold text-gray-700">
                                <span class="w-50px">@Course?.Participants.Count</span>
                            </div>
                            <div class="fw-semibold text-muted">Enrolled</div>
                        </div>
                    </div>
                </div>
                <div class="separator separator-dashed my-3"></div>
                 <div class="py-5 fs-6">
                    <div class="fw-bold mt-5">Description</div>
                    <div class="text-gray-600">@Course?.Description</div>
                    <div class="fw-bold mt-5">Deadline</div>
                    <div class="text-gray-600">@Course?.Deadline.ToShortDateString()</div>
                </div>
                 <div class="d-flex flex-center">
                    <button class="btn btn-primary" @onclick="Enroll">Enroll Now</button>
                    <button class="btn btn-light btn-active-light-primary ms-2">Download Materials</button>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-8">
         <!--begin::Tables Widget 9-->
        <div class="card mb-5 mb-xl-8">
            <!--begin::Header-->
            <div class="card-header border-0 pt-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold fs-3 mb-1">Participants</span>
                    <span class="text-muted mt-1 fw-semibold fs-7">Employees enrolled in this course</span>
                </h3>
            </div>
            <!--end::Header-->
            <!--begin::Body-->
            <div class="card-body py-3">
                <!--begin::Table container-->
                <div class="table-responsive">
                    <!--begin::Table-->
                    <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                        <!--begin::Table head-->
                        <thead>
                            <tr class="fw-bold text-muted">
                                <th class="min-w-150px">Employee</th>
                                <th class="min-w-140px">Department</th>
                                <th class="min-w-120px">Progress</th>
                                <th class="min-w-100px text-end">Status</th>
                            </tr>
                        </thead>
                        <!--end::Table head-->
                        <!--begin::Table body-->
                        <tbody>
                            @foreach(var p in Course.Participants)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="symbol symbol-45px me-5">
                                                <img src="@p.Avatar" alt="" />
                                            </div>
                                            <div class="d-flex justify-content-start flex-column">
                                                <a href="#" class="text-dark fw-bold text-hover-primary fs-6">@p.Name</a>
                                                <span class="text-muted fw-semibold text-muted d-block fs-7">@p.JobTitle</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="#" class="text-dark fw-bold text-hover-primary d-block fs-6">@p.Department</a>
                                    </td>
                                    <td class="d-flex flex-column">
                                        <span class="text-dark fw-bold text-hover-primary d-block fs-6">@p.Progress%</span>
                                         <div class="h-5px mx-3 w-100 bg-light mb-3">
                                            <div class="bg-success rounded h-5px" role="progressbar" style="width: @p.Progress%;" aria-valuenow="@p.Progress" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge badge-light-@(p.Status == "Completed" ? "success" : "primary")">@p.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <!--end::Table body-->
                    </table>
                    <!--end::Table-->
                </div>
                <!--end::Table container-->
            </div>
            <!--begin::Body-->
        </div>
        <!--end::Tables Widget 9-->
    </div>
</div>

@code {
    [Parameter]
    public string CourseId { get; set; }

    private CourseDetailViewModel Course;

    protected override void OnInitialized()
    {
        // Mock data logic
        Course = new CourseDetailViewModel
        {
            Title = CourseId == "Onboarding 101" ? "Onboarding 101" : "Advanced Excel",
            Description = "Comprehensive training program designed to equip employees with essential skills.",
            Duration = "4 Hours",
            Trainer = "HR Dept",
            Deadline = DateTime.Now.AddDays(7),
            Participants = new List<ParticipantViewModel>
            {
                new ParticipantViewModel { Name = "Phan Thanh Tùng", JobTitle = "Software Architect", Department = "IT", Avatar = "/assets/media/avatars/300-1.jpg", Progress = 100, Status = "Completed" },
                new ParticipantViewModel { Name = "Nguyen Van A", JobTitle = "Developer", Department = "IT", Avatar = "/assets/media/avatars/300-2.jpg", Progress = 50, Status = "In Progress" },
                 new ParticipantViewModel { Name = "Le Thi B", JobTitle = "Accountant", Department = "Finance", Avatar = "/assets/media/avatars/300-3.jpg", Progress = 0, Status = "Enrolled" }
            }
        };
    }

    private void Enroll() { /* Logic */ }

    public class CourseDetailViewModel
    {
        public string Title { get; set; }
        public string Description { get; set; }
        public string Duration { get; set; }
        public string Trainer { get; set; }
        public DateTime Deadline { get; set; }
        public List<ParticipantViewModel> Participants { get; set; } = new();
    }

    public class ParticipantViewModel
    {
        public string Name { get; set; }
        public string JobTitle { get; set; }
        public string Department { get; set; }
        public string Avatar { get; set; }
        public int Progress { get; set; }
        public string Status { get; set; }
    }
}
