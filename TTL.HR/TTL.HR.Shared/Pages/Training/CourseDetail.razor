@page "/training/course/{CourseId}"
@using TTL.HR.Shared.Components.Common

<PageTitle>@Course?.Title - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Card">
            @if (Course != null)
            {
                <div class="row g-5 g-xl-8">
                    <div class="col-xl-4">
                        <div class="card bg-success hoverable card-xl-stretch mb-xl-8 shadow-sm">
                            <div class="card-body">
                                <i class="ki-outline ki-teacher text-white fs-2x ms-n1"></i>
                                <div class="text-white fw-bold fs-2 mb-2 mt-5">@Course.Title</div>
                                <div class="fw-semibold text-white opacity-75">@Course.TrainerName</div>
                            </div>
                        </div>

                        <div class="card mb-5 mb-xl-8 shadow-sm border-0">
                            <div class="card-body pt-10">
                                <div class="d-flex flex-center flex-column mb-5">
                                    <div class="d-flex flex-wrap flex-center">
                                        <div class="border border-gray-300 border-dashed rounded py-3 px-3 mb-3">
                                            <div class="fs-4 fw-bold text-gray-700">
                                                <span class="w-75px">@Course.DurationHours giờ</span>
                                            </div>
                                            <div class="fw-semibold text-muted">Thời lượng</div>
                                        </div>
                                        <div class="border border-gray-300 border-dashed rounded py-3 px-3 mb-3 ms-2">
                                            <div class="fs-4 fw-bold text-gray-700">
                                                <span class="w-50px">@Participants.Count</span>
                                            </div>
                                            <div class="fw-semibold text-muted">Học viên</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="separator separator-dashed my-3"></div>
                                <div class="py-5 fs-6">
                                    <div class="fw-bold mt-5">Mô tả khóa học</div>
                                    <div class="text-gray-600">@Course.Description</div>
                                    <div class="fw-bold mt-5">Ngày bắt đầu</div>
                                    <div class="text-gray-600">@Course.StartDate.ToString("dd/MM/yyyy")</div>
                                    <div class="fw-bold mt-5">Trạng thái</div>
                                    <div class="text-gray-600">
                                        <span class="badge badge-light-primary fw-bold">@Course.Status</span>
                                    </div>
                                </div>
                                <div class="d-flex flex-center mt-5">
                                    <button class="btn btn-primary fw-bold w-100 mb-2" @onclick="Enroll">
                                        <i class="ki-outline ki-plus-square fs-2 me-1"></i> Đăng ký tham gia
                                    </button>
                                </div>
                                <div class="d-flex flex-center">
                                    <button class="btn btn-light btn-active-light-primary fw-bold w-100">
                                        <i class="ki-outline ki-cloud-download fs-2 me-1"></i> Tải tài liệu
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-8">
                        <div class="card mb-5 mb-xl-8 shadow-sm border-0">
                            <div class="card-header border-0 pt-5">
                                <h3 class="card-title align-items-start flex-column">
                                    <span class="card-label fw-bold fs-3 mb-1">Danh sách học viên</span>
                                    <span class="text-muted mt-1 fw-semibold fs-7">Tổng số @Participants.Count nhân viên đang tham gia</span>
                                </h3>
                                <div class="card-toolbar">
                                     <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        <i class="ki-outline ki-category fs-6"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="card-body py-3">
                                <div class="table-responsive">
                                    <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                                        <thead>
                                            <tr class="fw-bold text-muted bg-light">
                                                <th class="ps-4 min-w-150px rounded-start">Nhân viên</th>
                                                <th class="min-w-140px">Phòng ban / Chức vụ</th>
                                                <th class="min-w-120px text-center">Tiến độ</th>
                                                <th class="min-w-100px text-end pe-4 rounded-end">Trạng thái</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Participants.Any())
                                            {
                                                @foreach (var p in Participants)
                                                {
                                                    <tr>
                                                        <td class="ps-4">
                                                            <div class="d-flex align-items-center">
                                                                <div class="symbol symbol-45px me-5">
                                                                    @if (!string.IsNullOrEmpty(p.AvatarUrl))
                                                                    {
                                                                        <img src="@p.AvatarUrl" alt="" />
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="symbol-label bg-light-primary text-primary fw-bold">@p.FullName.Substring(0, 1)</span>
                                                                    }
                                                                </div>
                                                                <div class="d-flex justify-content-start flex-column">
                                                                    <a href="/employees/profile/@p.EmployeeId" class="text-dark fw-bold text-hover-primary fs-6">@p.FullName</a>
                                                                    <span class="text-muted fw-semibold d-block fs-7">@p.EmployeeId</span>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span class="text-dark fw-bold d-block fs-6">@p.Department</span>
                                                            <span class="text-muted fw-semibold d-block fs-7">@p.Position</span>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-column w-100 me-2">
                                                                <div class="d-flex flex-stack mb-2">
                                                                    <span class="text-muted me-2 fs-7 fw-bold">@p.Progress%</span>
                                                                </div>
                                                                <div class="progress h-6px w-100">
                                                                    <div class="progress-bar bg-success" role="progressbar" style="width: @p.Progress%" aria-valuenow="@p.Progress" aria-valuemin="0" aria-valuemax="100"></div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="text-end pe-4">
                                                            @{
                                                                var statusClass = p.Status switch
                                                                {
                                                                    "Completed" or "Hoàn thành" => "badge-light-success",
                                                                    "In Progress" or "Đang học" => "badge-light-warning",
                                                                    "Enrolled" or "Đã đăng ký" => "badge-light-primary",
                                                                    _ => "badge-light-secondary"
                                                                };
                                                            }
                                                            <span class="badge @statusClass fw-bold">@p.Status</span>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="4" class="text-center py-10">
                                                        <div class="text-muted fs-6">Chưa có nhân viên nào đăng ký khóa học này.</div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </SkeletonLoading>
    </div>
</div>
