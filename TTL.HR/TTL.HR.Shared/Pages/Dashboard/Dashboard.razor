@page "/dashboard"
@layout MainLayout
@rendermode InteractiveAuto

<PageTitle>Tổng quan hệ thống - TTL.HR</PageTitle>

@if (_isLoading)
{
    <div class="row g-5 g-xl-10">
        <div class="col-xl-3"><SkeletonLoading IsLoading="true" Type="SkeletonLoading.SkeletonType.Card" /></div>
        <div class="col-xl-3"><SkeletonLoading IsLoading="true" Type="SkeletonLoading.SkeletonType.Card" /></div>
        <div class="col-xl-3"><SkeletonLoading IsLoading="true" Type="SkeletonLoading.SkeletonType.Card" /></div>
        <div class="col-xl-3"><SkeletonLoading IsLoading="true" Type="SkeletonLoading.SkeletonType.Card" /></div>
    </div>
}
else if (_overview != null)
{
    <!--begin::Row - Tóm tắt chỉ số-->
    <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
        <!--begin::Col-->
        <div class="col-12 col-sm-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0 bg-primary">
                <div class="card-header pt-5">
                    <div class="card-title d-flex flex-column">
                        <span class="fs-2hx fw-bold text-white me-2 lh-1 ls-n2">@_overview.Stats.TotalEmployees.ToString("N0")</span>
                        <span class="text-white opacity-75 pt-1 fw-semibold fs-6">Tổng nhân sự hiện tại</span>
                    </div>
                    <div class="card-toolbar">
                        <a href="/employees" class="btn btn-sm btn-light-primary fw-bold btn-active-light-primary border-0 bg-white bg-opacity-10 text-white">Xem danh sách</a>
                    </div>
                </div>
                <div class="card-body d-flex align-items-end pt-0 pb-6">
                    <div class="d-flex align-items-center flex-column mt-3 w-100">
                        <div class="d-flex justify-content-between w-100 mt-auto mb-2 px-1">
                            <span class="fw-bolder text-white fs-6">@_overview.ContractDistribution.Label</span>
                            <span class="fw-bold text-white fs-6">@_overview.ContractDistribution.OfficialPercentage%</span>
                        </div>
                        <div class="h-8px w-100 bg-white bg-opacity-25 rounded">
                            <div class="bg-white rounded h-8px" role="progressbar" style="width: @_overview.ContractDistribution.OfficialPercentage%;" aria-valuenow="@_overview.ContractDistribution.OfficialPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->

        <!--begin::Col-->
        <div class="col-12 col-sm-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0">
                <div class="card-header pt-5">
                    <div class="card-title d-flex flex-column">
                        <div class="d-flex align-items-center">
                            <span class="fs-4 fw-semibold text-gray-400 me-1 align-self-start">VNĐ</span>
                            <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">@((_overview.PayrollStats.TotalBudget / 1000000000m).ToString("N1"))B</span>
                            <span class="badge badge-light-success fs-base">
                                <i class="ki-outline ki-arrow-up fs-5 text-success ms-n1"></i>@_overview.PayrollStats.GrowthPercentage%
                            </span>
                        </div>
                        <span class="text-gray-400 pt-1 fw-semibold fs-6">Quỹ lương dự tính (@_overview.PayrollStats.Period)</span>
                    </div>
                    <div class="card-toolbar">
                        <a href="/payroll/periods" class="btn btn-sm btn-light-success fw-bold">Chi tiết lương</a>
                    </div>
                </div>
                <div class="card-body pb-0 ps-4">
                    <div class="chart-container-premium" style="height: 120px; width: 100%;">
                        <ApexChart TItem="PayrollTrendDto" Title="" Options="_payrollChartOptions" Height="@("120")" Width="@("100%")">
                            <ApexPointSeries TItem="PayrollTrendDto"
                                            Items="_overview.PayrollTrend"
                                            Name="Lương"
                                            SeriesType="SeriesType.Area"
                                            XValue="@(e => e.Month)"
                                            YValue="@(e => (decimal)e.Amount)" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->

        <!--begin::Col-->
        <div class="col-12 col-sm-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0">
                <div class="card-header pt-5">
                    <div class="card-title d-flex flex-column">
                        <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">@_overview.Stats.ActiveJobPostings</span>
                        <span class="text-gray-400 pt-1 fw-semibold fs-6">Vị trí đang tuyển dụng</span>
                    </div>
                    <div class="card-toolbar">
                        <a href="/recruitment" class="btn btn-sm btn-light-primary fw-bold">Xem chi tiết</a>
                    </div>
                </div>
                <div class="card-body pt-2 pb-6">
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center">
                            <div class="bullet bullet-vertical h-10px bg-success me-3"></div>
                            <span class="text-gray-700 fs-7 fw-bold">@_overview.RecruitmentStats.RecentlyHired Nhân sự vừa tiếp nhận</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="bullet bullet-vertical h-10px bg-warning me-3"></div>
                            <span class="text-gray-700 fs-7 fw-bold">@_overview.RecruitmentStats.InterviewsThisWeek Lịch phỏng vấn tuần này</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="bullet bullet-vertical h-10px bg-primary me-3"></div>
                            <span class="text-gray-700 fs-7 fw-bold">@_overview.RecruitmentStats.NewCandidates Hồ sơ mới trong tuần</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->

        <!--begin::Col-->
        <div class="col-12 col-sm-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0 bg-light-danger">
                <div class="card-body d-flex flex-column justify-content-center p-6">
                    <div class="d-flex flex-stack mb-3">
                        <div class="d-flex flex-column">
                            <span class="fs-2hx fw-bold text-danger me-2 lh-1 ls-n2">@_overview.PendingApprovals.Count</span>
                            <span class="text-danger opacity-75 pt-1 fw-bold fs-6">Đơn chờ phê duyệt</span>
                        </div>
                        <div class="symbol symbol-50px">
                            <div class="symbol-label bg-white">
                                <i class="ki-outline ki-document fs-1 text-danger"></i>
                            </div>
                        </div>
                    </div>
                    <div class="separator separator-dashed border-danger opacity-25 mb-4"></div>
                    <div class="d-flex flex-stack">
                        <div class="fs-7 fw-bold text-gray-800">Cơ cấu: @_overview.PendingApprovals.Count(p => p.Type == "Leave") Nghỉ phép...</div>
                        <a href="/leave/requests" class="btn btn-danger btn-sm px-4 py-2 fs-8 fw-bold">Xử lý ngay</a>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->
    </div>
    <!--end::Row-->


    <!--begin::Row - Asset Clearances & Contracts-->
    <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
        <!--begin::Col - Asset Clearance Warnings-->
        <div class="col-xl-4">
            <div class="card card-flush h-xl-100 shadow-sm border-0 border-top border-warning border-3">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Cảnh báo thu hồi tài sản</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Nhân sự đã nghỉ việc/ngừng hoạt động nhưng chưa bàn giao tài sản</span>
                    </h3>
                </div>
                <div class="card-body pt-2">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-3">
                            <thead>
                                <tr class="fw-bold text-muted bg-light-warning">
                                    <th class="ps-4 min-w-150px rounded-start">Nhân viên</th>
                                    <th class="min-w-150px">Tài sản</th>
                                    <th class="min-w-100px text-end rounded-end pe-4">Ngày nghỉ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_overview.PendingAssetClearances == null || !_overview.PendingAssetClearances.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-10 text-muted fs-7">Không có tài sản cần thu hồi gấp.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in _overview.PendingAssetClearances)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-35px symbol-circle me-3">
                                                        <span class="symbol-label bg-light-danger text-danger fw-bold">@item.EmployeeName.Substring(0, 1)</span>
                                                    </div>
                                                    <span class="text-gray-800 fw-bold fs-7">@item.EmployeeName</span>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="text-gray-800 fw-bold fs-7">@item.AssetName</span>
                                                    <span class="text-muted fs-8">Mã: @item.AssetCode</span>
                                                </div>
                                            </td>
                                            <td class="text-end pe-4">
                                                <span class="badge badge-light-danger fw-bold">@(item.DepartureDate?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->

        <!--begin::Col - Contract Warnings-->
        <div class="col-xl-4">
            <div class="card card-flush h-xl-100 shadow-sm border-0 border-top border-primary border-3">
                 <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Cảnh báo hết hạn hợp đồng</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Danh sách nhân sự cần tái ký trong 30 ngày tới</span>
                    </h3>
                </div>
                <div class="card-body pt-2">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-3">
                             <tbody>
                                @if (_overview.ExpiringContracts == null || !_overview.ExpiringContracts.Any())
                                {
                                    <tr>
                                        <td colspan="2" class="text-center py-10 text-muted fs-7">Không có hợp đồng sắp hết hạn.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach(var contract in _overview.ExpiringContracts)
                                    {
                                         <tr>
                                            <td class="ps-4">
                                                <div class="d-flex flex-column">
                                                    <span class="text-gray-800 fw-bold fs-7">@contract.EmployeeName</span>
                                                    <span class="text-muted fs-8">@contract.Department</span>
                                                </div>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex flex-column align-items-end">
                                                    <span class="text-danger fw-bold fs-7">@contract.ExpiryDate.ToString("dd/MM/yyyy")</span>
                                                    <span class="badge badge-light-danger fs-9">Sắp hết hạn</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!--begin::Col - Birthday Alerts-->
        <div class="col-xl-4">
            <div class="card card-flush h-xl-100 shadow-sm border-0 border-top border-info border-3">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Sắp tới sinh nhật</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Nhân viên đón tuổi mới trong 30 ngày tới</span>
                    </h3>
                </div>
                <div class="card-body pt-2">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-3">
                            <tbody>
                                @if (_overview.BirthdayAlerts == null || !_overview.BirthdayAlerts.Any())
                                {
                                    <tr>
                                        <td colspan="2" class="text-center py-10 text-muted fs-7">Không có sinh nhật nào sắp tới.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var alert in _overview.BirthdayAlerts.OrderBy(a => a.DaysUntilBirthday))
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-35px symbol-circle me-3">
                                                        <span class="symbol-label bg-light-info text-info fw-bold">@alert.EmployeeName.Substring(0, 1)</span>
                                                    </div>
                                                    <div class="d-flex flex-column">
                                                        <span class="text-gray-800 fw-bold fs-7">@alert.EmployeeName</span>
                                                        <span class="text-muted fs-8">@alert.DOB.ToString("dd/MM")</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end pe-4">
                                                @if (alert.DaysUntilBirthday == 0)
                                                {
                                                    <span class="badge badge-light-success fw-bold p-2"><i class="bi bi-cake2-fill me-1"></i> Hôm nay</span>
                                                }
                                                else
                                                {
                                                    <div class="d-flex flex-column align-items-end">
                                                        <span class="text-info fw-bold fs-7">Còn @alert.DaysUntilBirthday ngày</span>
                                                        <span class="badge badge-light-info fs-9">Sắp tới</span>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--begin::Row - Attendance & Department Distribution-->
    <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
        <!--begin::Col - Daily Attendance-->
        <div class="col-xl-8">
            <div class="card card-flush h-xl-100 shadow-sm border-0">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Theo dõi chuyên cần hôm nay</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Số liệu chấm công ngày @DateTime.Now.ToString("dd/MM/yyyy")</span>
                    </h3>
                </div>
                <div class="card-body pt-5">
                    <div class="row g-5">
                        <div class="col-6 col-lg-3">
                            <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                                <span class="fs-4 fw-bolder text-gray-900">@_overview.AttendanceToday.Present.ToString("N0")</span>
                                <div class="fw-semibold text-gray-400 fs-7">Đang làm việc</div>
                            </div>
                        </div>
                        <div class="col-6 col-lg-3">
                            <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                                <span class="fs-4 fw-bolder text-warning">@_overview.AttendanceToday.Late.ToString("N0")</span>
                                <div class="fw-semibold text-gray-400 fs-7">Đi muộn</div>
                            </div>
                        </div>
                         <div class="col-6 col-lg-3">
                            <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                                <span class="fs-4 fw-bolder text-danger">@_overview.AttendanceToday.Absent.ToString("N0")</span>
                                <div class="fw-semibold text-gray-400 fs-7">Vắng mặt</div>
                            </div>
                        </div>
                         <div class="col-6 col-lg-3">
                            <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3 bg-light-primary">
                                <span class="fs-4 fw-bolder text-primary">@_overview.AttendanceToday.Total.ToString("N0")</span>
                                <div class="fw-semibold text-gray-400 fs-7">Tổng quân số</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-center mt-5 chart-container-premium" style="height: 250px;">
                        <ApexChart TItem="AttendanceData" Title="" Options="_attendanceChartOptions" Height="@("250")" Width="@("100%")">
                            <ApexPointSeries TItem="AttendanceData"
                                            Items="_attendanceData"
                                            Name="Tỷ lệ"
                                            SeriesType="SeriesType.Donut"
                                            XValue="@(e => e.Label)"
                                            YValue="@(e => (decimal)e.Value)" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>

        <!--begin::Col - Department Distribution-->
        <div class="col-xl-4">
            <div class="card card-flush h-xl-100 shadow-sm border-0">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Cơ cấu nhân sự</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Phân bổ theo phòng ban</span>
                    </h3>
                </div>
                <div class="card-body pt-5">
                    <div class="mb-5 chart-container-premium" style="height: 350px;">
                        <ApexChart TItem="DepartmentStat" Title="" Options="_deptChartOptions" Height="@("350")" Width="@("100%")">
                            <ApexPointSeries TItem="DepartmentStat"
                                            Items="_overview.DepartmentDistribution"
                                            Name="Nhân sự"
                                            SeriesType="SeriesType.Bar"
                                            XValue="@(e => e.DepartmentName)"
                                            YValue="@(e => (decimal)e.EmployeeCount)" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Row - Attendance & Department Distribution-->

    <!--begin::Row - New Modules: Trainings & Approvals-->
    <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
        <!--begin::Col - Upcoming Trainings-->
        <div class="col-xl-6">
            <div class="card card-flush h-xl-100 shadow-sm border-0">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Lịch đào tạo sắp tới</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Các khóa học đang và sắp diễn ra</span>
                    </h3>
                </div>
                <div class="card-body pt-5">
                    @if (_overview.UpcomingTrainings == null || !_overview.UpcomingTrainings.Any())
                    {
                        <div class="text-center py-10 text-muted fs-7">Không có lịch đào tạo mới.</div>
                    }
                    else
                    {
                        @foreach (var training in _overview.UpcomingTrainings)
                        {
                            <div class="d-flex align-items-center mb-7">
                                <div class="symbol symbol-50px me-5">
                                    <span class="symbol-label bg-light-primary">
                                        <i class="ki-outline ki-book-open fs-2x text-primary"></i>
                                    </span>
                                </div>
                                <div class="flex-grow-1">
                                    <a href="/training" class="text-gray-800 text-hover-primary fw-bold fs-6">@training.Title</a>
                                    <span class="text-muted d-block fw-semibold">Giảng viên: @training.Trainer | @training.DurationHours giờ</span>
                                </div>
                                <span class="badge badge-light-primary fs-8 fw-bold">@training.Status</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!--begin::Col - Pending Approvals Detail-->
        <div class="col-xl-6">
            <div class="card card-flush h-xl-100 shadow-sm border-0">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Yêu cầu chờ được duyệt</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Danh sách các đơn từ, yêu cầu cần xử lý</span>
                    </h3>
                </div>
                <div class="card-body pt-5">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                            <thead>
                                <tr class="fw-bold text-muted">
                                    <th class="min-w-150px">Yêu cầu</th>
                                    <th class="min-w-100px text-end">Ngày gửi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_overview.PendingApprovals == null || !_overview.PendingApprovals.Any())
                                {
                                    <tr>
                                        <td colspan="2" class="text-center py-10 text-muted fs-7">Tất cả yêu cầu đã được xử lý.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var approval in _overview.PendingApprovals)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-35px me-3">
                                                        <span class="symbol-label bg-light-@(approval.Type == "Leave" ? "warning" : "primary")">
                                                            <i class="ki-outline ki-@(approval.Type == "Leave" ? "calendar-8" : "user-tick") fs-4 text-@(approval.Type == "Leave" ? "warning" : "primary")"></i>
                                                        </span>
                                                    </div>
                                                    <div class="d-flex flex-column">
                                                        @if (approval.Type == "Leave")
                                                        {
                                                            <a href="/leave/requests" class="text-gray-800 text-hover-primary fw-bold fs-7">@approval.Title</a>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-gray-800 fw-bold fs-7">@approval.Title</span>
                                                        }
                                                        <span class="text-muted fs-8">Loại: @(approval.Type == "Leave" ? "Nghỉ phép" : "Tuyển dụng")</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                <span class="text-gray-600 fw-bold fs-7">@approval.Date.ToString("dd/MM/yyyy")</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

}
else
{
    <div class="p-10 text-center">
        <div class="mb-5">
            <i class="ki-outline ki-shield-cross fs-5x text-danger opacity-25"></i>
        </div>
        <div class="fs-4 fw-bold text-gray-800 mb-2">Không thể kết nối với trung tâm dữ liệu</div>
        <div class="fs-6 fw-semibold text-gray-500 mb-7">Vui lòng kiểm tra lại kết nối mạng hoặc liên hệ quản trị viên.</div>
        
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="notice d-flex bg-light-danger rounded border-danger border border-dashed p-6 mx-auto" style="max-width: 600px;">
                <i class="ki-outline ki-information-5 fs-2tx text-danger me-4"></i>
                <div class="d-flex flex-stack flex-grow-1">
                    <div class="fw-semibold text-start">
                        <h4 class="text-gray-900 fw-bold">Chi tiết lỗi:</h4>
                        <div class="fs-6 text-gray-700 font-monospace">@_errorMessage</div>
                    </div>
                </div>
            </div>
        }
        
        <div class="mt-8">
            <button class="btn btn-primary fw-bold" @onclick="OnInitializedAsync">
                <i class="ki-outline ki-arrows-circle fs-2"></i> Thử lại ngay
            </button>
        </div>
    </div>
}

