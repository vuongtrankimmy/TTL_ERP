@page "/dashboard"
@layout MainLayout

<PageTitle>Tổng quan hệ thống - TTL.HR</PageTitle>

<!--begin::Row - Tóm tắt chỉ số-->
<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <!--begin::Col-->
    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
        <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0 bg-primary">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <span class="fs-2hx fw-bold text-white me-2 lh-1 ls-n2">1,284</span>
                    <span class="text-white opacity-75 pt-1 fw-semibold fs-6">Tổng nhân sự hiện tại</span>
                </div>
                <div class="card-toolbar">
                    <a href="/employees" class="btn btn-sm btn-light-primary fw-bold btn-active-light-primary border-0 bg-white bg-opacity-10 text-white">Xem danh sách</a>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0 pb-6">
                <div class="d-flex align-items-center flex-column mt-3 w-100">
                    <div class="d-flex justify-content-between w-100 mt-auto mb-2 px-1">
                        <span class="fw-bolder text-white fs-6">85% Đã ký HĐ chính thức</span>
                        <span class="fw-bold text-white fs-6">85%</span>
                    </div>
                    <div class="h-8px w-100 bg-white bg-opacity-25 rounded">
                        <div class="bg-white rounded h-8px" role="progressbar" style="width: 85%;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->

    <!--begin::Col-->
    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
        <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <div class="d-flex align-items-center">
                        <span class="fs-4 fw-semibold text-gray-400 me-1 align-self-start">VNĐ</span>
                        <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">4.2B</span>
                        <span class="badge badge-light-success fs-base">
                            <i class="ki-outline ki-arrow-up fs-5 text-success ms-n1"></i>4.5%
                        </span>
                    </div>
                    <span class="text-gray-400 pt-1 fw-semibold fs-6">Quỹ lương dự tính (Tháng 02/2026)</span>
                </div>
                <div class="card-toolbar">
                    <a href="/payroll/list" class="btn btn-sm btn-light-success fw-bold">Chi tiết lương</a>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pb-6 ps-4">
                <div class="d-flex align-items-center">
                    <div class="symbol-group symbol-hover">
                        <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Phòng Kỹ thuật">
                            <img src="assets/media/avatars/300-1.jpg" alt="" />
                        </div>
                        <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Phòng Sale">
                            <img src="assets/media/avatars/300-2.jpg" alt="" />
                        </div>
                        <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Phòng Marketing">
                            <span class="symbol-label bg-info text-inverse-info fw-bold">M</span>
                        </div>
                        <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Hơn 12 người khác">
                            <span class="symbol-label bg-light-primary text-primary fw-bold">+12</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->

    <!--begin::Col-->
    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
        <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">28</span>
                    <span class="text-gray-400 pt-1 fw-semibold fs-6">Vị trí đang tuyển dụng</span>
                </div>
                <div class="card-toolbar">
                    <a href="/recruitment" class="btn btn-sm btn-light-primary fw-bold">Xem chi tiết</a>
                </div>
            </div>
            <div class="card-body pt-2 pb-6">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-center">
                        <div class="bullet bullet-vertical h-10px bg-success me-3"></div>
                        <span class="text-gray-700 fs-7 fw-bold">12 Ứng viên vừa trúng tuyển</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="bullet bullet-vertical h-10px bg-warning me-3"></div>
                        <span class="text-gray-700 fs-7 fw-bold">15 Lịch phỏng vấn tuần này</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="bullet bullet-vertical h-10px bg-primary me-3"></div>
                        <span class="text-gray-700 fs-7 fw-bold">45 Hồ sơ mới chờ duyệt</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->

    <!--begin::Col-->
    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
        <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0 bg-light-danger">
            <div class="card-body d-flex flex-column justify-content-center p-6">
                <div class="d-flex flex-stack mb-3">
                    <div class="d-flex flex-column">
                        <span class="fs-2hx fw-bold text-danger me-2 lh-1 ls-n2">14</span>
                        <span class="text-danger opacity-75 pt-1 fw-bold fs-6">Đơn chờ phê duyệt</span>
                    </div>
                    <div class="symbol symbol-50px">
                        <div class="symbol-label bg-white">
                            <i class="ki-outline ki-document fs-1 text-danger"></i>
                        </div>
                    </div>
                </div>
                <div class="separator separator-dashed border-danger opacity-25 mb-4"></div>
                <div class="d-flex flex-stack">
                    <div class="fs-7 fw-bold text-gray-800">Cơ cấu: 8 Nghỉ phép, 6 Tăng ca</div>
                    <a href="/leave/approvals" class="btn btn-danger btn-sm px-4 py-2 fs-8 fw-bold">Xử lý ngay</a>
                </div>
            </div>
        </div>
    </div>
    <!--end::Col-->
</div>
<!--end::Row-->

<!--begin::Row - Daily Admin Monitor (New)-->
<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <!--begin::Col - Daily Attendance-->
    <div class="col-xl-8">
        <div class="card card-flush h-xl-100 shadow-sm border-0">
            <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Theo dõi chuyên cần hôm nay</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Số liệu chấm công ngày @DateTime.Now.ToString("dd/MM/yyyy")</span>
                </h3>
                <div class="card-toolbar">
                    <a href="/attendance/timesheet" class="btn btn-sm btn-light btn-active-light-primary fw-bold">Xem bảng công</a>
                </div>
            </div>
            <div class="card-body pt-5">
                <div class="row g-5">
                    <!-- Stat 1: Có mặt -->
                    <div class="col-sm-6 col-lg-3">
                        <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fs-4 fw-bolder text-gray-900">1,150</span>
                                <span class="badge badge-light-success fs-7">90%</span>
                            </div>
                            <div class="fw-semibold text-gray-400 fs-7">Đang làm việc</div>
                        </div>
                        <div class="h-4px w-100 bg-light rounded">
                            <div class="bg-success rounded h-4px" role="progressbar" style="width: 90%"></div>
                        </div>
                    </div>
                    <!-- Stat 2: Đi muộn -->
                    <div class="col-sm-6 col-lg-3">
                        <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fs-4 fw-bolder text-warning">45</span>
                                <span class="badge badge-light-warning fs-7">3.5%</span>
                            </div>
                            <div class="fw-semibold text-gray-400 fs-7">Đi muộn</div>
                        </div>
                        <div class="h-4px w-100 bg-light rounded">
                            <div class="bg-warning rounded h-4px" role="progressbar" style="width: 35%"></div>
                        </div>
                    </div>
                    <!-- Stat 3: Nghỉ phép -->
                    <div class="col-sm-6 col-lg-3">
                        <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fs-4 fw-bolder text-primary">32</span>
                                <span class="badge badge-light-primary fs-7">2.5%</span>
                            </div>
                            <div class="fw-semibold text-gray-400 fs-7">Nghỉ có phép</div>
                        </div>
                        <div class="h-4px w-100 bg-light rounded">
                            <div class="bg-primary rounded h-4px" role="progressbar" style="width: 25%"></div>
                        </div>
                    </div>
                    <!-- Stat 4: Vắng mặt -->
                    <div class="col-sm-6 col-lg-3">
                        <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fs-4 fw-bolder text-danger">57</span>
                                <span class="badge badge-light-danger fs-7">4%</span>
                            </div>
                            <div class="fw-semibold text-gray-400 fs-7">Vắng/Không phép</div>
                        </div>
                        <div class="h-4px w-100 bg-light rounded">
                            <div class="bg-danger rounded h-4px" role="progressbar" style="width: 40%"></div>
                        </div>
                    </div>
                </div>
                <!-- Additional Info -->
                <div class="separator separator-dashed border-gray-300 my-5"></div>
                <div class="d-flex flex-stack">
                    <div class="d-flex align-items-center flex-wrap gap-2">
                         <span class="fs-7 fw-bold text-gray-600">Phòng ban tỉ lệ đi muộn cao nhất:</span>
                         <span class="badge badge-light-danger fw-bold">Marketing (12%)</span>
                         <span class="badge badge-light-danger fw-bold">IT Support (8%)</span>
                    </div>
                    <a href="/attendance" class="text-primary fw-bold fs-7 hover-underline">Phân tích chi tiết</a>
                </div>
            </div>
        </div>
    </div>
    
    <!--begin::Col - Request Queue -->
    <div class="col-xl-4">
        <div class="card card-flush h-xl-100 shadow-sm border-0">
            <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Hàng chờ xử lý</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Tổng hợp yêu cầu cần duyệt</span>
                </h3>
            </div>
            <div class="card-body pt-4">
                <div class="d-flex align-items-center mb-6">
                    <div class="symbol symbol-40px me-3">
                        <div class="symbol-label bg-light-warning">
                            <i class="ki-outline ki-calendar-tick fs-2 text-warning"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <a href="/leave/approvals" class="text-gray-800 fw-bold fs-6 text-hover-primary">Đơn xin nghỉ phép</a>
                        <span class="text-muted d-block fw-bold fs-7">8 đơn chờ duyệt</span>
                    </div>
                    <a href="/leave/approvals" class="btn btn-sm btn-icon btn-light-primary"><i class="ki-outline ki-arrow-right fs-3"></i></a>
                </div>
                <div class="d-flex align-items-center mb-6">
                    <div class="symbol symbol-40px me-3">
                        <div class="symbol-label bg-light-primary">
                            <i class="ki-outline ki-airplane fs-2 text-primary"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <a href="/attendance/leave-trip" class="text-gray-800 fw-bold fs-6 text-hover-primary">Công tác & Di chuyển</a>
                        <span class="text-muted d-block fw-bold fs-7">3 yêu cầu chờ duyệt</span>
                    </div>
                     <a href="/attendance/leave-trip" class="btn btn-sm btn-icon btn-light-primary"><i class="ki-outline ki-arrow-right fs-3"></i></a>
                </div>
                <div class="d-flex align-items-center mb-6">
                    <div class="symbol symbol-40px me-3">
                        <div class="symbol-label bg-light-success">
                            <i class="ki-outline ki-arrow-two-diagonals fs-2 text-success"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <a href="/attendance/shift-approval" class="text-gray-800 fw-bold fs-6 text-hover-primary">Đổi ca làm việc</a>
                        <span class="text-muted d-block fw-bold fs-7">5 yêu cầu chờ duyệt</span>
                    </div>
                     <a href="/attendance/shift-approval" class="btn btn-sm btn-icon btn-light-primary"><i class="ki-outline ki-arrow-right fs-3"></i></a>
                </div>
                <div class="d-flex align-items-center">
                    <div class="symbol symbol-40px me-3">
                        <div class="symbol-label bg-light-info">
                            <i class="ki-outline ki-briefcase fs-2 text-info"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <a href="/recruitment" class="text-gray-800 fw-bold fs-6 text-hover-primary">Đề xuất tuyển dụng</a>
                        <span class="text-muted d-block fw-bold fs-7">1 phiếu chờ duyệt</span>
                    </div>
                     <a href="/recruitment" class="btn btn-sm btn-icon btn-light-primary"><i class="ki-outline ki-arrow-right fs-3"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>
<!--end::Row-->

<!--begin::Row - Biểu đồ và Hoạt động-->
<div class="row g-5 g-xl-10">
    <!--begin::Col - Biểu đồ biến động-->
    <div class="col-xl-8 mb-5 mb-xl-10">
        <div class="card card-flush h-xl-100 shadow-sm border-0">
            <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Biến động nhân sự toàn hệ thống</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Chu kỳ 12 tháng gần nhất (2025 - 2026)</span>
                </h3>
                <div class="card-toolbar">
                    <div class="d-flex flex-stack gap-3">
                         <div class="d-flex align-items-center">
                             <span class="bullet bullet-dot bg-primary me-2 h-10px w-10px"></span>
                             <span class="fs-8 fw-bold text-gray-600">Gia nhập</span>
                         </div>
                         <div class="d-flex align-items-center">
                             <span class="bullet bullet-dot bg-danger me-2 h-10px w-10px"></span>
                             <span class="fs-8 fw-bold text-gray-600">Nghỉ việc</span>
                         </div>
                    </div>
                </div>
            </div>
            <div class="card-body pt-10 px-0 pb-0">
                <!-- Giả lập biểu đồ bằng cột Metronic (do không có JS Chart library sẵn tiện) -->
                <div class="d-flex flex-stack h-300px min-w-500px px-10">
                     @foreach(var (month, add, sub) in new[] { ("T3", 20, 5), ("T4", 35, 12), ("T5", 15, 8), ("T6", 45, 10), ("T7", 60, 15), ("T8", 25, 6), ("T9", 40, 12), ("T10", 30, 8), ("T11", 50, 20), ("T12", 70, 15), ("T1", 85, 10), ("T2", 40, 5) })
                     {
                         <div class="d-flex flex-column align-items-center h-100 position-relative w-100">
                             <div class="d-flex align-items-end h-100 gap-1 mb-2">
                                 <div class="bg-primary rounded-top w-15px" style="height: @(add*3)px;" data-bs-toggle="tooltip" title="Gia nhập: @add"></div>
                                 <div class="bg-danger rounded-top w-15px opacity-50" style="height: @(sub*3)px;" data-bs-toggle="tooltip" title="Nghỉ việc: @sub"></div>
                             </div>
                             <span class="fs-8 fw-bold text-gray-500">@month</span>
                         </div>
                     }
                </div>
                <div class="separator separator-dashed border-gray-300 mt-5 mx-10"></div>
                <div class="card-body pt-6 px-10">
                     <div class="d-flex flex-wrap gap-10">
                         <div class="d-flex flex-column">
                             <span class="fs-7 fw-bold text-gray-400">Tỷ lệ gia tăng mới</span>
                             <div class="d-flex align-items-center">
                                 <span class="fs-2 fw-bold text-gray-800 me-2">+24.5%</span>
                                 <span class="badge badge-light-success fs-9 fw-bold">Vượt mục tiêu</span>
                             </div>
                         </div>
                         <div class="d-flex flex-column">
                             <span class="fs-7 fw-bold text-gray-400">Chỉ số luân chuyển</span>
                             <div class="d-flex align-items-center">
                                 <span class="fs-2 fw-bold text-gray-800 me-2">3.2%</span>
                                 <span class="badge badge-light-primary fs-9 fw-bold">Ổn định</span>
                             </div>
                         </div>
                     </div>
                </div>
            </div>
        </div>
    </div>
    
    <!--begin::Col - Hoạt động gần đây-->
    <div class="col-xl-4 mb-5 mb-xl-10">
        <div class="card card-flush h-xl-100 shadow-sm border-0">
            <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Hoạt động thời gian thực</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Cập nhật lúc 07:25 AM</span>
                </h3>
                <div class="card-toolbar">
                    <button class="btn btn-icon btn-sm btn-active-light-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                        <i class="ki-outline ki-dots-square fs-2"></i>
                    </button>
                </div>
            </div>
            <div class="card-body pt-5">
                <div class="timeline-label">
                    <div class="timeline-item">
                        <div class="timeline-label fw-bold text-gray-800 fs-7 w-50px">08:00</div>
                        <div class="timeline-badge">
                            <i class="fa fa-genderless text-success fs-1"></i>
                        </div>
                        <div class="timeline-content ps-3">
                            <span class="fw-bold text-gray-800">Nguyễn Phi Hùng</span> đã hoàn thành check-in sớm.
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-label fw-bold text-gray-800 fs-7 w-50px">08:45</div>
                        <div class="timeline-badge">
                            <i class="fa fa-genderless text-warning fs-1"></i>
                        </div>
                        <div class="timeline-content ps-3">
                            <span class="fw-bold text-gray-800">Cảnh báo:</span> Có 12 nhân sự chưa check-in sáng nay.
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-label fw-bold text-gray-800 fs-7 w-50px">10:30</div>
                        <div class="timeline-badge">
                            <i class="fa fa-genderless text-primary fs-1"></i>
                        </div>
                        <div class="timeline-content ps-3">
                            Hệ thống đã tự động gửi email thông báo lương cho <span class="text-primary fw-bold">Khối Sản xuất</span>.
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-label fw-bold text-gray-800 fs-7 w-50px">14:00</div>
                        <div class="timeline-badge">
                            <i class="fa fa-genderless text-danger fs-1"></i>
                        </div>
                        <div class="timeline-content ps-3">
                            Phê duyệt nghỉ phép cho <span class="fw-bold text-gray-800">Trần Bích Thủy</span> (3 ngày).
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-label fw-bold text-gray-800 fs-7 w-50px">15:30</div>
                        <div class="timeline-badge">
                            <i class="fa fa-genderless text-success fs-1"></i>
                        </div>
                        <div class="timeline-content ps-3">
                            <span class="fw-bold text-gray-800">Lịch mới:</span> Phỏng vấn ứng viên <span class="text-primary fw-bold">Nguyễn Văn Anh</span> cho vị trí .NET Developer.
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-label fw-bold text-gray-800 fs-7 w-50px">16:15</div>
                        <div class="timeline-badge">
                            <i class="fa fa-genderless text-info fs-1"></i>
                        </div>
                        <div class="timeline-content ps-3">
                            <span class="fw-bold text-gray-800">Đào tạo:</span> Đã đăng ký 15 học viên mới vào khóa <span class="text-info fw-bold">Microservices & .NET Core</span>.
                        </div>
                    </div>
                </div>
                
                <div class="mt-10 bg-light-info rounded p-5 d-flex align-items-center">
                     <i class="ki-outline ki-award fs-2tx text-info me-4"></i>
                     <div class="d-flex flex-column">
                         <span class="text-gray-800 fw-bold fs-6">Kỉ niệm 5 năm làm việc</span>
                         <span class="text-gray-600 fs-7">Hôm nay: Lê Văn Cường (Phòng IT)</span>
                     </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!--begin::Row - Training Summary (New)-->
<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <div class="col-xl-12">
        <div class="card card-flush h-xl-100 shadow-sm border-0">
             <div class="card-header pt-7">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Lịch đào tạo nội bộ sắp tới</span>
                    <span class="text-gray-400 mt-1 fw-semibold fs-7">Các khóa học diễn ra trong tháng 11/2023</span>
                </h3>
                <div class="card-toolbar">
                    <a href="/training" class="btn btn-sm btn-light-primary fw-bold">Quản lý đào tạo</a>
                </div>
            </div>
            <div class="card-body pt-2">
                <div class="table-responsive">
