@page "/dashboard"
@layout MainLayout

<PageTitle>Tổng quan hệ thống - TTL.HR</PageTitle>

@if (_isLoading)
{
    <SkeletonLoading IsLoading="true" Type="SkeletonLoading.SkeletonType.Card" Rows="4" />
}
else if (_overview != null)
{
    <!--begin::Row - Tóm tắt chỉ số-->
    <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
        <!--begin::Col-->
        <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0 bg-primary">
                <div class="card-header pt-5">
                    <div class="card-title d-flex flex-column">
                        <span class="fs-2hx fw-bold text-white me-2 lh-1 ls-n2">@_overview.Stats.TotalEmployees.ToString("N0")</span>
                        <span class="text-white opacity-75 pt-1 fw-semibold fs-6">Tổng nhân sự hiện tại</span>
                    </div>
                    <div class="card-toolbar">
                        <a href="/employees" class="btn btn-sm btn-light-primary fw-bold btn-active-light-primary border-0 bg-white bg-opacity-10 text-white">Xem danh sách</a>
                    </div>
                </div>
                <div class="card-body d-flex align-items-end pt-0 pb-6">
                    <div class="d-flex align-items-center flex-column mt-3 w-100">
                        <div class="d-flex justify-content-between w-100 mt-auto mb-2 px-1">
                            <span class="fw-bolder text-white fs-6">85% Đã ký HĐ chính thức</span>
                            <span class="fw-bold text-white fs-6">85%</span>
                        </div>
                        <div class="h-8px w-100 bg-white bg-opacity-25 rounded">
                            <div class="bg-white rounded h-8px" role="progressbar" style="width: 85%;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->

        <!--begin::Col-->
        <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0">
                <div class="card-header pt-5">
                    <div class="card-title d-flex flex-column">
                        <div class="d-flex align-items-center">
                            <span class="fs-4 fw-semibold text-gray-400 me-1 align-self-start">VNĐ</span>
                            <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">4.2B</span>
                            <span class="badge badge-light-success fs-base">
                                <i class="ki-outline ki-arrow-up fs-5 text-success ms-n1"></i>4.5%
                            </span>
                        </div>
                        <span class="text-gray-400 pt-1 fw-semibold fs-6">Quỹ lương dự tính (Tháng 02/2026)</span>
                    </div>
                    <div class="card-toolbar">
                        <a href="/payroll/list" class="btn btn-sm btn-light-success fw-bold">Chi tiết lương</a>
                    </div>
                </div>
                <div class="card-body d-flex align-items-end pb-6 ps-4">
                    <div class="d-flex align-items-center">
                        <div class="symbol-group symbol-hover">
                            <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Phòng Kỹ thuật">
                                <img src="assets/media/avatars/300-1.jpg" alt="" />
                            </div>
                            <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Phòng Sale">
                                <img src="assets/media/avatars/300-2.jpg" alt="" />
                            </div>
                            <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Phòng Marketing">
                                <span class="symbol-label bg-info text-inverse-info fw-bold">M</span>
                            </div>
                            <div class="symbol symbol-30px symbol-circle" data-bs-toggle="tooltip" title="Hơn 12 người khác">
                                <span class="symbol-label bg-light-primary text-primary fw-bold">+12</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->

        <!--begin::Col-->
        <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0">
                <div class="card-header pt-5">
                    <div class="card-title d-flex flex-column">
                        <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">@_overview.Stats.ActiveJobPostings</span>
                        <span class="text-gray-400 pt-1 fw-semibold fs-6">Vị trí đang tuyển dụng</span>
                    </div>
                    <div class="card-toolbar">
                        <a href="/recruitment" class="btn btn-sm btn-light-primary fw-bold">Xem chi tiết</a>
                    </div>
                </div>
                <div class="card-body pt-2 pb-6">
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center">
                            <div class="bullet bullet-vertical h-10px bg-success me-3"></div>
                            <span class="text-gray-700 fs-7 fw-bold">12 Ứng viên vừa trúng tuyển</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="bullet bullet-vertical h-10px bg-warning me-3"></div>
                            <span class="text-gray-700 fs-7 fw-bold">15 Lịch phỏng vấn tuần này</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="bullet bullet-vertical h-10px bg-primary me-3"></div>
                            <span class="text-gray-700 fs-7 fw-bold">45 Hồ sơ mới chờ duyệt</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->

        <!--begin::Col-->
        <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3">
            <div class="card card-flush h-md-100 mb-5 mb-xl-10 shadow-sm border-0 bg-light-danger">
                <div class="card-body d-flex flex-column justify-content-center p-6">
                    <div class="d-flex flex-stack mb-3">
                        <div class="d-flex flex-column">
                            <span class="fs-2hx fw-bold text-danger me-2 lh-1 ls-n2">@_overview.PendingApprovals.Count</span>
                            <span class="text-danger opacity-75 pt-1 fw-bold fs-6">Đơn chờ phê duyệt</span>
                        </div>
                        <div class="symbol symbol-50px">
                            <div class="symbol-label bg-white">
                                <i class="ki-outline ki-document fs-1 text-danger"></i>
                            </div>
                        </div>
                    </div>
                    <div class="separator separator-dashed border-danger opacity-25 mb-4"></div>
                    <div class="d-flex flex-stack">
                        <div class="fs-7 fw-bold text-gray-800">Cơ cấu: @_overview.PendingApprovals.Count(p => p.Type == "Leave") Nghỉ phép...</div>
                        <a href="/leave/approvals" class="btn btn-danger btn-sm px-4 py-2 fs-8 fw-bold">Xử lý ngay</a>
                    </div>
                </div>
            </div>
        </div>
        <!--end::Col-->
    </div>
    <!--end::Row-->


    <!--begin::Row - Daily Admin Monitor (New)-->
    <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
        <!--begin::Col - Daily Attendance-->
        <div class="col-xl-8">
            <div class="card card-flush h-xl-100 shadow-sm border-0">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Theo dõi chuyên cần hôm nay</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Số liệu chấm công ngày @DateTime.Now.ToString("dd/MM/yyyy")</span>
                    </h3>
                </div>
                <div class="card-body pt-5">
                    <div class="row g-5">
                        <!-- Stat 1: Có mặt -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                                <span class="fs-4 fw-bolder text-gray-900">@_overview.AttendanceToday.Present.ToString("N0")</span>
                                <div class="fw-semibold text-gray-400 fs-7">Đang làm việc</div>
                            </div>
                        </div>
                        <!-- Stat 2: Đi muộn -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                                <span class="fs-4 fw-bolder text-warning">@_overview.AttendanceToday.Late.ToString("N0")</span>
                                <div class="fw-semibold text-gray-400 fs-7">Đi muộn</div>
                            </div>
                        </div>
                         <!-- Stat 3: Vắng mặt -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
                                <span class="fs-4 fw-bolder text-danger">@_overview.AttendanceToday.Absent.ToString("N0")</span>
                                <div class="fw-semibold text-gray-400 fs-7">Vắng mặt</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--begin::Row - Training Summary (New)-->
    <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
        <div class="col-xl-12">
            <div class="card card-flush h-xl-100 shadow-sm border-0">
                 <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Lịch đào tạo nội bộ sắp tới</span>
                        <span class="text-gray-400 mt-1 fw-semibold fs-7">Các khóa học đang diễn ra</span>
                    </h3>
                </div>
                <div class="card-body pt-2">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-4">
                            <thead>
                                <tr class="fw-bold text-muted bg-light">
                                    <th class="ps-4 min-w-200px rounded-start">Khóa học</th>
                                    <th class="min-w-150px">Giảng viên</th>
                                    <th class="min-w-120px">Thời lượng</th>
                                    <th class="min-w-100px text-end rounded-end pe-4">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var course in _overview.UpcomingTrainings)
                                {
                                     <tr>
                                        <td class="ps-4">@course.Title</td>
                                        <td>@course.Trainer</td>
                                        <td>@course.DurationHours giờ</td>
                                        <td class="text-end pe-4"><span class="badge badge-light-primary">@course.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="p-10 text-center">
        <div class="fs-4 fw-bold text-gray-600">Không thể kết nối với trung tâm dữ liệu. Vui lòng thử lại sau.</div>
    </div>
}

