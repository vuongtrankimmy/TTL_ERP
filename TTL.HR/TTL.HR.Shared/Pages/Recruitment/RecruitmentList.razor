@page "/recruitment"
@using TTL.HR.Shared.Components.Common

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <!-- Stats Dashboard -->
        <div class="row g-5 g-xl-8 mb-8">
            <div class="col-xl-3">
                <div class="card card-xl-stretch shadow-sm bg-light-primary border-0">
                    <div class="card-body">
                        <i class="ki-outline ki-briefcase fs-2x text-primary mb-5"></i>
                        <div class="text-gray-900 fw-bolder fs-2 mb-2 mt-5">@_jobs.Count</div>
                        <div class="fw-bold text-gray-400">Tin đang tuyển</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3">
                <div class="card card-xl-stretch shadow-sm bg-light-info border-0">
                    <div class="card-body">
                        <i class="ki-outline ki-people fs-2x text-info mb-5"></i>
                        <div class="text-gray-900 fw-bolder fs-2 mb-2 mt-5">45</div>
                        <div class="fw-bold text-gray-400">Hồ sơ chờ duyệt</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3">
                <div class="card card-xl-stretch shadow-sm bg-light-success border-0">
                    <div class="card-body">
                        <i class="ki-outline ki-check-circle fs-2x text-success mb-5"></i>
                        <div class="text-gray-900 fw-bolder fs-2 mb-2 mt-5">12</div>
                        <div class="fw-bold text-gray-400">Đã tuyển trong tháng</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3">
                <div class="card card-xl-stretch shadow-sm bg-light-warning border-0">
                    <div class="card-body">
                        <i class="ki-outline ki-chart-line-star fs-2x text-warning mb-5"></i>
                        <div class="text-gray-900 fw-bolder fs-2 mb-2 mt-5">85%</div>
                        <div class="fw-bold text-gray-400">Tỷ lệ hoàn thành</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Card -->
        <div class="card mb-8 shadow-sm">
            <div class="card-body py-4 px-6">
                <div class="d-flex flex-wrap align-items-center">
                    <!-- Search -->
                    <div class="position-relative w-md-250px me-4 my-1">
                        <span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4 text-gray-400">
                           <i class="ki-outline ki-magnifier fs-2"></i>
                        </span>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm kiếm vị trí..." />
                    </div>

                    <!-- Department Filter -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Phòng ban: Tất cả</option>
                            <option>Kỹ thuật</option>
                            <option>Kinh doanh</option>
                            <option>Nhân sự</option>
                        </select>
                    </div>

                    <!-- Status Filter -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Trạng thái: Tất cả</option>
                            <option>Đang tuyển</option>
                            <option>Đã đóng</option>
                            <option>Tạm dừng</option>
                        </select>
                    </div>

                    <!-- Action Button -->
                    <div class="ms-auto my-1">
                        <a href="/recruitment/kanban" class="btn btn-light-info fw-bold fs-7 px-6 me-3 border-0 shadow-sm"><i class="ki-outline ki-kanban fs-2 me-1"></i>Bảng Kanban</a>
                        <a href="/recruitment/add" class="btn btn-primary fw-bold fs-7 px-6 shadow-sm"><i class="ki-outline ki-plus-square fs-2 me-1"></i>Đăng tin mới</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="card shadow-sm border-0">
            <div class="card-header border-0 pt-6">
                <div class="card-title">
                    <div class="d-flex align-items-center position-relative my-1">
                        <span class="fs-4 fw-bolder text-dark">Danh sách vị trí tuyển dụng</span>
                        <span class="badge badge-light-primary fw-bolder fs-7 ms-2">@_jobs.Count tin</span>
                    </div>
                </div>
            </div>
            <div class="card-body py-4">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="5" Columns="7">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-4">
                            <thead>
                                <tr class="fw-bolder text-muted bg-light">
                                    <th class="ps-4 min-w-200px rounded-start">Vị trí</th>
                                    <th class="min-w-150px">Phòng ban</th>
                                    <th class="min-w-100px text-center">Số lượng</th>
                                    <th class="min-w-100px text-center">Hạn nộp</th>
                                    <th class="min-w-100px text-center">Ứng viên</th>
                                    <th class="min-w-100px text-center">Trạng thái</th>
                                    <th class="min-w-100px text-end rounded-end pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var job in _jobs)
                                {
                                    <tr class="hover-elevate">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="d-flex justify-content-start flex-column">
                                                    <a href="/recruitment/details/@job.Id" class="text-dark fw-bold text-hover-primary fs-6">@job.Title</a>
                                                    <span class="text-muted fw-semibold d-block fs-7">@job.Code</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-gray-800 fw-bold d-block fs-6">@job.Department</span>
                                            <span class="text-muted fw-semibold d-block fs-7">@job.Type</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-gray-800 fw-bold d-block fs-6">@job.HiringCount</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-gray-800 fw-bold d-block fs-6">@job.Deadline.ToString("dd/MM/yyyy")</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge badge-light-info fw-bold fs-7">@job.ApplicantsCount hồ sơ</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @job.StatusClass fw-bold fs-7">@job.Status</span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <a href="/recruitment/details/@job.Id" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1" title="Chi tiết">
                                                <i class="ki-outline ki-eye fs-3"></i>
                                            </a>
                                            <button class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1" title="Sửa" @onclick="() => HandleEdit(job.Id)">
                                                <i class="ki-outline ki-pencil fs-3"></i>
                                            </button>
                                            <button class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm" title="Xóa" @onclick="() => PromptDelete(job)">
                                                <i class="ki-outline ki-trash fs-3"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </SkeletonLoading>
            </div>
        </div>
    </div>
</div>

<DeleteConfirmationModal 
    IsVisible="@IsDeleteModalOpen"
    Title="Xóa tin tuyển dụng"
    Message="Bạn đang yêu cầu xóa tin tuyển dụng"
    ItemName="@(ItemToDelete?.Title ?? "")"
    OnConfirmed="ConfirmDelete"
    OnCancelled="CloseDeleteModal" />
