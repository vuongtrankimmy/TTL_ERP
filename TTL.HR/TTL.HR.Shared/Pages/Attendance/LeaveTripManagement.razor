@page "/attendance/leave-trip"
@using TTL.HR.Shared.Components.Common

<PageTitle>Quản lý Nghỉ phép & Công tác - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
	<div id="kt_content_container" class="container-fluid">
		<!-- Filters -->
		<div class="card mb-8 shadow-sm border-0">
			<div class="card-body py-4 px-6">
				<div class="d-flex flex-wrap align-items-center">
					<!-- Search -->
					<div class="position-relative w-md-250px me-4 my-1">
						<span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4">
							<i class="ki-outline ki-magnifier fs-2"></i>
						</span>
						<input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm theo tên NV..." 
                               value="@_searchTerm" @oninput="OnSearch" />
					</div>

					<!-- Department -->
					<div class="w-md-175px me-4 my-1">
						<select class="form-select form-select-solid fs-7 fw-bold border-0">
							<option>Phòng ban: Tất cả</option>
							<option>Kỹ thuật</option>
							<option>Marketing</option>
						</select>
					</div>

					<!-- Status -->
					<div class="w-md-175px me-4 my-1">
						<select class="form-select form-select-solid fs-7 fw-bold border-0">
							<option>Trạng thái: Tất cả</option>
							<option>Chờ phê duyệt</option>
							<option>Đã phê duyệt</option>
						</select>
					</div>

					<!-- More Filters -->
					<div class="ms-auto my-1">
						<button class="btn btn-light-primary fw-bold fs-7 px-6"><i class="ki-outline ki-filter me-1"></i>Lọc thêm</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Selection Bar -->
		<div class="d-flex flex-stack mb-6">
			<div class="d-flex align-items-center">
				<div class="form-check form-check-sm form-check-custom form-check-solid me-5">
					<input class="form-check-input" type="checkbox" id="check_all_requests" />
					<label class="form-check-label fw-bold text-gray-700 fs-7 ms-2 text-nowrap" for="check_all_requests">Chọn tất cả (@_filteredRequests.Count yêu cầu)</label>
				</div>
			</div>
			<div class="d-flex align-items-center gap-3 text-end justify-content-end">
				<button class="btn btn-sm btn-light-primary px-4 py-2 fs-8 fw-semibold"><i class="ki-outline ki-plus fs-7 me-1"></i>Tạo yêu cầu mới</button>
			</div>
		</div>

		<!-- Table -->
		<div class="card shadow-sm border-0 overflow-hidden">
			<div class="card-body p-0">
				<SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10" Columns="7">
					<div class="table-responsive">
						<table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-6">
							<thead class="bg-light">
								<tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
									<th class="w-10px pe-2"></th>
									<th class="min-w-200px">NHÂN VIÊN</th>
									<th class="min-w-125px text-center">LOẠI YÊU CẦU</th>
									<th class="min-w-150px">THỜI GIAN</th>
									<th class="min-w-250px">LÝ DO</th>
									<th class="min-w-150px text-center">TRẠNG THÁI</th>
									<th class="min-w-150px text-end">THAO TÁC</th>
								</tr>
							</thead>
							<tbody class="fw-semibold text-gray-700">
                                @if (_filteredRequests.Any())
                                {
                                    @foreach (var item in _filteredRequests)
                                    {
                                        <tr class="hover-elevate cursor-pointer" @onclick="() => OpenDetail(item)">
                                            <td @onclick:stopPropagation="true">
                                                <div class="form-check form-check-sm form-check-custom form-check-solid">
                                                    <input class="form-check-input" type="checkbox" value="@item.Id" />
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-40px symbol-circle me-4">
                                                        @if (!string.IsNullOrEmpty(item.Avatar))
                                                        {
                                                            <img src="@item.Avatar" alt="" />
                                                        }
                                                        else
                                                        {
                                                            <span class="symbol-label bg-light-info text-info fs-6 fw-bold">@item.EmployeeName.Substring(0, 1)</span>
                                                        }
                                                    </div>
                                                    <div class="d-flex justify-content-start flex-column">
                                                        <span class="text-dark fw-bolder fs-6 text-hover-primary">@item.EmployeeName</span>
                                                        <span class="text-muted fw-bold fs-7">@item.Department</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @GetTypeClass(item.Type) fw-bold px-4 py-2 rounded-pill">@item.Type @(string.IsNullOrEmpty(item.SubType) ? "" : $"({item.SubType})")</span>
                                            </td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="text-gray-800 fw-bolder fs-7">@item.StartDate.ToString("dd/MM") - @item.EndDate.ToString("dd/MM/yyyy")</span>
                                                    <span class="text-muted fs-8">@item.TotalDays ngày</span>
                                                </div>
                                            </td>
                                            <td><span class="text-gray-600 fs-7 text-truncate d-inline-block" style="max-width: 250px;">@item.Reason</span></td>
                                            <td class="text-center">
                                                <span class="badge @GetStatusClass(item.Status) fw-bold px-4 py-2 rounded-pill d-inline-flex align-items-center">
                                                    @if (item.IsPending)
                                                    {
                                                        <span class="bullet bullet-dot bg-warning w-6px h-6px me-2 pulse pulse-warning"></span>
                                                    }
                                                    @item.Status
                                                </span>
                                            </td>
                                            <td class="text-end" @onclick:stopPropagation="true">
                                                @if (item.IsPending)
                                                {
                                                    <button class="btn btn-icon btn-sm btn-light-success me-2 hover-scale" title="Phê duyệt" @onclick="() => RequestApprove(item)"><i class="ki-outline ki-check fs-2"></i></button>
                                                    <button class="btn btn-icon btn-sm btn-light-danger me-2 hover-scale" title="Từ chối" @onclick="() => RequestReject(item)"><i class="ki-outline ki-cross fs-2"></i></button>
                                                }
                                                <button class="btn btn-icon btn-sm btn-light-primary border border-primary border-opacity-10 hover-scale" title="Chi tiết" @onclick="() => OpenDetail(item)">
                                                    <i class="ki-outline ki-eye fs-2"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-20">
                                            <div class="text-muted fs-4">Không tìm thấy yêu cầu nào phù hợp.</div>
                                        </td>
                                    </tr>
                                }
							</tbody>
						</table>
					</div>
					<!-- Pagination -->
					<div class="d-flex flex-stack flex-wrap px-7 py-5">
						<div class="fs-7 fw-bold text-gray-700">Hiển thị @_filteredRequests.Count mục</div>
						<ul class="pagination">
							<li class="page-item previous disabled"><a href="#" class="page-link">Trước</a></li>
							<li class="page-item active"><a href="#" class="page-link">1</a></li>
							<li class="page-item next"><a href="#" class="page-link">Sau</a></li>
						</ul>
					</div>
				</SkeletonLoading>
			</div>
		</div>
	</div>
</div>

<!-- Detail Drawer -->
<div class="bg-body drawer drawer-end @(_showDetail ? "drawer-on" : "")" style="width: 500px; max-width: 90vw; transition: transform 0.3s ease-in-out; position: fixed; top: 0; right: 0; bottom: 0; z-index: 110; transform: translateX(@(_showDetail ? "0" : "100%")); box-shadow: -5px 0 15px rgba(0,0,0,0.1); display: block;">
	@if (_selectedRequest != null)
	{
		<div class="card w-100 rounded-0 border-0 h-100">
			<div class="card-header pe-5 border-0 pt-7 ms-2">
				<div class="card-title">
					<div class="d-flex justify-content-center flex-column me-3">
						<span class="fs-2 fw-bolder text-gray-900 mb-1 text-uppercase">Chi tiết yêu cầu</span>
						<div class="mb-0 fs-7 fw-semibold text-muted">Mã: #REQ-@(_selectedRequest.Id)</div>
					</div>
				</div>
				<div class="card-toolbar">
					<button class="btn btn-sm btn-icon btn-active-light-primary bg-light" @onclick="CloseDetail"><i class="ki-outline ki-cross fs-1"></i></button>
				</div>
			</div>
			<div class="card-body hover-scroll-overlay-y px-9">
				<!-- User Info -->
				<div class="d-flex align-items-center mb-8 bg-light-primary rounded p-6 border border-primary border-dashed">
					<div class="symbol symbol-65px symbol-circle me-5">
						@if (!string.IsNullOrEmpty(_selectedRequest.Avatar))
						{
							<img src="@_selectedRequest.Avatar" alt="" />
						}
						else
						{
							<span class="symbol-label bg-primary text-inverse-primary fs-2 fw-bold">@_selectedRequest.EmployeeName.Substring(0, 1)</span>
						}
					</div>
					<div class="flex-grow-1">
						<span class="text-gray-900 fw-bold fs-4 d-block">@_selectedRequest.EmployeeName</span>
						<span class="text-muted fw-semibold">@_selectedRequest.Department</span>
					</div>
				</div>

				<!-- Request Info -->
				<div class="mb-8">
					<h5 class="text-gray-800 fw-bold mb-5 fs-5 border-start border-primary border-4 ps-3">Thông tin đăng ký</h5>
					<div class="row g-4">
						<div class="col-6">
							<div class="border border-gray-300 border-dashed rounded py-4 px-5 bg-light-white">
								<div class="fs-7 text-muted fw-bold mb-1">Loại</div>
								<div class="fs-6 fw-bolder text-gray-800">@_selectedRequest.Type</div>
								<div class="fs-8 text-muted">@_selectedRequest.SubType</div>
							</div>
						</div>
						<div class="col-6">
							<div class="border border-gray-300 border-dashed rounded py-4 px-5 bg-light-white">
								<div class="fs-7 text-muted fw-bold mb-1">Thời lượng</div>
								<div class="fs-6 fw-bolder text-gray-800">@_selectedRequest.TotalDays ngày</div>
							</div>
						</div>
						<div class="col-12">
							<div class="border border-gray-300 border-dashed rounded py-4 px-5 bg-light-white">
								<div class="fs-7 text-muted fw-bold mb-1">Thời gian</div>
								<div class="fs-6 fw-bolder text-gray-800">@_selectedRequest.StartDate.ToString("dd/MM/yyyy") - @_selectedRequest.EndDate.ToString("dd/MM/yyyy")</div>
							</div>
						</div>
					</div>
				</div>

				<div class="mb-8">
					<label class="fw-bold text-gray-800 mb-3 fs-6 ps-1">Lý do/Nội dung</label>
					<div class="bg-light-secondary rounded p-5 border border-dashed border-gray-400 text-gray-700 fs-6">
						@_selectedRequest.Reason
					</div>
				</div>

				@if (!string.IsNullOrEmpty(_selectedRequest.ManagerNote))
				{
					<div class="mb-8">
						<label class="fw-bold text-gray-800 mb-3 fs-6 ps-1">Phản hồi từ quản lý</label>
						<div class="bg-light-info rounded p-5 border border-info border-opacity-25 text-gray-700 fs-6">
							@_selectedRequest.ManagerNote
						</div>
					</div>
				}

				<div class="mb-6">
					<label class="fw-bold text-gray-800 mb-3 fs-6 ps-1">Trạng thái hiện tại</label>
					<div>
						<span class="badge @GetStatusClass(_selectedRequest.Status) fw-bold px-6 py-3 fs-7 rounded-pill">
							@if (_selectedRequest.IsPending)
							{
								<span class="bullet bullet-dot bg-warning w-8px h-8px me-2 pulse pulse-warning"></span>
							}
							@_selectedRequest.Status
						</span>
					</div>
				</div>
			</div>
			@if (_selectedRequest.IsPending)
			{
				<div class="card-footer border-0 d-flex gap-4 justify-content-end p-9 bg-light">
					<button class="btn btn-light-danger btn-active-danger flex-grow-1 fw-bold py-4" @onclick="() => RequestReject(_selectedRequest)">Từ chối</button>
					<button class="btn btn-primary flex-grow-1 fw-bold py-4" @onclick="() => RequestApprove(_selectedRequest)">Phê duyệt</button>
				</div>
			}
		</div>
	}
</div>

<!-- Backdrop -->
@if (_showDetail)
{
	<div class="drawer-overlay" style="z-index: 109; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="CloseDetail"></div>
}

<GenericActionModal IsVisible="_showActionModal"
                    Title="@_modalTitle"
                    Heading="@_modalHeading"
                    Message="@_modalMessage"
                    Color="@_modalColor"
                    Icon="@_modalIcon"
                    ConfirmLabel="@_modalConfirmLabel"
                    ShowReasonInput="_showReasonInput"
                    IsReasonRequired="@(_actionType == "REJECT")"
                    ReasonPlaceholder="@(_actionType == "REJECT" ? "Vui lòng nhập lý do từ chối (bắt buộc)..." : "")"
                    OnConfirmed="ConfirmAction"
                    OnCancelled="CloseModal" />
