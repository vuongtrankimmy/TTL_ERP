@page "/attendance/leave-trip"
@using TTL.HR.Shared.Components.Common

<PageTitle>Quản lý Nghỉ phép & Công tác - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
	<div id="kt_content_container" class="container-fluid">
		<!-- Header & Tabs -->
        <div class="card mb-8 shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <div class="d-flex flex-stack flex-wrap p-8">
                    <div class="d-flex flex-column">
                        <h1 class="text-gray-900 fw-bolder fs-2 mb-1">Quản lý Nghỉ phép & Công tác</h1>
                        <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 pt-1">
                            <li class="breadcrumb-item text-muted">Chấm công</li>
                            <li class="breadcrumb-item"><span class="bullet bg-gray-300 w-5px h-2px"></span></li>
                            <li class="breadcrumb-item text-gray-900">Nghỉ phép & Công tác</li>
                        </ul>
                    </div>
                </div>

                <div class="px-8 border-top bg-light-light bg-opacity-50">
                    <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "All" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("All")'>
                                Tất cả <span class="badge badge-light-dark ms-2">@(_summary.TotalCount)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "Pending" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("Pending")'>
                                Chờ duyệt <span class="badge badge-light-warning ms-2">@_summary.PendingCount</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "Approved" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("Approved")'>
                                Đã duyệt <span class="badge badge-light-success ms-2">@_summary.ApprovedCount</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "Rejected" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("Rejected")'>
                                Từ chối <span class="badge badge-light-danger ms-2">@_summary.RejectedCount</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

		<!-- Filter Bar -->
        <div class="card mb-6 shadow-xs border-0 rounded-3">
            <div class="card-body py-4 px-8">
                <div class="d-flex flex-wrap align-items-center">
                    <div class="position-relative w-md-300px me-auto my-1">
                        <i class="ki-outline ki-magnifier fs-2 position-absolute top-50 translate-middle-y ms-4 text-gray-500"></i>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm theo tên NV, mã NV, lý do..." @oninput="OnSearch" value="@_searchTerm" />
                    </div>
                </div>
            </div>
        </div>

		<!-- Table -->
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-10">
            <div class="card-body p-0">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-200 align-middle gs-8 gy-5 mb-0">
                            <thead class="bg-light-light">
                                <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
                                    <th class="w-10px pe-2">
                                        <div class="form-check form-check-sm form-check-custom form-check-solid">
                                            <input class="form-check-input" type="checkbox" />
                                        </div>
                                    </th>
                                    <th class="min-w-200px">Nhân viên / Đối tượng</th>
                                    <th class="min-w-150px text-center">Loại đơn</th>
                                    <th class="min-w-150px">Thời gian dự kiến</th>
                                    <th class="min-w-250px">Lý do cụ thể</th>
                                    <th class="min-w-150px text-center">Trạng thái</th>
                                    <th class="min-w-150px text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _requests)
                                {
                                    <tr class="hover-elevate cursor-pointer" @onclick="() => OpenDetail(item)">
                                        <td>
                                            <div class="form-check form-check-sm form-check-custom form-check-solid">
                                                <input class="form-check-input" type="checkbox" @onclick:stopPropagation />
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="symbol symbol-circle symbol-45px me-3">
                                                    @if (!string.IsNullOrEmpty(item.Avatar))
                                                    {
                                                        <img src="@item.Avatar" alt="" />
                                                    }
                                                    else
                                                    {
                                                        <div class="symbol-label bg-light-primary text-primary fw-bold fs-6">@(!string.IsNullOrEmpty(item.EmployeeName) ? item.EmployeeName.Substring(0, 1) : "N")</div>
                                                    }
                                                </div>
                                                <div class="d-flex flex-column">
                                                    <span class="text-gray-900 fw-bold fs-6 mb-1">@item.EmployeeName</span>
                                                    <span class="text-muted fw-semibold fs-8">@item.EmployeeCode • @item.Department</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @GetTypeClass(item.Type) fw-bold px-4 py-3 rounded-pill">@item.Type</span>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <div class="d-flex align-items-center mb-1">
                                                    <i class="ki-outline ki-calendar-8 fs-7 text-primary me-2"></i>
                                                    <span class="text-gray-800 fw-bold fs-7">@item.StartDate.ToString("dd/MM") - @item.EndDate.ToString("dd/MM/yyyy")</span>
                                                </div>
                                                <div class="d-flex align-items-center">
                                                    <i class="ki-outline ki-time fs-7 text-muted me-2"></i>
                                                    <span class="text-muted fw-semibold fs-8">@item.TotalDays ngày</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="text-gray-700 fs-7 text-truncate d-inline-block" style="max-width: 250px;" title="@item.Reason">
                                                @item.Reason
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @GetStatusClass(item.Status) fw-bold px-4 py-2 d-inline-flex align-items-center">
                                                <span class="bullet bullet-dot @(GetStatusClass(item.Status).Replace("badge-light-", "bg-")) w-6px h-6px me-2 @(item.IsPending ? "pulse pulse-warning" : "")"></span>@item.Status
                                            </span>
                                        </td>
                                        <td class="text-end pe-8">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm shadow-sm" @onclick="() => OpenDetail(item)" @onclick:stopPropagation title="Xem chi tiết">
                                                    <i class="ki-outline ki-eye fs-3"></i>
                                                </button>
                                                @if (item.IsPending)
                                                {
                                                    <button class="btn btn-icon btn-bg-light btn-active-color-success btn-sm shadow-sm" @onclick="() => RequestApprove(item)" @onclick:stopPropagation title="Duyệt">
                                                        <i class="ki-outline ki-check fs-2"></i>
                                                    </button>
                                                    <button class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm shadow-sm" @onclick="() => RequestReject(item)" @onclick:stopPropagation title="Từ chối">
                                                        <i class="ki-outline ki-cross fs-2"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!_requests.Any() && !_isLoading)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-20">
                                            <div class="d-flex flex-column align-items-center">
                                                <i class="ki-outline ki-notification-on fs-5x text-gray-200 mb-5"></i>
                                                <span class="text-muted fs-6 fw-bold">Hiện không có yêu cầu nào trong danh sách.</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination -->
                    <div class="d-flex flex-stack flex-wrap px-8 py-6 bg-light-light bg-opacity-30 border-top">
                        <div class="fs-7 fw-bold text-gray-700">
                            Hiển thị <span class="text-gray-900 fw-bolder">@_requests.Count</span> của tổng số <span class="text-gray-900 fw-bolder">@_totalCount</span> yêu cầu
                        </div>
                        <ul class="pagination pagination-outline">
                            <li class="page-item previous @(_pageIndex <= 1 ? "disabled" : "")">
                                <a href="javascript:;" class="page-link" @onclick="() => ChangePage(_pageIndex - 1)"><i class="ki-outline ki-left fs-6"></i></a>
                            </li>
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                var p = i;
                                <li class="page-item @(_pageIndex == p ? "active" : "")">
                                    <a href="javascript:;" class="page-link" @onclick="() => ChangePage(p)">@p</a>
                                </li>
                            }
                            <li class="page-item next @(_pageIndex >= TotalPages ? "disabled" : "")">
                                <a href="javascript:;" class="page-link" @onclick="() => ChangePage(_pageIndex + 1)"><i class="ki-outline ki-right fs-6"></i></a>
                            </li>
                        </ul>
                    </div>
                </SkeletonLoading>
            </div>
        </div>
	</div>
</div>

<!-- Detail Drawer -->
<div class="bg-body drawer drawer-end @(_showDetail ? "drawer-on" : "")" style="width: 500px; max-width: 90vw; transition: transform 0.3s ease-in-out; position: fixed; top: 0; right: 0; bottom: 0; z-index: 110; transform: translateX(@(_showDetail ? "0" : "100%")); box-shadow: -5px 0 15px rgba(0,0,0,0.1); display: block;">
	@if (_selectedRequest != null)
	{
		<div class="card w-100 rounded-0 border-0 h-100">
			<div class="card-header pe-5 border-0 pt-7 ms-2">
				<div class="card-title">
					<div class="d-flex justify-content-center flex-column me-3">
						<span class="fs-2 fw-bolder text-gray-900 mb-1 text-uppercase">Chi tiết yêu cầu</span>
						<div class="mb-0 fs-7 fw-semibold text-muted">Mã: #REQ-@(_selectedRequest.Id.Substring(Math.Max(0, _selectedRequest.Id.Length - 6)))</div>
					</div>
				</div>
				<div class="card-toolbar">
					<button class="btn btn-sm btn-icon btn-active-light-primary bg-light" @onclick="CloseDetail"><i class="ki-outline ki-cross fs-1"></i></button>
				</div>
			</div>
			<div class="card-body hover-scroll-overlay-y px-9">
				<!-- User Info -->
				<div class="d-flex align-items-center mb-8 bg-light-primary rounded p-6 border border-primary border-dashed">
					<div class="symbol symbol-65px symbol-circle me-5 border border-white border-3 shadow-sm">
						@if (!string.IsNullOrEmpty(_selectedRequest.Avatar))
						{
							<img src="@_selectedRequest.Avatar" alt="" />
						}
						else
						{
							<div class="symbol-label bg-primary text-inverse-primary fs-2 fw-bold">@_selectedRequest.EmployeeName.Substring(0, 1)</div>
						}
					</div>
					<div class="flex-grow-1">
						<span class="text-gray-900 fw-bold fs-4 d-block">@_selectedRequest.EmployeeName</span>
						<span class="text-muted fw-semibold">@_selectedRequest.Department</span>
                        <div class="mt-1">
                            <span class="badge @GetStatusClass(_selectedRequest.Status) fs-9 fw-bold px-2 py-0.5">@_selectedRequest.Status</span>
                        </div>
					</div>
				</div>

				<!-- Request Info -->
				<div class="mb-8">
					<h5 class="text-gray-800 fw-bold mb-5 fs-5 border-start border-primary border-4 ps-3 text-uppercase">Thông tin đăng ký</h5>
					<div class="row g-4">
						<div class="col-6">
							<div class="border border-gray-300 border-dashed rounded py-4 px-5 bg-light-light bg-opacity-50">
								<div class="fs-7 text-muted fw-bold mb-1">Loại</div>
								<div class="fs-6 fw-bolder text-gray-800">@_selectedRequest.Type</div>
							</div>
						</div>
						<div class="col-6">
							<div class="border border-gray-300 border-dashed rounded py-4 px-5 bg-light-light bg-opacity-50">
								<div class="fs-7 text-muted fw-bold mb-1">Thời lượng</div>
								<div class="fs-6 fw-bolder text-gray-800">@_selectedRequest.TotalDays ngày</div>
							</div>
						</div>
						<div class="col-12">
							<div class="border border-gray-300 border-dashed rounded py-4 px-5 bg-light-light bg-opacity-50">
								<div class="fs-7 text-muted fw-bold mb-1">Thời gian</div>
								<div class="fs-6 fw-bolder text-gray-800">@_selectedRequest.StartDate.ToString("dd/MM/yyyy") - @_selectedRequest.EndDate.ToString("dd/MM/yyyy")</div>
							</div>
						</div>
					</div>
				</div>

				<div class="mb-8">
					<label class="fw-bold text-gray-800 mb-3 fs-6 ps-1">Lý do/Nội dung</label>
					<div class="bg-light-secondary rounded p-5 border border-dashed border-gray-400 text-gray-700 fs-6 lh-lg">
						@_selectedRequest.Reason
					</div>
				</div>

				@if (!string.IsNullOrEmpty(_selectedRequest.ManagerNote))
				{
					<div class="mb-8">
						<label class="fw-bold text-gray-800 mb-3 fs-6 ps-1">Phản hồi từ quản lý</label>
						<div class="bg-light-info rounded p-5 border border-info border-opacity-25 text-gray-700 fs-6 lh-lg">
							@_selectedRequest.ManagerNote
						</div>
					</div>
				}
			</div>
			@if (_selectedRequest.IsPending)
			{
				<div class="card-footer border-0 d-flex gap-4 justify-content-end p-9 bg-light">
					<button class="btn btn-light-danger btn-active-danger flex-grow-1 fw-bold py-4 fs-7" @onclick="() => RequestReject(_selectedRequest)">Từ chối</button>
					<button class="btn btn-primary flex-grow-1 fw-bold py-4 fs-7" @onclick="() => RequestApprove(_selectedRequest)">Phê duyệt</button>
				</div>
			}
            else
            {
                <div class="card-footer border-0 p-9 bg-light">
                    <button class="btn btn-light flex-grow-1 fw-bold py-4 fs-7 w-100" @onclick="CloseDetail">Đóng</button>
                </div>
            }
		</div>
	}
</div>

<!-- Backdrop -->
@if (_showDetail)
{
	<div class="drawer-overlay" style="z-index: 109; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="CloseDetail"></div>
}

<GenericActionModal IsVisible="_showActionModal"
                    Title="@_modalTitle"
                    Heading="@_modalHeading"
                    Message="@_modalMessage"
                    Color="@_modalColor"
                    Icon="@_modalIcon"
                    ConfirmLabel="@_modalConfirmLabel"
                    ShowReasonInput="_showReasonInput"
                    IsReasonRequired="@(_actionType == "REJECT")"
                    ReasonPlaceholder="@(_actionType == "REJECT" ? "Vui lòng nhập lý do từ chối (bắt buộc)..." : "Nhập lời nhắn gửi nhân viên (không bắt buộc)...")"
                    OnConfirmed="ConfirmAction"
                    OnCancelled="CloseModal" />

