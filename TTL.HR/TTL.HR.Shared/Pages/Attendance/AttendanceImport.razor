@page "/attendance/import"
@inherits AttendanceImportBase

<PageTitle>Import Dữ liệu Chấm công - TTL ERP</PageTitle>

<div class="d-flex flex-column flex-column-fluid">
    <!-- Toolbar -->
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">
                    Import Dữ liệu Chấm công
                </h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
                    </li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-400 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-muted">Chấm công</li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-400 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-dark">Import dữ liệu</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-xxl">
            
            <!-- Stepper Header -->
            <div class="card mb-5">
                <div class="card-body py-10">
                    <div class="stepper stepper-pills stepper-column d-flex flex-column flex-xl-row flex-row-fluid" id="kt_stepper_example_basic">
                        <div class="stepper-nav d-flex flex-row justify-content-between w-100 flex-wrap">
                            <div class="stepper-item me-5 @(currentStep == 1 ? "current" : (currentStep > 1 ? "completed" : ""))" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">1</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Tải tệp</h3>
                                        <div class="stepper-desc">Chọn file Excel</div>
                                    </div>
                                </div>
                            </div>
                            <div class="stepper-item me-5 @(currentStep == 2 ? "current" : (currentStep > 2 ? "completed" : ""))" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">2</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Mapping</h3>
                                        <div class="stepper-desc">Ánh xạ cột dữ liệu</div>
                                    </div>
                                </div>
                            </div>
                            <div class="stepper-item me-5 @(currentStep == 3 ? "current" : (currentStep > 3 ? "completed" : ""))" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">3</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Preview</h3>
                                        <div class="stepper-desc">Kiểm tra kết quả</div>
                                    </div>
                                </div>
                            </div>
                            <div class="stepper-item @(currentStep == 4 ? "current" : "")" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">4</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Hoàn tất</h3>
                                        <div class="stepper-desc">Lưu và xem báo cáo</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-flush">
                <div class="card-body">
                    @if (currentStep == 1)
                    {
                        <!-- Step 1: Upload -->
                        <div class="row g-10">
                            <div class="col-xl-6 border-end">
                                <h3 class="fw-bold text-dark mb-7">1. Chọn nguồn & Tải tệp</h3>
                                
                                <div class="mb-10">
                                    <label class="form-label fw-bold">Nguồn dữ liệu:</label>
                                    <div class="nav-group nav-group-outline" data-kt-buttons="true">
                                        <button class="btn btn-outline btn-outline-dashed btn-active-light-primary px-6 py-3 me-2 @(importSource == "Fingerprint" ? "active" : "")" @onclick='() => SetSource("Fingerprint")'>
                                            <i class="ki-outline ki-fingerprint fs-2 me-1"></i>Máy vân tay
                                        </button>
                                        <button class="btn btn-outline btn-outline-dashed btn-active-light-primary px-6 py-3 @(importSource == "QR" ? "active" : "")" @onclick='() => SetSource("QR")'>
                                            <i class="ki-outline ki-scan-barcode fs-2 me-1"></i>QR Checkin
                                        </button>
                                    </div>
                                </div>

                                <div class="mb-10">
                                    <label class="form-label fw-bold">Tải tệp dữ liệu:</label>
                                    <div class="fv-row">
                                    <div class="dropzone d-flex align-items-center justify-content-center p-10 border-dashed rounded overflow-hidden transition-3ms @(_isDragging ? "dropzone-active border-primary bg-light-primary" : "bg-light")" 
                                         style="position: relative; min-height: 200px;"
                                         @ondragenter="HandleDragEnter" 
                                         @ondragleave="HandleDragLeave"
                                         @ondragover:prevent>
                                         
                                         @if (_isProcessing)
                                         {
                                             <div class="position-absolute w-100 h-100 top-0 start-0 d-flex flex-column align-items-center justify-content-center z-index-2 bg-white bg-opacity-75">
                                                 <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                                                  <span class="text-gray-800 fw-bold">@(_progressStatus != "" ? _progressStatus : "Đang xử lý tệp...")</span>
                                                  @if (_progressPercentage > 0)
                                                  {
                                                      <div class="progress w-75 mt-3" style="height: 8px;">
                                                          <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: @((int)_progressPercentage)%"></div>
                                                      </div>
                                                      <span class="fs-8 text-muted mt-1">@((int)_progressPercentage)%</span>
                                                  }
                                             </div>
                                         }

                                         <div class="text-center @(selectedFile != null ? "d-none" : "")">
                                             <i class="ki-outline ki-file-up fs-3x text-primary mb-3"></i>
                                             <div class="fs-6 fw-bold text-gray-700">Kéo thả tệp hoặc click để chọn</div>
                                             <span class="text-muted fs-7">Hỗ trợ .xlsx, .xls, .csv, .txt, .json, .mdb (Max 10MB)</span>
                                             <InputFile OnChange="@OnInputFileChange" class="position-absolute opacity-0 w-100 h-100 top-0 start-0 cursor-pointer" accept=".xlsx,.xls,.csv,.txt,.json,.mdb" disabled="@_isProcessing" />
                                         </div>

                                         @if (selectedFile != null)
                                         {
                                             <div class="text-center position-relative z-index-1 animate__animated animate__zoomIn">
                                                 <i class="ki-outline ki-document fs-3x text-success mb-3"></i>
                                                 <div class="fs-6 fw-bold text-gray-700">@selectedFile.Name</div>
                                                 <span class="text-muted fs-7">@((selectedFile.Size / 1024).ToString("N0")) KB</span>
                                                 <div class="mt-4">
                                                     <button type="button" class="btn btn-sm btn-light-danger" @onclick="RemoveFile" disabled="@_isProcessing">
                                                         <i class="ki-outline ki-cross fs-4"></i>Xóa tệp
                                                     </button>
                                                 </div>
                                             </div>
                                         }
                                     </div>
                                    </div>
                                </div>

                                <div class="separator separator-dashed my-8"></div>

                                <div class="mb-5">
                                    <label class="form-label fw-bold">Xem trước nội dung / Hoặc dán văn bản thô (Hiển thị tối đa 10 dòng):</label>
                                    @if (rawDataTable.Any())
                                    {
                                        <div class="table-responsive border rounded mb-3 custom-scrollbar overflow-auto animate__animated animate__fadeIn" style="max-height: 350px;">
                                            <table class="table table-bordered table-sm table-striped fs-8 mb-0 align-middle">
                                                <thead class="position-sticky top-0 bg-light z-index-1">
                                                    <tr class="fw-bold text-gray-800 bg-light">
                                                        @if (fileHeaders.Any())
                                                        {
                                                            @foreach (var header in fileHeaders)
                                                            {
                                                                <th class="px-3 py-2 text-nowrap">@header</th>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            @for (int i = 0; i < rawDataTable.First().Count; i++)
                                                            {
                                                                <th class="px-3 py-2 text-nowrap">Cột @(i + 1)</th>
                                                            }
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in (fileHeaders.Any() ? rawDataTable.Skip(1) : rawDataTable))
                                                    {
                                                        <tr>
                                                            @foreach (var cell in row)
                                                            {
                                                                <td class="px-3 py-1 text-nowrap text-muted">@cell</td>
                                                            }
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    <textarea class="form-control form-control-solid @(rawDataTable.Any() ? "d-none" : "")" rows="6" placeholder="Nhập văn bản thô tại đây (cách nhau bởi dấu phẩy)..." @bind="rawData" @oninput="OnRawDataChanged"></textarea>
                                </div>
                                <div class="d-flex justify-content-end">
                                    <button class="btn btn-primary px-10 py-3" @onclick="ProcessNextStep" disabled="@(!CanProceed() || _isProcessing)">
                                        @if (_isProcessing)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        Tiếp tục <i class="ki-outline ki-arrow-right fs-3 ms-2"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-xl-6">
                                <h3 class="fw-bold text-dark mb-7">Hướng dẫn & Lưu ý</h3>
                                <div class="bg-light-info p-5 rounded d-flex mb-7 border border-info border-dashed">
                                    <i class="ki-outline ki-information-5 fs-1 text-info me-4"></i>
                                    <div class="text-dark fw-semibold">Hệ thống tự động lọc bản ghi sớm nhất làm Check-in và muộn nhất làm Check-out trong cùng một ngày làm việc.</div>
                                </div>
                                <div class="mb-5">
                                    <h4 class="fs-6 fw-bold mb-4 text-gray-700">Minh họa nguyên tắc lọc dữ liệu:</h4>
                                    <div class="row align-items-center g-0 mb-3">
                                        <div class="col-5">
                                            <div class="table-responsive border rounded text-center">
                                                <div class="bg-light py-2 fw-bold fs-8 border-bottom">Dữ liệu thô tải lên</div>
                                                <table class="table table-row-bordered table-striped mb-0">
                                                    <tbody class="fs-8">
                                                        <tr><td>GD-001</td><td class="text-success fw-bold">08:00</td></tr>
                                                        <tr><td>GD-001</td><td class="text-muted">12:15</td></tr>
                                                        <tr><td class="border-bottom-0">GD-001</td><td class="text-info fw-bold border-bottom-0">17:05</td></tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                        <div class="col-2 text-center">
                                            <i class="ki-outline ki-arrow-right fs-2x text-primary animate-pulse"></i>
                                            <div class="fs-9 fw-bold mt-1 text-primary">Xử lý</div>
                                        </div>
                                        <div class="col-5">
                                            <div class="table-responsive border rounded text-center h-100">
                                                <div class="bg-light py-2 fw-bold fs-8 border-bottom">Kết quả Bảng công</div>
                                                <table class="table mb-0 h-100">
                                                    <tbody class="fs-8">
                                                        <tr>
                                                            <td class="border-bottom-0 align-middle py-6">GD-001</td>
                                                            <td class="border-bottom-0 align-middle py-6"><span class="badge badge-light-success fs-9 px-2">IN: 08:00</span></td>
                                                            <td class="border-bottom-0 align-middle py-6"><span class="badge badge-light-info fs-9 px-2">OUT: 17:05</span></td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-muted fs-8 fst-italic text-center">
                                        (Các bản ghi ở giữa như 12:15 sẽ được bỏ qua)
                                    </div>
                                </div>
                                <div class="mb-5">
                                    <h4 class="fs-6 fw-bold mb-3 text-gray-700">TXT & JSON:</h4>
                                    <ul class="fs-7 text-muted lh-lg">
                                        <li><strong>TXT:</strong> Phân tách bởi dấu phẩy, Tab hoặc dấu chấm phẩy. KhÔNG có tiêu đề. Ví dụ: <br><code>GD-001, 2026-02-21 08:00</code></li>
                                         <li><strong>JSON:</strong> Mảng các đối tượng: <br><code>[{"EmployeeCode": "NV001", "Timestamp": "2026-02-21 08:00:15"}]</code></li>
                                         <li><strong>MDB:</strong> Truy xuất từ database máy vân tay (ZKTeco, WiseEye...). Quét bảng <code>T_data</code> hoặc <code>CHECKINOUT</code>.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                    else if (currentStep == 2)
                    {
                        <!-- Step 2: Mapping -->
                        <div class="max-w-600px mx-auto my-10 text-center">
                            <i class="ki-outline ki-setting-2 fs-4x text-primary mb-5"></i>
                            <h2 class="fw-bold text-dark mb-2">Ánh xạ cột dữ liệu</h2>
                            <p class="text-gray-500 mb-10">Chọn cột tương ứng trong tệp Excel của bạn để hệ thống có thể đọc đúng dữ liệu.</p>

                            <div class="text-start bg-light p-8 rounded border mb-10">
                                <div class="mb-7">
                                    <label class="form-label fw-bold fs-6">1. Cột chứa Mã Nhân viên:</label>
                                    <select class="form-select form-select-solid" @bind="employeeCodeColIndex">
                                        @for (int i = 0; i < fileHeaders.Count; i++)
                                        {
                                            <option value="@(i + 1)">Cột @(i + 1): @fileHeaders[i]</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold fs-6">2. Cột chứa Thời gian quét (DateTime):</label>
                                    <select class="form-select form-select-solid" @bind="timestampColIndex">
                                        @for (int i = 0; i < fileHeaders.Count; i++)
                                        {
                                            <option value="@(i + 1)">Cột @(i + 1): @fileHeaders[i]</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between">
                                <button class="btn btn-light px-10 py-3" @onclick="GoBack"><i class="ki-outline ki-arrow-left fs-3 me-2"></i> Quay lại</button>
                                <button class="btn btn-primary px-10 py-3" @onclick="GoToPreview" disabled="@_isProcessing">
                                    @if (_isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Xem trước dữ liệu <i class="ki-outline ki-arrow-right fs-3 ms-2"></i>
                                </button>
                            </div>
                        </div>
                    }
                    else if (currentStep == 3 && importResult != null)
                    {
                        <!-- Step 3: Preview -->
                        <div class="d-flex flex-stack mb-7">
                            <div class="d-flex flex-column">
                                <h3 class="fw-bold text-dark">Xem trước dữ liệu (@(importResult.PreviewItems.Count) bản ghi)</h3>
                                <p class="text-gray-500 pb-0 mb-0">Hệ thống đã phân tích dữ liệu, vui lòng kiểm tra trước khi nhấn Lưu.</p>
                            </div>
                            <div class="d-flex">
                                <button class="btn btn-light me-3" @onclick="GoBack"><i class="ki-outline ki-arrow-left fs-3 me-1"></i>Quay lại</button>
                                <button class="btn btn-success" @onclick="ConfirmImport" disabled="@_isProcessing">
                                    @if (_isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    <i class="ki-outline ki-disk fs-3 me-1"></i>Lưu vào Database
                                </button>
                            </div>
                        </div>

                        @if (importResult.DuplicateCount > 0)
                        {
                            <div class="alert alert-dismissible bg-light-warning d-flex flex-column flex-sm-row p-5 mb-5 border border-warning border-dashed">
                                <i class="ki-outline ki-notification-on fs-2hx text-warning me-4 mb-5 mb-sm-0"></i>
                                <div class="d-flex flex-column pe-0 pe-sm-10">
                                    <h5 class="fw-bold text-warning mb-1">Dữ liệu trùng lặp (@importResult.DuplicateCount bản ghi)</h5>
                                    <span class="fs-7 text-gray-700">Hệ thống đã tự động loại bỏ các bản ghi có cùng nhân viên và thời gian quét thẻ để đảm bảo tính chính xác.</span>
                                </div>
                            </div>
                        }

                        <!-- Tabs for Step 3 -->
                        <ul class="nav nav-tabs nav-line-tabs nav-line-tabs-2x mb-5 fs-6 fw-bold border-bottom-0">
                            <li class="nav-item">
                                <a class="nav-link text-active-primary py-4 active" data-bs-toggle="tab" href="#kt_tab_processed">
                                    <i class="ki-outline ki-calendar-8 fs-3 me-2"></i>Bảng tổng hợp công theo ngày
                                    <span class="badge badge-light-primary ms-2 fs-8">@importResult.PreviewItems.Count</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-active-primary py-4" data-bs-toggle="tab" href="#kt_tab_raw">
                                    <i class="ki-outline ki-file-sheet fs-3 me-2"></i>Dữ liệu thô gốc (Scans)
                                    @if (importResult.RawItems.Any())
                                    {
                                        <span class="badge badge-light-info ms-2 fs-8">@importResult.RawItems.Count</span>
                                    }
                                </a>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <!-- Processed Tab -->
                            <div class="tab-pane fade show active" id="kt_tab_processed" role="tabpanel">
                                <div class="table-responsive border rounded custom-scrollbar bg-white shadow-sm" style="max-height: 550px; overflow-y: auto;">
                                    <table class="table table-hover table-row-dashed align-middle gs-6 gy-5 mb-0">
                                        <thead class="position-sticky top-0 bg-light z-index-2 shadow-sm">
                                            <tr class="fw-bold fs-7 text-gray-800 border-bottom-2 border-gray-200 bg-light">
                                                <th class="ps-4 min-w-150px">Nhân viên</th>
                                                <th class="min-w-100px text-center">Ngày</th>
                                                <th class="min-w-100px text-center">Giờ vào</th>
                                                <th class="min-w-100px text-center">Giờ ra</th>
                                                <th class="min-w-150px">Ca làm việc</th>
                                                <th class="min-w-100px text-center">Tổng công</th>
                                                <th class="min-w-120px text-center">Trạng thái</th>
                                                <th class="text-end pe-4 min-w-100px">Ghi chú</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var empGroup in importResult.PreviewItems.GroupBy(r => r.EmployeeCode).OrderBy(g => g.Key))
                                            {
                                                <tr class="bg-light-primary">
                                                    <td colspan="8" class="fw-bold py-3 ps-4">
                                                        <div class="d-flex align-items-center">
                                                            <div class="symbol symbol-35px symbol-circle me-3">
                                                                <div class="symbol-label bg-primary text-inverse-primary fw-bold">
                                                                    @(empGroup.First().EmployeeName?.Length > 0 ? empGroup.First().EmployeeName.Substring(0, 1).ToUpper() : "U")
                                                                </div>
                                                            </div>
                                                            <div class="d-flex flex-column">
                                                                <span class="text-primary fs-6 fw-bold">@empGroup.First().EmployeeName</span>
                                                                <span class="text-muted fs-8 fw-semibold">Mã NV: @empGroup.Key • @empGroup.Count() ngày công</span>
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                @foreach (var item in empGroup.OrderBy(x => x.Date))
                                                {
                                                    <tr class="hover-elevate-up transition-3ms">
                                                        <td class="ps-4">
                                                            <div class="d-flex flex-column">
                                                                <span class="text-gray-800 fw-bold fs-7">@item.EmployeeName</span>
                                                                <span class="text-muted fs-8">@item.EmployeeCode</span>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <span class="text-gray-700 fw-semibold fs-7 text-nowrap">@FormatService.FormatDate(item.Date)</span>
                                                        </td>
                                                        <td class="text-center">
                                                            @if (item.CheckIn.HasValue)
                                                            {
                                                                <span class="badge badge-light-success fs-7 fw-bold px-3 py-2 border border-success border-dashed">@FormatService.FormatTime(FormatService.ToLocalTime(item.CheckIn))</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge badge-light-secondary fs-8 fw-bold">--:--</span>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            @if (item.CheckOut.HasValue)
                                                            {
                                                                <span class="badge badge-light-info fs-7 fw-bold px-3 py-2 border border-info border-dashed">@FormatService.FormatTime(FormatService.ToLocalTime(item.CheckOut))</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge badge-light-secondary fs-8 fw-bold">--:--</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-column">
                                                                <span class="text-gray-800 fw-bold fs-7">@item.ShiftName</span>
                                                                <span class="text-muted fs-8 fw-semibold text-uppercase text-nowrap">@item.ShiftCode</span>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <div class="d-flex flex-column align-items-center">
                                                                <span class="text-dark fw-bolder fs-7">@FormatService.FormatNumber(item.WorkingHours, 1) h</span>
                                                                @if (item.OvertimeHours > 0)
                                                                {
                                                                    <span class="badge badge-light-primary fs-9 fw-bold mt-1">+@FormatService.FormatNumber(item.OvertimeHours, 1) OT</span>
                                                                }
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            @{
                                                                var statusClass = item.Status switch {
                                                                    "Normal" => "success",
                                                                    "Late" => "warning",
                                                                    "EarlyLeave" => "warning",
                                                                    "Late & Early" => "danger",
                                                                    "Absent" => "danger",
                                                                    "Missing Check-in" => "danger",
                                                                    "Mã NV không hợp lệ" => "danger",
                                                                    _ => "secondary"
                                                                };
                                                                var statusText = item.Status switch {
                                                                    "Normal" => "Bình thường",
                                                                    "Late" => "Đi trễ",
                                                                    "EarlyLeave" => "Về sớm",
                                                                    "Late & Early" => "Trễ & Sớm",
                                                                    "Absent" => "Vắng mặt",
                                                                    "Missing Check-in" => "Thiếu Check-in",
                                                                    "Mã NV không hợp lệ" => "Mã NV lỗi",
                                                                    _ => item.Status
                                                                };
                                                            }
                                                            <span class="badge badge-light-@statusClass fs-8 fw-bold px-3 py-2 rounded-pill">@statusText</span>
                                                        </td>
                                                        <td class="text-end pe-4">
                                                            @if (item.LateMinutes > 0) { <div class="text-warning fs-8 fw-bold"><i class="ki-outline ki-time text-warning fs-9 me-1"></i>Trễ: @item.LateMinutes ph</div> }
                                                            @if (item.EarlyLeaveMinutes > 0) { <div class="text-danger fs-8 fw-bold mt-1"><i class="ki-outline ki-time text-danger fs-9 me-1"></i>Sớm: @item.EarlyLeaveMinutes ph</div> }
                                                            @if (item.LateMinutes == 0 && item.EarlyLeaveMinutes == 0 && item.Status == "Normal") { <span class="badge badge-circle badge-light-success w-20px h-20px"><i class="ki-outline ki-check fs-9 text-success"></i></span> }
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Raw Scans Tab -->
                            <div class="tab-pane fade" id="kt_tab_raw" role="tabpanel">
                                @if (importResult.RawItems.Any())
                                {
                                    <div class="table-responsive border rounded bg-white shadow-sm" style="max-height: 550px; overflow-y: auto;">
                                        <table class="table table-hover table-row-dashed align-middle gs-4 gy-3 mb-0 fs-8">
                                            <thead class="position-sticky top-0 bg-light z-index-2 shadow-sm">
                                                <tr class="fw-bold fs-7 text-gray-800 text-uppercase bg-light">
                                                    @if (importResult.FileHeaders.Any())
                                                    {
                                                        @foreach (var header in importResult.FileHeaders)
                                                        {
                                                            <th class="px-3">@header</th>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <th class="ps-6">Mã Nhân Viên</th>
                                                        <th>Thời Gian Quét</th>
                                                        <th class="text-end pe-6">Nguồn</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var empGroup in importResult.RawItems.GroupBy(r => r.EmployeeCode).OrderBy(g => g.Key))
                                                {
                                                    <tr class="bg-light-info text-info">
                                                        <td colspan="@(importResult.FileHeaders.Any() ? importResult.FileHeaders.Count : 3)" class="fw-bolder py-3 ps-6">
                                                            <i class="ki-outline ki-user text-info me-2 fs-5"></i> Nhân viên: @empGroup.Key (@empGroup.Count() lần quét thẻ)
                                                        </td>
                                                    </tr>
                                                    @foreach (var raw in empGroup.OrderBy(x => x.Timestamp))
                                                    {
                                                        <tr class="hover-elevate-up transition-3ms">
                                                            @if (importResult.FileHeaders.Any())
                                                            {
                                                                @foreach (var header in importResult.FileHeaders)
                                                                {
                                                                    <td class="px-3 text-gray-700">
                                                                        @(raw.RowData != null && raw.RowData.ContainsKey(header) ? raw.RowData[header] : string.Empty)
                                                                    </td>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <td class="ps-10">
                                                                    <span class="badge badge-light-dark fs-7 fw-bold px-3">@raw.EmployeeCode</span>
                                                                </td>
                                                                <td>
                                                                     <div class="d-flex align-items-center">
                                                                         <i class="ki-outline ki-time fs-5 text-gray-500 me-2"></i>
                                                                         <span class="text-gray-800 fw-bold fs-7">@FormatService.FormatDateTime(FormatService.ToLocalTime(raw.Timestamp))</span>
                                                                     </div>
                                                                </td>
                                                                <td class="text-end pe-6 text-muted fs-8">@importSource</td>
                                                            }
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="notice d-flex bg-light-warning rounded border-warning border border-dashed p-6">
                                        <i class="ki-outline ki-information fs-2tx text-warning me-4"></i>
                                        <div class="d-flex flex-stack flex-grow-1">
                                            <div class="fw-semibold">
                                                <h4 class="text-gray-900 fw-bold">Không có dữ liệu thô!</h4>
                                                <div class="fs-6 text-gray-700">Dữ liệu thô không được trích xuất từ định dạng này hoặc tệp trống.</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (currentStep == 4 && importResult != null)
                    {
                        <!-- Step 4: Result -->
                        <div class="text-center py-20">
                            <div class="mb-10 animate__animated animate__bounceIn">
                                <i class="ki-outline ki-check-circle fs-5x text-success mb-5"></i>
                                <h1 class="fw-bold text-dark mb-3">Nhập dữ liệu thành công!</h1>
                                <p class="text-gray-500 fs-5">Hệ thống đã xử lý xong @importResult.SuccessCount bản ghi dữ liệu chấm công.</p>
                            </div>

                            <div class="row g-5 max-w-800px mx-auto mb-10">
                                <div class="col-4">
                                    <div class="bg-light-success px-4 py-8 rounded-2 border border-success border-dashed text-center h-100 shadow-sm transition-3ms hover-elevate-up">
                                        <div class="fs-2hx fw-bold text-success mb-2">@FormatService.FormatNumber(importResult.SuccessCount)</div>
                                        <div class="text-success fw-bold fs-7">Thành công</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="bg-light-danger px-4 py-8 rounded-2 border border-danger border-dashed text-center h-100 shadow-sm transition-3ms hover-elevate-up">
                                        <div class="fs-2hx fw-bold text-danger mb-2">@FormatService.FormatNumber(importResult.FailureCount)</div>
                                        <div class="text-danger fw-bold fs-7">Lỗi dữ liệu</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="bg-light-warning px-4 py-8 rounded-2 border border-warning border-dashed text-center h-100 shadow-sm transition-3ms hover-elevate-up">
                                        <div class="fs-2hx fw-bold text-warning mb-2">@FormatService.FormatNumber(importResult.DuplicateCount)</div>
                                        <div class="text-warning fw-bold fs-7">Đã trùng / Bỏ qua</div>
                                    </div>
                                </div>
                            </div>

                            @if (importResult.Errors.Any())
                            {
                                <div class="text-start max-w-800px mx-auto mb-10">
                                    <h5 class="fw-bold text-danger mb-4">Các lỗi gặp phải:</h5>
                                    <div class="bg-light-danger p-5 rounded max-h-300px scroll-y border border-danger border-dashed text-gray-700">
                                        @foreach (var error in importResult.Errors)
                                        {
                                            <div class="d-flex align-items-center mb-2">
                                                <i class="bullet bullet-dot bg-danger me-2"></i>
                                                <span class="fs-7">@error</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (importResult.RawItems.Any())
                            {
                                <div class="text-start max-w-800px mx-auto mb-10">
                                    <div class="d-flex align-items-center justify-content-between mb-4">
                                        <h5 class="fw-bold text-dark mb-0">Dữ liệu thô đã nhập (@importResult.RawItems.Count bản ghi):</h5>
                                        <button class="btn btn-sm btn-light-info" @onclick="ToggleRawData">
                                            <i class="ki-outline ki-@(showRawData ? "minus" : "plus") fs-4"></i>
                                            @(showRawData ? "Thu gọn" : "Xem chi tiết")
                                        </button>
                                    </div>
                                    @if (showRawData)
                                    {
                                        <div class="table-responsive border rounded bg-white max-h-400px scroll-y animate__animated animate__fadeIn">
                                            <table class="table table-row-dashed table-striped align-middle gs-4 gy-2 mb-0 fs-9">
                                                <thead class="bg-light position-sticky top-0">
                                                    <tr class="fw-bold text-gray-800">
                                                        <th class="ps-4">Mã NV</th>
                                                        <th>Thời gian quét</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var raw in importResult.RawItems.Take(500))
                                                    {
                                                        <tr>
                                                            <td class="ps-4 fw-bold">@raw.EmployeeCode</td>
                                                            <td>@FormatService.FormatDateTime(FormatService.ToLocalTime(raw.Timestamp))</td>
                                                        </tr>
                                                    }
                                                    @if (importResult.RawItems.Count > 500)
                                                    {
                                                        <tr>
                                                            <td colspan="2" class="text-center text-muted py-2 bg-light">... hiển thị 500 bản ghi đầu tiên ...</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="d-flex justify-content-center border-top pt-10">
                                <button class="btn btn-secondary me-4 px-10" @onclick="Reset">Import mới</button>
                                <a href="/attendance/timesheet" class="btn btn-primary px-10">Kiểm tra Bảng công <i class="ki-outline ki-arrow-right fs-3 ms-2"></i></a>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <!-- Recently Imported List -->
            @if (recentlyImported != null)
            {
                <div class="card card-flush shadow-sm mt-8 mt-lg-10">
                    <div class="card-header pt-7">
                        <h3 class="card-title align-items-start flex-column">
                            <span class="card-label fw-bold text-gray-800">Dữ liệu chấm công gần đây</span>
                            <span class="text-muted mt-1 fw-semibold fs-7">Hiển thị các bản ghi chấm công mới cập nhật trên hệ thống</span>
                        </h3>
                        <div class="card-toolbar">
                        <button class="btn btn-sm btn-light-primary fw-bold" @onclick="LoadHistory" disabled="@_isLoadingHistory">
                            @if (_isLoadingHistory) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            <i class="ki-outline ki-arrows-circle fs-4 me-1"></i> Làm mới
                        </button>
                    </div>
                </div>
                <div class="card-body pt-3">
                    <div class="table-responsive border-bottom custom-scrollbar" style="max-height: 600px; overflow-y: auto;">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                            <thead>
                                <tr class="fw-bold text-muted fs-7 text-uppercase border-bottom-0 bg-light">
                                    <th class="ps-4 min-w-150px rounded-start">Nhân viên</th>
                                    <th class="min-w-100px">Ngày</th>
                                    <th class="min-w-80px text-center">Check-In</th>
                                    <th class="min-w-80px text-center">Check-Out</th>
                                    <th class="min-w-80px text-center">Công/OT</th>
                                    <th class="min-w-100px text-center">Trạng thái</th>
                                    <th class="min-w-100px text-end pe-4 rounded-end">Số phút trễ/sớm</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_isLoadingHistory)
                                {
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <tr>
                                            <td class="ps-4"><div class="d-flex align-items-center"><div class="symbol symbol-40px symbol-circle me-3 bg-gray-200 animate-pulse"></div><div class="flex-grow-1"><div class="h-10px w-100px bg-gray-200 rounded animate-pulse mb-2"></div><div class="h-8px w-60px bg-gray-100 rounded animate-pulse"></div></div></div></td>
                                            <td><div class="h-10px w-80px bg-gray-100 rounded animate-pulse"></div></td>
                                            <td class="text-center"><div class="h-20px w-50px bg-gray-100 rounded animate-pulse mx-auto"></div></td>
                                            <td class="text-center"><div class="h-20px w-50px bg-gray-100 rounded animate-pulse mx-auto"></div></td>
                                            <td class="text-center"><div class="h-10px w-60px bg-gray-100 rounded animate-pulse mx-auto"></div></td>
                                            <td class="text-end pe-4"><div class="h-20px w-70px bg-gray-100 rounded animate-pulse ms-auto"></div></td>
                                        </tr>
                                    }
                                }
                                else if (recentlyImported.Any())
                                {
                                    @foreach (var item in recentlyImported)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-40px symbol-circle me-3">
                                                        @if (!string.IsNullOrEmpty(item.Avatar))
                                                        {
                                                            <img src="@item.Avatar" alt="" />
                                                        }
                                                        else
                                                        {
                                                            <div class="symbol-label bg-light-primary text-primary fw-bold">@(item.EmployeeName?.Length > 0 ? item.EmployeeName.Substring(0, 1) : "A")</div>
                                                        }
                                                    </div>
                                                    <div class="d-flex justify-content-start flex-column">
                                                        <span class="text-gray-900 fw-bold text-hover-primary fs-6">@item.EmployeeName</span>
                                                        <span class="text-muted fw-semibold fs-7">@item.EmployeeId</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="text-gray-800 fw-bold fs-7">@FormatService.FormatDate(item.Date)</span>
                                            </td>
                                            <td class="text-center">
                                                @if (item.CheckIn.HasValue)
                                                {
                                                    <span class="badge badge-light-success fw-bold">@FormatService.FormatTime(FormatService.ToLocalTime(item.CheckIn))</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">--:--</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (item.CheckOut.HasValue)
                                                {
                                                    <span class="badge badge-light-info fw-bold">@FormatService.FormatTime(FormatService.ToLocalTime(item.CheckOut))</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">--:--</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex flex-column">
                                                     <span class="text-gray-800 fw-bold fs-7">@FormatService.FormatNumber(item.TotalWorkingHours, 1) h</span>
                                                     @if (item.OvertimeHours > 0)
                                                     {
                                                         <span class="text-primary fw-bold fs-8">+@FormatService.FormatNumber(item.OvertimeHours, 1) OT</span>
                                                     }
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                @{
                                                    var histStatusClass = item.Status switch {
                                                        "Normal" or "Bình thường" => "success",
                                                        "Late" or "Đi trễ" => "warning",
                                                        "EarlyLeave" or "Về sớm" => "warning",
                                                        "Late & Early" or "Trễ & Sớm" => "danger",
                                                        "Absent" or "Vắng mặt" => "danger",
                                                        "Missing Check-in" or "Thiếu Check-in" => "danger",
                                                        _ => "primary"
                                                    };
                                                    var histStatusText = item.Status switch {
                                                        "Normal" => "Bình thường",
                                                        "Late" => "Đi trễ",
                                                        "EarlyLeave" => "Về sớm",
                                                        "Late & Early" => "Trễ & Sớm",
                                                        "Absent" => "Vắng mặt",
                                                        "Missing Check-in" => "Thiếu Check-in",
                                                        _ => item.Status
                                                    };
                                                }
                                                <span class="badge badge-light-@histStatusClass fs-8 fw-bold">@histStatusText</span>
                                            </td>
                                            <td class="text-end pe-4">
                                                @if (item.LateMinutes > 0)
                                                {
                                                    <div class="text-warning fs-8 fw-bold">Trễ: @item.LateMinutes ph</div>
                                                }
                                                @if (item.EarlyLeaveMinutes > 0)
                                                {
                                                    <div class="text-danger fs-8 fw-bold mt-1">Sớm: @item.EarlyLeaveMinutes ph</div>
                                                }
                                                @if (item.LateMinutes == 0 && item.EarlyLeaveMinutes == 0)
                                                {
                                                    <i class="ki-outline ki-check text-success fs-3"></i>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-10">
                                            <div class="text-muted fs-6">Chưa có dữ liệu chấm công nào được hiển thị. Vui lòng thực hiện Import hoặc nhấn Làm mới.</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            }
        </div>
    </div>
</div>

<style>
    .transition-3ms {
        transition: all 0.3s ease;
    }
    .hover-elevate-up:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.08);
        z-index: 1;
    }
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #bbb;
    }
    .dropzone-active {
        border-style: solid !important;
        border-width: 2px !important;
        background-color: var(--bs-light-primary) !important;
        box-shadow: inset 0 0 10px rgba(var(--bs-primary-rgb), 0.1);
        transform: scale(1.02);
    }
</style>

