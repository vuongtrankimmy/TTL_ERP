@page "/attendance/import"
@inherits AttendanceImportBase

<PageTitle>Import Dữ liệu Chấm công - TTL ERP</PageTitle>

<div class="d-flex flex-column flex-column-fluid">
    <!-- Toolbar -->
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">
                    Import Dữ liệu Chấm công
                </h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
                    </li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-400 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-muted">Chấm công</li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-400 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-dark">Import dữ liệu</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-xxl">
            
            <!-- Stepper Header -->
            <div class="card mb-5">
                <div class="card-body py-10">
                    <div class="stepper stepper-pills stepper-column d-flex flex-column flex-xl-row flex-row-fluid" id="kt_stepper_example_basic">
                        <div class="stepper-nav d-flex flex-row justify-content-between w-100 flex-wrap">
                            <div class="stepper-item me-5 @(currentStep == 1 ? "current" : (currentStep > 1 ? "completed" : ""))" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">1</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Tải tệp</h3>
                                        <div class="stepper-desc">Chọn file Excel</div>
                                    </div>
                                </div>
                            </div>
                            <div class="stepper-item me-5 @(currentStep == 2 ? "current" : (currentStep > 2 ? "completed" : ""))" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">2</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Mapping</h3>
                                        <div class="stepper-desc">Ánh xạ cột dữ liệu</div>
                                    </div>
                                </div>
                            </div>
                            <div class="stepper-item me-5 @(currentStep == 3 ? "current" : (currentStep > 3 ? "completed" : ""))" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">3</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Preview</h3>
                                        <div class="stepper-desc">Kiểm tra kết quả</div>
                                    </div>
                                </div>
                            </div>
                            <div class="stepper-item @(currentStep == 4 ? "current" : "")" data-kt-stepper-element="nav">
                                <div class="stepper-wrapper d-flex align-items-center">
                                    <div class="stepper-icon w-40px h-40px">
                                        <i class="stepper-check ki-outline ki-check fs-2"></i>
                                        <span class="stepper-number">4</span>
                                    </div>
                                    <div class="stepper-label">
                                        <h3 class="stepper-title">Hoàn tất</h3>
                                        <div class="stepper-desc">Lưu và xem báo cáo</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-flush">
                <div class="card-body">
                    @if (currentStep == 1)
                    {
                        <!-- Step 1: Upload -->
                        <div class="row g-10">
                            <div class="col-xl-6 border-end">
                                <h3 class="fw-bold text-dark mb-7">1. Chọn nguồn & Tải tệp</h3>
                                
                                <div class="mb-10">
                                    <label class="form-label fw-bold">Nguồn dữ liệu:</label>
                                    <div class="nav-group nav-group-outline" data-kt-buttons="true">
                                        <button class="btn btn-outline btn-outline-dashed btn-active-light-primary px-6 py-3 me-2 @(importSource == "Fingerprint" ? "active" : "")" @onclick='() => SetSource("Fingerprint")'>
                                            <i class="ki-outline ki-fingerprint fs-2 me-1"></i>Máy vân tay
                                        </button>
                                        <button class="btn btn-outline btn-outline-dashed btn-active-light-primary px-6 py-3 @(importSource == "QR" ? "active" : "")" @onclick='() => SetSource("QR")'>
                                            <i class="ki-outline ki-scan-barcode fs-2 me-1"></i>QR Checkin
                                        </button>
                                    </div>
                                </div>

                                <div class="mb-10">
                                    <label class="form-label fw-bold">Tải tệp dữ liệu:</label>
                                    <div class="fv-row">
                                        <div class="dropzone d-flex align-items-center justify-content-center p-10 border-dashed rounded" style="background: #f8f9fa; position: relative;">
                                            <div class="text-center">
                                                <i class="ki-outline ki-file-up fs-3x text-primary mb-3"></i>
                                                <div class="fs-6 fw-bold text-gray-700">Kéo thả tệp hoặc click để chọn</div>
                                                <span class="text-muted fs-7">Hỗ trợ .xlsx, .xls, .csv, .txt, .json (Max 10MB)</span>
                                                <InputFile OnChange="@OnInputFileChange" class="position-absolute opacity-0 w-100 h-100 top-0 start-0 cursor-pointer" accept=".xlsx,.xls,.csv,.txt,.json" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="separator separator-dashed my-8"></div>

                                <div class="mb-5">
                                    <label class="form-label fw-bold">Hoặc dán văn bản thô:</label>
                                    <textarea class="form-control form-control-solid" rows="6" placeholder="NV001, 2024-02-21 08:00&#10;NV002, 2024-02-21 08:05" @bind="rawData"></textarea>
                                </div>
                                <div class="d-flex justify-content-end">
                                    <button class="btn btn-primary px-10 py-3" @onclick="GoToPreview" disabled="@(string.IsNullOrEmpty(rawData))">
                                        Tiếp tục với dữ liệu thô <i class="ki-outline ki-arrow-right fs-3 ms-2"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-xl-6">
                                <h3 class="fw-bold text-dark mb-7">Hướng dẫn & Lưu ý</h3>
                                <div class="bg-light-info p-5 rounded d-flex mb-7 border border-info border-dashed">
                                    <i class="ki-outline ki-information-5 fs-1 text-info me-4"></i>
                                    <div class="text-dark fw-semibold">Hệ thống tự động lọc bản ghi sớm nhất làm Check-in và muộn nhất làm Check-out trong cùng một ngày làm việc.</div>
                                </div>
                                <div class="mb-5">
                                    <h4 class="fs-6 fw-bold mb-3 text-gray-700">Mẫu định dạng chuẩn (Excel/CSV):</h4>
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-striped text-center">
                                            <thead>
                                                <tr class="fw-bold fs-7 bg-light">
                                                    <th>Cột A (Mã NV)</th>
                                                    <th>Cột B (Thời gian)</th>
                                                </tr>
                                            </thead>
                                            <tbody class="fs-7">
                                                <tr><td>GD-001</td><td>2026-02-21 08:00:15</td></tr>
                                                <tr><td>GD-001</td><td>2026-02-21 17:05:40</td></tr>
                                                <tr><td>NV-102</td><td>2026-02-21 07:55:00</td></tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="mb-5">
                                    <h4 class="fs-6 fw-bold mb-3 text-gray-700">TXT & JSON:</h4>
                                    <ul class="fs-7 text-muted lh-lg">
                                        <li><strong>TXT:</strong> Phân tách bởi dấu phẩy, Tab hoặc dấu chấm phẩy. KhÔNG có tiêu đề. Ví dụ: <br><code>GD-001, 2026-02-21 08:00</code></li>
                                        <li><strong>JSON:</strong> Mảng các đối tượng: <br><code>[{"EmployeeCode": "NV001", "Timestamp": "2026-02-21 08:00:15"}]</code></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                    else if (currentStep == 2)
                    {
                        <!-- Step 2: Mapping -->
                        <div class="max-w-600px mx-auto my-10 text-center">
                            <i class="ki-outline ki-setting-2 fs-4x text-primary mb-5"></i>
                            <h2 class="fw-bold text-dark mb-2">Ánh xạ cột dữ liệu</h2>
                            <p class="text-gray-500 mb-10">Chọn cột tương ứng trong tệp Excel của bạn để hệ thống có thể đọc đúng dữ liệu.</p>

                            <div class="text-start bg-light p-8 rounded border mb-10">
                                <div class="mb-7">
                                    <label class="form-label fw-bold fs-6">1. Cột chứa Mã Nhân viên:</label>
                                    <select class="form-select form-select-solid" @bind="employeeCodeColIndex">
                                        @for (int i = 0; i < fileHeaders.Count; i++)
                                        {
                                            <option value="@(i + 1)">Cột @(i + 1): @fileHeaders[i]</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold fs-6">2. Cột chứa Thời gian quét (DateTime):</label>
                                    <select class="form-select form-select-solid" @bind="timestampColIndex">
                                        @for (int i = 0; i < fileHeaders.Count; i++)
                                        {
                                            <option value="@(i + 1)">Cột @(i + 1): @fileHeaders[i]</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between">
                                <button class="btn btn-light px-10 py-3" @onclick="Reset">Hủy bỏ</button>
                                <button class="btn btn-primary px-10 py-3" @onclick="GoToPreview" disabled="@_isProcessing">
                                    @if (_isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Xem trước dữ liệu <i class="ki-outline ki-arrow-right fs-3 ms-2"></i>
                                </button>
                            </div>
                        </div>
                    }
                    else if (currentStep == 3 && importResult != null)
                    {
                        <!-- Step 3: Preview -->
                        <div class="d-flex flex-stack mb-7">
                            <div class="d-flex flex-column">
                                <h3 class="fw-bold text-dark">Xem trước dữ liệu (@importResult.SuccessCount bản ghi)</h3>
                                <p class="text-gray-500 pb-0 mb-0">Hệ thống đã phân tích dữ liệu, vui lòng kiểm tra trước khi nhấn Lưu.</p>
                            </div>
                            <div class="d-flex">
                                <button class="btn btn-light me-3" @onclick="() => currentStep = 2"><i class="ki-outline ki-setting-3 fs-3 me-1"></i>Sửa mapping</button>
                                <button class="btn btn-success" @onclick="ConfirmImport" disabled="@_isProcessing">
                                    @if (_isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    <i class="ki-outline ki-disk fs-3 me-1"></i>Lưu vào Database
                                </button>
                            </div>
                        </div>

                        <div class="table-responsive border rounded">
                            <table class="table table-hover table-row-dashed align-middle gs-4 gy-4">
                                <thead>
                                    <tr class="fw-bold fs-6 text-gray-800 bg-light">
                                        <th>Nhân viên</th>
                                        <th>Ngày</th>
                                        <th>Check-In</th>
                                        <th>Check-Out</th>
                                        <th>Ca làm</th>
                                        <th>Trạng thái</th>
                                        <th class="text-center">Số phút</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in importResult.PreviewItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="d-flex flex-column">
                                                        <span class="text-dark fw-bold text-hover-primary mb-1 fs-6">@item.EmployeeName</span>
                                                        <span class="text-muted fw-semibold fs-7">#@item.EmployeeCode</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <span class="badge badge-light-success fs-7 fw-bold">@(item.CheckIn?.ToString("HH:mm") ?? "-")</span>
                                            </td>
                                            <td>
                                                <span class="badge badge-light-info fs-7 fw-bold">@(item.CheckOut?.ToString("HH:mm") ?? "-")</span>
                                            </td>
                                            <td>
                                                <span class="text-gray-700 fw-semibold fs-7">@item.ShiftName</span>
                                            </td>
                                            <td>
                                                @{
                                                    var statusClass = item.Status switch {
                                                        "Normal" => "success",
                                                        "Late" => "warning",
                                                        "EarlyLeave" => "warning",
                                                        "Absent" => "danger",
                                                        _ => "primary"
                                                    };
                                                    var statusText = item.Status switch {
                                                        "Normal" => "Bình thường",
                                                        "Late" => "Đi trễ",
                                                        "EarlyLeave" => "Về sớm",
                                                        "Absent" => "Vắng mặt",
                                                        _ => item.Status
                                                    };
                                                }
                                                <span class="badge badge-light-@statusClass fs-8 fw-bold">@statusText</span>
                                            </td>
                                            <td class="text-center">
                                                @if (item.LateMinutes > 0) { <span class="text-warning fs-8 fw-bold">Trễ: @item.LateMinutes ph</span> }
                                                @if (item.EarlyLeaveMinutes > 0) { <div class="text-danger fs-8 fw-bold">Sớm: @item.EarlyLeaveMinutes ph</div> }
                                                @if (item.LateMinutes == 0 && item.EarlyLeaveMinutes == 0) { <i class="ki-outline ki-check text-success fs-3"></i> }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (currentStep == 4 && importResult != null)
                    {
                        <!-- Step 4: Result -->
                        <div class="text-center py-20">
                            <div class="mb-10">
                                <i class="ki-outline ki-check-circle fs-5x text-success mb-5"></i>
                                <h1 class="fw-bold text-dark mb-3">Nhập dữ liệu thành công!</h1>
                                <p class="text-gray-500 fs-5">Hệ thống đã xử lý xong @importResult.SuccessCount bản ghi dữ liệu chấm công.</p>
                            </div>

                            <div class="row g-5 max-w-600px mx-auto mb-10">
                                <div class="col-6">
                                    <div class="bg-light-success px-6 py-8 rounded-2 border border-success border-dashed">
                                        <div class="fs-2hx fw-bold text-success mb-2">@importResult.SuccessCount</div>
                                        <div class="text-success fw-bold fs-6">Thành công</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light-danger px-6 py-8 rounded-2 border border-danger border-dashed">
                                        <div class="fs-2hx fw-bold text-danger mb-2">@importResult.FailureCount</div>
                                        <div class="text-danger fw-bold fs-6">Thất bại</div>
                                    </div>
                                </div>
                            </div>

                            @if (importResult.Errors.Any())
                            {
                                <div class="text-start max-w-800px mx-auto mb-10">
                                    <h5 class="fw-bold text-danger mb-4">Các lỗi gặp phải:</h5>
                                    <div class="bg-light-danger p-5 rounded max-h-300px scroll-y">
                                        @foreach (var error in importResult.Errors)
                                        {
                                            <div class="d-flex align-items-center mb-2">
                                                <i class="bullet bullet-dot bg-danger me-2"></i>
                                                <span class="text-gray-700 fs-7">@error</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="d-flex justify-content-center">
                                <button class="btn btn-light me-4 px-10" @onclick="Reset">Import mới</button>
                                <a href="/attendance/timesheet" class="btn btn-primary px-10">Kiểm tra Bảng công</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <!-- Recently Imported List -->
            <div class="card card-flush shadow-sm mt-8 mt-lg-10">
                <div class="card-header pt-7">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold text-gray-800">Dữ liệu đã import hôm nay</span>
                        <span class="text-muted mt-1 fw-semibold fs-7">Hiển thị các bản ghi chấm công được cập nhật trong ngày</span>
                    </h3>
                    <div class="card-toolbar">
                        <button class="btn btn-sm btn-light-primary fw-bold" @onclick="LoadHistory" disabled="@_isLoadingHistory">
                            @if (_isLoadingHistory) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            <i class="ki-outline ki-arrows-circle fs-4 me-1"></i> Làm mới
                        </button>
                    </div>
                </div>
                <div class="card-body pt-3">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                            <thead>
                                <tr class="fw-bold text-muted fs-7 text-uppercase border-bottom-0 bg-light">
                                    <th class="ps-4 min-w-150px rounded-start">Nhân viên</th>
                                    <th class="min-w-125px">Thời gian</th>
                                    <th class="min-w-125px text-center">Check-In</th>
                                    <th class="min-w-125px text-center">Check-Out</th>
                                    <th class="min-w-125px text-center">Ca làm</th>
                                    <th class="min-w-100px text-end pe-4 rounded-end">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_isLoadingHistory)
                                {
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <tr>
                                            <td class="ps-4"><div class="d-flex align-items-center"><div class="symbol symbol-40px symbol-circle me-3 bg-gray-200 animate-pulse"></div><div class="flex-grow-1"><div class="h-10px w-100px bg-gray-200 rounded animate-pulse mb-2"></div><div class="h-8px w-60px bg-gray-100 rounded animate-pulse"></div></div></div></td>
                                            <td><div class="h-10px w-80px bg-gray-100 rounded animate-pulse"></div></td>
                                            <td class="text-center"><div class="h-20px w-50px bg-gray-100 rounded animate-pulse mx-auto"></div></td>
                                            <td class="text-center"><div class="h-20px w-50px bg-gray-100 rounded animate-pulse mx-auto"></div></td>
                                            <td class="text-center"><div class="h-10px w-60px bg-gray-100 rounded animate-pulse mx-auto"></div></td>
                                            <td class="text-end pe-4"><div class="h-20px w-70px bg-gray-100 rounded animate-pulse ms-auto"></div></td>
                                        </tr>
                                    }
                                }
                                else if (recentlyImported.Any())
                                {
                                    @foreach (var item in recentlyImported)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-40px symbol-circle me-3">
                                                        @if (!string.IsNullOrEmpty(item.Avatar))
                                                        {
                                                            <img src="@item.Avatar" alt="" />
                                                        }
                                                        else
                                                        {
                                                            <div class="symbol-label bg-light-primary text-primary fw-bold">@item.EmployeeName.Substring(0, 1)</div>
                                                        }
                                                    </div>
                                                    <div class="d-flex justify-content-start flex-column">
                                                        <span class="text-gray-900 fw-bold text-hover-primary fs-6">@item.EmployeeName</span>
                                                        <span class="text-muted fw-semibold fs-7">@item.EmployeeId</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="text-gray-800 fw-bold fs-7">@item.Date.ToString("dd/MM/yyyy")</span>
                                            </td>
                                            <td class="text-center">
                                                @if (item.CheckIn.HasValue)
                                                {
                                                    <span class="badge badge-light-success fw-bold">@item.CheckIn.Value.ToString("HH:mm")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">--:--</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (item.CheckOut.HasValue)
                                                {
                                                    <span class="badge badge-light-info fw-bold">@item.CheckOut.Value.ToString("HH:mm")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">--:--</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @{
                                                    var histStatusClass = item.Status switch {
                                                        "Normal" or "Bình thường" => "success",
                                                        "Late" or "Đi trễ" => "warning",
                                                        "EarlyLeave" or "Về sớm" => "warning",
                                                        "Absent" or "Vắng mặt" => "danger",
                                                        _ => "primary"
                                                    };
                                                    var histStatusText = item.Status switch {
                                                        "Normal" => "Bình thường",
                                                        "Late" => "Đi trễ",
                                                        "EarlyLeave" => "Về sớm",
                                                        "Absent" => "Vắng mặt",
                                                        _ => item.Status
                                                    };
                                                }
                                                <span class="badge badge-light-@histStatusClass fs-8 fw-bold">@histStatusText</span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <span class="badge badge-light-primary fs-8 fw-bold">Máy vân tay</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-10">
                                            <div class="text-muted fs-6">Chưa có dữ liệu nào được import trong ngày hôm nay.</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

