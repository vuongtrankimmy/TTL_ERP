@page "/attendance/shift-approval"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
	<div id="kt_content_container" class="container-fluid">
		<!-- Tabs -->
		<div class="d-flex flex-stack flex-wrap mb-6">
			<ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bolder">
				<li class="nav-item">
					<a class="nav-link text-active-primary py-4 me-10 @(activeTab == 0 ? "active" : "")" href="#" @onclick="() => SetTab(0)" @onclick:preventDefault>
						Chờ duyệt <span class="badge badge-circle badge-light-danger ms-2 w-20px h-20px fs-9">@_requests.Count(x => x.IsPending)</span>
					</a>
				</li>
				<li class="nav-item">
                    <a class="nav-link text-active-primary py-4 me-10 @(activeTab == 1 ? "active" : "")" href="#" @onclick="() => SetTab(1)" @onclick:preventDefault>
                        Đã duyệt <span class="badge badge-circle badge-light-success ms-2 w-20px h-20px fs-9">@_requests.Count(x => x.Status == "Đã duyệt")</span>
                    </a>
                </li>
				<li class="nav-item">
                    <a class="nav-link text-active-primary py-4 @(activeTab == 2 ? "active" : "")" href="#" @onclick="() => SetTab(2)" @onclick:preventDefault>
                        Từ chối <span class="badge badge-circle badge-light-danger ms-2 w-20px h-20px fs-9">@_requests.Count(x => x.Status == "Từ chối")</span>
                    </a>
                </li>
			</ul>
		</div>

		<!-- Filters -->
		<div class="card mb-8 shadow-sm">
			<div class="card-body py-4 px-6">
				<div class="d-flex flex-wrap align-items-center">
					<!-- Search -->
					<div class="position-relative w-md-250px me-4 my-1">
						<span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
								<path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"></path>
							</svg>
						</span>
						<input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm theo tên, mã NV..." />
					</div>

					<!-- Department -->
					<div class="w-md-200px me-4 my-1">
						<select class="form-select form-select-solid fs-7 fw-bold">
							<option>Phòng ban: Tất cả</option>
							<option>Kỹ thuật</option>
							<option>Kinh doanh</option>
						</select>
					</div>

					<!-- Shift Type -->
					<div class="w-md-200px me-4 my-1">
						<select class="form-select form-select-solid fs-7 fw-bold">
							<option>Loại ca: Tất cả</option>
							<option>Ca sáng</option>
							<option>Ca chiều</option>
							<option>Ca tối</option>
						</select>
					</div>

					<!-- More Filters -->
					<div class="ms-auto my-1">
						<button class="btn btn-light-primary fw-bold fs-7 px-6"><i class="bi bi-funnel me-1"></i>Lọc thêm</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Selection Bar -->
		<div class="d-flex flex-stack mb-6">
			<div class="d-flex align-items-center">
				<div class="form-check form-check-sm form-check-custom form-check-solid me-5">
					<input class="form-check-input" type="checkbox" id="check_all_requests" />
					<label class="form-check-label fw-bold text-gray-700 fs-7 ms-2 text-nowrap" for="check_all_requests">Chọn tất cả (12 yêu cầu)</label>
				</div>
			</div>
			<div class="d-flex align-items-center gap-3 text-end justify-content-end">
				<button class="btn btn-sm btn-light border border-gray-300 px-3 py-2 fs-8 fw-semibold"><i class="bi bi-download fs-6 me-1"></i>Xuất báo cáo</button>
				<button class="btn btn-sm btn-primary px-4 py-2 fs-8 fw-semibold"><i class="bi bi-check-all fs-7 me-1"></i>Duyệt nhanh</button>
			</div>
		</div>

		<!-- Table -->
		<div class="card shadow-sm border-0">
			<div class="card-body p-0">
				<SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="8" Columns="8">
					<div class="table-responsive">
						<table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5">
							<thead>
								<tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
									<th class="w-10px pe-2"></th>
									<th class="min-w-200px">NHÂN VIÊN</th>
									<th class="min-w-120px text-center">CA HIỆN TẠI</th>
									<th class="min-w-120px text-center">CA MUỐN ĐỔI</th>
									<th class="min-w-200px">LÝ DO</th>
									<th class="min-w-120px">NGÀY ÁP DỤNG</th>
									<th class="min-w-150px text-center">TRẠNG THÁI</th>
									<th class="min-w-150px text-end">THAO TÁC</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var item in FilteredRequests)
								{
									<tr class="hover-elevate cursor-pointer">
										<td>
											<div class="form-check form-check-sm form-check-custom form-check-solid">
												<input class="form-check-input" type="checkbox" value="@item.Id" />
											</div>
										</td>
										<td>
											<div class="d-flex align-items-center">
												<div class="symbol symbol-40px symbol-circle me-4">
													@if (!string.IsNullOrEmpty(item.Avatar))
													{
														<img src="@item.Avatar" alt="" />
													}
													else
													{
														<span class="symbol-label bg-light-danger text-danger fs-6 fw-bolder">@item.EmployeeName.Substring(0, 1)</span>
													}
												</div>
												<div class="d-flex justify-content-start flex-column">
													<span class="text-dark fw-bolder fs-6 cursor-pointer text-hover-primary" @onclick="() => OpenDetail(item)">@item.EmployeeName</span>
													<span class="text-muted fw-bold fs-7">@item.EmployeeId • @item.Department</span>
												</div>
											</div>
										</td>
										<td class="text-center">
											<span class="badge @item.CurrentShiftClass fw-bold px-3 py-1">@item.CurrentShift</span>
										</td>
										<td class="text-center">
											<span class="badge @item.TargetShiftClass fw-bold px-3 py-1">@item.TargetShift</span>
										</td>
										<td>
											<span class="text-gray-600 fs-7" data-bs-toggle="tooltip" title="@item.Reason">
												@(item.Reason.Length > 30 ? item.Reason.Substring(0, 30) + "..." : item.Reason)
											</span>
										</td>
										<td><span class="text-gray-800 fw-bold fs-7">@item.RequestedDate.ToString("dd/MM/yyyy")</span></td>
										<td class="text-center">
											@{
												var statusClass = item.Status switch {
													"Approved" or "Đã duyệt" => "badge-light-success",
													"Rejected" or "Từ chối" => "badge-light-danger",
													_ => "badge-light-warning"
												};
											}
											<span class="badge @statusClass fw-bold px-4 py-2 rounded-pill d-inline-flex align-items-center">
												@if (item.IsPending)
												{
													<span class="bullet bullet-dot bg-warning w-6px h-6px me-2 pulse pulse-warning"></span>
												}
												@item.Status
											</span>
										</td>
										<td class="text-end">
											@if (item.IsPending)
											{
												<button class="btn btn-icon btn-sm btn-light-success me-2" title="Duyệt" @onclick="() => ApproveRequest(item)"><i class="bi bi-check-lg fs-5"></i></button>
												<button class="btn btn-icon btn-sm btn-light-danger me-2" title="Từ chối" @onclick="() => RejectRequest(item)"><i class="bi bi-x-lg fs-5"></i></button>
											}
											<button class="btn btn-icon btn-sm btn-light-primary border border-primary border-opacity-10" title="Chi tiết" @onclick="() => OpenDetail(item)">
												<i class="bi bi-eye-fill fs-6"></i>
											</button>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
					<!-- Pagination -->
					<div class="d-flex flex-stack flex-wrap px-7 py-5 border-top">
						<div class="fs-7 fw-bold text-gray-700">Hiển thị 1-4 trên tổng số 12 yêu cầu</div>
						<ul class="pagination">
							<li class="page-item previous disabled"><a href="#" class="page-link">Trước</a></li>
							<li class="page-item active"><a href="#" class="page-link">1</a></li>
							<li class="page-item next"><a href="#" class="page-link">Sau</a></li>
						</ul>
					</div>
				</SkeletonLoading>
			</div>
		</div>
	</div>
</div>

<!-- Drawer for Detail -->
<div class="bg-body drawer drawer-end @(_showDetail ? "drawer-on" : "")" style="width: 500px; max-width: 90vw; transition: transform 0.3s ease-in-out; position: fixed; top: 0; right: 0; bottom: 0; z-index: 105; transform: translateX(@(_showDetail ? "0" : "100%")); box-shadow: -5px 0 15px rgba(0,0,0,0.1); overflow-y: auto;">
	@if (_selectedRequest != null)
	{
		<div class="card w-100 rounded-0 border-0">
			<div class="card-header pe-5 border-0 pt-5">
				<div class="card-title">
					<div class="d-flex justify-content-center flex-column me-3">
						<a href="#" class="fs-4 fw-bold text-gray-900 text-hover-primary me-1 mb-2 lh-1 text-uppercase">Chi tiết đổi ca</a>
						<div class="mb-0 fs-7 fw-semibold text-muted">Mã yêu cầu: #SR-@(202300 + _selectedRequest.Id)</div>
					</div>
				</div>
				<div class="card-toolbar">
					<button class="btn btn-sm btn-icon btn-active-light-primary bg-light" @onclick="CloseDetail"><i class="ki-outline ki-cross fs-2"></i></button>
				</div>
			</div>
			<div class="card-body">
				<!-- User Info -->
				<div class="d-flex align-items-center mb-7">
					<div class="symbol symbol-60px symbol-circle me-5">
						@if (!string.IsNullOrEmpty(_selectedRequest.Avatar))
						{
							<img src="@_selectedRequest.Avatar" alt="@_selectedRequest.EmployeeName" />
						}
						else
						{
							<span class="symbol-label bg-light-info text-info fs-2 fw-bold">@_selectedRequest.EmployeeName.Substring(0, 1)</span>
						}
					</div>
					<div class="flex-grow-1">
						<a href="#" class="text-gray-900 fw-bold text-hover-primary fs-5">@_selectedRequest.EmployeeName</a>
						<span class="text-muted d-block fw-semibold">@_selectedRequest.EmployeeId • @_selectedRequest.Department</span>
					</div>
				</div>

				<!-- Shift Details -->
				<div class="row mb-7">
					<div class="col-6">
						<div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
							<div class="fs-7 text-muted fw-bold">Ca hiện tại</div>
							<div class="fs-5 fw-bolder text-gray-800 mt-1">@_selectedRequest.CurrentShift</div>
						</div>
					</div>
					<div class="col-6">
						<div class="border border-gray-300 border-dashed rounded py-3 px-4 mb-3">
							<div class="fs-7 text-muted fw-bold">Ca muốn đổi</div>
							<div class="fs-5 fw-bolder text-primary mt-1">@_selectedRequest.TargetShift</div>
						</div>
					</div>
				</div>

				<!-- Info Grid -->
				<div class="mb-5">
					<label class="fw-bold text-gray-700 mb-1">Ngày áp dụng</label>
					<div class="fw-bold fs-6 text-gray-900 border-bottom pb-2">@_selectedRequest.RequestedDate.ToString("dd/MM/yyyy")</div>
				</div>

				<div class="mb-5">
					<label class="fw-bold text-gray-700 mb-1">Lý do</label>
					<div class="fw-semibold fs-6 text-gray-800 border p-3 rounded bg-light">
						@_selectedRequest.Reason
					</div>
				</div>

				<div class="mb-5">
					<label class="fw-bold text-gray-700 mb-1">Trạng thái hiện tại</label>
					<div>
						@{
							var statusClassDetail = _selectedRequest.Status switch {
								"Approved" or "Đã duyệt" => "badge-light-success",
								"Rejected" or "Từ chối" => "badge-light-danger",
								_ => "badge-light-warning"
							};
						}
						<span class="badge @statusClassDetail fw-bold px-4 py-2 fs-7">
							@if (_selectedRequest.IsPending)
							{
								<span class="bullet bullet-dot bg-warning w-6px h-6px me-2 pulse pulse-warning"></span>
							}
							@_selectedRequest.Status
						</span>
					</div>
				</div>

				<!-- Timeline / History (Mock) -->
				<div class="separator separator-dashed my-5"></div>
				<div class="mb-0">
					<h5 class="mb-4">Lịch sử phê duyệt</h5>
					<div class="timeline-label">
						<div class="timeline-item">
							<div class="timeline-label fw-bold text-gray-800 fs-6">@_selectedRequest.RequestedDate.ToString("HH:mm dd/MM")</div>
							<div class="timeline-badge"><i class="fa fa-genderless text-primary fs-1"></i></div>
							<div class="timeline-content text-muted ps-3">
								<span class="fw-bold text-gray-800">@_selectedRequest.EmployeeName</span> gửi yêu cầu mới
							</div>
						</div>
						@if (!_selectedRequest.IsPending)
						{
							<div class="timeline-item">
								<div class="timeline-label fw-bold text-gray-800 fs-6">Thành công</div>
								<div class="timeline-badge"><i class="fa fa-genderless text-success fs-1"></i></div>
								<div class="timeline-content text-muted ps-3">
									Quản lý đã @_selectedRequest.Status.ToLower()
									<div class="text-gray-600 mt-1 fs-7">Ghi chú: @(string.IsNullOrEmpty(_selectedRequest.ManagerNote) ? "Đã kiểm tra lịch làm việc." : _selectedRequest.ManagerNote)</div>
								</div>
							</div>
						}
						else
						{
							<div class="timeline-item">
								<div class="timeline-label fw-bold text-gray-800 fs-6">...</div>
								<div class="timeline-badge"><i class="fa fa-genderless text-warning fs-1"></i></div>
								<div class="timeline-content text-muted ps-3">
									Đang chờ quản lý phê duyệt trực tiếp
								</div>
							</div>
						}
					</div>
				</div>
			</div>

			@if (_selectedRequest.IsPending)
			{
				<div class="card-footer border-0 d-flex gap-3 justify-content-end p-5 bg-light-light">
					<button class="btn btn-light-danger flex-grow-1" @onclick="() => RejectRequest(_selectedRequest)">Từ chối</button>
					<button class="btn btn-primary flex-grow-1" @onclick="() => ApproveRequest(_selectedRequest)">Phê duyệt</button>
				</div>
			}
		</div>
	}
</div>

<!-- Backdrop -->
@if (_showDetail)
{
	<div class="drawer-overlay" style="z-index: 104; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="CloseDetail"></div>
}

<GenericActionModal IsVisible="_showActionModal"
                    Title="@_modalTitle"
                    Heading="@_modalHeading"
                    Message="@_modalMessage"
                    Color="@_modalColor"
                    Icon="@_modalIcon"
                    ConfirmLabel="@_modalConfirmLabel"
                    ShowReasonInput="_showReasonInput"
                    IsReasonRequired="_showReasonInput"
                    ReasonPlaceholder="Nhập lý do cụ thể..."
                    OnConfirmed="ConfirmAction"
                    OnCancelled="CloseModal" />


