@page "/attendance/timesheet"
@using TTL.HR.Shared.Components.Common
@using TTL.HR.Shared.Pages.User.Components

<PageTitle>Bảng công nhân viên - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">

        <!-- Filters Bar -->
        <div class="card mb-8 shadow-sm border-0">
            <div class="card-body py-4 px-6">
                <div class="d-flex flex-wrap align-items-center">
                    <!-- Search -->
                    <div class="position-relative w-md-250px me-4 my-1">
                        <i class="ki-outline ki-magnifier fs-3 position-absolute top-50 translate-middle-y ms-4 text-gray-500"></i>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm tên, mã nhân viên..." 
                               @bind="_searchTerm" @bind:event="oninput" />
                    </div>

                    <!-- Period -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Tháng 02/2026</option>
                            <option>Tháng 01/2026</option>
                            <option>Tháng 12/2025</option>
                        </select>
                    </div>

                    <!-- Department -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Phòng ban: Tất cả</option>
                            <option>Phòng Kỹ thuật</option>
                            <option>Phòng Nhân sự</option>
                            <option>Phòng Kinh doanh</option>
                        </select>
                    </div>

                    <!-- Actions -->
                    <div class="ms-auto my-1 d-flex gap-2">
                        <button class="btn btn-icon btn-light-primary btn-sm" title="Làm mới dữ liệu" @onclick="LoadData">
                            <i class="ki-outline ki-arrows-loop fs-4"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Selection Bar -->
        <div class="d-flex flex-stack mb-6">
            <div class="d-flex align-items-center">
                <div class="form-check form-check-sm form-check-custom form-check-solid me-5">
                    <input class="form-check-input" type="checkbox" id="check_all_timesheet" />
                    <label class="form-check-label fw-bold text-gray-700 fs-7 ms-2 text-nowrap" for="check_all_timesheet">Chọn tất cả (@FilteredTimesheets.Count nhân viên)</label>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-light-primary fw-bold px-4 py-2 fs-7 shadow-sm"><i class="ki-outline ki-exit-up fs-5 me-1"></i>Xuất Excel</button>
                <button class="btn btn-sm btn-primary fw-bold px-4 py-2 fs-7 shadow-sm"><i class="ki-outline ki-lock fs-5 me-1"></i>Chốt công hàng loạt</button>
            </div>
        </div>

        <!-- Table -->
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10">
                    <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5 mb-0">
                        <thead class="bg-light">
                            <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
                                <th class="w-10px pe-2 text-center text-nowrap">STT</th>
                                <th class="min-w-220px">NHÂN VIÊN</th>
                                <th class="min-w-150px">PHÒNG BAN</th>
                                <th class="min-w-90px text-center">CÔNG CHUẨN</th>
                                <th class="min-w-90px text-center">CÔNG THỰC</th>
                                <th class="min-w-100px text-center">MUỘN/SỚM</th>
                                <th class="min-w-90px text-center">NGHỈ/LỄ</th>
                                <th class="min-w-100px text-center text-success">OT (H)</th>
                                <th class="min-w-120px text-center">TRẠNG THÁI</th>
                                <th class="min-w-120px text-end pe-7">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody class="fw-semibold text-gray-700">
                            @if (FilteredTimesheets.Any())
                            {
                                int index = 1;
                                @foreach (var item in FilteredTimesheets)
                                {
                                    <tr class="hover-elevate cursor-pointer">
                                        <td class="text-center">@index</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="symbol symbol-40px symbol-circle me-3">
                                                    @if (!string.IsNullOrEmpty(item.Avatar))
                                                    {
                                                        <img src="@item.Avatar" alt="user" />
                                                    }
                                                    else
                                                    {
                                                        <div class="symbol-label bg-light-primary text-primary fw-bold">@item.EmployeeName.Substring(0, 1)</div>
                                                    }
                                                </div>
                                                <div class="d-flex justify-content-start flex-column">
                                                    <a href="javascript:void(0)" @onclick="() => OpenDetail(item.EmployeeId)" class="text-gray-900 fw-bold text-hover-primary fs-6">@item.EmployeeName</a>
                                                    <span class="text-muted fw-semibold fs-7 text-uppercase">@item.EmployeeId • @item.Role</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="text-gray-600 fw-bold">@item.Department</span></td>
                                        <td class="text-center fw-bolder text-gray-800">@item.StandardWork</td>
                                        <td class="text-center fw-bolder text-primary">@item.ActualWork.ToString("F1")</td>
                                        <td class="text-center">
                                            <span class="text-danger fw-bold">@item.LateCount</span>/<span class="text-gray-500 fw-bold">@item.EarlyLeaveCount</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-warning fw-bold">@item.LeaveDays</span>/<span class="text-gray-500 fw-bold">@item.HolidayDays</span>
                                        </td>
                                        <td class="text-center fw-bold text-success">@item.OvertimeHours.ToString("F1")h</td>
                                        <td class="text-center">
                                            <span class="badge @GetStatusBadgeClass(item.Status) fw-bold px-4 py-2 rounded-pill d-inline-flex align-items-center">
                                                <span class="bullet bullet-dot @GetStatusBulletClass(item.Status) w-6px h-6px me-2"></span>@TranslateStatus(item.Status)
                                            </span>
                                        </td>
                                        <td class="text-end pe-7">
                                            <button type="button" class="btn btn-icon btn-sm btn-light-primary btn-active-primary me-2 shadow-sm" title="Chi tiết công" @onclick="() => OpenDetail(item.EmployeeId)">
                                                <i class="ki-outline ki-eye fs-4"></i>
                                            </button>
                                            <button class="btn btn-icon btn-sm btn-light-success btn-active-success shadow-sm" title="Chốt công" @onclick="() => LockTimesheet(item.Id)">
                                                <i class="ki-outline ki-check fs-4"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" class="text-center py-20">
                                        <div class="text-muted fs-4">Không tìm thấy dữ liệu chấm công.</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                </SkeletonLoading>
            </div>
        </div>

    </div>
</div>

<!-- Drawer for Detail -->
<div class="bg-body drawer drawer-end @(_showDetail ? "drawer-on" : "")" style="width: 1200px; max-width: 95vw; transition: transform 0.3s ease-in-out; position: fixed; top: 0; right: 0; bottom: 0; z-index: 110; transform: translateX(@(_showDetail ? "0" : "100%")); box-shadow: -5px 0 15px rgba(0,0,0,0.1); overflow-y: auto;">
    <div class="card w-100 rounded-0 border-0">
        <div class="card-header pe-5 border-0 pt-7">
             <div class="card-title">
                 <div class="d-flex justify-content-center flex-column me-3">
                     <span class="fs-2 fw-bolder text-gray-900 mb-1">Chi tiết chấm công</span>
                     <div class="mb-0 fs-7 fw-semibold text-muted">Dữ liệu ghi nhận từ máy chấm công và đơn từ</div>
                 </div>
             </div>
             <div class="card-toolbar">
                  <button class="btn btn-sm btn-icon btn-active-light-primary bg-light" @onclick="CloseDetail"><i class="ki-outline ki-cross fs-1"></i></button>
             </div>
        </div>
        <div class="card-body">
             <UserAttendanceHistory EmployeeId="@_selectedEmployeeId" />
        </div>
    </div>
</div>

<!-- Backdrop -->
@if (_showDetail)
{
    <div class="drawer-overlay" style="z-index: 109; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="CloseDetail"></div>
}
