@page "/attendance"
@namespace TTL.HR.Shared.Pages.Attendance

@inject IFormatService FormatService



<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">

        <!-- Summary Stats Dashboard -->
        <div class="row g-5 mb-8">
            <div class="col-6 col-md-3">
                <div class="card border-0 border-start border-primary border-2 shadow-xs h-100 bg-light-primary">
                    <div class="card-body d-flex flex-column justify-content-center px-6 py-4">
                        <span class="text-muted fs-8 fw-bold text-uppercase mb-1 ls-1">@L["Label_TotalEmployees"]</span>
                        <div class="d-flex align-items-center">
                            <span class="fs-2qx fw-bold text-gray-800 me-2">@FilteredEmployees.Count</span>

                            <span class="badge badge-light-primary fw-bold px-2 py-1">@L["Label_Month"] @_currentMonth/@_currentYear</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 border-start border-success border-2 shadow-xs h-100 bg-light-success">
                    <div class="card-body d-flex flex-column justify-content-center px-6 py-4">
                        <span class="text-muted fs-8 fw-bold text-uppercase mb-1 ls-1">@L["Label_TotalActualWork"]</span>
                        <div class="d-flex align-items-center">
                            <span class="fs-2qx fw-bold text-gray-800 me-2">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.ActualWork), 1)</span>


                            <span class="text-success fs-7 fw-bold"><i class="bi bi-check-circle-fill me-1"></i>Hợp lệ</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 border-start border-info border-2 shadow-xs h-100 bg-light-info">
                    <div class="card-body d-flex flex-column justify-content-center px-6 py-4">
                        <span class="text-muted fs-8 fw-bold text-uppercase mb-1 ls-1">@L["Label_TotalOTHours"]</span>
                        <div class="d-flex align-items-center">
                            <span class="fs-2qx fw-bold text-gray-800 me-2">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.OvertimeHours), 1)</span>


                            <span class="text-info fs-7 fw-bold">Giờ (OT)</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 border-start border-danger border-2 shadow-xs h-100 bg-light-danger">
                    <div class="card-body d-flex flex-column justify-content-center px-6 py-4">
                        <span class="text-muted fs-8 fw-bold text-uppercase mb-1 ls-1">@L["Label_TotalLateEarly"]</span>
                        <div class="d-flex align-items-center">
                            <span class="fs-2qx fw-bold text-gray-800 me-2">@(FilteredEmployees.Sum(e => e.LateMinutes + e.EarlyLeaveMinutes))</span>

                            <span class="text-danger fs-7 fw-bold"><i class="bi bi-clock-history me-1"></i>Muộn/Sớm</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Unified Filters Bar -->
        <EmployeeToolbar 
            SearchQuery="@_searchTerm"
            Departments="@_departments"
            OnSearchChanged="OnSearchChange"
            OnDepartmentChanged="async (id) => { _selectedDepartmentId = id; _currentPage = 1; await LoadData(); }"
            ShowExport="true"
            OnExport="ExportExcel">
            <ExtraFilters>
                <!-- Period Selector (Specific to Attendance) -->
                <div class="w-md-175px me-4 my-1">
                    <select class="form-select form-select-solid fs-7 fw-bold" @onchange="OnPeriodChange">
                        @foreach (var p in _periods)
                        {
                            <option value="@p.ToString("yyyy-MM-dd")" selected="@(p.Month == _currentMonth && p.Year == _currentYear)">@L["Label_Month"] @p.ToString("MM/yyyy")</option>
                        }
                    </select>
                </div>
            </ExtraFilters>
            <CustomActions>
                @if (_isPeriodLocked)
                {
                    <button class="btn btn-sm btn-success fw-bold fs-7 px-4 ms-2" disabled>
                        <i class="bi bi-check-circle me-1"></i>@L["Label_LockedAttendance"]
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-primary fw-bold fs-7 px-4 ms-2" @onclick="LockMonth" disabled="@_isLoading">
                        <i class="bi bi-lock me-1"></i>@L["Label_LockAttendanceMonth"]
                    </button>
                }
                <button class="btn btn-icon btn-light-primary btn-sm ms-2 border border-primary border-dashed" title="Lọc thêm"><i class="bi bi-funnel"></i></button>
            </CustomActions>
        </EmployeeToolbar>

        <!-- Selection Info -->
        <div class="d-flex flex-stack mb-6">
            <div class="d-flex align-items-center">
                <div class="form-check form-check-sm form-check-custom form-check-solid me-5">
                    <input class="form-check-input" type="checkbox" id="check_all_timesheet" />
                    <label class="form-check-label fw-bold text-gray-700 fs-7 ms-2 text-nowrap" for="check_all_timesheet">Chọn tất cả (@_totalItems nhân viên)</label>
                </div>
                <div class="h-20px border-start border-gray-300 mx-5"></div>
                <span class="text-muted fs-7 fw-semibold">Hiển thị @_employees.Count / @_totalItems kết quả</span>
            </div>
        </div>


        <!-- Unified Table -->
        <EmployeeDataGrid 
            TItem="AttendanceModel"
            Items="FilteredEmployees"
            IsLoading="_isLoading"
            CurrentPage="@_currentPage"
            TotalCount="@_totalItems"
            PageSize="@_pageSize"
            Rows="@_pageSize"
            OnPageChanged="OnPageChange"
            Columns="13">
            <HeaderTemplate>
                <th class="w-10px pe-2"></th>
                <th class="min-w-180px">@L["Label_Employee"].ToString().ToUpper()</th>
                <th class="min-w-120px">@L["Label_Department"].ToString().ToUpper()</th>
                <th class="min-w-60px text-center">@L["Label_Standard"].ToString().ToUpper()</th>
                <th class="min-w-60px text-center">@L["Label_Actual"].ToString().ToUpper()</th>
                <th class="min-w-80px text-center">@L["Label_WorkHours"].ToString().ToUpper()</th>
                <th class="min-w-60px text-center">@L["Label_Late"].ToString().ToUpper()</th>
                <th class="min-w-60px text-center">@L["Label_Early"].ToString().ToUpper()</th>
                <th class="min-w-60px text-center">@L["Label_Leave"].ToString().ToUpper()</th>
                <th class="min-w-60px text-center">@L["Label_Holiday"].ToString().ToUpper()</th>
                <th class="min-w-70px text-center">@L["Label_TotalOTHours"].ToString().ToUpper()</th>
                <th class="min-w-100px text-center">@L["Label_Status"].ToString().ToUpper()</th>
                <th class="min-w-100px text-end pe-7">@L["Label_Actions"].ToString().ToUpper()</th>
            </HeaderTemplate>
            <RowTemplate Context="item">
                <td><div class="form-check form-check-sm form-check-custom form-check-solid"><input class="form-check-input timesheet-checkbox" type="checkbox" value="1" @onclick:stopPropagation /></div></td>
                <td class="d-flex align-items-center">
                    <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                        <a href="javascript:;" class="kt_drawer_employee_detail_toggle" @onclick="() => openDetail(item)">
                            @if (!string.IsNullOrEmpty(item.Avatar))
                            {
                                <div class="symbol-label"><img src="@item.Avatar" alt="@item.EmployeeName" class="w-100" /></div>
                            }
                            else
                            {
                                <div class="symbol-label bg-light-primary text-primary fw-bolder">@(item.EmployeeName?.Length > 0 ? item.EmployeeName.Substring(0, 1) : "N")</div>
                            }
                        </a>
                    </div>
                    <div class="d-flex flex-column">
                        <a href="javascript:;" class="kt_drawer_employee_detail_toggle text-gray-900 fw-bold text-hover-primary mb-1 fs-6" @onclick="() => openDetail(item)">@item.EmployeeName</a>
                        <span class="text-muted fw-semibold fs-7 mb-1">@item.EmployeeCode • @item.Role</span>
                        <div class="d-flex align-items-center">
                            <span class="badge @(GetShiftClass(item.ShiftColor, "badge-light-")) fw-bold fs-9 px-2 py-0" style="@(GetShiftStyle(item.ShiftColor))">@item.ShiftName</span>
                        </div>
                    </div>
                </td>
                <td><span class="text-gray-700 fw-bold">@item.Department</span></td>
                <td class="text-center fw-bolder text-gray-800">@item.StandardWork</td>
                <td class="text-center fw-bolder text-primary">@FormatService.FormatNumber(item.ActualWork, 1)</td>
                <td class="text-center fw-bold text-dark">@FormatService.FormatNumber(item.TotalWorkingHours, 1) h</td>

                <td class="text-center"><span class="text-danger fw-bold">@item.LateMinutes</span></td>
                <td class="text-center"><span class="text-gray-600 fw-bold">@item.EarlyLeaveMinutes</span></td>
                <td class="text-center"><span class="text-warning fw-bold">@item.LeaveDays</span></td>
                <td class="text-center"><span class="text-gray-600 fw-bold">@item.HolidayDays</span></td>
                <td class="text-center fw-bold text-success">@FormatService.FormatNumber(item.OvertimeHours, 1) h</td>
                <td class="text-center">
                    <span class="badge badge-light-@(string.IsNullOrEmpty(item.StatusColor) ? "info" : item.StatusColor) fw-bold px-4 py-2 rounded-pill d-inline-flex align-items-center">
                        <span class="bullet bullet-dot bg-@(string.IsNullOrEmpty(item.StatusColor) ? "info" : item.StatusColor) w-6px h-6px me-2"></span>@item.Status
                    </span>
                </td>
                <td class="text-end pe-7">
                    <button class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-2 shadow-sm" title="Chi tiết công" @onclick="() => openDetail(item)" @onclick:stopPropagation>
                        <i class="ki-outline ki-eye fs-3"></i>
                    </button>
                    @if (item.Status == "Locked" || item.Status == "Đã chốt")
                    {
                        <button class="btn btn-icon btn-bg-light btn-active-color-success btn-sm shadow-sm" title="Đã chốt" disabled @onclick:stopPropagation>
                            <i class="ki-outline ki-check-all fs-3"></i>
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-icon btn-bg-light btn-active-color-success btn-sm shadow-sm" title="Chốt công" @onclick="() => LockTimesheet(item.EmployeeId)" @onclick:stopPropagation>
                            <i class="ki-outline ki-check fs-3"></i>
                        </button>
                    }
                </td>
            </RowTemplate>
            <FooterTemplate>
                <tr>
                    <td></td>
                    <td colspan="2" class="text-end ps-0">@L["Label_Total"].ToString().ToUpper() (@FilteredEmployees.Count @L["Label_Employees"]):</td>
                    <td class="text-center">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.StandardWork))</td>
                    <td class="text-center text-primary">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.ActualWork), 1)</td>
                    <td class="text-center text-dark">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.TotalWorkingHours), 1) h</td>
                    <td class="text-center text-danger">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.LateMinutes))</td>
                    <td class="text-center text-gray-600">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.EarlyLeaveMinutes))</td>
                    <td class="text-center text-warning">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.LeaveDays))</td>
                    <td class="text-center text-gray-600">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.HolidayDays))</td>
                    <td class="text-center text-success">@FormatService.FormatNumber(FilteredEmployees.Sum(e => e.OvertimeHours), 1) h</td>
                    <td colspan="2"></td>
                </tr>
            </FooterTemplate>
        </EmployeeDataGrid>

    </div>
</div>

<!-- ATTENDANCE DETAIL DRAWER (Ported from leave-management.html) -->
<div class="bg-white drawer drawer-end @(_showDetail ? "drawer-on" : "")" 
     style="width: 500px; max-width: 100vw; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showDetail ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <!-- Header -->
        <div class="card-header pe-5">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column me-3">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">@L["Label_Details"] @L["Label_Month"].ToString().ToLower() @_currentMonth/@_currentYear</span>
                    <span class="fs-7 fw-bold text-muted mt-2">MàNV: @(_selectedEmployee?.Id ?? "---")</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeDetail">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="card-body hover-scroll-overlay-y">
            @if (_selectedEmployee != null)
            {
                <div class="d-flex flex-stack bg-light rounded p-5 mb-8 border border-gray-100">
                    <div class="d-flex align-items-center">
                        <div class="symbol symbol-70px symbol-circle me-5 shadow-xs">
                            @if (!string.IsNullOrEmpty(_selectedEmployee.Avatar))
                            {
                                <img src="@_selectedEmployee.Avatar" alt="" />
                            }
                            else
                            {
                                <div class="symbol-label fs-2 fw-bold bg-primary text-inverse-primary">@(_selectedEmployee.EmployeeName?.Length > 0 ? _selectedEmployee.EmployeeName.Substring(0, 1) : "A")</div>
                            }
                        </div>
                        <div class="d-flex flex-column">
                            <div class="d-flex align-items-center mb-1">
                                <span class="text-gray-900 fw-bolder fs-5 me-2">@_selectedEmployee.EmployeeName</span>
                                <span class="badge badge-light-@(string.IsNullOrEmpty(_selectedEmployee.StatusColor) ? "info" : _selectedEmployee.StatusColor) fw-bold fs-9 px-2 py-1">@_selectedEmployee.Status</span>
                            </div>
                            <span class="text-muted fw-bold fs-7">@_selectedEmployee.Department - @_selectedEmployee.Role</span>
                            <div class="d-flex align-items-center mt-1">
                                <span class="badge @(GetShiftClass(_selectedEmployee.ShiftColor, "badge-light-")) fw-bold fs-9 px-2 py-0" style="@(GetShiftStyle(_selectedEmployee.ShiftColor))">@_selectedEmployee.ShiftName</span>
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="fs-9 fw-bold text-uppercase text-muted opacity-75 d-block mb-1">@L["Label_Actual"].ToString().ToUpper()</span>
                        <span class="badge badge-primary fs-7 fw-bolder px-3 py-2">@FormatService.FormatNumber(_selectedEmployee.ActualWork, 1) <span class="fs-9 fw-normal ms-1">@L["Label_WorkDayUnit"]</span></span>
                    </div>
                </div>

                <!-- Attendance Stats -->
                <h3 class="fw-bolder fs-6 mb-5 text-uppercase"><i class="ki-outline ki-chart-line text-primary me-2"></i>@L["Label_TotalRank"]</h3>
                <div class="row g-5 mb-8">
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@_selectedEmployee.LateCount/@_selectedEmployee.EarlyLeaveCount</div>
                            <div class="fw-bold text-muted fs-8">@L["Label_Late"]/@L["Label_Early"]</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@FormatService.FormatNumber(_selectedEmployee.OvertimeHours, 1) h</div>
                            <div class="fw-bold text-muted fs-8">@L["Label_TotalOTHours"] (OT)</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@_selectedEmployee.LeaveDays/@_selectedEmployee.HolidayDays</div>
                            <div class="fw-bold text-muted fs-8">@L["Label_Leave"]/@L["Label_Holiday"]</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@(_selectedEmployee.StandardWork > 0 ? FormatService.FormatNumber(_selectedEmployee.ActualWork / _selectedEmployee.StandardWork * 100, 0) : "0")%</div>
                            <div class="fw-bold text-muted fs-8">@L["Label_AttendanceRate"]</div>
                        </div>
                    </div>
                </div>

                <!-- Day-by-Day Logs -->
                <h3 class="fw-bolder fs-6 mb-5 text-uppercase"><i class="ki-outline ki-calendar-8 text-primary me-2"></i>@L["Label_AttendanceLog"]</h3>
                <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-4">
                        <thead>
                            <tr class="fw-bold text-muted fs-8 text-uppercase">
                                <th class="min-w-80px">@L["Label_Date"]</th>
                                <th class="min-w-70px text-center">@L["Label_CheckIn"]</th>
                                <th class="min-w-70px text-center">@L["Label_CheckOut"]</th>
                                <th class="min-w-60px text-center">@L["Label_Late"]</th>
                                <th class="min-w-60px text-center">@L["Label_Early"]</th>
                                <th class="min-w-60px text-center">OT</th>
                                <th class="min-w-60px text-end">@L["Label_Actual"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in _selectedDetails)
                            {
                                <tr>
                                    <td><span class="text-gray-800 fw-bold fs-8">@FormatService.FormatDate(detail.Date).Substring(0, 5)</span></td>
                                    <td class="text-center">
                                        @if (detail.CheckIn.HasValue)
                                        {
                                            <span class="text-gray-800 fs-8">@FormatService.FormatTime(detail.CheckIn)</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (detail.CheckOut.HasValue)
                                        {
                                            <span class="text-gray-800 fs-8">@FormatService.FormatTime(detail.CheckOut)</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (detail.LateMinutes > 0)
                                        {
                                            <span class="text-danger fw-bold fs-8">@detail.LateMinutes p</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (detail.EarlyLeaveMinutes > 0)
                                        {
                                            <span class="text-warning fw-bold fs-8">@detail.EarlyLeaveMinutes p</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (detail.OvertimeHours > 0)
                                        {
                                            <span class="text-success fw-bold fs-8">@FormatService.FormatNumber(detail.OvertimeHours, 1)</span>
                                        }
                                    </td>
                                    <td class="text-end"><span class="text-gray-900 fw-bolder fs-8">@FormatService.FormatNumber(detail.WorkValue, 1)</span></td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Warning Block -->
                @if (_selectedEmployee.LateCount > 0)
                {
                    <div class="alert alert-dismissible bg-light-warning d-flex flex-column flex-sm-row p-5 mb-8 border border-warning">
                        <i class="ki-outline ki-information-5 fs-2hx text-warning me-4 mb-5 mb-sm-0"></i>
                        <div class="d-flex flex-column">
                            <h4 class="fw-bold text-gray-800 mb-1">@L["Label_SystemNotice"]</h4>
                            <span class="fs-7 text-gray-700">@string.Format(L["Message_LateNotice"], _selectedEmployee.LateCount)</span>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Footer -->
        <div class="card-footer border-0 d-flex gap-3 justify-content-between p-10">
            <button type="button" class="btn btn-light flex-grow-1 fs-7 fw-bold" @onclick="closeDetail">@L["Label_Close"]</button>
            @if (_isPeriodLocked)
            {
                <button type="button" class="btn btn-light-success flex-grow-1 fs-7 fw-bold" disabled>Đã chốt công xong</button>
            }
            else
            {
                <button type="button" class="btn btn-primary flex-grow-1 fs-7 fw-bold" @onclick="LockMonth" disabled="@_isLoading">@L["Label_QuickLock"]</button>
            }
        </div>
    </div>
</div>

<!-- Backdrop -->
@if (_showDetail)
{
    <div class="drawer-overlay" style="z-index: 105; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="closeDetail"></div>
}


