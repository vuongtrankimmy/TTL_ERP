@page "/attendance"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">

        <!-- Filters Bar -->
        <div class="card mb-8 shadow-sm">
            <div class="card-body py-4 px-6">
                <div class="d-flex flex-wrap align-items-center">
                    <!-- Search -->
                    <div class="position-relative w-md-250px me-4 my-1">
                        <span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"></path>
                            </svg>
                        </span>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm tên, mã nhân viên..." />
                    </div>

                    <!-- Period -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Tháng 02/2026</option>
                            <option>Tháng 01/2026</option>
                            <option>Tháng 12/2025</option>
                        </select>
                    </div>

                    <!-- Department -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Phòng ban: Tất cả</option>
                            <option>Phòng Kỹ thuật</option>
                            <option>Phòng Nhân sự</option>
                        </select>
                    </div>

                    <!-- Actions -->
                    <div class="ms-auto my-1 d-flex gap-2">
                        <button class="btn btn-icon btn-light-primary btn-sm" title="Làm mới dữ liệu"><i class="bi bi-arrow-repeat fs-5"></i></button>
                        <button class="btn btn-light-primary fw-bold fs-7 px-6 ms-2"><i class="bi bi-funnel me-1"></i>Lọc thêm</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Selection Bar -->
        <div class="d-flex flex-stack mb-6">
            <div class="d-flex align-items-center">
                <div class="form-check form-check-sm form-check-custom form-check-solid me-5">
                    <input class="form-check-input" type="checkbox" id="check_all_timesheet" />
                    <label class="form-check-label fw-bold text-gray-700 fs-7 ms-2 text-nowrap" for="check_all_timesheet">Chọn tất cả (124 nhân viên)</label>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3 text-end justify-content-end">
                <button class="btn btn-sm btn-light border border-gray-300 px-3 py-2 fs-8 fw-semibold"><i class="bi bi-file-earmark-excel fs-6 me-1"></i>Xuất Excel</button>
                <button class="btn btn-sm btn-primary px-4 py-2 fs-8 fw-semibold"><i class="bi bi-lock fs-7 me-1"></i>Chốt công tháng</button>
            </div>
        </div>

        <!-- Table -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10" Columns="10">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5">
                            <thead>
                                <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
                                    <th class="w-10px pe-2"></th>
                                    <th class="min-w-180px">NHÂN VIÊN</th>
                                    <th class="min-w-120px">PHÒNG BAN</th>
                                    <th class="min-w-80px text-center">CÔNG CHUẨN</th>
                                    <th class="min-w-80px text-center">CÔNG THỰC</th>
                                    <th class="min-w-80px text-center">MUỘN/SỚM</th>
                                    <th class="min-w-80px text-center">NGHỈ/LỄ</th>
                                    <th class="min-w-80px text-center">TĂNG CA</th>
                                    <th class="min-w-100px text-center">TRẠNG THÁI</th>
                                    <th class="min-w-100px text-end pe-7">THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in _employees)
                                {
                                    <tr class="hover-elevate cursor-pointer" @onclick="() => openDetail(emp)">
                                        <td><div class="form-check form-check-sm form-check-custom form-check-solid"><input class="form-check-input timesheet-checkbox" type="checkbox" value="1" @onclick:stopPropagation /></div></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="symbol symbol-40px symbol-circle me-3">
                                                    @if (!string.IsNullOrEmpty(emp.Avatar))
                                                    {
                                                        <img src="@emp.Avatar" alt="user" />
                                                     }
                                                     else
                                                     {
                                                        <div class="symbol-label bg-light-danger text-danger fw-bolder">@emp.EmployeeName.Substring(0, 1)</div>
                                                     }
                                                </div>
                                                <div class="d-flex justify-content-start flex-column"><span class="text-dark fw-bolder fs-6">@emp.EmployeeName</span><span class="text-muted fw-bold fs-7">@emp.EmployeeId • @emp.Role</span></div>
                                            </div>
                                        </td>
                                        <td><span class="text-gray-700 fw-bold">@emp.Department</span></td>
                                        <td class="text-center fw-bolder text-gray-800">@emp.StandardWork</td>
                                        <td class="text-center fw-bolder text-primary">@emp.ActualWork</td>
                                        <td class="text-center"><span class="text-danger fw-bold">@emp.LateCount</span>/<span class="text-gray-600 fw-bold">@emp.EarlyLeaveCount</span></td>
                                        <td class="text-center"><span class="text-warning fw-bold">@emp.LeaveDays</span>/<span class="text-gray-600 fw-bold">@emp.HolidayDays</span></td>
                                        <td class="text-center fw-bold text-success">@emp.OvertimeHours h</td>
                                        <td class="text-center">
                                            <span class="badge @GetStatusColor(emp.Status) fw-bold px-4 py-2 rounded-pill d-inline-flex align-items-center">
                                                <span class="bullet bullet-dot @(GetStatusColor(emp.Status).Replace("badge-light-", "bg-")) w-6px h-6px me-2"></span>@emp.Status
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-icon btn-sm btn-light-primary border border-primary border-opacity-10 me-2" title="Chi tiết công" @onclick="() => openDetail(emp)" @onclick:stopPropagation><i class="bi bi-eye-fill fs-6"></i></button>
                                            <button class="btn btn-icon btn-sm btn-light-success border border-success border-opacity-10" title="Chốt công" @onclick:stopPropagation><i class="bi bi-check-lg fs-5"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination -->
                    <div class="px-7 py-5">
                        <div class="d-flex flex-stack flex-wrap">
                            <div class="fs-7 fw-bold text-gray-700">Hiển thị 1 đến 10 của 124 nhân viên</div>
                            <ul class="pagination">
                                <li class="page-item previous disabled"><a href="#" class="page-link"><i class="next"></i></a></li>
                                <li class="page-item active"><a href="#" class="page-link">1</a></li>
                                <li class="page-item next"><a href="#" class="page-link"><i class="next"></i></a></li>
                            </ul>
                        </div>
                    </div>
                </SkeletonLoading>
            </div>
        </div>

    </div>
</div>

<!-- ATTENDANCE DETAIL DRAWER (Ported from leave-management.html) -->
<div class="bg-white drawer drawer-end @(_showDetail ? "drawer-on" : "")" 
     style="width: 500px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showDetail ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <!-- Header -->
        <div class="card-header pe-5">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column me-3">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Chi tiết công tháng 02/2026</span>
                    <span class="fs-7 fw-bold text-muted mt-2">MÃ NV: @(_selectedEmployee?.Id ?? "---")</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeDetail">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="card-body hover-scroll-overlay-y">
            @if (_selectedEmployee != null)
            {
                <!-- Employee Summary -->
                <div class="d-flex flex-stack bg-light-primary rounded p-6 mb-8 border border-primary border-dashed">
                    <div class="d-flex align-items-center">
                        <div class="symbol symbol-60px symbol-circle me-5 border border-white border-3 shadow-sm">
                            @if (!string.IsNullOrEmpty(_selectedEmployee.Avatar))
                            {
                                <img src="@_selectedEmployee.Avatar" alt="" />
                            }
                            else
                            {
                                <div class="symbol-label fs-2 fw-bold bg-primary text-inverse-primary">@_selectedEmployee.EmployeeName.Substring(0, 1)</div>
                            }
                        </div>
                        <div class="d-flex flex-column">
                            <div class="d-flex align-items-center mb-1">
                                <span class="text-gray-900 fw-bolder fs-5 me-2">@_selectedEmployee.EmployeeName</span>
                                <span class="badge @GetStatusColor(_selectedEmployee.Status) fw-bold fs-9 px-2 py-1">@_selectedEmployee.Status</span>
                            </div>
                            <span class="text-muted fw-bold fs-7">@_selectedEmployee.Department - @_selectedEmployee.Role</span>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="fs-9 fw-bold text-uppercase text-muted opacity-75 d-block mb-1">CÔNG THỰC</span>
                        <span class="badge badge-primary fs-7 fw-bolder px-3 py-2">@_selectedEmployee.ActualWork <span class="fs-9 fw-normal ms-1">công</span></span>
                    </div>
                </div>

                <!-- Attendance Stats -->
                <h3 class="fw-bolder fs-6 mb-5 text-uppercase"><i class="ki-outline ki-chart-line text-primary me-2"></i>Thống kê tổng quát</h3>
                <div class="row g-5 mb-8">
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@_selectedEmployee.LateCount/@_selectedEmployee.EarlyLeaveCount</div>
                            <div class="fw-bold text-muted fs-8">Đi muộn/Về sớm</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@_selectedEmployee.OvertimeHours h</div>
                            <div class="fw-bold text-muted fs-8">Tăng ca (OT)</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@_selectedEmployee.LeaveDays/@_selectedEmployee.HolidayDays</div>
                            <div class="fw-bold text-muted fs-8">Nghỉ phép/Lễ</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border border-gray-300 border-dashed rounded min-w-100px py-3 px-4 mb-3">
                            <div class="fs-6 fw-bolder text-gray-700">@((_selectedEmployee.ActualWork / _selectedEmployee.StandardWork * 100).ToString("0"))%</div>
                            <div class="fw-bold text-muted fs-8">Tỷ lệ chuyên cần</div>
                        </div>
                    </div>
                </div>

                <!-- Day-by-Day Logs -->
                <h3 class="fw-bolder fs-6 mb-5 text-uppercase"><i class="ki-outline ki-calendar-8 text-primary me-2"></i>Nhật ký chấm công</h3>
                <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-4">
                        <thead>
                            <tr class="fw-bold text-muted fs-8 text-uppercase">
                                <th class="min-w-100px">Ngày</th>
                                <th class="min-w-100px text-center">Giờ vào</th>
                                <th class="min-w-100px text-center">Giờ ra</th>
                                <th class="min-w-80px text-end">Công</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in _selectedDetails)
                            {
                                <tr>
                                    <td><span class="text-gray-800 fw-bold fs-7">@detail.Date.ToString("dd/MM") - @detail.DayOfWeek</span></td>
                                    <td class="text-center">
                                        @if (detail.CheckIn.HasValue)
                                        {
                                            <span class="badge @(detail.IsLate ? "badge-light-danger" : "badge-light-success") fs-7 fw-bold">@detail.CheckIn.Value.ToString("HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fs-8">--:--</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (detail.CheckOut.HasValue)
                                        {
                                            <span class="badge @(detail.IsEarlyLeave ? "badge-light-danger" : "badge-light-success") fs-7 fw-bold">@detail.CheckOut.Value.ToString("HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fs-8">--:--</span>
                                        }
                                    </td>
                                    <td class="text-end"><span class="text-gray-800 fw-bolder fs-7">@detail.WorkValue.ToString("0.0")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Warning Block -->
                @if (_selectedEmployee.LateCount > 0)
                {
                    <div class="alert alert-dismissible bg-light-warning d-flex flex-column flex-sm-row p-5 mb-8 border border-warning">
                        <i class="ki-outline ki-information-5 fs-2hx text-warning me-4 mb-5 mb-sm-0"></i>
                        <div class="d-flex flex-column">
                            <h4 class="fw-bold text-gray-800 mb-1">Lưu ý từ hệ thống</h4>
                            <span class="fs-7 text-gray-700">Nhân viên này có @_selectedEmployee.LateCount ngày đi muộn. Vui lòng kiểm tra lý do giải trình nếu có.</span>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Footer -->
        <div class="card-footer border-0 d-flex gap-3 justify-content-between p-10">
            <button type="button" class="btn btn-light flex-grow-1 fs-7 fw-bold" @onclick="closeDetail">Đóng</button>
            <button type="button" class="btn btn-primary flex-grow-1 fs-7 fw-bold">Chốt công nhanh</button>
        </div>
    </div>
</div>

<!-- Backdrop -->
@if (_showDetail)
{
    <div class="drawer-overlay" style="z-index: 105; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="closeDetail"></div>
}


