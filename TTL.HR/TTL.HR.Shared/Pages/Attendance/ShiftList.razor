@page "/attendance/shifts"
@using TTL.HR.Application.Modules.Attendance.Models
@using TTL.HR.Shared.Components.Common
@using TTL.HR.Shared.Components.HumanResource
@inject IStringLocalizer<SharedResource> L

<div class="post d-flex flex-column-fluid" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        
        <!-- Simplified Action Bar (No Redundant Title) -->
        <div class="d-flex align-items-center justify-content-end mb-8 gap-3">
            <button type="button" class="btn btn-sm btn-light-primary fw-boldest px-6 ripple shadow-sm" @onclick='() => NavigationManager.NavigateTo("/attendance/scheduler")'>
                <i class="ki-outline ki-calendar-8 fs-4 me-2"></i>SƠ ĐỒ TỔNG QUÁT
            </button>
            <button type="button" class="btn btn-sm btn-primary fw-boldest px-6 shadow-sm ripple" @onclick="() => OpenShiftDialog()">
                <i class="ki-outline ki-plus fs-3 me-2"></i>THÊM CA MỚI
            </button>
        </div>

        <div class="card shadow-sm border-0">

            <div class="card-body py-4">
                <!-- Filters -->
                <div class="d-flex flex-stack mb-5">
                    <div class="d-flex align-items-center position-relative my-1">
                        <i class="ki-outline ki-magnifier fs-2 position-absolute ms-4 text-gray-500"></i>
                        <input type="text" class="form-control form-control-solid w-250px ps-12 fs-7" 
                               placeholder="Tìm tên hoặc mã ca..." @bind="_searchTerm" @bind:event="oninput" />
                    </div>
                    
                    <div class="d-flex justify-content-end align-items-center">
                        <span class="text-muted fs-7 fw-bold me-3">Hiển thị @_filteredShifts.Count() ca</span>
                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-300 align-middle gs-4 gy-4">
                        <thead>
                            <tr class="fw-bold text-gray-600 fs-8 text-uppercase bg-light">
                                <th class="min-w-150px ps-4 rounded-start">Tên ca</th>
                                <th class="min-w-100px text-center">Mã ca</th>
                                <th class="min-w-150px text-center">Thời gian làm việc</th>
                                <th class="min-w-100px text-center">Nghỉ ngơi</th>
                                <th class="min-w-100px text-center">Màu sắc</th>
                                <th class="min-w-100px text-end pe-4 rounded-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_isLoading)
                            {
                                <tr>
                                    <td colspan="6">
                                        <div class="skeleton-line h-40px w-100 mb-2"></div>
                                    </td>
                                </tr>
                            }
                            else if (!_filteredShifts.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-10">
                                        <div class="d-flex flex-column flex-center">
                                            <i class="ki-outline ki-ghost fs-3x text-gray-300 mb-3"></i>
                                            <span class="text-gray-500 fs-7 fw-bold">Không tìm thấy dữ liệu ca làm việc</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var shift in _filteredShifts)
                                {
                                    <tr class="hover-bg-light">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="symbol symbol-30px me-3">
                                                    @{
                                                        var isH = shift.Color.StartsWith("#");
                                                        var sStyle = isH ? $"background-color: {shift.Color}20 !important; color: {shift.Color} !important; border: 1px solid {shift.Color}50 !important;" : "";
                                                        var sClass = !isH ? $"bg-light-{shift.Color} text-{shift.Color} border border-{shift.Color} border-opacity-50" : "";
                                                    }
                                                    <div class="symbol-label fw-boldest fs-9 @sClass" style="@sStyle">@shift.Name.Substring(0, 1).ToUpper()</div>
                                                </div>
                                                <div>
                                                    <span class="text-gray-900 fw-boldest fs-7">@shift.Name</span>
                                                    @if (shift.IsOvernight)
                                                    {
                                                        <span class="badge badge-light-danger fw-bold fs-10 ms-2 py-0">QUA ĐÊM</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge badge-light fw-bold fs-8">@shift.Code</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex flex-center gap-2">
                                                <span class="badge badge-light-success border border-success border-dashed fw-bold fs-8">@shift.StartTime</span>
                                                <span class="text-gray-400">→</span>
                                                <span class="badge badge-light-danger border border-danger border-dashed fw-bold fs-8">@shift.EndTime</span>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrEmpty(shift.BreakStartTime) && shift.BreakStartTime != "00:00")
                                            {
                                                <span class="text-gray-600 fs-8 fw-bold">@shift.BreakStartTime - @shift.BreakEndTime</span>
                                            }
                                            else
                                            {
                                                <span class="text-gray-400 fs-10 fw-bold italic">Không nghỉ</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var isHexC = shift.Color.StartsWith("#");
                                                var bStyle = isHexC ? $"background-color: {shift.Color}15 !important; color: {shift.Color} !important; border: 1px dashed {shift.Color} !important;" : "";
                                                var bClass = !isHexC ? $"badge-light-{shift.Color} border border-{shift.Color} border-dashed" : "badge-outline";
                                            }
                                            <span class="badge fw-boldest fs-10 px-3 @bClass" style="@bStyle">
                                                @(isHexC ? shift.Color.ToUpper() : shift.Color.ToUpper())
                                            </span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-icon btn-light-primary btn-sm ripple" 
                                                        title="Xem lịch" @onclick="() => GoToScheduler(shift)">
                                                    <i class="ki-outline ki-calendar-8 fs-4"></i>
                                                </button>
                                                <button class="btn btn-icon btn-light-warning btn-sm ripple" 
                                                        title="Phân bổ nhân sự gán ca" @onclick="() => GoToAllocation(shift)">
                                                    <i class="ki-outline ki-profile-user fs-4 text-warning"></i>
                                                </button>
                                                <button class="btn btn-icon btn-light-info btn-sm ripple position-relative" 
                                                        title="Danh sách đối tượng" @onclick="() => OpenAssignedObjects(shift)">
                                                    <i class="ki-outline ki-people fs-4"></i>
                                                    @if (shift.AssignedCount > 0)
                                                    {
                                                        <span class="position-absolute top-0 start-100 translate-middle badge badge-circle badge-primary w-15px h-15px fs-10" style="margin-top: -5px; margin-left: -5px;">@shift.AssignedCount</span>
                                                    }
                                                </button>
                                                <button class="btn btn-icon btn-light-warning btn-sm ripple" @onclick="() => OpenShiftDialog(shift)" title="Sửa">
                                                    <i class="ki-outline ki-pencil fs-4"></i>
                                                </button>
                                                <button class="btn btn-icon btn-light-danger btn-sm ripple" @onclick="() => PromptDelete(shift)" title="Xóa">
                                                    <i class="ki-outline ki-trash fs-4"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal content remains same as previous version -->
@if (_showDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); z-index: 105;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pt-7 px-10">
                    <h3 class="modal-title fw-bolder fs-3">@(string.IsNullOrEmpty(_editingModel.Id) ? "Thêm ca làm việc mới" : "Cập nhật ca làm việc")</h3>
                    <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="() => _showDialog = false">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </div>
                </div>
                
                <div class="modal-body px-10 py-5">
                    <div class="mb-5">
                        <label class="form-label fs-8 fw-bold text-gray-700 required">Tên ca làm việc</label>
                        <input type="text" class="form-control form-control-solid fs-7" @bind="_editingModel.Name" placeholder="Ví dụ: Ca hành chính" />
                    </div>
                    
                    <div class="row g-5 mb-5">
                        <div class="col-md-6">
                            <label class="form-label fs-8 fw-bold text-gray-700 required">Mã ca</label>
                            <input type="text" class="form-control form-control-solid fs-7" @bind="_editingModel.Code" placeholder="HC-01" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fs-8 fw-bold text-gray-700 required">Màu sắc hiển thị</label>
                            <div class="d-flex flex-wrap gap-2 mb-3 mt-2">
                                @foreach (var color in _predefinedColors)
                                {
                                    <div class="cursor-pointer rounded-circle border @(_editingModel.Color == color ? "border-primary border-4 shadow-sm" : "border-gray-300") @(GetShiftClass(color, "bg-"))" 
                                         style="width: 25px; height: 25px; @(GetShiftStyle(color))" 
                                         @onclick="() => _editingModel.Color = color"
                                         title="@color">
                                    </div>
                                }
                            </div>
                            <div class="input-group input-group-sm input-group-solid">
                                <span class="input-group-text p-1">
                                    <input type="color" class="form-control form-control-color border-0 w-20px h-20px p-0" @bind="_editingModel.Color" />
                                </span>
                                <input type="text" class="form-control fs-8" @bind="_editingModel.Color" placeholder="#HEX..." />
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex flex-stack mb-5 bg-light-light p-4 rounded-3 border border-dashed">
                        <div class="me-5">
                            <label class="fs-7 fw-boldest text-gray-800">Cơ chế linh động</label>
                            <div class="fs-9 text-muted fw-bold">Tự động chấm công theo ngày giờ làm việc công ty</div>
                        </div>
                        <div class="form-check form-switch form-check-custom form-check-solid">
                            <input class="form-check-input w-40px h-20px" type="checkbox" @bind="_editingModel.IsFlexible" />
                        </div>
                    </div>

                    <div class="d-flex flex-stack mb-5 bg-light-light p-4 rounded-3 border border-dashed">
                        <div class="me-5">
                            <label class="fs-7 fw-boldest text-gray-800">Ca qua đêm</label>
                            <div class="fs-9 text-muted fw-bold">Ca làm việc kết thúc vào ngày hôm sau</div>
                        </div>
                        <div class="form-check form-switch form-check-custom form-check-solid">
                            <input class="form-check-input w-40px h-20px" type="checkbox" @bind="_editingModel.IsOvernight" />
                        </div>
                    </div>

                    @if (!_editingModel.IsFlexible)
                    {
                        <div class="row g-5 mb-5 animation-slide-in">
                            <div class="col-md-6">
                                <label class="form-label fs-8 fw-bold text-gray-700 required">Thời gian bắt đầu</label>
                                <input type="time" class="form-control form-control-solid fs-7" value="@_editingModel.StartTime" @onchange="@(e => _editingModel.StartTime = e.Value?.ToString())" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fs-8 fw-bold text-gray-700 required">Thời gian kết thúc</label>
                                <input type="time" class="form-control form-control-solid fs-7" value="@_editingModel.EndTime" @onchange="@(e => _editingModel.EndTime = e.Value?.ToString())" />
                            </div>
                        </div>

                        <div class="row g-5 mb-5 animation-slide-in">
                            <div class="col-md-6">
                                <label class="form-label fs-8 fw-bold text-gray-700">Giờ nghỉ từ</label>
                                <input type="time" class="form-control form-control-solid fs-7" value="@_editingModel.BreakStartTime" @onchange="@(e => _editingModel.BreakStartTime = e.Value?.ToString())" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fs-8 fw-bold text-gray-700">Giờ nghỉ đến</label>
                                <input type="time" class="form-control form-control-solid fs-7" value="@_editingModel.BreakEndTime" @onchange="@(e => _editingModel.BreakEndTime = e.Value?.ToString())" />
                            </div>
                        </div>
                    }

                    <div class="row g-5 mb-5">
                        <div class="col-md-6">
                            <label class="form-label fs-8 fw-bold text-gray-700">Ngày áp dụng từ</label>
                            <input type="date" class="form-control form-control-solid fs-7" @bind="_editingModel.StartDate" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fs-8 fw-bold text-gray-700">Đến ngày</label>
                            <input type="date" class="form-control form-control-solid fs-7" @bind="_editingModel.EndDate" />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label fs-8 fw-bold text-gray-700 mb-3">Thứ áp dụng mặc định</label>
                        <div class="d-flex flex-wrap gap-2">
                            @{
                                var days = new[] { 
                                    new { Name = "T2", Day = DayOfWeek.Monday },
                                    new { Name = "T3", Day = DayOfWeek.Tuesday },
                                    new { Name = "T4", Day = DayOfWeek.Wednesday },
                                    new { Name = "T5", Day = DayOfWeek.Thursday },
                                    new { Name = "T6", Day = DayOfWeek.Friday },
                                    new { Name = "T7", Day = DayOfWeek.Saturday },
                                    new { Name = "CN", Day = DayOfWeek.Sunday }
                                };
                            }
                            @foreach (var day in days)
                            {
                                <div class="form-check form-check-custom form-check-solid form-check-sm">
                                    <input class="form-check-input" type="checkbox" id="day_@day.Day" 
                                           checked="@(_editingModel.WorkingDays.Contains(day.Day))"
                                           @onchange="@(e => ToggleWorkingDay(day.Day))" />
                                    <label class="form-check-label fw-bold fs-9 text-gray-600 cursor-pointer" for="day_@day.Day">@day.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 pb-10 px-10">
                    <button type="button" class="btn btn-light fw-bold" @onclick="() => _showDialog = false">Hủy</button>
                    <button type="button" class="btn btn-warning fw-bold px-10 @(_isSaving ? "disabled" : "")" 
                            style="background-color: #f64e1f !important; border-color: #f64e1f !important;"
                            @onclick="SaveShiftAsync">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Lưu thông tin
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
<DeleteConfirmationModal 
    IsVisible="@_isDeleteModalOpen"
    Title="Xóa ca làm việc"
    Message="Bạn đang yêu cầu xóa ca"
    ItemName="@(_shiftToDelete?.Name ?? "")"
    OnConfirmed="ConfirmDeleteShift"
    OnCancelled="CloseDeleteModal" />

@if (_showAssignedObjects)
{
    <div class="drawer drawer-end drawer-on show shadow-sm" 
         style="width: 400px; z-index: 1060; position: fixed; top: 0; right: 0; bottom: 0; background: white; transition: all 0.3s ease-in-out; border-left: 1px solid #ebedf3;">
        <div class="card w-100 border-0 rounded-0 h-100 d-flex flex-column">
            <div class="card-header border-0 pt-7 px-8 min-h-auto pb-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bolder text-dark fs-3 mb-1">Đối tượng gán ca</span>
                    <span class="text-muted fw-bold fs-7">Ca: @(_selectedShiftForDetail?.Name ?? "N/A")</span>
                </h3>
                <div class="card-toolbar">
                    <button type="button" class="btn btn-sm btn-icon btn-active-light-primary" @onclick="CloseAssignedObjects">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </button>
                </div>
            </div>

            <div class="card-body py-5 px-8 overflow-auto flex-grow-1">
                @if (_isLoadingDetail)
                {
                    <div class="d-flex flex-column flex-center py-20">
                        <div class="spinner-border text-primary mb-5" role="status"></div>
                        <span class="text-muted fs-7 fw-bold">Đang tải danh sách...</span>
                    </div>
                }
                else if (!_allAssignedEmployees.Any())
                {
                    <div class="d-flex flex-column flex-center py-10 bg-light-light rounded-4 border border-dashed text-center px-4">
                        <i class="ki-outline ki-user-cross fs-2x text-gray-400 mb-4"></i>
                        <span class="text-gray-600 fs-7 fw-bold mb-5">Chưa có ai được gán ca này trong tháng</span>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-stack mb-5">
                    <div class="d-flex flex-column">
                        <div class="fw-bold text-gray-700 fs-8 text-uppercase ls-1">Nhân sự hiện tại (@_totalDetailCount)</div>
                        <div class="d-flex align-items-center gap-2 mt-2">
                             <div class="position-relative flex-grow-1">
                                <i class="ki-outline ki-magnifier fs-4 position-absolute ms-3 top-50 translate-middle-y text-gray-400"></i>
                                <input type="text" class="form-control form-control-solid form-control-sm ps-10 fs-10" 
                                       placeholder="Thêm nhân viên nhanh..." 
                                       @oninput="OnAddSearchInput" />
                            </div>
                            <button class="btn btn-sm btn-icon btn-light-warning ripple" 
                                    title="Gán ca (Nâng cao)"
                                    @onclick="() => OpenAssignDrawer(_selectedShiftForDetail)">
                                <i class="ki-outline ki-plus fs-3"></i>
                            </button>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(_quickAddSearch))
                    {
                        <div class="bg-light-light rounded-4 p-4 border border-dashed mb-5 mt-2">
                            <div class="fw-boldest text-gray-800 fs-9 mb-3 text-uppercase">Kết quả tìm kiếm:</div>
                            <div class="d-flex flex-column gap-2" style="max-height: 200px; overflow-y: auto;">
                                @foreach (var emp in _quickAddResults)
                                {
                                    <div class="d-flex align-items-center bg-white p-2 rounded-3 border border-gray-200">
                                        <div class="symbol symbol-30px me-3">
                                            <div class="symbol-label bg-light-primary text-primary fs-9 fw-bold">@emp.FullName?.Substring(0, 1)</div>
                                        </div>
                                        <div class="d-flex flex-column flex-grow-1">
                                            <span class="text-gray-900 fw-bold fs-9">@emp.FullName</span>
                                            <span class="text-muted fs-11">@emp.Code</span>
                                        </div>
                                        <button class="btn btn-xs btn-light-success fw-boldest" @onclick="() => QuickAddEmployee(emp)">
                                            + GÁN
                                        </button>
                                    </div>
                                }
                                @if (!_quickAddResults.Any())
                                {
                                    <div class="text-center py-2 text-muted fs-11">Không tìm thấy nhân viên</div>
                                }
                            </div>
                        </div>
                    }

                    <div class="d-flex flex-stack mb-5">
                            <button class="btn btn-icon btn-xs btn-light-primary @(_detailPageIndex <= 1 ? "disabled" : "")" 
                                    @onclick="() => ChangeDetailPage(_detailPageIndex - 1)">
                                <i class="ki-outline ki-arrow-left fs-9"></i>
                            </button>
                            <span class="fs-9 fw-boldest text-gray-800 px-2">@_detailPageIndex/@_totalDetailPages</span>
                            <button class="btn btn-icon btn-xs btn-light-primary @(_detailPageIndex >= _totalDetailPages ? "disabled" : "")" 
                                    @onclick="() => ChangeDetailPage(_detailPageIndex + 1)">
                                <i class="ki-outline ki-arrow-right fs-9"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="d-flex flex-column gap-3">
                        @foreach (var emp in _pagedAssignedEmployees)
                        {
                            <div class="d-flex align-items-center bg-white rounded-3 p-3 border border-gray-200 hover-bg-light transition-all">
                                <div class="symbol symbol-35px me-3">
                                    <div class="symbol-label bg-light-warning text-warning fw-bold fs-7">
                                        @(emp.EmployeeName?.Substring(0, 1))
                                    </div>
                                </div>
                                <div class="d-flex flex-column flex-grow-1">
                                    <span class="text-gray-900 fw-bold fs-7">@emp.EmployeeName</span>
                                    <span class="text-muted fs-10">@emp.EmployeeCode • @emp.Department</span>
                                </div>
                                <div class="text-end d-flex align-items-center gap-2">
                                    <div class="d-flex flex-column align-items-end">
                                        <div class="badge badge-light-primary fw-bold fs-10 px-2 py-1">
                                            @{
                                                var dayCount = emp.Schedules.Count(s => s.ShiftId == _selectedShiftForDetail?.Id);
                                                @($"{dayCount} ngày")
                                            }
                                        </div>
                                        <div class="mt-1">
                                             @{
                                                 var shiftDays = emp.Schedules.Where(s => s.ShiftId == _selectedShiftForDetail?.Id).OrderBy(s => s.Date).ToList();
                                                 if (shiftDays.Any())
                                                 {
                                                     <span class="text-gray-500 fs-10 fw-semibold">@shiftDays.First().Date.ToString("dd/MM")-@shiftDays.Last().Date.ToString("dd/MM")</span>
                                                 }
                                             }
                                        </div>
                                    </div>
                                    <button class="btn btn-icon btn-sm btn-light-danger btn-active-danger ripple ms-2" 
                                            title="Gỡ khỏi ca"
                                            @onclick="() => RemoveAssignment(emp)">
                                        <i class="ki-outline ki-trash fs-5"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    @if (_totalDetailPages > 1)
                    {
                        <div class="mt-5 d-flex justify-content-center">
                            <ul class="pagination pagination-outline">
                                @for (int i = 1; i <= _totalDetailPages; i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(pageNum == _detailPageIndex ? "active" : "")">
                                        <button class="page-link py-1 px-3 fs-9 fw-boldest" @onclick="() => ChangeDetailPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
            
            <div class="card-footer border-0 py-6 px-10 bg-light-light">
                <button class="btn btn-primary w-100 fw-bold" @onclick='() => NavigationManager.NavigateTo("/attendance/scheduler")'>
                    <i class="ki-outline ki-calendar-8 fs-3 me-2"></i>Xem lịch tổng quát
                </button>
            </div>
        </div>
    </div>
    
    <div class="modal-backdrop fade show" style="z-index: 1055; background-color: rgba(0,0,0,0.2) !important;" @onclick="CloseAssignedObjects"></div>
}

<!-- Employee Selection Drawer -->
<EmployeeSelectionDrawer 
    Title="@($"Gán ca làm việc: {(_assigningShift?.Name ?? "")}")"
    IsVisible="@_showAssignDrawer"
    IsVisibleChanged="@(val => _showAssignDrawer = val)"
    Employees="@_allEmployees"
    InitialSelectedIds="@_initialSelectedEmployeesForAssign"
    IsLoading="@_isAssigning"
    OnSave="HandleAssignSchedule">
    
    <div class="row g-5">
        <div class="col-md-6">
            <label class="form-label fs-8 fw-bold text-gray-700 required">Từ ngày</label>
            <input type="date" class="form-control form-control-solid fs-7" 
                   value="@(_assignStartDate.ToString("yyyy-MM-dd"))" 
                   @onchange="@(e => _assignStartDate = DateTime.Parse(e.Value?.ToString() ?? DateTime.Today.ToString("yyyy-MM-dd")))" />
        </div>
        <div class="col-md-6">
            <label class="form-label fs-8 fw-bold text-gray-700 required">Đến ngày</label>
            <input type="date" class="form-control form-control-solid fs-7" 
                   value="@(_assignEndDate.ToString("yyyy-MM-dd"))" 
                   @onchange="@(e => _assignEndDate = DateTime.Parse(e.Value?.ToString() ?? DateTime.Today.ToString("yyyy-MM-dd")))" />
        </div>
    </div>
</EmployeeSelectionDrawer>

