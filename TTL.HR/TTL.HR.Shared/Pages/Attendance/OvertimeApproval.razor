@page "/attendance/overtime"

<div class="d-flex flex-column flex-column-fluid">
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">Phê duyệt Tăng ca</h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a href="/dashboard" class="text-muted text-hover-primary">Bảng điều khiển</a>
                    </li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-500 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-muted">Quản lý Chấm công</li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-500 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-gray-900">Danh sách Tăng ca</li>
                </ul>
            </div>
        </div>
    </div>

    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-fluid">
            <!-- Stats -->
            <div class="row g-5 g-xl-10 mb-5 mb-xl-10">
                <div class="col-md-3">
                    <div class="card card-flush h-md-100 shadow-sm">
                        <div class="card-header pt-5">
                            <div class="card-title d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">@_summary.PendingCount</span>
                                <span class="text-gray-500 pt-1 fw-semibold fs-6">Đang chờ duyệt</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-end pe-0">
                            <span class="fs-6 fw-bolder text-warning">Yêu cầu mới cần xử lý</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card card-flush h-md-100 shadow-sm">
                        <div class="card-header pt-5">
                            <div class="card-title d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">@_summary.ApprovedCount</span>
                                <span class="text-gray-500 pt-1 fw-semibold fs-6">Đã phê duyệt</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-end pe-0">
                            <span class="fs-6 fw-bolder text-success">Tính vào lương tháng</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card card-flush h-md-100 shadow-sm">
                        <div class="card-header pt-5">
                            <div class="card-title d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">@_summary.TotalHours.ToString("F1")</span>
                                <span class="text-gray-500 pt-1 fw-semibold fs-6">Tổng giờ OT</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-end pe-0">
                            <span class="fs-6 fw-bolder text-primary">Tổng cộng tháng này</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card card-flush h-md-100 shadow-sm bg-light-danger border-danger border-dashed">
                        <div class="card-header pt-5">
                            <div class="card-title d-flex flex-column">
                                <span class="fs-2hx fw-bold text-danger me-2 lh-1 ls-n2">@_summary.RejectedCount</span>
                                <span class="text-danger pt-1 fw-semibold fs-6">Đã từ chối</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-end pe-0">
                            <span class="fs-6 fw-bolder text-danger">Yêu cầu không hợp lệ</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- List -->
            <div class="card shadow-sm">
                <div class="card-header border-0 pt-6">
                    <div class="card-title">
                        <div class="d-flex align-items-center position-relative my-1">
                            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
                            <input type="text" @oninput="Search" class="form-control form-control-solid w-250px ps-13" placeholder="Tìm tên, mã NV..." />
                        </div>
                    </div>
                    <div class="card-toolbar">
                        <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
                            <li class="nav-item">
                                <a class="nav-link text-active-primary py-5 me-6 @(activeTab == 0 ? "active" : "")" href="javascript:void(0)" @onclick="() => SetTab(0)">Chờ duyệt</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-active-primary py-5 me-6 @(activeTab == 1 ? "active" : "")" href="javascript:void(0)" @onclick="() => SetTab(1)">Đã duyệt</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-active-primary py-5 me-6 @(activeTab == 2 ? "active" : "")" href="javascript:void(0)" @onclick="() => SetTab(2)">Từ chối</a>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="card-body py-4">
                    <div class="table-responsive">
                        <table class="table align-middle table-row-dashed fs-6 gy-5">
                            <thead>
                                <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                                    <th class="min-w-125px">Nhân viên</th>
                                    <th class="min-w-125px">Ngày</th>
                                    <th class="text-center min-w-100px">Khung giờ</th>
                                    <th class="text-center min-w-100px">Số giờ</th>
                                    <th class="text-center min-w-100px">Hệ số</th>
                                    <th class="min-w-125px">Lý do</th>
                                    <th class="min-w-100px text-center">Trạng thái</th>
                                    <th class="text-end min-w-100px">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="text-gray-600 fw-semibold">
                                @if (_isLoading)
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-10">
                                            <div class="spinner-border text-primary" role="status">
                                                <span class="visually-hidden">Loading...</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else if (!_requests.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-10">Không có dữ liệu tăng ca.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var req in _requests)
                                    {
                                        <tr>
                                            <td class="d-flex align-items-center">
                                                <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                                                    <a href="javascript:void(0)">
                                                        <div class="symbol-label">
                                                            <img src="@req.AvatarUrl" alt="@req.EmployeeName" class="w-100" />
                                                        </div>
                                                    </a>
                                                </div>
                                                <div class="d-flex flex-column">
                                                    <a href="javascript:void(0)" class="text-gray-800 text-hover-primary mb-1 fw-bold">@req.EmployeeName</a>
                                                    <span>@req.EmployeeCode - @req.DepartmentName</span>
                                                </div>
                                            </td>
                                            <td>@req.Date.ToString("dd/MM/yyyy")</td>
                                            <td class="text-center">
                                                <code class="fs-8 text-primary">@req.StartTime - @req.EndTime</code>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-light-primary fw-bold">@req.Hours.ToString("F1")h</span>
                                            </td>
                                            <td class="text-center">x @req.Multiplier</td>
                                            <td>
                                                <div class="text-gray-800 fw-bold">@req.Reason</div>
                                                @if (!string.IsNullOrEmpty(req.ManagerNote))
                                                {
                                                    <div class="text-muted fs-8 italic mt-1">Ghi chú: @req.ManagerNote</div>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-light-@req.Color">@req.Status</span>
                                            </td>
                                            <td class="text-end">
                                                @if (req.StatusId == 1 || req.Status == "Pending")
                                                {
                                                    <button class="btn btn-icon btn-active-light-success w-30px h-30px me-1" @onclick="() => ApproveRequest(req)" title="Phê duyệt">
                                                        <i class="ki-outline ki-check fs-3"></i>
                                                    </button>
                                                    <button class="btn btn-icon btn-active-light-danger w-30px h-30px" @onclick="() => RejectRequest(req)" title="Từ chối">
                                                        <i class="ki-outline ki-cross fs-3"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-light btn-active-light-primary" @onclick="() => OpenDetail(req)">Chi tiết</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="row">
                        <div class="col-sm-12 col-md-5 d-flex align-items-center justify-content-center justify-content-md-start">
                            <div class="text-muted fs-7">Hiển thị @_requests.Count trong @_totalCount bản ghi</div>
                        </div>
                        <div class="col-sm-12 col-md-7 d-flex align-items-center justify-content-center justify-content-md-end">
                            <ul class="pagination">
                                <li class="page-item previous @(_pageIndex == 1 ? "disabled" : "")">
                                    <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(_pageIndex - 1)"><i class="previous"></i></a>
                                </li>
                                @for (int i = 1; i <= TotalPages; i++)
                                {
                                    var p = i;
                                    <li class="page-item @(_pageIndex == p ? "active" : "")">
                                        <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(p)">@p</a>
                                    </li>
                                }
                                <li class="page-item next @(_pageIndex == TotalPages ? "disabled" : "")">
                                    <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(_pageIndex + 1)"><i class="next"></i></a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<GenericActionModal IsVisible="_showActionModal"
                    Title="@_modalTitle"
                    Heading="@_modalHeading"
                    Message="@_modalMessage"
                    Color="@_modalColor"
                    Icon="@_modalIcon"
                    ConfirmLabel="@_modalConfirmLabel"
                    ShowReasonInput="_showReasonInput"
                    OnCancelled="CloseModal"
                    OnConfirmed="ConfirmAction" />
