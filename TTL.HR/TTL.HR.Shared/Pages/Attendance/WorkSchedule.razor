@page "/attendance/schedule"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <!-- Filters -->
        <div class="card mb-8 shadow-sm">
            <div class="card-body py-4 px-6">
                <div class="d-flex flex-wrap align-items-center">
                    <!-- Search -->
                    <div class="position-relative w-md-250px me-4 my-1">
                        <span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"></path>
                            </svg>
                        </span>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm theo tên, mã NV..." @bind="_searchTerm" @bind:event="oninput" @onkeyup="@(() => ApplyFilters())" />
                    </div>

                    <!-- Department -->
                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold" @onchange="OnDepartmentChange">
                            <option value="">Phòng ban: Tất cả</option>
                            @foreach (var dept in _departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Type -->
                    <div class="w-md-150px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold" @onchange="OnShiftTypeChange">
                            <option value="">Ca làm việc: Tất cả</option>
                            @foreach (var sh in _shifts)
                            {
                                <option value="@sh.Id">@sh.Name</option>
                            }
                        </select>
                    </div>

                    <div class="ms-auto my-1">
                        <button class="btn btn-light-primary fw-bold fs-7 px-6" @onclick="RefreshData"><i class="bi bi-arrow-clockwise me-1"></i>Làm mới</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Selection Bar -->
        <div class="d-flex flex-stack mb-6">
            <div class="d-flex align-items-center">
                <div class="form-check form-check-sm form-check-custom form-check-solid me-5">
                    <input class="form-check-input" type="checkbox" id="check_all_staff" checked="@_isAllSelected" @onchange="ToggleSelectAll" />
                    <label class="form-check-label fw-bold text-gray-700 fs-7 ms-2 text-nowrap" for="check_all_staff">Đã chọn @_selectedEmpIds.Count nhân viên</label>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-primary px-4 py-2 fs-8 fw-semibold" @onclick="OpenBulkAssign" disabled="@(_selectedEmpIds.Count == 0)"><i class="bi bi-calendar-check fs-7 me-1"></i>Cập nhật lịch</button>
                <button class="btn btn-sm btn-light fw-bolder px-5 text-gray-700 border" @onclick="ExportExcel"><i class="bi bi-file-earmark-excel me-2"></i>Xuất Excel</button>
            </div>
        </div>

        <!-- Table -->
        <div class="card shadow-sm border-0">
            <div class="card-header border-0 pt-5">
                <div class="card-title">
                    <h3 class="card-label fw-bolder text-dark">Lịch làm việc nhân viên</h3>
                    <span class="text-muted mt-1 fw-bold fs-7 ms-2">Tuần: @_startDate.ToString("dd/MM") - @_endDate.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="card-toolbar">
                    <div class="d-flex align-items-center">
                        <button class="btn btn-icon btn-sm btn-light-primary me-2" @onclick="() => ChangeWeek(-1)"><i class="bi bi-chevron-left"></i></button>
                        <div class="position-relative">
                            <i class="bi bi-calendar-range fs-4 position-absolute ms-4 mt-2 text-primary"></i>
                            <input type="text" class="form-control form-control-white form-control-sm w-225px ps-12 fs-7 fw-bold border-gray-300" readonly value="@_startDate.ToString("dd/MM/yyyy") - @_endDate.ToString("dd/MM/yyyy")" />
                        </div>
                        <button class="btn btn-icon btn-sm btn-light-primary ms-2" @onclick="() => ChangeWeek(1)"><i class="bi bi-chevron-right"></i></button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10" Columns="5">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5">
                            <thead>
                                <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
                                    <th class="w-10px pe-2"></th>
                                    <th class="min-w-200px cursor-pointer hover-primary" @onclick='() => SortBy("Name")'>
                                        NHÂN VIÊN 
                                        @if (_sortBy == "Name") { <i class="bi bi-chevron-@(_isAsc ? "up" : "down") ms-1 fs-9"></i> }
                                    </th>
                                    <th class="min-w-150px cursor-pointer hover-primary" @onclick='() => SortBy("Dept")'>
                                        PHÒNG BAN
                                        @if (_sortBy == "Dept") { <i class="bi bi-chevron-@(_isAsc ? "up" : "down") ms-1 fs-9"></i> }
                                    </th>
                                    <th class="min-w-250px cursor-pointer hover-primary" @onclick='() => SortBy("Shift")'>
                                        CA LÀM VIỆC HIỆN TẠI
                                        @if (_sortBy == "Shift") { <i class="bi bi-chevron-@(_isAsc ? "up" : "down") ms-1 fs-9"></i> }
                                    </th>
                                    <th class="min-w-150px">GÁN CA MỚI</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in _pagedSchedules)
                                {
                                    <tr class="hover-elevate cursor-pointer" @onclick="() => openDetail(emp)">
                                        <td>
                                            <div class="form-check form-check-sm form-check-custom form-check-solid">
                                                <input class="form-check-input staff-checkbox" type="checkbox" checked="@_selectedEmpIds.Contains(emp.Id)" @onchange="@(e => ToggleSelectEmp(emp.Id, e))" @onclick:stopPropagation />
                                            </div>
                                        </td>
                                        <td class="d-flex align-items-center">
                                            <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                                                <a href="javascript:;" class="kt_drawer_employee_detail_toggle" @onclick="() => openDetail(emp)">
                                                    @if (!string.IsNullOrEmpty(emp.Avatar))
                                                    {
                                                        <div class="symbol-label"><img src="@emp.Avatar" alt="@emp.EmployeeName" class="w-100" /></div>
                                                    }
                                                    else
                                                    {
                                                        <div class="symbol-label bg-light-primary text-primary fw-bolder">@(emp.EmployeeName?.Length > 0 ? emp.EmployeeName.Substring(0, 1) : "N")</div>
                                                    }
                                                </a>
                                            </div>
                                            <div class="d-flex flex-column">
                                                <a href="javascript:;" class="kt_drawer_employee_detail_toggle text-gray-900 fw-bold text-hover-primary mb-1 fs-6" @onclick="() => openDetail(emp)">@emp.EmployeeName</a>
                                                <span class="text-muted fw-semibold fs-7">@emp.EmployeeCode</span>
                                            </div>
                                        </td>
                                        <td><span class="text-gray-700 fs-7 fw-bold">@emp.Department</span></td>
                                        <td>
                                            <span class="badge @(GetShiftClass(emp.ShiftColor, "badge-light-")) fw-bold px-4 py-2 rounded-pill d-inline-flex align-items-center" style="@(GetShiftStyle(emp.ShiftColor))">
                                                <span class="bullet bullet-dot @(GetShiftClass(emp.BulletBg, "bg-")) w-6px h-6px me-2" style="@(GetShiftStyle(emp.BulletBg))"></span>@emp.CurrentShift
                                            </span>
                                            @if (emp.IsNextShiftAssigned)
                                            {
                                                <i class="bi bi-arrow-right text-gray-400 mx-2"></i>
                                                <span class="badge badge-light-secondary fw-bold px-3 py-1 fs-9">@emp.NextShift</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm shadow-sm" title="Điều chỉnh lịch" @onclick="() => openDetail(emp)" @onclick:stopPropagation>
                                                <i class="ki-outline ki-calendar-edit fs-3"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination -->
                    <div class="d-flex flex-stack flex-wrap px-7 py-5">
                        <div class="fs-7 fw-bold text-gray-700">Hiển thị @(_pagedSchedules.Count) trong tổng số @(_filteredSchedules.Count) nhân viên</div>
                        <ul class="pagination">
                            <li class="page-item previous @(_currentPage == 1 ? "disabled" : "")">
                                <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(_currentPage - 1)">
                                    <i class="ki-outline ki-left fs-6"></i>
                                </a>
                            </li>

                            @if (_totalPages <= 7)
                            {
                                @for (int i = 1; i <= _totalPages; i++)
                                {
                                    <li class="page-item @(i == _currentPage ? "active" : "")">
                                        <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(i)">@i</a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="page-item @(1 == _currentPage ? "active" : "")">
                                    <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(1)">1</a>
                                </li>
                                @if (_currentPage > 3) { <li class="page-item disabled"><a class="page-link">...</a></li> }

                                @for (int i = Math.Max(2, _currentPage - 1); i <= Math.Min(_totalPages - 1, _currentPage + 1); i++)
                                {
                                    <li class="page-item @(i == _currentPage ? "active" : "")">
                                        <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(i)">@i</a>
                                    </li>
                                }

                                @if (_currentPage < _totalPages - 2) { <li class="page-item disabled"><a class="page-link">...</a></li> }
                                <li class="page-item @(_totalPages == _currentPage ? "active" : "")">
                                    <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(_totalPages)">@_totalPages</a>
                                </li>
                            }

                            <li class="page-item next @(_currentPage == _totalPages ? "disabled" : "")">
                                <a href="javascript:void(0)" class="page-link" @onclick="() => ChangePage(_currentPage + 1)">
                                    <i class="ki-outline ki-right fs-6"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
                </SkeletonLoading>
            </div>
        </div>

        <div class="notice d-flex bg-light-primary rounded border-primary border border-dashed p-6 mb-8 mt-5">
            <i class="ki-outline ki-information-5 fs-2hx text-primary me-4"></i>
            <div class="d-flex flex-stack flex-grow-1">
                <div class="fw-bold">
                    <h4 class="text-gray-900 fw-bolder fs-6 mb-1">Lưu ý khi gán ca làm việc</h4>
                    <div class="fs-7 text-gray-700 lh-lg">
                        1. Lịch làm việc mới sẽ có hiệu lực từ ngày kế tiếp sau khi được phê duyệt.<br/>
                        2. Đối với các ca đặc thù (ca đêm, ca gãy), hệ thống sẽ tự động tính toán phụ cấp tương ứng.<br/>
                        3. Đảm bảo nhân viên có đủ thời gian nghỉ ngơi ít nhất 11 tiếng giữa 2 ca làm việc.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SCHEDULE DETAIL DRAWER -->
<div class="bg-white drawer drawer-end @(_showDetail ? "drawer-on" : "")" 
     style="width: 500px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showDetail ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <!-- Header -->
        <div class="card-header pe-5">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column me-3">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">
                        @(_selectedSchedule != null ? "Chi tiết lịch làm việc" : "Cập nhật lịch hàng loạt")
                    </span>
                    <span class="fs-7 fw-bold text-muted mt-2">
                        @(_selectedSchedule != null ? $"Mã NV: {_selectedSchedule.EmployeeId}" : $"Đang chọn: {_assignModel.EmployeeIds.Count} nv")
                    </span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeDetail">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="card-body hover-scroll-overlay-y">
            @if (_selectedSchedule != null)
            {
                <!-- Employee Info -->
                <div class="d-flex align-items-center bg-light-primary rounded p-5 mb-8 border border-primary border-dashed">
                    <div class="symbol symbol-70px symbol-circle me-5">
                        <div class="symbol-label">
                            @if (!string.IsNullOrEmpty(_selectedSchedule.Avatar))
                            {
                                <img src="@_selectedSchedule.Avatar" alt="@_selectedSchedule.EmployeeName" class="w-100" />
                            }
                            else
                            {
                                <div class="symbol-label bg-light-primary text-primary fs-2 fw-bold">@_selectedSchedule.EmployeeName.Substring(0, 1)</div>
                            }
                        </div>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-primary fw-bolder fs-5">@_selectedSchedule.EmployeeName</span>
                        <span class="text-muted fw-bold fs-7 mb-1">@_selectedSchedule.Department</span>
                        <div class="d-flex flex-wrap gap-2 mt-1">
                            <span class="badge @(GetShiftClass(_selectedSchedule.ShiftColor, "badge-light-")) fw-bold fs-9 px-2 py-1" style="@(GetShiftStyle(_selectedSchedule.ShiftColor))">@_selectedSchedule.CurrentShift</span>
                        </div>
                    </div>
                </div>

                <!-- Shift Details Card -->
                <div class="card bg-light-light mb-8 border-0">
                    <div class="card-body p-6">
                        <h3 class="fw-bolder fs-6 mb-5 text-gray-800 text-uppercase">Thông tin ca hiện tại</h3>
                        <div class="d-flex flex-column gap-4">
                            <div class="d-flex flex-stack fs-7">
                                <span class="text-muted fw-bold">Mã ca:</span>
                                <span class="text-gray-800 fw-bolder">
                                    @{
                                        var currentShiftObj = _shifts.FirstOrDefault(s => s.Id == _selectedSchedule.CurrentShiftId);
                                        @currentShiftObj?.Code
                                    }
                                </span>
                            </div>
                            <div class="d-flex flex-stack fs-7">
                                <span class="text-muted fw-bold">Thời gian:</span>
                                <span class="text-gray-800 fw-bolder">
                                    @(currentShiftObj != null ? $"{currentShiftObj.StartTime} - {currentShiftObj.EndTime}" : "N/A")
                                </span>
                            </div>
                            <!-- Static content for stats -->
                        </div>
                    </div>
                </div>

                <!-- Schedule History / Calendar Mini -->
                <h3 class="fw-bolder fs-6 mb-5 text-gray-800 text-uppercase">Lịch làm việc tuần này</h3>
                <div class="row g-2 mb-8">
                    @{
                        var days = new[] { "T2", "T3", "T4", "T5", "T6", "T7", "CN" };
                        for (int i = 0; i < days.Length; i++)
                        {
                            var dayLabel = days[i];
                            var shiftCode = _selectedSchedule.WeeklySchedule.Count > i ? _selectedSchedule.WeeklySchedule[i] : "-";
                            <div class="col">
                                <div class="border rounded py-3 px-0 text-center bg-white @(dayLabel == "CN" ? "bg-light-danger opacity-75" : "")" style="min-width: 0;">
                                    <div class="fs-10 fw-bold text-muted mb-1">@dayLabel</div>
                                    <div class="fs-9 fw-bolder @(dayLabel == "CN" ? "text-danger" : "text-gray-800")">@shiftCode</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }

            <!-- Assignment Section (Shared) -->
            <div class="border-top pt-5">
                <h3 class="fw-bolder fs-6 mb-5 text-gray-800 text-uppercase">
                    @(_selectedSchedule != null ? "Gán lịch làm việc tháng tới" : "Thiết lập lịch làm việc chung")
                </h3>
                <div class="mb-5">
                    <label class="form-label fs-7 fw-bold text-gray-700">Chọn ca làm việc mới</label>
                    <select class="form-select form-select-solid fs-7" @bind="_assignModel.ShiftId">
                        <option value="">-- Chọn ca làm việc --</option>
                        @foreach (var shift in _shifts)
                        {
                            <option value="@shift.Id">@shift.Name (@shift.StartTime - @shift.EndTime)</option>
                        }
                    </select>
                </div>
                <div class="row g-5 mb-5">
                    <div class="col-md-6">
                        <label class="form-label fs-7 fw-bold text-gray-700">Ngày bắt đầu</label>
                        <input type="date" class="form-control form-control-solid fs-7" @bind="_assignModel.StartDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fs-7 fw-bold text-gray-700">Ngày kết thúc</label>
                        <input type="date" class="form-control form-control-solid fs-7" @bind="_assignModel.EndDate" />
                    </div>
                </div>
                <div class="mb-5">
                    <label class="form-label fs-7 fw-bold text-gray-700 d-block mb-3">Ngày áp dụng trong tuần</label>
                    <div class="d-flex flex-wrap gap-4">
                        @foreach (var day in Enum.GetValues<DayOfWeek>())
                        {
                            var dayName = GetDayName(day);
                            <div class="form-check form-check-custom form-check-solid">
                                <input class="form-check-input" type="checkbox" id="day_@day" 
                                       checked="@_assignModel.DaysOfWeek.Contains(day)" 
                                       @onchange="@(e => ToggleDayOfWeek(day, e))" />
                                <label class="form-check-label text-gray-700 fs-7" for="day_@day">@dayName</label>
                            </div>
                        }
                    </div>
                </div>
                 <div class="mb-5">
                    <label class="form-label fs-7 fw-bold text-gray-700">Ghi chú</label>
                    <textarea class="form-control form-control-solid fs-7" rows="3" @bind="_assignModel.Note"></textarea>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="card-footer border-0 d-flex gap-3 justify-content-between p-10">
            <button type="button" class="btn btn-light flex-grow-1 fs-7 fw-bold" @onclick="closeDetail">Hủy bỏ</button>
            <button type="button" class="btn btn-primary flex-grow-1 fs-7 fw-bold" @onclick="SaveSchedule" disabled="@(_isProcessing)">
                @if (_isProcessing) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Lưu thay đổi
            </button>
        </div>
    </div>
</div>

<!-- Backdrop -->
@if (_showDetail)
{
    <div class="drawer-overlay" style="z-index: 105; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="closeDetail"></div>
}


