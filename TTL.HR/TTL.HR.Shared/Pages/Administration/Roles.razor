@page "/administration/roles"

<div class="d-flex flex-column flex-column-fluid">
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">
                    Roles & Permissions
                </h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted"><a href="/" class="text-muted text-hover-primary">Home</a></li>
                    <li class="breadcrumb-item"><span class="bullet bg-gray-400 w-5px h-2px"></span></li>
                    <li class="breadcrumb-item text-muted">Administration</li>
                </ul>
            </div>
            <div class="d-flex align-items-center gap-2 gap-lg-3">
                <button class="btn btn-primary" @onclick="OpenCreateRoleModal">
                    <i class="fas fa-plus fs-2"></i> Create Role
                </button>
            </div>
        </div>
    </div>

    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-xxl">
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-5 g-xl-9">
                @foreach (var role in RoleList)
                {
                    <div class="col-md-4">
                        <div class="card card-flush h-md-100">
                            <div class="card-header">
                                <div class="card-title">
                                    <h2>@role.Name</h2>
                                </div>
                            </div>
                            <div class="card-body pt-1">
                                <div class="fw-bold text-gray-600 mb-5">Total users with this role: @role.UserCount</div>
                                <div class="d-flex flex-column text-gray-600">
                                    @foreach (var perm in role.Permissions.Take(5))
                                    {
                                        <div class="d-flex align-items-center py-2">
                                            <span class="bullet bg-primary me-3"></span> @perm
                                        </div>
                                    }
                                    @if(role.Permissions.Count > 5)
                                    {
                                        <div class='d-flex align-items-center py-2'>
                                            <span class='bullet bg-primary me-3'></span> <em>and @(role.Permissions.Count - 5) more...</em>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="card-footer flex-wrap pt-0">
                                <button type="button" class="btn btn-light btn-active-light-primary my-1 me-2" @onclick="() => ViewRole(role)">View Role</button>
                                <button type="button" class="btn btn-light btn-active-light-primary my-1" @onclick="() => EditRole(role)">Edit Role</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<RoleViewModel> RoleList = new();

    protected override void OnInitialized()
    {
        // Mock data
        RoleList = new List<RoleViewModel>
        {
            new RoleViewModel { 
                Name = "Administrator", 
                UserCount = 5, 
                Permissions = new List<string> { "All Permissions", "System Management", "User Management" } 
            },
            new RoleViewModel { 
                Name = "HR Manager", 
                UserCount = 2, 
                Permissions = new List<string> { "Employee Management", "Recruitment", "Training", "Payroll View" } 
            },
            new RoleViewModel { 
                Name = "Developer", 
                UserCount = 15, 
                Permissions = new List<string> { "Task Management", "Time Logging", "Project View" } 
            },
             new RoleViewModel { 
                Name = "Analyst", 
                UserCount = 3, 
                Permissions = new List<string> { "Report View", "Data Analysis" } 
            },
             new RoleViewModel { 
                Name = "Support", 
                UserCount = 6, 
                Permissions = new List<string> { "Ticket Management", "Customer View" } 
            }
        };
    }

    private void OpenCreateRoleModal() { /* Logic to open modal */ }
    private void ViewRole(RoleViewModel role) { /* Logic to view role */ }
    private void EditRole(RoleViewModel role) { /* Logic to edit role */ }

    public class RoleViewModel
    {
        public string Name { get; set; }
        public int UserCount { get; set; }
        public List<string> Permissions { get; set; } = new();
    }
}
