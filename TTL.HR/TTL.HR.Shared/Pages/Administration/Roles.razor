@page "/administration/roles"
@using TTL.HR.Application.Modules.Common.Models
@using TTL.HR.Application.Modules.Common.Interfaces

<PageTitle>Quản lý Vai trò - TTL.HR</PageTitle>

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
        <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
            <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">Quản lý Vai trò</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                <li class="breadcrumb-item text-muted"> <a href="/" class="text-muted text-hover-primary">Trang chủ</a> </li>
                <li class="breadcrumb-item"> <span class="bullet bg-gray-400 w-5px h-2px"></span> </li>
                <li class="breadcrumb-item text-muted">Quản trị</li>
                <li class="breadcrumb-item"> <span class="bullet bg-gray-400 w-5px h-2px"></span> </li>
                <li class="breadcrumb-item text-dark">Vai trò</li>
            </ul>
        </div>
        <div class="d-flex align-items-center gap-2 gap-lg-3">
            <div class="d-flex align-items-center position-relative my-1">
                <i class="ki-outline ki-magnifier fs-4 position-absolute ms-4 text-gray-500"></i>
                <input type="text" class="form-control form-control-sm form-control-solid w-200px ps-12" 
                       placeholder="Tìm vai trò..." @bind="RoleSearchTerm" @bind:event="oninput" @onkeyup="HandleRoleSearch" />
            </div>
            <button type="button" class="btn btn-sm btn-primary fw-bold" @onclick="openAddRole">
                <i class="ki-outline ki-plus fs-2"></i> Tạo vai trò
            </button>
        </div>
    </div>
</div>

<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-fluid">
        @if (_isLoading)
        {
            <div class="d-flex justify-content-center py-20">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-5 g-xl-9">
                @if (!_roles.Any() && !string.IsNullOrEmpty(RoleSearchTerm))
                {
                    <div class="col-12 text-center py-20">
                        <div class="text-muted fs-5 fw-bold">Không tìm thấy vai trò nào phù hợp với từ khóa "@RoleSearchTerm"</div>
                        <button class="btn btn-link py-2" @onclick="ClearRoleSearch">Xóa tìm kiếm</button>
                    </div>
                }
                @foreach (var role in _roles)
                {
                    <div class="col-md-4">
                        <div class="card card-flush h-md-100 shadow-sm border-0 hover-elevate">
                            <div class="card-header pt-7">
                                <div class="card-title">
                                    <h2 class="fw-bolder fs-3 text-gray-800">@role.Name</h2>
                                </div>
                            </div>
                            <div class="card-body pt-1">
                                <div class="fw-bolder text-gray-600 mb-5">Tổng số: <span class="text-primary">@role.UsersCount</span> người dùng</div>
                                <div class="d-flex flex-column text-gray-600 fs-7">
                                    @for (int i = 0; i < Math.Min(5, role.PermissionNames.Count); i++)
                                    {
                                        <div class="d-flex align-items-center py-1">
                                            <span class="bullet bg-primary opacity-50 me-3"></span>
                                            <span>@(role.PermissionNames[i])</span>
                                        </div>
                                    }
                                    @if (role.Permissions.Count > 5)
                                    {
                                        <div class="d-flex align-items-center py-1">
                                            <span class="bullet bg-gray-300 me-3"></span>
                                            <em class="text-muted">và @(role.Permissions.Count - 5) quyền khác...</em>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="card-footer flex-wrap pt-0 pb-7">
                                <button type="button" class="btn btn-light btn-sm me-2 fw-bold" @onclick="() => openRoleDetail(role)">
                                    <i class="ki-outline ki-information-5 fs-5 me-1"></i>Thành viên
                                </button>
                                <button type="button" class="btn btn-light-primary btn-sm me-2 fw-bold" @onclick="() => openEditRole(role)">
                                    <i class="ki-outline ki-pencil fs-5 me-1"></i>Sửa
                                </button>
                                @if (!role.IsSystem)
                                {
                                    <button type="button" class="btn btn-light-danger btn-sm fw-bold" @onclick="() => promptDeleteRole(role)">
                                        <i class="ki-outline ki-trash fs-5 me-1"></i>Xóa
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }

                <div class="col-md-4">
                    <div class="card h-md-100 shadow-sm border-dashed border-primary bg-light-primary bg-opacity-10 hover-elevate cursor-pointer" @onclick="openAddRole">
                        <div class="card-body d-flex flex-column flex-center p-10">
                            <i class="ki-outline ki-plus fs-3tx text-primary mb-3"></i>
                            <div class="fw-bolder fs-4 text-gray-800">Tạo vai trò mới</div>
                            <span class="fs-8 text-muted mt-2">Thiết lập nhóm quyền truy cập mới cho hệ thống</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- DRAWER TẠO VAI TRÒ MỚI -->
<div class="bg-white drawer drawer-end @(_showAddRoleDrawer ? "drawer-on" : "")" 
     style="width: 500px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 1060; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showAddRoleDrawer ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <div class="card-header pe-5 py-6">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">@(_isEditMode ? "Chỉnh sửa vai trò" : "Thiết lập vai trò mới")</span>
                    <span class="fs-8 fw-bold text-muted mt-2">@(_isEditMode ? "Cập nhật tên, mô tả và quyền hạn của vai trò" : "Cấu hình tên nhóm và các quyền cơ bản ban đầu")</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeAddRole">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <div class="card-body hover-scroll-overlay-y py-8 px-10">
            <div class="mb-5">
                <label class="required fs-7 fw-bold mb-3">Tên vai trò / Nhóm</label>
                <input type="text" class="form-control form-control-solid fs-7" placeholder="VD: Giám sát ATTT" @bind="_newRoleName" />
            </div>

            <div class="mb-10">
                <label class="fs-7 fw-bold mb-3">Mô tả</label>
                <textarea class="form-control form-control-solid fs-7" rows="2" placeholder="Ghi chú ngắn gọn về mục đích của vai trò..." @bind="_newRoleDescription"></textarea>
            </div>
            
            <div class="mb-10">
                <label class="fs-7 fw-bold mb-5">Danh sách quyền hạn</label>
                <div class="hover-scroll-y" style="max-height: 400px">
                    @foreach (var group in _availablePerms.GroupBy(x => x.Group))
                    {
                        <div class="mb-5">
                            <h6 class="fs-8 text-uppercase fw-bolder text-gray-600 mb-3 border-bottom pb-2">@group.Key</h6>
                            <div class="d-flex flex-column gap-3 ps-2">
                                @foreach (var p in group)
                                {
                                    <div class="form-check form-check-custom form-check-solid">
                                        <input class="form-check-input w-15px h-15px" type="checkbox" @bind="p.IsSelected" id="perm_@p.Id" />
                                        <label class="form-check-label" for="perm_@p.Id">
                                            <span class="fw-bold text-gray-800 fs-7">@p.Name</span>
                                            <span class="text-muted ms-1" style="font-size: 0.65rem">(@p.Code)</span>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card-footer py-6 px-10 border-0 bg-light-light d-flex gap-3 justify-content-end">
            <button type="button" class="btn btn-sm btn-light fw-bold px-6" @onclick="closeAddRole">Hủy bỏ</button>
            <button type="button" class="btn btn-sm btn-primary fw-bold px-6" @onclick="confirmCreateRole">@(_isEditMode ? "Lưu thay đổi" : "Tạo vai trò")</button>
        </div>
    </div>
</div>

<!-- DRAWER CHI TIẾT VAI TRÒ & GÁN NHÂN VIÊN -->
<div class="bg-white drawer drawer-end @(_showRoleDetailDrawer ? "drawer-on" : "")" 
     style="width: 800px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 1060; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showRoleDetailDrawer ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <div class="card-header pe-5 py-6">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Quản lý Vai trò: @(_selectedRole?.Name)</span>
                    <span class="fs-8 fw-bold text-muted mt-2">Thông tin quyền hạn và danh sách nhân viên được gán</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeRoleDetail">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <div class="card-body hover-scroll-overlay-y py-8 px-10">
            <!-- Thông tin quyền -->
            <div class="mb-10">
                <div class="d-flex flex-stack mb-5">
                    <span class="fw-bolder text-gray-800 fs-6">Danh sách quyền hạn</span>
                    <span class="badge badge-light-primary fs-7 fw-bold">Tổng: @(_selectedRole?.Permissions.Count) quyền</span>
                </div>
                <div class="row row-cols-2 g-3">
                    @if (_selectedRole != null)
                    {
                        @if (_selectedRole.PermissionNames.Any())
                        {
                            @foreach (var pName in _selectedRole.PermissionNames)
                            {
                                <div class="col">
                                    <div class="d-flex align-items-center p-3 rounded bg-light-light border border-dashed border-gray-300">
                                        <span class="bullet bg-primary me-3"></span>
                                        <span class="text-gray-700 fs-7">@pName</span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                             @foreach (var pId in _selectedRole.Permissions)
                             {
                                <div class="col">
                                    <div class="d-flex align-items-center p-3 rounded bg-light-light border border-dashed border-gray-300">
                                        <span class="bullet bg-primary me-3"></span>
                                        <span class="text-gray-700 fs-7">@GetPermissionName(pId)</span>
                                    </div>
                                </div>
                             }
                        }
                    }
                </div>
            </div>

            <div class="separator separator-dashed my-8"></div>

            <!-- Quản lý nhân viên -->
            <div class="d-flex flex-stack mb-5">
                <div class="d-flex align-items-center position-relative my-1">
                    <i class="ki-outline ki-magnifier fs-4 position-absolute ms-4"></i>
                    <input type="text" class="form-control form-control-solid w-250px ps-12 fs-7" placeholder="Tìm thành viên..." @bind="_memberSearchQuery" @bind:event="oninput" />
                </div>
                <button type="button" class="btn btn-primary btn-sm" @onclick="openAddUser">
                    <i class="ki-outline ki-plus fs-3 me-1"></i>Thêm nhân viên
                </button>
            </div>

            <div class="table-responsive">
                <table class="table align-middle table-row-dashed fs-7 gy-4">
                    <thead>
                        <tr class="text-start text-muted fw-bolder text-uppercase gs-0">
                            <th class="min-w-200px">Nhân viên</th>
                            <th class="min-w-100px">Mã NV</th>
                            <th class="text-end min-w-50px"></th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700 fw-bold">
                        @if (FilteredMembers.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center py-10">
                                    <div class="text-muted fs-8">Chưa có nhân viên nào trong vai trò này.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in FilteredMembers)
                            {
                                <tr>
                                    <td class="d-flex align-items-center">
                                        <div class="symbol symbol-circle symbol-35px overflow-hidden me-3">
                                            <div class="symbol-label">
                                                <img src="@(string.IsNullOrEmpty(user.Avatar) ? "assets/media/avatars/blank.png" : user.Avatar)" alt="" class="w-100" />
                                            </div>
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="text-gray-800 text-hover-primary mb-1 fs-7">@user.Name</span>
                                            <span class="fs-9 text-gray-500">@user.Department - @user.Position</span>
                                        </div>
                                    </td>
                                    <td><span class="badge badge-light fw-bold">@user.Code</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-icon btn-light-danger btn-sm" @onclick="() => removeUser(user)">
                                            <i class="ki-outline ki-trash fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- DRAWER CHỌN NHÂN VIÊN -->
<div class="bg-white drawer drawer-end @(_showUserPicker ? "drawer-on" : "")" 
     style="width: 500px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 1070; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showUserPicker ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <div class="card-header pe-5 py-6">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Thêm nhân viên vào vai trò</span>
                    <span class="fs-8 fw-bold text-muted mt-2">Chọn nhân viên để cấp quyền @(_selectedRole?.Name)</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeAddUser">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <div class="card-body hover-scroll-overlay-y py-8 px-10">
            <div class="mb-7">
                <div class="position-relative">
                    <i class="ki-outline ki-magnifier fs-3 position-absolute top-50 translate-middle-y ms-4"></i>
                    <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm tên hoặc mã NV..." @bind="_employeeSearchQuery" @bind:event="oninput" />
                </div>
            </div>
            
            <div class="separator separator-dashed my-5"></div>

            <div class="d-flex flex-column gap-5">
                @foreach (var emp in FilteredAvailableEmployees)
                {
                    <div class="d-flex flex-stack @(emp.IsSelected ? "bg-light-primary p-3 rounded" : "")">
                        <div class="d-flex align-items-center me-3">
                            <div class="symbol symbol-45px symbol-circle me-3">
                                <img src="@emp.Avatar" alt="" />
                            </div>
                            <div class="d-flex flex-column">
                                <span class="text-gray-800 fw-bold fs-6">@emp.Name</span>
                                <span class="text-muted fs-8">@emp.Code - @emp.Position</span>
                            </div>
                        </div>
                        <div class="form-check form-check-custom form-check-solid">
                            <input class="form-check-input" type="checkbox" @bind="emp.IsSelected" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card-footer py-6 px-10 border-0 bg-light-light d-flex gap-3 justify-content-end">
            <button type="button" class="btn btn-sm btn-light fw-bold px-6" @onclick="closeAddUser">Hủy bỏ</button>
            <button type="button" class="btn btn-sm btn-primary fw-bold px-6" @onclick="confirmAddUsers">Xác nhận thêm</button>
        </div>
    </div>
</div>

@if (_showUserPicker || _showAddRoleDrawer || _showRoleDetailDrawer)
{
    <div class="drawer-overlay" style="z-index: 1055; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="() => { closeAddUser(); closeAddRole(); closeRoleDetail(); }"></div>
}

<!-- Delete Confirmation Modal -->
<TTL.HR.Shared.Components.Common.DeleteConfirmationModal 
    IsVisible="@_isDeleteModalOpen"
    Title="Xóa Vai trò"
    Message="Bạn đang yêu cầu xóa vai trò"
    ItemName="@(_roleToDelete?.Name ?? "")"
    OnConfirmed="confirmDeleteRole"
    OnCancelled="closeDeleteModal" />
