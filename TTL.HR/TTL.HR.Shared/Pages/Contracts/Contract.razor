@page "/contracts"
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
<!-- Content -->
<div id="kt_content_container" class="card">
	<!-- Filter & Toolbar -->
	<div class=" card-flush mb-6">
		<div class="card-header border-0 pt-6">
			<!-- Search -->
			<div class="card-title">
				<div class="d-flex align-items-center position-relative my-1">
					<span class="svg-icon svg-icon-1 position-absolute ms-6">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
							<rect opacity="0.5" x="17.0365" y="15.1223" width="8.15546" height="2" rx="1" transform="rotate(45 17.0365 15.1223)" fill="currentColor"></rect>
							<path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"></path>
						</svg>
					</span>
					<input type="text" class="form-control form-control-solid w-250px ps-14" placeholder="Tìm kiếm mẫu hợp đồng..." @bind="SearchQuery" @bind:event="oninput" />
				</div>
			</div>

			<!-- Toolbar -->
			<div class="card-toolbar">
				<!-- Advanced Filter -->
				<button type="button" class="btn btn-light-primary me-3" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
					<span class="svg-icon svg-icon-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
							<path d="M19.0759 3H4.72777C3.95892 3 3.47768 3.83148 3.86067 4.49814L8.56967 12.6949C9.17923 13.7559 9.5 14.9582 9.5 16.1819V19.5072C9.5 20.2189 10.2223 20.7028 10.8805 20.432L13.8805 19.1977C14.2553 19.0435 14.5 18.6783 14.5 18.273V13.8372C14.5 12.8089 14.8171 11.8056 15.408 10.964L19.8943 4.57465C20.3596 3.912 19.8856 3 19.0759 3Z" fill="currentColor"></path>
						</svg>
					</span>
					Lọc
				</button>
				<!-- Filter Menu -->
				<div class="menu menu-sub menu-sub-dropdown w-300px w-md-325px" data-kt-menu="true">
					<div class="px-7 py-5">
						<div class="fs-5 text-dark fw-bolder">Tùy chọn lọc mẫu</div>
					</div>
					<div class="separator border-gray-200"></div>
					<div class="px-7 py-5">
						<div class="mb-10">
							<label class="form-label fs-6 fw-bold">Loại hợp đồng:</label>
							<select class="form-select form-select-solid fw-bolder">
								<option value="">Vui lòng chọn</option>
								<option value="Thử việc">Thử việc</option>
								<option value="Chính thức">Chính thức</option>
								<option value="Cộng tác viên">Cộng tác viên</option>
								<option value="Đào tạo">Đào tạo</option>
							</select>
						</div>
						<div class="mb-10">
							<label class="form-label fs-6 fw-bold">Trạng thái mẫu:</label>
							<select class="form-select form-select-solid fw-bolder">
								<option value="">Vui lòng chọn</option>
								<option value="Đang sử dụng">Đang sử dụng</option>
								<option value="Nháp">Nháp</option>
								<option value="Ngừng sử dụng">Ngừng sử dụng</option>
							</select>
						</div>
						<div class="d-flex justify-content-end">
							<button type="reset" class="btn btn-light btn-active-light-primary fw-bold me-2 px-6">Reset</button>
							<button type="submit" class="btn btn-primary fw-bold px-6">Áp dụng</button>
						</div>
					</div>
				</div>

				<!-- Export Excel -->
				<button type="button" class="btn btn-light-success me-3">
					<span class="svg-icon svg-icon-2">
						<i class="bi bi-file-earmark-spreadsheet"></i>
					</span>
					Xuất Excel
				</button>

				<!-- Add New -->
				<button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/contracts/add")'>
					<span class="svg-icon svg-icon-2">
						<svg xmlns="http://www.svg.com/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
							<rect opacity="0.5" x="11.364" y="20.364" width="16" height="2" rx="1" transform="rotate(-90 11.364 20.364)" fill="currentColor"></rect>
							<rect x="4.36396" y="11.364" width="16" height="2" rx="1" fill="currentColor"></rect>
						</svg>
					</span>
					Tạo mẫu mới
				</button>
			</div>
		</div>
		<div class="card-body pt-0">
			<!-- Tabs -->
			<ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bolder mb-5">
				<li class="nav-item">
					<a class="nav-link text-active-primary ms-0 me-10 @(ActiveTab == "All" ? "active" : "")"
					   href="javascript:void(0)" @onclick='() => SetActiveTab("All")'>
						Tất cả mẫu (@AllTemplates.Count)
					</a>
				</li>
				<li class="nav-item">
					<a class="nav-link text-active-primary ms-0 me-10 @(ActiveTab == "Active" ? "active" : "")"
					   href="javascript:void(0)" @onclick='() => SetActiveTab("Active")'>
						Đang sử dụng (@AllTemplates.Count(t => t.Status == "Đang sử dụng"))
					</a>
				</li>
				<li class="nav-item">
					<a class="nav-link text-active-primary ms-0 me-10 @(ActiveTab == "Draft" ? "active" : "")"
					   href="javascript:void(0)" @onclick='() => SetActiveTab("Draft")'>
						Nháp (@AllTemplates.Count(t => t.Status == "Nháp"))
					</a>
				</li>
			</ul>

			<!-- Table -->
			<div class="table-responsive">
				<table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_contract_templates">
					<thead>
						<tr class="text-start text-muted fw-bolder fs-7 text-uppercase gs-0">
							<th class="min-w-300px ps-4">Tên mẫu hợp đồng</th>
							<th class="min-w-150px">Số hiệu mẫu</th>
							<th class="min-w-125px">Ngày tạo</th>
							<th class="min-w-200px">Người cập nhật cuối</th>
							<th class="min-w-125px text-center">Trạng thái</th>
							<th class="min-w-100px text-end pe-4">Thao tác</th>
						</tr>
					</thead>
					<tbody class="text-gray-600 fw-bold">
						@foreach (var template in FilteredTemplates)
						{
							<tr class="hover-elevate-up cursor-pointer" @onclick='() => ShowDetail(template)'>
								<td class="ps-4">
									<div class="d-flex align-items-center">
										<div class="symbol symbol-40px bg-light-@template.Color me-4 d-flex align-items-center justify-content-center border border-dashed border-@template.Color rounded-2">
											<i class="@template.Icon text-@template.Color fs-3"></i>
										</div>
										<div class="d-flex flex-column">
											<span class="text-gray-800 fw-bolder mb-1 fs-6 text-hover-primary">@template.Name</span>
											<span class="text-muted fs-8">@template.Description</span>
										</div>
									</div>
								</td>
								<td><span class="badge badge-light fw-bolder text-gray-700">@template.Code</span></td>
								<td>@template.CreatedDate</td>
								<td>
									<div class="d-flex align-items-center">
										<div class="symbol symbol-circle symbol-25px me-2">
											<div class="symbol-label fs-8 fw-bold bg-light-primary text-primary">@template.UpdaterInitials</div>
										</div>
										<span>@template.UpdaterName</span>
									</div>
								</td>
								<td class="text-center">
									<span class="badge @(template.Status == "Đang sử dụng" ? "badge-light-success" : "badge-light-secondary") fw-bolder px-4 py-2">
										@template.Status
									</span>
								</td>
								<td class="text-end pe-4">
									<div class="d-flex justify-content-end flex-shrink-0">
										<a href="javascript:;" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1" title="Xem chi tiết" @onclick:stopPropagation @onclick="() => ShowDetail(template)">
											<i class="ki-outline ki-eye fs-3"></i>
										</a>
										<a href="/contracts/edit/@template.Code" class="btn btn-icon btn-bg-light btn-active-color-warning btn-sm me-1" title="Chỉnh sửa" @onclick:stopPropagation>
											<i class="ki-outline ki-pencil fs-3"></i>
										</a>
										<button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm" title="Xóa" @onclick:stopPropagation @onclick="() => DeleteTemplate(template)">
											<i class="ki-outline ki-trash fs-3"></i>
										</button>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>

			<!-- Pagination -->
			<div class="d-flex flex-stack flex-wrap pt-10">
				<div class="fs-6 fw-bold text-gray-700">Hiển thị @FilteredTemplates.Count() của @AllTemplates.Count mẫu</div>
				<ul class="pagination">
					<li class="page-item previous disabled"><a href="#" class="page-link"><i class="previous"></i></a></li>
					<li class="page-item active"><a href="#" class="page-link">1</a></li>
					<li class="page-item next"><a href="#" class="page-link"><i class="next"></i></a></li>
				</ul>
			</div>
		</div>
	</div>

	<!-- Bottom Info Cards -->
	<div class="row g-6">
		<div class="col-lg-4">
			<div class="card card-flush h-100 bg-light-primary border-primary border-dashed border">
				<div class="card-body d-flex align-items-center p-5">
					<i class="bi bi-lightbulb-fill text-primary fs-2qx me-4"></i>
					<div class="d-flex flex-column">
						<span class="fw-bolder fs-6 text-primary mb-1">Tra cứu nhanh</span>
						<span class="fs-7 text-gray-700">Bạn có thể tìm kiếm bằng số hiệu (VD: QT-NS-01) để định vị nhanh mẫu văn bản cần dùng.</span>
					</div>
				</div>
			</div>
		</div>
		<div class="col-lg-4">
			<div class="card card-flush h-100 bg-white border">
				<div class="card-body d-flex align-items-center p-5">
					<i class="bi bi-info-circle-fill text-gray-500 fs-2qx me-4"></i>
					<div class="d-flex flex-column">
						<span class="fw-bolder fs-6 text-gray-800 mb-1">Mô tả chi tiết</span>
						<span class="fs-7 text-gray-600">Di chuột vào tên mẫu để xem nhanh phần mô tả chi tiết của từng loại hợp đồng.</span>
					</div>
				</div>
			</div>
		</div>
		<div class="col-lg-4">
			<div class="card card-flush h-100 bg-light-info border-info border-dashed border">
				<div class="card-body d-flex align-items-center p-5">
					<i class="bi bi-bar-chart-fill text-info fs-2qx me-4"></i>
					<div class="d-flex flex-column">
						<span class="fw-bolder fs-6 text-info mb-1">Thống kê sử dụng</span>
						<span class="fs-7 text-gray-700">Cột "Số lượng áp dụng" cho biết tổng số hợp đồng thực tế đã được ký kết từ mẫu này.</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- DRAWER: CONTRACT DETAIL -->
<div id="kt_drawer_contract_detail" class="bg-white" data-kt-drawer="true" data-kt-drawer-name="contract-detail"
     data-kt-drawer-activate="true" data-kt-drawer-overlay="true"
     data-kt-drawer-width="{default:'300px', 'md': '600px'}" data-kt-drawer-direction="end"
     data-kt-drawer-close="#kt_drawer_contract_detail_close">

    <div class="card shadow-none rounded-0 w-100 h-100">
        <div class="card-header border-0 pt-7 pb-5">
            <h3 class="card-title fw-bolder text-gray-900 fs-2">Chi tiết mẫu hợp đồng</h3>
            <div class="card-toolbar">
                <button type="button" class="btn btn-sm btn-icon btn-active-light-primary" id="kt_drawer_contract_detail_close">
                    <i class="bi bi-x-lg fs-2"></i>
                </button>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="px-10 mb-10">
                <div class="d-flex align-items-center mb-7">
                    <div class="symbol symbol-70px bg-light-@selectedTemplate?.Color me-5 d-flex align-items-center justify-content-center border border-dashed border-@selectedTemplate?.Color rounded-3">
                        <i class="@selectedTemplate?.Icon text-@selectedTemplate?.Color fs-1"></i>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-gray-900 fw-bolder fs-3">@selectedTemplate?.Name</span>
                        <span class="text-muted fw-bold fs-6">Mã mẫu: <span class="text-primary">@selectedTemplate?.Code</span></span>
                    </div>
                </div>

                <div class="separator separator-dashed border-gray-300 mb-8"></div>

                <div class="mb-8">
                    <h4 class="text-gray-800 fw-bolder mb-4">Mô tả tổng quan</h4>
                    <div class="bg-light-light p-4 rounded-2 border border-dashed border-gray-300">
                        <p class="text-gray-600 fs-6 mb-0">@selectedTemplate?.Description</p>
                    </div>
                </div>

                <div class="row g-10 mb-8">
                    <div class="col-6">
                        <h4 class="text-gray-800 fw-bolder mb-3">Thông tin tạo</h4>
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-items-center fs-6 text-gray-700">
                                <i class="bi bi-calendar-event me-2"></i> @selectedTemplate?.CreatedDate
                            </div>
                            <div class="d-flex align-items-center fs-6 text-gray-700">
                                <i class="bi bi-person me-2"></i> @selectedTemplate?.UpdaterName
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <h4 class="text-gray-800 fw-bolder mb-3">Trạng thái</h4>
                        <span class="badge @(selectedTemplate?.Status == "Đang sử dụng" ? "badge-light-success" : "badge-light-secondary") fs-7 fw-bolder px-4 py-3">
                            @selectedTemplate?.Status
                        </span>
                    </div>
                </div>

                <div class="mb-8">
                    <h4 class="text-gray-800 fw-bolder mb-4">Cấu hình mẫu</h4>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center p-3 border border-dashed border-gray-300 rounded-2 bg-hover-light cursor-pointer">
                            <i class="bi bi-file-earmark-word text-primary fs-2 me-4"></i>
                            <div class="d-flex flex-column">
                                <span class="fw-bold text-gray-800">Word Template</span>
                                <span class="fs-8 text-muted text-uppercase">Tập tin chuẩn nén (.docx)</span>
                            </div>
                            <button class="btn btn-icon btn-sm btn-light-primary ms-auto"><i class="bi bi-download"></i></button>
                        </div>
                        <div class="d-flex align-items-center p-3 border border-dashed border-gray-300 rounded-2 bg-hover-light cursor-pointer">
                            <i class="bi bi-code-square text-warning fs-2 me-4"></i>
                            <div class="d-flex flex-column">
                                <span class="fw-bold text-gray-800">HTML Draft</span>
                                <span class="fs-8 text-muted text-uppercase">Cấu trúc hiển thị web</span>
                            </div>
                            <button class="btn btn-icon btn-sm btn-light-warning ms-auto"><i class="bi bi-pencil"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer border-0 d-flex gap-2 p-10">
            <button type="button" class="btn btn-primary flex-grow-1" @onclick='() => Navigation.NavigateTo($"/contracts/edit/{selectedTemplate?.Code}")'>
                <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa mẫu
            </button>
            <button type="button" class="btn btn-light-danger btn-icon" @onclick="() => DeleteTemplate(selectedTemplate)">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>
</div>

@code {
	private string ActiveTab = "All";
	private string SearchQuery = "";
    private TemplateItem? selectedTemplate;
    private string deleteConfirmInput = "";

	private List<TemplateItem> AllTemplates = new List<TemplateItem>
	{
		new TemplateItem { Name = "Hợp đồng thử việc 2024", Description = "Mẫu chuẩn cho nhân viên mới", Code = "QT-NS-01/2024", CreatedDate = "15/01/2024", UpdaterName = "Nguyễn Văn An", UpdaterInitials = "NA", Status = "Đang sử dụng", Icon = "bi bi-file-earmark-text", Color = "primary" },
		new TemplateItem { Name = "Hợp đồng lao động chính thức (Dài hạn)", Description = "Ký kết sau khi hết thử việc", Code = "QT-NS-02/2024", CreatedDate = "10/01/2024", UpdaterName = "Trần Thị Bích", UpdaterInitials = "TB", Status = "Đang sử dụng", Icon = "bi bi-patch-check", Color = "info" },
		new TemplateItem { Name = "Hợp đồng lao động thời vụ (Draft)", Description = "Dành cho nhân viên bán thời gian", Code = "QT-NS-TEMP-05", CreatedDate = "05/01/2024", UpdaterName = "Lê Văn Cường", UpdaterInitials = "LC", Status = "Nháp", Icon = "bi bi-pencil-square", Color = "dark" },
		new TemplateItem { Name = "Hợp đồng cộng tác viên chuyên gia", Description = "Sử dụng cho tư vấn độc lập", Code = "QT-NS-03/2024", CreatedDate = "20/01/2024", UpdaterName = "Nguyễn Văn An", UpdaterInitials = "NA", Status = "Đang sử dụng", Icon = "bi bi-person-badge", Color = "success" },
		new TemplateItem { Name = "Hợp đồng đào tạo và cam kết", Description = "Dành cho các khóa học chuyên sâu", Code = "QT-NS-04/2024", CreatedDate = "25/01/2024", UpdaterName = "Hoàng Bá Trung", UpdaterInitials = "HT", Status = "Đang sử dụng", Icon = "bi bi-book", Color = "warning" },
		new TemplateItem { Name = "Phụ lục hợp đồng về điều chỉnh lương", Description = "Bản nháp cho đợt review Q1", Code = "PL-NS-01-DRAFT", CreatedDate = "01/02/2024", UpdaterName = "Trần Thị Bích", UpdaterInitials = "TB", Status = "Nháp", Icon = "bi bi-cash-stack", Color = "danger" },
		new TemplateItem { Name = "Hợp đồng lao động xác định thời hạn (1 năm)", Description = "Mẫu chuẩn nhân viên phổ thông", Code = "QT-NS-12M/2024", CreatedDate = "12/01/2024", UpdaterName = "Nguyễn Văn An", UpdaterInitials = "NA", Status = "Đang sử dụng", Icon = "bi bi-calendar-check", Color = "primary" },
		new TemplateItem { Name = "Hợp đồng cho người lao động nước ngoài", Description = "Bao gồm các điều khoản visa/working permit", Code = "QT-NS-EXPAT-DRAFT", CreatedDate = "02/02/2024", UpdaterName = "Hoàng Bá Trung", UpdaterInitials = "HT", Status = "Nháp", Icon = "bi bi-globe", Color = "info" },
		new TemplateItem { Name = "Thỏa thuận bảo mật thông tin (NDA)", Description = "Bản bổ sung đi kèm hợp đồng chính", Code = "QT-SEC-01/2024", CreatedDate = "18/01/2024", UpdaterName = "Lê Văn Cường", UpdaterInitials = "LC", Status = "Đang sử dụng", Icon = "bi bi-shield-lock", Color = "success" },
		new TemplateItem { Name = "Hợp đồng lao động (3 năm)", Description = "Mẫu dành cho cấp quản lý", Code = "QT-NS-36M/2024", CreatedDate = "08/01/2024", UpdaterName = "Nguyễn Văn An", UpdaterInitials = "NA", Status = "Đang sử dụng", Icon = "bi bi-award", Color = "primary" }
	};

	private IEnumerable<TemplateItem> FilteredTemplates
	{
		get
		{
			var templates = ActiveTab switch
			{
				"Active" => AllTemplates.Where(t => t.Status == "Đang sử dụng"),
				"Draft" => AllTemplates.Where(t => t.Status == "Nháp"),
				_ => AllTemplates
			};

			if (!string.IsNullOrWhiteSpace(SearchQuery))
			{
				templates = templates.Where(t =>
					t.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
					t.Code.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));
			}

			return templates;
		}
	}

	private void SetActiveTab(string tab)
	{
		ActiveTab = tab;
	}

    private void ShowDetail(TemplateItem template)
    {
        selectedTemplate = template;
        StateHasChanged();
        JSRuntime.InvokeVoidAsync("openContractDetail");
    }

    private bool IsDeleteButtonEnabled => deleteConfirmInput.ToUpper() == "XÓA";

    private async Task DeleteTemplate(TemplateItem? template)
    {
        if (template == null) return;
        selectedTemplate = template;
        deleteConfirmInput = ""; 
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("showModal", "#kt_modal_delete_confirm");
    }

    private async Task ConfirmDeleteExecution()
    {
        if (selectedTemplate == null || !IsDeleteButtonEnabled) return;

        var name = selectedTemplate.Name;
        AllTemplates.Remove(selectedTemplate);
        
        // Đóng các UI
        await JSRuntime.InvokeVoidAsync("hideAllContractUI");

        await JSRuntime.InvokeVoidAsync("Swal.fire", new
        {
            title = "Đã xóa thành công!",
            text = $"Mẫu hợp đồng {name} đã được loại bỏ.",
            icon = "success",
            buttonsStyling = false,
            confirmButtonText = "Hoàn tất",
            customClass = new { confirmButton = "btn fw-bold btn-primary" }
        });

        selectedTemplate = null;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("eval", "KTMenu.createInstances(); KTDrawer.createInstances();");
    }

    public class TemplateItem
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string Code { get; set; } = "";
        public string CreatedDate { get; set; } = "";
        public string UpdaterName { get; set; } = "";
        public string UpdaterInitials { get; set; } = "";
        public string Status { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Color { get; set; } = "";
    }
}

<!-- MODAL: DELETE CONFIRMATION -->
<div class="modal fade" id="kt_modal_delete_confirm" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered mw-500px">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header pb-0 border-0 justify-content-end">
                <button type="button" class="btn btn-sm btn-icon btn-active-color-primary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            
            <div class="modal-body pt-0 pb-15 px-15 text-center">
                <!-- Icon -->
                <div class="mb-8">
                    <i class="bi bi-exclamation-triangle text-danger fs-5x"></i>
                </div>
                
                <!-- Title -->
                <h1 class="fw-bolder text-gray-900 mb-3 fs-1">Xác nhận xóa mẫu</h1>
                
                <!-- Content -->
                <div class="text-gray-600 fw-bold fs-6 mb-8 px-5">
                    Bạn có chắc chắn muốn xóa vĩnh viễn mẫu hợp đồng này không? 
                    Hành động này sẽ gỡ bỏ hoàn toàn cấu hình mẫu khỏi hệ thống.
                </div>
                
                <!-- Target Item Info -->
                <div class="d-flex flex-center flex-column bg-light-danger border border-dashed border-danger rounded-3 p-5 mb-10">
                    <div class="symbol symbol-50px bg-white p-3 rounded-circle shadow-sm mb-3">
                         <i class="@selectedTemplate?.Icon text-danger fs-1"></i>
                    </div>
                    <span class="fs-4 fw-bolder text-gray-800">@selectedTemplate?.Name</span>
                    <span class="fs-7 text-muted fw-bold">Mã: @selectedTemplate?.Code</span>
                </div>
                
                <!-- Validation -->
                <div class="mb-10 text-start">
                    <label class="form-label fw-bold text-gray-700 fs-7 mb-2">Để xác nhận, vui lòng nhập chính xác từ <span class="text-danger">XÓA</span> bên dưới:</label>
                    <input type="text" class="form-control form-control-solid border-danger bg-light-danger text-center fw-bolder fs-4 h-50px" 
                           placeholder="..." @bind="deleteConfirmInput" @bind:event="oninput" />
                </div>
                
                <!-- Actions -->
                <div class="d-flex flex-center">
                    <button type="button" class="btn btn-light-primary fw-bold me-3 px-8" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="button" class="btn btn-danger fw-bold px-8" disabled="@(!IsDeleteButtonEnabled)" @onclick="ConfirmDeleteExecution">
                        Đúng, Xác nhận xóa
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.openContractDetail = () => {
        const drawerElement = document.querySelector('#kt_drawer_contract_detail');
        if (drawerElement) {
            const drawer = KTDrawer.getInstance(drawerElement);
            if (drawer) {
                drawer.show();
            } else {
                // Nếu chưa có instance, hiển thị thủ công (phòng trường hợp render chậm)
                const newDrawer = new KTDrawer(drawerElement);
                newDrawer.show();
            }
        }
    };

    window.showModal = (selector) => {
        const el = document.querySelector(selector);
        if (el) {
            const modal = bootstrap.Modal.getOrCreateInstance(el);
            modal.show();
        }
    };

    window.hideAllContractUI = () => {
        const modals = ['#kt_modal_delete_confirm', '#kt_drawer_contract_detail'];
        modals.forEach(selector => {
            const el = document.querySelector(selector);
            if(el) {
                const inst = selector.includes('drawer') ? KTDrawer.getInstance(el) : bootstrap.Modal.getInstance(el);
                if(inst) inst.hide();
            }
        });
        document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
    };
</script>