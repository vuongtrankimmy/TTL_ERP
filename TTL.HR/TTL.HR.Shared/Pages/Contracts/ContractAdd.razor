                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Ma_Nhan_Vien}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Ngay_Sinh}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Quoc_Tich}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Nghe_Nghiep}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{So_So_Lao_Dong}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Group: Hop Dong -->
                            <div class="mb-8">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-file-text-fill text-danger me-2"></i>
                                    <span class="fw-bold text-danger fs-7 text-uppercase">HỢP ĐỒNG</span>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Ma_Hop_Dong}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Loai_Hop_Dong}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Thoi_Han_Hop_Dong}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Ngay_Bat_Dau}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Ngay_Ket_Thuc}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Dia_Diem_Lam_Viec}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Thoi_Gian_Lam_Viec}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Ngay_Ky}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Dia_Diem_Ky}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Group: To Chuc -->
                            <div class="mb-8">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-building-fill text-info me-2"></i>
                                    <span class="fw-bold text-info fs-7 text-uppercase">TỔ CHỨC</span>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Chuc_Vu}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Phong_Ban}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Group: Luong -->
                            <div class="mb-10">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-cash-stack text-success me-2"></i>
                                    <span class="fw-bold text-success fs-7 text-uppercase">LƯƠNG</span>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Muc_Luong}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Phu_Cap}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Help Button -->
                            <div class="mt-auto pt-4">
                                <button type="button" class="btn btn-outline btn-outline-primary w-100 fw-bold" @onclick="ShowHelp">
                                    <i class="bi bi-question-circle-fill me-2"></i> Hướng dẫn sử dụng
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- PREVIEW MODAL -->
<div class="modal fade" id="preview_modal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-white border-0 py-5 px-10 flex-stack">
                <h2 class="modal-title fs-4 fw-bolder text-gray-900">Xem trước hợp đồng</h2>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-0 bg-light position-relative">
                <!-- Floating Print Button (Sticky) -->
                <div class="d-print-none" style="position: sticky; top: 20px; right: 40px; float: right; z-index: 100; margin-bottom: -60px; pointer-events: none;">
                    <button type="button" class="btn btn-primary shadow-lg fw-bold px-6 py-4 rounded-pill d-flex align-items-center gap-2 hover-elevate-up m-5" onclick="window.print()" style="pointer-events: auto;">
                        <i class="bi bi-printer fs-3"></i>
                        <span>In hợp đồng</span>
                    </button>
                </div>

                <div class="p-10">
                    <div class="contract-paper mx-auto shadow-sm" style="background: #fff; width: 210mm; min-height: 297mm; padding: 25mm 20mm; font-family: 'Times New Roman', Times, serif; font-size: 16px; line-height: 1.6;">
                       @((MarkupString)PreviewContent)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- HELP MODAL -->
<div class="modal fade" id="help_modal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary py-5 px-10 flex-stack">
                <h2 class="modal-title fs-4 fw-bolder text-white">Hướng dẫn sử dụng Mẫu Hợp đồng</h2>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-10 bg-white">
                <div class="mb-10">
                    <h3 class="fw-bolder text-dark mb-4">1. Soạn thảo nội dung</h3>
                    <ul class="fs-6 text-gray-700">
                        <li class="mb-2"><strong>Soạn thảo trực tiếp:</strong> Bạn có thể gõ văn bản trực tiếp vào khung soạn thảo. Các công cụ định dạng (đậm, nghiêng, gạch chân...) chưa được hỗ trợ đầy đủ trong phiên bản này, vui lòng sử dụng phím tắt (Ctrl+B, Ctrl+I) nếu cần.</li>
                        <li class="mb-2"><strong>Copy từ Word:</strong> Bạn có thể copy nội dung từ file Word và dán vào đây. Tuy nhiên, một số định dạng phức tạp có thể bị mất hoặc hiển thị không đúng. Hãy kiểm tra kỹ sau khi dán.</li>
                        <li class="mb-2"><strong>Canh chỉnh:</strong> Sử dụng các phím Space/Tab để canh chỉnh vị trí văn bản (ví dụ: Quốc hiệu, Tiêu ngữ).</li>
                    </ul>
                </div>

                <div class="mb-10">
                    <h3 class="fw-bolder text-dark mb-4">2. Chèn biến động (Quan trọng)</h3>
                    <div class="alert alert-dismissible bg-light-primary border border-primary d-flex flex-column flex-sm-row p-5 mb-5">
                        <i class="bi bi-info-circle-fill fs-2hx text-primary me-4 mb-5 mb-sm-0"></i>
                        <div class="d-flex flex-column pe-0 pe-sm-10">
                            <h5 class="mb-1">Biến là gì?</h5>
                            <span>Biến là các từ khóa đặc biệt được bao quanh bởi hai dấu ngoặc nhọn, ví dụ: <code>{{Ten_Nhan_Vien}}</code>. Khi tạo hợp đồng cho nhân viên cụ thể, hệ thống sẽ tự động thay thế các biến này bằng thông tin thực tế của nhân viên đó.</span>
                        </div>
                    </div>
                    
                    <p class="fs-6 fw-bold text-gray-800 mb-2">Cách chèn biến:</p>
                    <ul class="fs-6 text-gray-700">
                        <li class="mb-2"><strong>Cách 1 (Kéo thả):</strong> Nhấn giữ chuột vào tên biến ở danh sách bên phải, kéo và thả vào vị trí mong muốn trong khung soạn thảo.</li>
                        <li class="mb-2"><strong>Cách 2 (Gõ thủ công):</strong> Bạn có thể tự gõ chính xác mã biến (bao gồm cả dấu <code>{{</code> và <code>}}</code>). Ví dụ: gõ <code>{{Muc_Luong}}</code> để hiển thị mức lương.</li>
                    </ul>
                </div>

                <div class="mb-0">
                    <h3 class="fw-bolder text-dark mb-4">3. Xem trước và Lưu</h3>
                    <ul class="fs-6 text-gray-700">
                        <li class="mb-2"><strong>Xem thử (Preview):</strong> Nhấn nút "Xem thử" để xem mẫu hợp đồng hiển thị như thế nào khi thay thế các biến bằng dữ liệu giả định. Bạn cũng có thể in thử hợp đồng tại đây.</li>
                        <li class="mb-2"><strong>Lưu mẫu:</strong> Sau khi hoàn tất, nhấn "Lưu thay đổi" để cập nhật mẫu hợp đồng vào hệ thống.</li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer bg-light p-5">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đã hiểu</button>
            </div>
        </div>
    </div>
</div>

<!-- Dedicated Print Container (Hidden on screen) -->
<div id="print_only_area" class="d-none d-print-block">
    @((MarkupString)PreviewContent)
</div>

<script>
    window.showModal = (selector) => {
        const el = document.querySelector(selector);
        if (el && typeof bootstrap !== 'undefined') {
            const modal = bootstrap.Modal.getOrCreateInstance(el);
            modal.show();
        } else {
            console.error('Modal element not found or Bootstrap not loaded');
        }
    };

    function allowDrop(ev) {
        ev.preventDefault();
    }

    function drag(ev) {
        // Send the text: {{Variable_Name}}
        ev.dataTransfer.setData("text", ev.target.innerText.trim());
    }

    function drop(ev) {
        ev.preventDefault();
        var data = ev.dataTransfer.getData("text");
        
        // Insert text at cursor position or drop target
        if (document.caretRangeFromPoint) {
            const range = document.caretRangeFromPoint(ev.clientX, ev.clientY);
            if (range) {
                const textNode = document.createTextNode(data);
                range.insertNode(textNode);
                range.collapse(false);
                const sel = window.getSelection();
                sel.removeAllRanges();
                sel.addRange(range);
            }
        } else if (document.caretPositionFromPoint) { // Firefox
             const range = document.caretPositionFromPoint(ev.clientX, ev.clientY);
             if (range) {
                const textNode = document.createTextNode(data);
                range.offsetNode.parentNode.insertBefore(textNode, range.offsetNode.nextSibling); // Rough approx
             }
        } else {
            // Fallback: append to target
            ev.target.innerHTML += data;
        }

        // Trigger input event to update model
        ev.target.dispatchEvent(new Event('input', { bubbles: true }));
    }

    function handlePaste(e) {
        e.preventDefault();
        var text = (e.originalEvent || e).clipboardData.getData('text/plain');
        var html = (e.originalEvent || e).clipboardData.getData('text/html');

        if (html) {
            // HTML Paste: Clean it first
            var clean = cleanHtml(html);
            // Insert cleaned HTML. The editor's root style will cascade to elements without inline styles.
            document.execCommand('insertHTML', false, clean);
        } else if (text) {
            // Plain Text Paste: Auto-format as Contract Paragraphs
            // Escape HTML chars
            let safeText = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
            
            // Split into paragraphs to ensure proper formatting
            let lines = safeText.split(/\r?\n/);
            let formattedHtml = "";
            
            lines.forEach(line => {
                let trimmed = line.trim();
                if (trimmed) {
                    // Standard Contract Paragraph Style: 13pt, Times New Roman, Justify, Spacing
                    formattedHtml += `<p style="margin-top:6pt; margin-bottom:6pt; text-align:justify; font-family:'Times New Roman'; font-size:13pt; line-height:1.5">${trimmed}</p>`;
                } else {
                    // Empty line spacing
                    formattedHtml += `<p style="margin-top:6pt; margin-bottom:6pt">&nbsp;</p>`;
                }
            });
            
            document.execCommand('insertHTML', false, formattedHtml);
        }
    }

    function cleanHtml(input) {
        if (!input) return "";
        let output = input;

        // 1. Remove comments
        output = output.replace(/<!--[\s\S]*?-->/g, "");

        // 2. Remove script and style blocks
        output = output.replace(/<script\b[^>]*>[\s\S]*?<\/script>/gm, "");
        output = output.replace(/<style\b[^>]*>[\s\S]*?<\/style>/gm, "");

        // 3. Remove XML tags and Office namespaces
        output = output.replace(/<\/?xml[^>]*>/g, "");
        output = output.replace(/<\/?o:[^>]*>/g, "");
        output = output.replace(/<\/?w:[^>]*>/g, "");
        output = output.replace(/<\/?m:[^>]*>/g, "");

        // 4. Remove Mso classes only (leave other formatting)
        output = output.replace(/\sclass="Mso[^"]*"/gi, "");
        // Also remove 'lang' which is useless
        output = output.replace(/\slang="[^"]*"/gi, "");
        
        // 5. Remove empty spans
        output = output.replace(/<span>\s*<\/span>/gi, "");

        return output;
    }

    function formatContract() {
        if (!confirm('Bạn có chắc chắn muốn chuẩn hóa định dạng toàn bộ văn bản về chuẩn Hợp đồng?\n(Font Times New Roman, Cỡ 13pt, Canh đều, Giãn dòng 1.5)')) return;

        const editor = document.getElementById("contract_editor");
        if (!editor) return;

        // Force editor style
        editor.style.fontFamily = "'Times New Roman', Times, serif";
        editor.style.fontSize = "13pt";
        editor.style.lineHeight = "1.5";
        editor.style.textAlign = "justify";

        // Select all elements inside
        const allElements = editor.querySelectorAll("*");
        allElements.forEach(el => {
            // Remove inline fonts/sizes/lineheights/colors to inherit from parent
            el.style.fontFamily = "";
            el.style.fontSize = "";
            el.style.lineHeight = "";
            el.style.backgroundColor = "";
            
             // Reset color unless it's a link or highlight
            if (el.tagName !== 'A' && !el.classList.contains('dynamic-value-highlight')) {
                el.style.color = "";
            }
            
            // Normalize P margins
            if (el.tagName === 'P') {
                el.style.marginTop = "6pt";
                el.style.marginBottom = "6pt";
                el.style.textAlign = "justify";
            }
            // Headers center bold
            if (['H1','H2','H3'].includes(el.tagName)) {
                el.style.textAlign = "center";
                el.style.fontWeight = "bold";
                el.style.marginTop = "12pt";
                el.style.marginBottom = "12pt";
            }
        });
        
        // Trigger input
        editor.dispatchEvent(new Event('input', { bubbles: true }));
    }

    // Helper to get HTML content from editor with basic cleaning
    window.getEditorContent = () => {
        const el = document.getElementById("contract_editor");
        if (!el) return "";
        
        // Clean again on save just to be sure
        return cleanHtml(el.innerHTML);
    };
</script>
