@page "/contracts/add"
@page "/contracts/edit/{*Id}"

<style>
    .dynamic-value-highlight {
        background-color: #f1faff;
        color: #009ef7;
        padding: 0 2px;
        border-radius: 3px;
        border-bottom: 1px dashed #009ef7;
    }

    /* Fixed size for editor contents to match A4 look in UI */
    .contract-paper {
        box-shadow: 0 0.5rem 1.5rem 0.5rem rgba(0, 0, 0, 0.075);
    }

    @@media print {
        .dynamic-value-highlight {
            background-color: transparent !important;
            color: black !important;
            padding: 0 !important;
            border: none !important;
        }

        /* Hide ALL screen elements */
        #template_editor_view, 
        .modal, 
        .modal-backdrop,
        #kt_app_header,
        #kt_app_sidebar,
        #kt_app_footer {
            display: none !important;
        }

        /* Essential resets for the body */
        body, html {
            height: auto !important;
            overflow: visible !important;
            background-color: white !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 210mm !important;
        }
        
        /* Show only the dedicated print container */
        #print_only_area {
            display: block !important;
            position: absolute;
            left: 0;
            top: 0;
            width: 210mm !important;
            padding: 20mm !important;
            background: white !important;
            font-family: 'Times New Roman', Times, serif;
            font-size: 16px;
            line-height: 1.6;
            color: black !important;
        }

        /* Ensure smooth flow for multi-page documents */
        .page-break {
            page-break-after: always;
        }

        @@page {
            size: A4;
            margin: 0;
        }
    }
</style>

<div id="template_editor_view" class="d-flex flex-column h-100">
    <!-- Sub Header / Toolbar -->
    <div class="toolbar py-3 py-lg-4 mb-0 border-bottom bg-white" style="z-index: 95; flex-shrink: 0;">
            <div class="container-fluid d-flex flex-stack mr-5">
                <!-- Left: Breadcrumb -->
                <div class="page-title d-flex flex-column me-3 ms-5">
                </div>
                
                <!-- Right: Actions -->
                <div class="d-flex align-items-center gap-3">
                    <a href="/contracts" class="btn btn-sm btn-light-primary fw-bolder"><i class="bi bi-arrow-left me-1"></i> Quay lại</a>
                    <button class="btn btn-light fw-bold btn-sm border" @onclick="ShowPreview" disabled="@IsLoading">Xem thử (Dữ liệu giả)</button>
                    <button class="btn btn-primary fw-bold btn-sm" @onclick="SaveTemplate" disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-save me-1"></i>
                        }
                        Lưu thay đổi
                    </button>
                    <div class="symbol symbol-35px ms-2">
                        <div class="symbol-label bg-light-primary text-primary fw-bolder">A</div>
                    </div>
                </div>
            </div>
    </div>

    <!-- Main Content -->
    <div class="d-flex flex-column flex-grow-1 overflow-hidden" style="background-color: #f5f8fa;">
        <div class="container-fluid h-100 py-6">
            <div class="row h-100 g-6">
                <!-- Left Content: Form & Editor -->
                <div class="col-lg-9 d-flex flex-column h-100">
                    <!-- Info Card (Fixed height) -->
                    <div class="card shadow-sm mb-6 border-0 flex-shrink-0">
                        <div class="card-body p-6">
                            <div class="row g-5">
                                <div class="col-md-5">
                                    <label class="form-label fs-7 fw-bolder text-gray-700 mb-2 required">Tên mẫu hợp đồng</label>
                                    <input type="text" class="form-control form-control-solid" @bind="TemplateModel.Name" placeholder="Nhập tên mẫu..." />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fs-7 fw-bolder text-gray-700 mb-2">Số hiệu mẫu (Code)</label>
                                    <input type="text" class="form-control form-control-solid" @bind="TemplateModel.Code" placeholder="Mã..." />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fs-7 fw-bolder text-gray-700 mb-2">Số lượng sử dụng</label>
                                    <input type="text" class="form-control form-control-solid text-center fw-bolder" value="@TemplateModel.UsageCount" disabled readonly />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fs-7 fw-bolder text-gray-700 mb-2 required">Trạng thái</label>
                                    <select class="form-select form-select-solid" @bind="TemplateModel.StatusId">
                                        @foreach (var item in templateStatusLookups)
                                        {
                                            <option value="@item.LookupID">@item.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fs-7 fw-bolder text-gray-700 mb-2">Loại mẫu hợp đồng</label>
                                    <select class="form-select form-select-solid" @bind="TemplateModel.TypeId">
                                        <option value="">-- Chọn loại hợp đồng --</option>
                                        @foreach (var item in contractTypeLookups)
                                        {
                                            <option value="@item.LookupID">@item.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fs-7 fw-bolder text-gray-700 mb-2">Mô tả chi tiết mẫu</label>
                                    <textarea class="form-control form-control-solid" rows="2" placeholder="Nhập mô tả về phạm vi áp dụng của mẫu hợp đồng này..." @bind="TemplateModel.Description"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 flex-shrink-0">
                            <h3 class="fw-bolder text-dark fs-4 mb-1">Nội dung mẫu hợp đồng</h3>
                            <div class="text-muted fs-7">Chỉnh sửa nội dung văn bản và chèn các biến động từ danh sách bên phải.</div>
                    </div>

                    <!-- Editor Wrapper (Flexible height) -->
                    <div class="card shadow-sm border-0 flex-grow-1 d-flex flex-column overflow-hidden">
                        <div class="card-header border-bottom px-4 min-h-50px flex-shrink-0">
                            <!-- Fake Toolbar -->
                            <div class="card-toolbar d-flex align-items-center gap-2">
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary me-2" onclick="formatContract()" title="Chuẩn hóa định dạng (Font Times New Roman, 13pt, Justified)"><i class="bi bi-magic fs-5"></i></button>
                                <div class="vr mx-2 h-20px my-auto"></div>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary ms-0" onclick="document.execCommand('bold',false,null);" title="In đậm"><i class="bi bi-type-bold fs-5"></i></button>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" onclick="document.execCommand('italic',false,null);" title="In nghiêng"><i class="bi bi-type-italic fs-5"></i></button>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" onclick="document.execCommand('underline',false,null);" title="Gạch chân"><i class="bi bi-type-underline fs-5"></i></button>
                                <div class="vr mx-2 h-20px my-auto"></div>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" onclick="document.execCommand('justifyLeft',false,null);" title="Canh trái"><i class="bi bi-text-left fs-5"></i></button>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" onclick="document.execCommand('justifyCenter',false,null);" title="Canh giữa"><i class="bi bi-text-center fs-5"></i></button>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" onclick="document.execCommand('justifyRight',false,null);" title="Canh phải"><i class="bi bi-text-right fs-5"></i></button>
                                <div class="vr mx-2 h-20px my-auto"></div>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" onclick="var url = prompt('Nhập đường dẫn:', 'http://'); if(url) document.execCommand('createLink',false,url);" title="Chèn liên kết"><i class="bi bi-link-45deg fs-5"></i></button>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" onclick="var url = prompt('Nhập đường dẫn ảnh:', 'http://'); if(url) document.execCommand('insertImage',false,url);" title="Chèn ảnh"><i class="bi bi-image fs-5"></i></button>
                                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary disabled" title="Chèn bảng (Chưa hỗ trợ)"><i class="bi bi-table fs-5"></i></button>
                            </div>
                        </div>
                        <div class="card-body p-10 bg-white overflow-auto flex-grow-1">
                            <div id="contract_editor" class="editor-content mx-auto p-5" contenteditable="true" 
                                 ondragover="allowDrop(event)" 
                                 ondrop="drop(event)"
                                 onpaste="handlePaste(event)"
                                 style="max-width: 800px; line-height: 1.5; font-family: 'Times New Roman', Times, serif; font-size: 13pt; text-align: justify; color: #000; min-height: 500px; outline: none; border: 1px dashed #e4e6ef;">
                                @((MarkupString)TemplateContent)
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Sidebar: Variables -->
                <div class="col-lg-3 d-flex flex-column h-100">
                    <div class="card shadow-sm border-0 bg-white flex-grow-1 d-flex flex-column overflow-hidden">
                        <div class="card-header pt-6 border-0 d-flex flex-column flex-shrink-0">
                            <h3 class="card-title fw-bolder text-dark fs-5 mb-0">Danh sách biến</h3>
                            <div class="text-muted fs-8 mt-1">Nhấp hoặc kéo thả biến vào văn bản để tự động điền thông tin khi xuất file.</div>
                        </div>
                        <div class="card-body pt-4 overflow-auto flex-grow-1">
                            <!-- Search -->
                            <div class="position-relative mb-6">
                                <span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4">
                                        <i class="bi bi-search text-gray-500"></i>
                                </span>
                                <input type="text" class="form-control form-control-solid form-control-sm ps-10" placeholder="Tìm kiếm biến..." />
                            </div>
                            
                             <!-- Group: Cong Ty -->
                            <div class="mb-8">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-building-fill text-warning me-2"></i>
                                    <span class="fw-bold text-warning fs-7 text-uppercase">CÔNG TY</span>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Ten_Cong_Ty}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{Dia_Chi_Cong_Ty}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{SDT_Cong_Ty}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{MST_Cong_Ty}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
                                        <span class="fs-7 fw-bold text-gray-700">{{STK_Cong_Ty}}</span>
                                        <i class="bi bi-grid-3x3-gap-fill text-gray-300"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Group: Nhan Vien -->
                            <div class="mb-8">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-person-fill text-primary me-2"></i>
                                    <span class="fw-bold text-primary fs-7 text-uppercase">NHÂN VIÊN</span>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded border border-dashed border-gray-300 cursor-pointer hover-elevate-up" draggable="true" ondragstart="drag(event)">
