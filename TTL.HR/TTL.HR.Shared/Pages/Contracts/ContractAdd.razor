<!-- PREVIEW MODAL -->
<div class="modal fade" id="preview_modal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-white border-0 py-5 px-10 flex-stack">
                <h2 class="modal-title fs-4 fw-bolder text-gray-900">Xem trước hợp đồng</h2>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-0 bg-light position-relative">
                <!-- Floating Print Button (Sticky) -->
                <div class="d-print-none" style="position: sticky; top: 20px; right: 40px; float: right; z-index: 100; margin-bottom: -60px; pointer-events: none;">
                    <button type="button" class="btn btn-primary shadow-lg fw-bold px-6 py-4 rounded-pill d-flex align-items-center gap-2 hover-elevate-up m-5" onclick="window.print()" style="pointer-events: auto;">
                        <i class="bi bi-printer fs-3"></i>
                        <span>In hợp đồng</span>
                    </button>
                </div>

                <div class="p-10">
                    <div class="contract-paper mx-auto shadow-sm" style="background: #fff; width: 210mm; min-height: 297mm; padding: 25mm 20mm; font-family: 'Times New Roman', Times, serif; font-size: 16px; line-height: 1.6;">
                       @((MarkupString)PreviewContent)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Dedicated Print Container (Hidden on screen) -->
<div id="print_only_area" class="d-none d-print-block">
    @((MarkupString)PreviewContent)
</div>

<script>
    window.showModal = (selector) => {
        const el = document.querySelector(selector);
        if (el && typeof bootstrap !== 'undefined') {
            const modal = bootstrap.Modal.getOrCreateInstance(el);
            modal.show();
        } else {
            console.error('Modal element not found or Bootstrap not loaded');
        }
    };
</script>
