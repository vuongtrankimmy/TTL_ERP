@namespace TTL.HR.Shared.Pages.User.Components

<style>
    @@media print {
        body * { visibility: hidden; }
        #payroll-print-content, #payroll-print-content * { visibility: visible; }
        #payroll-print-content { position: absolute; left: 0; top: 0; width: 100%; border: none !important; }
        .no-print { display: none !important; }
    }
</style>

<div class="card mb-5 mb-xl-10 animate__animated animate__fadeIn">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Lịch sử Lương & Thưởng</span>
            <span class="text-muted mt-1 fw-semibold fs-7">Danh sách các kỳ thanh toán gần nhất</span>
        </h3>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                <thead>
                    <tr class="fw-bold text-muted text-uppercase fs-7">
                        <th class="min-w-150px">Kỳ lương</th>
                        <th class="min-w-140px">Lương cơ bản</th>
                        <th class="min-w-120px">Phụ cấp & Thưởng</th>
                        <th class="min-w-110px">Thực nhận</th>
                        <th class="min-w-100px text-end">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_isLoading)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-10">
                                <span class="spinner-border spinner-border-sm me-2"></span> Đang tải...
                            </td>
                        </tr>
                    }
                    else if (!_salaries.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-10">
                                <span class="text-muted">Chưa có dữ liệu thanh toán lương.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in _salaries)
                        {
                            <tr @onclick="() => OpenDetail(item)" style="cursor: pointer;" class="hover-elevate-sm transition-all">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="symbol symbol-45px me-4">
                                            <span class="symbol-label bg-@GetStatusBgCard(item)">
                                                <i class="ki-outline ki-wallet fs-2 text-white"></i>
                                            </span>
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="text-gray-900 fw-bold fs-6">Tháng @item.Month/@item.Year</span>
                                            <span class="text-muted fw-semibold d-block fs-7">Kỳ lương định kỳ</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-gray-800 fw-bold d-block fs-6">@item.BasicSalary.ToString("N0") <span class="fs-8 fw-normal">đ</span></span>
                                </td>
                                <td>
                                    <span class="text-success fw-bold d-block fs-6">@((item.Allowance + item.Bonus).ToString("N0")) <span class="fs-8 fw-normal">đ</span></span>
                                </td>
                                <td>
                                    <span class="text-primary fw-bold d-block fs-6">@item.NetSalary.ToString("N0") <span class="fs-8 fw-normal">đ</span></span>
                                </td>
                                <td class="text-end">
                                    <span class="badge badge-light-@GetStatusColor(item) px-4 py-2 rounded-pill fs-7 fw-bold">@(string.IsNullOrEmpty(item.StatusName) ? item.Status : item.StatusName)</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- PAYROLL DETAIL DRAWER -->
<div class="drawer drawer-end @(_isDrawerOpen ? "drawer-on" : "")" style="width: 500px; max-width: 100vw; z-index: 1060; transition: transform 0.3s ease-in-out; position: fixed; right: 0; top: 0; bottom: 0; background: white; box-shadow: -10px 0 30px rgba(0,0,0,0.1); transform: @(_isDrawerOpen ? "translateX(0)" : "translateX(100%)")">
    @if (_selectedPayroll != null)
    {
        <div class="card w-100 rounded-0 border-0 h-100 shadow-lg" id="payroll-print-content">
            <div class="card-header border-0 pt-7 mb-2 ms-2">
                <h3 class="card-title fw-bolder text-gray-900 fs-2">Chi tiết Phiếu lương</h3>
                <div class="card-toolbar">
                    <button class="btn btn-sm btn-icon btn-active-light-primary" @onclick="CloseDrawer">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </button>
                </div>
            </div>
            
            <div class="card-body p-9 scroll-y">
                <!-- Header Info -->
                <div class="d-flex align-items-center mb-8 bg-@GetStatusBgCard(_selectedPayroll) p-6 rounded shadow-sm">
                    <div class="symbol symbol-50px me-5 bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center">
                         <i class="ki-outline ki-wallet fs-1 text-white"></i>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-white fw-bold fs-4">Tháng @_selectedPayroll.Month / @_selectedPayroll.Year</span>
                        <span class="badge badge-light-@GetStatusColor(_selectedPayroll) fw-bold fs-8 px-2 py-1 mt-1" style="width: fit-content;">
                             @(string.IsNullOrEmpty(_selectedPayroll.StatusName) ? _selectedPayroll.Status : _selectedPayroll.StatusName)
                        </span>
                    </div>
                </div>


                <!-- 1. THU NHẬP (INCOME) -->
                <div class="mb-10">
                    <div class="d-flex flex-stack mb-5 border-bottom border-gray-200 pb-2">
                        <h4 class="fw-bold fs-6 text-uppercase text-gray-500 mb-0">Thu nhập cộng</h4>
                        <i class="ki-outline ki-plus-square fs-3 text-success"></i>
                    </div>

                    <div class="d-flex flex-stack mb-2">
                        <span class="text-gray-600 fw-semibold fs-6">Lương thỏa thuận (HĐ)</span>
                        <span class="text-gray-500 fw-bold fs-6">@_selectedPayroll.BasicSalary.ToString("N0") đ</span>
                    </div>

                    @{
                        var paidDays = _selectedPayroll.ActualWorkDays + _selectedPayroll.LeaveDays + _selectedPayroll.HolidayDays;
                    }
                    <div class="bg-gray-50 rounded p-4 mb-4 border border-dashed border-gray-200 ps-6">
                        <div class="d-flex flex-stack mb-2">
                             <div class="d-flex flex-column">
                                 <span class="text-gray-700 fw-bold fs-7">Lương tính theo công:</span>
                                 <span class="text-muted fs-9 italic">(@paidDays ngày/ @_selectedPayroll.TotalRequiredDays ngày chuẩn)</span>
                             </div>
                             <span class="text-gray-800 fw-bolder fs-6">@_selectedPayroll.TotalWorkSalary.ToString("N0") đ</span>
                        </div>
                        
                        @if (paidDays == 0)
                        {
                            <div class="text-danger fs-9 fw-bold mt-1">
                                <i class="ki-outline ki-information-5 fs-9 text-danger me-1"></i>
                                Cảnh báo: Chưa ghi nhận ngày công!
                            </div>
                        }
                    </div>

                    @if (_selectedPayroll.OvertimeSalary > 0)
                    {
                        <div class="d-flex flex-stack mb-4">
                            <span class="text-gray-600 fw-semibold fs-6">Lương tăng ca (OT)</span>
                            <span class="text-gray-800 fw-bold fs-6">+@_selectedPayroll.OvertimeSalary.ToString("N0") đ</span>
                        </div>
                    }

                    @if (_selectedPayroll.AllowanceDetails != null && _selectedPayroll.AllowanceDetails.Any())
                    {
                        @foreach (var allow in _selectedPayroll.AllowanceDetails)
                        {
                            <div class="d-flex flex-stack mb-3 ps-4">
                                <span class="text-muted fs-7"><i class="ki-outline ki-minus fs-9 me-1"></i>@allow.Name</span>
                                <span class="text-success fw-semibold fs-7">+@allow.Amount.ToString("N0") đ</span>
                            </div>
                        }
                    }

                    @if (_selectedPayroll.Bonus > 0)
                    {
                        <div class="d-flex flex-stack mb-4 border-top border-gray-100 pt-3 mt-3">
                            <span class="text-success fw-bold fs-6">Thưởng (Bonus)</span>
                            <span class="text-success fw-bold fs-6">+@_selectedPayroll.Bonus.ToString("N0") đ</span>
                        </div>
                    }

                    <div class="separator separator-dashed my-5"></div>
                    <div class="d-flex flex-stack bg-light-success p-4 rounded border border-success border-opacity-10">
                        <span class="text-gray-800 fw-bolder fs-6">Tổng thu nhập (Gross)</span>
                        <span class="text-success fw-bolder fs-5">@_selectedPayroll.GrossSalary.ToString("N0") đ</span>
                    </div>
                </div>

                <!-- 2. KHẤU TRỪ & THUẾ (DEDUCTIONS) -->
                <div class="mb-10">
                    <div class="d-flex flex-stack mb-5 border-bottom border-gray-200 pb-2">
                        <h4 class="fw-bold fs-6 text-uppercase text-gray-500 mb-0">Khoản giảm trừ</h4>
                        <i class="ki-outline ki-minus-square fs-3 text-danger"></i>
                    </div>

                    <div class="d-flex flex-stack mb-4">
                        <span class="text-gray-600 fw-semibold fs-6">Các loại Bảo hiểm (10.5%)</span>
                        <span class="text-danger fw-bold fs-6">-@_selectedPayroll.InsuranceAmount.ToString("N0") đ</span>
                    </div>
                    <div class="ps-4 mb-4">
                        <div class="d-flex flex-stack mb-2">
                            <span class="text-muted fs-8">BHXH (8%)</span>
                            <span class="text-gray-600 fs-8">@_selectedPayroll.BhxhAmount.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex flex-stack mb-2">
                            <span class="text-muted fs-8">BHYT (1.5%)</span>
                            <span class="text-gray-600 fs-8">@_selectedPayroll.BhytAmount.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex flex-stack mb-2">
                            <span class="text-muted fs-8">BHTN (1%)</span>
                            <span class="text-gray-600 fs-8">@_selectedPayroll.BhtnAmount.ToString("N0") đ</span>
                        </div>
                    </div>

                    @if (_selectedPayroll.TaxAmount > 0)
                    {
                        <div class="d-flex flex-stack mb-4">
                            <div class="d-flex flex-column">
                                <span class="text-gray-600 fw-semibold fs-6">Thuế TNCN</span>
                                <span class="text-muted fs-9">TS: @_selectedPayroll.TaxableIncome.ToString("N0") đ</span>
                            </div>
                            <span class="text-danger fw-bold fs-6">-@_selectedPayroll.TaxAmount.ToString("N0") đ</span>
                        </div>
                    }

                    @if (_selectedPayroll.UnionFee > 0)
                    {
                        <div class="d-flex flex-stack mb-4">
                            <span class="text-gray-600 fw-semibold fs-6">Kinh phí Công đoàn</span>
                            <span class="text-danger fw-bold fs-6">-@_selectedPayroll.UnionFee.ToString("N0") đ</span>
                        </div>
                    }

                    @if (_selectedPayroll.DeductionDetails != null && _selectedPayroll.DeductionDetails.Any())
                    {
                        @foreach (var ded in _selectedPayroll.DeductionDetails)
                        {
                            <div class="d-flex flex-stack mb-3 ps-4">
                                <span class="text-muted fs-7"><i class="ki-outline ki-minus fs-9 me-1"></i>@ded.Name</span>
                                <span class="text-danger fw-semibold fs-7">-@ded.Amount.ToString("N0") đ</span>
                            </div>
                        }
                    }

                    @if (_selectedPayroll.AdvanceAmount > 0)
                    {
                        <div class="d-flex flex-stack mb-4 border-top border-gray-100 pt-3 mt-3">
                            <span class="text-gray-700 fw-semibold fs-6">Tạm ứng lương</span>
                            <span class="text-danger fw-bold fs-6">-@_selectedPayroll.AdvanceAmount.ToString("N0") đ</span>
                        </div>
                    }

                    <div class="separator separator-dashed my-5"></div>
                    <div class="d-flex flex-stack bg-light-danger p-4 rounded border border-danger border-opacity-10">
                        <span class="text-gray-800 fw-bolder fs-6">Tổng khấu trừ</span>
                        <span class="text-danger fw-bolder fs-5">-@_selectedPayroll.TotalDeduction.ToString("N0") đ</span>
                    </div>
                </div>

                <!-- 3. GHI CHÚ / CẢNH BÁO -->
                @if (!string.IsNullOrEmpty(_selectedPayroll.WarningMessage) || !string.IsNullOrEmpty(_selectedPayroll.ConfirmationComment))
                {
                    <div class="mb-5 bg-light-warning p-5 rounded border border-warning border-dashed">
                        <h4 class="text-warning fw-bold fs-7 text-uppercase mb-3"><i class="ki-outline ki-information-5 fs-7 text-warning me-2"></i>Lưu ý & Ghi chú</h4>
                        <p class="text-gray-700 fs-7 mb-0">@(_selectedPayroll.WarningMessage ?? _selectedPayroll.ConfirmationComment)</p>
                    </div>
                }

                <!-- FINAL NET SALARY -->
                <div class="bg-danger rounded p-8 d-flex flex-stack shadow-sm mb-5 mt-10 overflow-hidden position-relative border border-white border-opacity-10">
                    <div class="d-flex flex-column position-relative z-index-1">
                        <span class="text-white fw-bold fs-6">THỰC LĨNH CUỐI CÙNG</span>
                        <span class="text-white text-opacity-75 fs-8">Kỳ tháng @_selectedPayroll.Month / @_selectedPayroll.Year</span>
                    </div>
                    <span class="text-white fw-bolder fs-1 position-relative z-index-1">@_selectedPayroll.NetSalary.ToString("N0") <span class="fs-4 fw-normal">đ</span></span>
                    <i class="ki-outline ki-wallet fs-4tx text-white opacity-20 position-absolute end-0 bottom-0 mb-n5 me-n5"></i>
                </div>
            </div>
            
            <div class="card-footer border-0 py-8 px-9 d-flex gap-3 no-print">
                <button type="button" class="btn btn-light fw-bold flex-grow-1" @onclick="CloseDrawer">Đóng lại</button>
                <button type="button" class="btn btn-primary fw-bold flex-grow-1" @onclick="PrintPayslip">
                    <i class="ki-outline ki-printer fs-4 me-2"></i>In phiếu lương
                </button>
            </div>
        </div>
    }
</div>

@if (_isDrawerOpen)
{
    <div class="modal-backdrop fade show" @onclick="CloseDrawer" style="z-index: 1050"></div>
}

