@using TTL.HR.Application.Modules.HumanResource.Models
@using TTL.HR.Shared.Components.Common
@using Microsoft.AspNetCore.Components.Forms

<!-- ===== DOCUMENTS TAB ===== -->
<div class="animate__animated animate__fadeIn">

    @if (string.IsNullOrEmpty(EmployeeId) && !_isLoading)
    {
        <div class="card p-10 text-center shadow-sm border-0">
            <i class="ki-outline ki-information-5 fs-2tx text-warning mb-4"></i>
            <div class="text-muted fs-5">Không tìm thấy hồ sơ nhân viên để hiển thị tài liệu.</div>
        </div>
    }
    else
    {
        <!-- Header Stats Bar -->
        <div class="card mb-6 shadow-sm border-0">
            <div class="card-body d-flex align-items-center justify-content-between py-5 px-8 flex-wrap gap-4">
                <div class="d-flex align-items-center gap-8">
                    <div>
                        <div class="text-muted fs-7 fw-semibold text-uppercase mb-1">Tổng tài liệu</div>
                        @if (_isLoading)
                        {
                            <div class="fs-2 fw-bold text-gray-800">...</div>
                        }
                        else
                        {
                            <div class="fs-2 fw-bold text-gray-800">@(_profile?.Documents?.Count ?? 0)</div>
                        }
                    </div>
                    <div class="separator separator-dashed border-gray-300 h-50px"></div>
                    <div>
                        <div class="text-muted fs-7 fw-semibold text-uppercase mb-1">Đã xác thực</div>
                        @if (_isLoading)
                        {
                            <div class="fs-2 fw-bold text-success">...</div>
                        }
                        else
                        {
                            <div class="fs-2 fw-bold text-success">@(_profile?.Documents?.Count(d => d.Status == "Verified") ?? 0)</div>
                        }
                    </div>
                    <div class="separator separator-dashed border-gray-300 h-50px"></div>
                    <div>
                        <div class="text-muted fs-7 fw-semibold text-uppercase mb-1">Chờ duyệt</div>
                        @if (_isLoading)
                        {
                            <div class="fs-2 fw-bold text-warning">...</div>
                        }
                        else
                        {
                            <div class="fs-2 fw-bold text-warning">@(_profile?.Documents?.Count(d => d.Status == "Pending") ?? 0)</div>
                        }
                    </div>
                    @if (!_isLoading && _profile != null)
                    {
                        <div class="separator separator-dashed border-gray-300 h-50px"></div>
                        <div class="d-flex flex-column min-w-150px">
                            <div class="text-muted fs-7 fw-semibold text-uppercase mb-2">Hoàn thiện hồ sơ</div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="progress flex-grow-1 h-8px bg-light-primary rounded">
                                    <div class="progress-bar bg-primary rounded" style="width: @CompletionPercent%"></div>
                                </div>
                                <span class="fw-bold fs-7 text-primary">@CompletionPercent%</span>
                            </div>
                        </div>
                    }
                </div>
                <button type="button" class="btn btn-primary fw-bold px-6 shadow-sm" @onclick="OpenUploadModal">
                    <i class="ki-outline ki-cloud-add fs-2 me-2"></i>Tải lên tài liệu
                </button>
            </div>
        </div>

        <!-- Document Grid -->
        @if (_isLoading)
        {
            <div class="row g-6">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body d-flex flex-column align-items-center p-8">
                                <div class="skeleton skeleton-circle w-60px h-60px mb-4"></div>
                                <div class="skeleton skeleton-text w-80 mb-2"></div>
                                <div class="skeleton skeleton-text w-50"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (_profile?.Documents != null && _profile.Documents.Any())
        {
            <div class="row g-6 g-xl-9">
                @foreach (var doc in _profile.Documents)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card h-100 border-0 shadow-sm hover-elevate-up document-card" style="cursor: pointer; transition: all 0.25s ease;">
                            <div class="card-body d-flex flex-column p-0">
                                <!-- File Thumbnail -->
                                <div class="d-flex justify-content-center align-items-center bg-light-secondary rounded-top p-8"
                                     style="min-height: 130px; position: relative;">
                                    <img src="@GetFileIcon(doc.FileType)" alt="" class="w-60px opacity-85" />
                                    <span class="badge badge-@doc.StatusColor position-absolute top-0 end-0 m-3 px-3 py-2 fw-bold fs-9">
                                        @doc.StatusLabel
                                    </span>
                                </div>

                                <!-- File Info -->
                                <div class="d-flex flex-column p-5 flex-grow-1">
                                    <div class="fw-bold text-gray-800 fs-6 mb-1 text-truncate" title="@doc.DocumentName">
                                        @doc.DocumentName
                                    </div>
                                    <div class="text-primary fw-semibold fs-8 mb-1">
                                        @GetDocumentTypeLabel(doc.DocumentType)
                                    </div>
                                    <div class="text-muted fs-8 mb-3">
                                        @doc.FileSizeDisplay · @doc.CreatedAt.ToString("dd/MM/yyyy")
                                    </div>
                                    @if (doc.ExpiryDate.HasValue)
                                    {
                                        var isExpired = doc.ExpiryDate.Value < DateTime.Now;
                                        var isSoonExpired = !isExpired && doc.ExpiryDate.Value < DateTime.Now.AddDays(30);
                                        <div class="d-flex align-items-center gap-1 mb-3">
                                            <i class="ki-outline ki-timer fs-7 @(isExpired ? "text-danger" : isSoonExpired ? "text-warning" : "text-muted")"></i>
                                            <span class="fs-8 @(isExpired ? "text-danger fw-bold" : isSoonExpired ? "text-warning fw-semibold" : "text-muted")">
                                                HH: @doc.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                                @if (isExpired) { <text> (Đã hết hạn)</text> }
                                                else if (isSoonExpired) { <text> (Sắp hết hạn)</text> }
                                            </span>
                                        </div>
                                    }

                                    <!-- Actions -->
                                    <div class="d-flex gap-2 mt-auto">
                                        <button class="btn btn-sm btn-icon btn-light-primary btn-active-primary flex-fill shadow-sm"
                                                title="Xem tài liệu" @onclick="() => OpenViewModal(doc)">
                                            <i class="ki-outline ki-eye fs-4"></i>
                                        </button>
                                        <a href="@doc.FileUrl" target="_blank" download="@doc.DocumentName"
                                           class="btn btn-sm btn-icon btn-light-success btn-active-success flex-fill shadow-sm"
                                           title="Tải xuống">
                                            <i class="ki-outline ki-cloud-download fs-4"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Upload Card -->
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border border-2 border-gray-300 border-dashed shadow-none hover-border-primary"
                         style="cursor: pointer; transition: all 0.2s ease;" @onclick="OpenUploadModal">
                        <div class="card-body d-flex flex-center text-center flex-column p-10">
                            <div class="w-60px h-60px bg-light-primary rounded-circle d-flex align-items-center justify-content-center mb-4">
                                <i class="ki-outline ki-cloud-add fs-2tx text-primary"></i>
                            </div>
                            <div class="fs-6 fw-bold text-gray-800 mb-2">Tải lên tài liệu</div>
                            <div class="fs-8 fw-semibold text-muted">PDF, JPG, PNG, DOC<br />(tối đa 10MB)</div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-20 text-center">
                    <div class="w-100px h-100px bg-light-primary rounded-circle d-flex align-items-center justify-content-center mb-6">
                        <i class="ki-outline ki-folder-up fs-3tx text-primary"></i>
                    </div>
                    <h3 class="fw-bold text-gray-800 mb-3">Chưa có tài liệu nào</h3>
                    <div class="text-muted fs-6 mb-8 mw-400px">
                        Hồ sơ điện tử của bạn chưa có tài liệu. Hãy tải lên CMND/CCCD, bằng cấp và các giấy tờ cần thiết.
                    </div>
                    <button type="button" class="btn btn-primary btn-lg px-8 shadow" @onclick="OpenUploadModal">
                        <i class="ki-outline ki-cloud-add fs-2 me-2"></i>Tải lên ngay
                    </button>
                </div>
            </div>
        }
    }
</div>

<!-- ===== UPLOAD MODAL ===== -->
@if (_showUploadModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content shadow-lg border-0 rounded-3">
                <div class="modal-header border-0 pt-7 px-8">
                    <div>
                        <h3 class="modal-title fw-bold text-dark fs-2">Tải lên tài liệu</h3>
                        <div class="text-muted fs-7 mt-1">Tải lên tài liệu cá nhân vào hồ sơ điện tử của bạn</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseUploadModal" disabled="@_isUploading"></button>
                </div>
                <div class="modal-body py-5 px-8">

                    @if (_uploadSuccess)
                    {
                        <div class="notice d-flex bg-light-success rounded border-success border border-dashed p-6">
                            <i class="ki-outline ki-double-check fs-2tx text-success me-4"></i>
                            <div class="fw-semibold">
                                <h4 class="text-gray-900 fw-bold">Tải lên thành công!</h4>
                                <div class="fs-6 text-gray-700">Tài liệu đã được gửi và đang chờ HR xác thực.</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-6">
                            <!-- Document Type -->
                            <div class="col-md-6 fv-row">
                                <label class="required fs-6 fw-semibold mb-2">Loại tài liệu</label>
                                <select class="form-select form-select-solid fw-bold" @bind="_selectedDocumentType">
                                    @foreach (var kv in DocumentTypes)
                                    {
                                        <option value="@kv.Key">@kv.Value</option>
                                    }
                                </select>
                            </div>

                            <!-- Expiry Date -->
                            <div class="col-md-6 fv-row">
                                <label class="fs-6 fw-semibold mb-2">Ngày hết hạn (nếu có)</label>
                                <input type="date" class="form-control form-control-solid"
                                       @bind="_expiryDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            </div>

                            <!-- File Upload Zone -->
                            <div class="col-12 fv-row">
                                <label class="required fs-6 fw-semibold mb-2">Tệp tài liệu</label>
                                <div class="dropzone @(string.IsNullOrEmpty(_selectedFileName) ? "" : "dropzone--completed")"
                                     style="border: 2px dashed #d0d5dd; border-radius: 12px; padding: 32px; text-align: center; background: #f8f9fa; transition: all 0.2s ease;">
                                    <InputFile id="docUploadInput" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"
                                               OnChange="OnFileSelected" style="display: none;" />
                                    @if (string.IsNullOrEmpty(_selectedFileName))
                                    {
                                        <label for="docUploadInput" style="cursor: pointer;" class="d-flex flex-column align-items-center">
                                            <i class="ki-outline ki-cloud-add fs-3x text-primary mb-3"></i>
                                            <div class="fw-bold text-gray-800 fs-6 mb-1">Kéo thả hoặc nhấp để chọn tệp</div>
                                            <div class="text-muted fs-8">PDF, JPG, PNG, DOC, DOCX · Tối đa 10MB</div>
                                        </label>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center gap-4">
                                            <i class="ki-outline ki-document-text fs-3x text-primary"></i>
                                            <div class="text-start">
                                                <div class="fw-bold text-gray-800 fs-6">@_selectedFileName</div>
                                                <div class="text-muted fs-8">Đã chọn</div>
                                            </div>
                                            <label for="docUploadInput" class="btn btn-sm btn-light-primary ms-2" style="cursor: pointer;">
                                                <i class="ki-outline ki-arrows-circle fs-5 me-1"></i>Đổi tệp
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Note -->
                            <div class="col-12 fv-row">
                                <label class="fs-6 fw-semibold mb-2">Ghi chú</label>
                                <textarea class="form-control form-control-solid" rows="2"
                                          placeholder="Ghi chú thêm về tài liệu (nếu có)..."
                                          @bind="_note"></textarea>
                            </div>

                            @if (!string.IsNullOrEmpty(_uploadError))
                            {
                                <div class="col-12">
                                    <div class="alert alert-danger d-flex align-items-center py-4">
                                        <i class="ki-outline ki-cross-circle fs-2 text-danger me-3"></i>
                                        <div class="fw-semibold">@_uploadError</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                @if (!_uploadSuccess)
                {
                    <div class="modal-footer border-0 pt-0 pb-7 px-8 gap-3">
                        <button type="button" class="btn btn-light fw-bold px-6" @onclick="CloseUploadModal"
                                disabled="@_isUploading">Hủy</button>
                        <button type="button" class="btn btn-primary fw-bold px-8" @onclick="HandleUpload"
                                disabled="@(_isUploading || string.IsNullOrEmpty(_selectedFileName))">
                            @if (_isUploading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <text>Đang tải lên...</text>
                            }
                            else
                            {
                                <i class="ki-outline ki-cloud-add fs-4 me-1"></i>
                                <text>Tải lên</text>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- ===== VIEW DOCUMENT MODAL ===== -->
@if (_showViewModal && _viewingDocument != null)
{
    var doc = _viewingDocument;
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.7);">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content shadow-lg border-0 rounded-3" style="max-height: 90vh;">
                <div class="modal-header border-0 pt-6 px-7">
                    <div class="d-flex align-items-center gap-4">
                        <div class="w-45px h-45px bg-light-primary rounded d-flex align-items-center justify-content-center">
                            <img src="@GetFileIcon(doc.FileType)" alt="" class="w-30px" />
                        </div>
                        <div>
                            <h4 class="modal-title fw-bold text-dark mb-0">@doc.DocumentName</h4>
                            <div class="text-muted fs-8">
                                @GetDocumentTypeLabel(doc.DocumentType) ·
                                @doc.FileSizeDisplay ·
                                <span class="badge badge-light-@doc.StatusColor ms-1">@doc.StatusLabel</span>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseViewModal"></button>
                </div>
                <div class="modal-body p-0 overflow-hidden" style="flex: 1; min-height: 0; max-height: calc(90vh - 140px);">
                    @if (IsImage(doc.FileType))
                    {
                        <div class="d-flex align-items-center justify-content-center bg-dark p-4" style="height: 100%;">
                            <img src="@doc.FileUrl" alt="@doc.DocumentName"
                                 style="max-width: 100%; max-height: 65vh; object-fit: contain; border-radius: 8px;" />
                        </div>
                    }
                    else if (doc.FileType.ToLower() == "pdf")
                    {
                        <iframe src="@doc.FileUrl" width="100%" style="height: 65vh; border: 0;"></iframe>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center py-20 text-center">
                            <img src="@GetFileIcon(doc.FileType)" alt="" class="w-80px mb-6 opacity-75" />
                            <div class="fw-bold text-gray-700 fs-5 mb-2">@doc.DocumentName</div>
                            <div class="text-muted fs-7 mb-8">Không thể xem trực tiếp. Hãy tải xuống để mở.</div>
                            <a href="@doc.FileUrl" download="@doc.DocumentName" target="_blank"
                               class="btn btn-primary px-8 shadow">
                                <i class="ki-outline ki-cloud-download fs-3 me-2"></i>Tải xuống
                            </a>
                        </div>
                    }
                </div>
                <div class="modal-footer border-0 py-4 px-7 d-flex justify-content-between">
                    <div class="text-muted fs-8">
                        Ngày tải lên: @doc.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        @if (doc.ExpiryDate.HasValue)
                        {
                            <span class="ms-4">Hết hạn: @doc.ExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                        }
                    </div>
                    <div class="d-flex gap-3">
                        <a href="@doc.FileUrl" download="@doc.DocumentName" target="_blank"
                           class="btn btn-sm btn-light-success fw-bold px-5">
                            <i class="ki-outline ki-cloud-download fs-5 me-1"></i>Tải xuống
                        </a>
                        <button type="button" class="btn btn-sm btn-light fw-bold px-5" @onclick="CloseViewModal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
