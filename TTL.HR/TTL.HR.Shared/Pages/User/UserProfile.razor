@page "/user/profile"
@using TTL.HR.Shared.Pages.User.Components
@using TTL.HR.Application.Modules.Common.Models

@if (currentUser == null && _isLoadingProfile)
{
    <div class="d-flex flex-column flex-center p-20">
        <div class="spinner-border text-primary w-60px h-60px" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div class="text-gray-500 fw-semibold fs-5 mt-5">Đang tải hồ sơ của bạn...</div>
    </div>
}
else
{
    <!--begin::Navbar-->
    <div class="card mb-5 mb-xl-10">
        <div class="card-body pt-9 pb-0">
            <div class="d-flex flex-wrap flex-sm-nowrap">
                <div class="me-7 mb-4">
                    <div class="symbol symbol-100px symbol-lg-160px symbol-fixed position-relative">
                        <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(currentEmployee?.FullName ?? currentUser?.FullName ?? "User"))&background=random&size=200" alt="image" />
                        <div class="position-absolute translate-middle bottom-0 start-100 mb-6 bg-success rounded-circle border border-4 border-body h-20px w-20px"></div>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
                        <div class="d-flex flex-column">
                            <div class="d-flex align-items-center mb-2">
                                <a href="javascript:void(0)" class="text-gray-900 text-hover-primary fs-2 fw-bold me-1">
                                    @(currentEmployee?.FullName ?? currentUser?.FullName ?? "N/A")
                                </a>
                                <i class="ki-outline ki-verify fs-1 text-primary"></i>
                            </div>
                            <div class="d-flex flex-wrap fw-semibold fs-6 mb-4 pe-2">
                                <span class="d-flex align-items-center text-gray-400 me-5 mb-2"><i class="ki-outline ki-profile-circle fs-4 me-1"></i>@(currentEmployee?.PositionName ?? "Nhân viên")</span>
                                <span class="d-flex align-items-center text-gray-400 me-5 mb-2"><i class="ki-outline ki-geolocation fs-4 me-1"></i>@(currentEmployee?.DepartmentName ?? "Văn phòng")</span>
                                <span class="d-flex align-items-center text-gray-400 mb-2"><i class="ki-outline ki-sms fs-4 me-1"></i>@(currentEmployee?.Email ?? currentUser?.Email ?? "N/A")</span>
                            </div>
                        </div>
                        <div class="d-flex my-4">
                            <button class="btn btn-sm btn-light-primary me-2" @onclick="ShowChangePasswordModal"><i class="ki-outline ki-key fs-3"></i>Đổi mật khẩu</button>
                            <button class="btn btn-sm btn-primary" @onclick="ShowEditProfileModal"><i class="ki-outline ki-pencil fs-3"></i>Chỉnh sửa hồ sơ</button>
                        </div>
                    </div>
                </div>
            </div>
            <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
                <li class="nav-item mt-2"><a class="nav-link text-active-primary ms-0 me-10 py-5 @(activeTab == "overview" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("overview")'>Tổng quan</a></li>
                <li class="nav-item mt-2"><a class="nav-link text-active-primary ms-0 me-10 py-5 @(activeTab == "contracts" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("contracts")'>Hợp đồng</a></li>
                <li class="nav-item mt-2"><a class="nav-link text-active-primary ms-0 me-10 py-5 @(activeTab == "salary" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("salary")'>Lương & Thưởng</a></li>
                <li class="nav-item mt-2"><a class="nav-link text-active-primary ms-0 me-10 py-5 @(activeTab == "documents" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("documents")'>Tài liệu</a></li>
                <li class="nav-item mt-2"><a class="nav-link text-active-primary ms-0 me-10 py-5 @(activeTab == "leave" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("leave")'>Nghỉ phép</a></li>
                <li class="nav-item mt-2"><a class="nav-link text-active-primary ms-0 me-10 py-5 @(activeTab == "audit" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("audit")'>Nhật ký</a></li>
                <li class="nav-item mt-2"><a class="nav-link text-active-primary ms-0 me-10 py-5 @(activeTab == "debug" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetActiveTab("debug")'>Gỡ lỗi</a></li>
            </ul>
        </div>
    </div>

    <div class="tab-content">
        @if (activeTab == "overview")
        {
            <div class="card mb-5 mb-xl-10 animate__animated animate__fadeIn">
                <div class="card-header"><h3 class="card-title fw-bold">Chi tiết hồ sơ nhân sự</h3></div>
                <div class="card-body p-9">
                    <div class="row mb-7"><label class="col-lg-4 fw-semibold text-muted">Mã nhân viên</label><div class="col-lg-8 fw-bold fs-6">@(currentEmployee?.Code ?? "N/A")</div></div>
                    <div class="row mb-7"><label class="col-lg-4 fw-semibold text-muted">Họ và tên</label><div class="col-lg-8 fw-bold fs-6">@(currentEmployee?.FullName ?? currentUser?.FullName ?? "N/A")</div></div>
                    <div class="row mb-7"><label class="col-lg-4 fw-semibold text-muted">Phòng ban</label><div class="col-lg-8 fw-bold fs-6">@(currentEmployee?.DepartmentName ?? "N/A")</div></div>
                    <div class="row mb-7"><label class="col-lg-4 fw-semibold text-muted">Chức vụ</label><div class="col-lg-8 fw-bold fs-6">@(currentEmployee?.PositionName ?? "N/A")</div></div>
                    <div class="row mb-7"><label class="col-lg-4 fw-semibold text-muted">Số điện thoại</label><div class="col-lg-8 fw-bold fs-6">@(currentEmployee?.Phone ?? "N/A")</div></div>
                </div>
            </div>
        }
        else if (activeTab == "contracts") { <UserContracts EmployeeId="@employeeId" /> }
        else if (activeTab == "salary") { <UserSalary EmployeeId="@employeeId" /> }
        else if (activeTab == "documents") { <UserDocuments EmployeeId="@employeeId" /> }
        else if (activeTab == "leave") { <UserLeave EmployeeId="@employeeId" /> }
        else if (activeTab == "audit") { <UserAuditLog EmployeeId="@employeeId" /> }
        else if (activeTab == "debug")
        {
            <div class="card mb-5 mb-xl-10">
                <div class="card-header"><h3 class="card-title fw-bold">Hệ thống gỡ lỗi</h3></div>
                <div class="card-body p-9">
                    <div class="row mb-7"><label class="col-lg-4 text-muted">User ID</label><div class="col-lg-8 fw-bold">@(currentUser?.Id ?? "N/A")</div></div>
                    <div class="d-flex align-items-center mb-5">
                        <select class="form-select form-select-solid me-3 w-50" @bind="_selectedEmployeeToLink">
                            <option value="">-- Chọn nhân viên --</option>
                            @if (_allEmployees != null)
                            {
                                @foreach (var emp in _allEmployees)
                                {
                                    <option value="@emp.Id">@emp.FullName (@emp.Code) - @(string.IsNullOrEmpty(emp.Username) ? "Chưa kết nối" : emp.Username)</option>
                                }
                            }
                        </select>
                        <button class="btn btn-primary" @onclick="HandleLinkIdentity">Kết nối ngay</button>
                    </div>
                    @if (!string.IsNullOrEmpty(_linkMessage)) { <div class="alert alert-info">@_linkMessage</div> }
                </div>
            </div>
        }
    </div>
}

@if (isEditModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">Chỉnh sửa thông tin</h3>
                    <div class="btn btn-icon btn-sm" @onclick="CloseModals"><i class="ki-outline ki-cross fs-1"></i></div>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_modalError)) { <div class="alert alert-danger">@_modalError</div> }
                    @if (!string.IsNullOrEmpty(_modalSuccess)) { <div class="alert alert-success">@_modalSuccess</div> }
                    <div class="mb-5"><label class="form-label fw-bold">Họ và tên</label><input type="text" class="form-control" @bind="_editFullName" /></div>
                    <div class="mb-5"><label class="form-label fw-bold">Số điện thoại</label><input type="text" class="form-control" @bind="_editPhone" /></div>
                    <div class="mb-5"><label class="form-label fw-bold">Email</label><input type="email" class="form-control" @bind="_editEmail" /></div>
                </div>
                <div class="modal-footer"><button class="btn btn-light" @onclick="CloseModals">Hủy</button><button class="btn btn-primary" @onclick="HandleSaveProfile">Lưu thay đổi</button></div>
            </div>
        </div>
    </div>
}

@if (isPasswordModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">Đổi mật khẩu</h3>
                    <div class="btn btn-icon btn-sm" @onclick="CloseModals"><i class="ki-outline ki-cross fs-1"></i></div>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_modalError)) { <div class="alert alert-danger">@_modalError</div> }
                    @if (!string.IsNullOrEmpty(_modalSuccess)) { <div class="alert alert-success">@_modalSuccess</div> }
                    <div class="mb-5"><label class="form-label fw-bold">Mật khẩu hiện tại</label><input type="password" class="form-control" @bind="_currentPassword" /></div>
                    <div class="mb-5"><label class="form-label fw-bold">Mật khẩu mới</label><input type="password" class="form-control" @bind="_newPassword" /></div>
                    <div class="mb-5"><label class="form-label fw-bold">Xác nhận mật khẩu</label><input type="password" class="form-control" @bind="_confirmPassword" /></div>
                </div>
                <div class="modal-footer"><button class="btn btn-light" @onclick="CloseModals">Hủy</button><button class="btn btn-primary" @onclick="HandleChangePassword">Cập nhật mật khẩu</button></div>
            </div>
        </div>
    </div>
}
