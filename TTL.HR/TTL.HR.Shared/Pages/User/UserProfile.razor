            <div class="modal-footer flex-center">
                <button type="reset" class="btn btn-light me-3" @onclick="CloseModals">Hủy</button>
                <button type="submit" class="btn btn-primary" @onclick="HandleChangePassword">Cập nhật mật khẩu</button>
            </div>
        </div>
    </div>
</div>
<!--end::Change Password Modal-->


