@page "/administration/roles"
@layout MainLayout

<PageTitle>Danh sách vai trò & Gán nhân viên - TTL.HR</PageTitle>

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <!--begin::Toolbar container-->
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
        <!--begin::Page title-->
        <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
            <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">Roles</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                <li class="breadcrumb-item text-muted">
                    <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
                </li>
                <li class="breadcrumb-item">
                    <span class="bullet bg-gray-400 w-5px h-2px"></span>
                </li>
                <li class="breadcrumb-item text-muted">Roles</li>
            </ul>
        </div>
        <!--end::Page title-->
        <!--begin::Actions-->
        <div class="d-flex align-items-center gap-2 gap-lg-3">
            <button type="button" class="btn btn-sm btn-primary fw-bold" @onclick="openAddRole">
                <i class="ki-outline ki-plus fs-2"></i> Tạo vai trò
            </button>
        </div>
        <!--end::Actions-->
    </div>
    <!--end::Toolbar container-->
</div>
<!--end::Toolbar-->

<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!--begin::Row-->
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-5 g-xl-9">
            @foreach (var role in _roles)
            {
                <div class="col-md-4">
                    <div class="card card-flush h-md-100 shadow-sm border-0">
                        <div class="card-header pt-7">
                            <div class="card-title">
                                <h2 class="fw-bolder fs-3 text-gray-800">@role.Name</h2>
                            </div>
                        </div>
                        <div class="card-body pt-1">
                            <div class="fw-bolder text-gray-600 mb-5">Tổng số: @role.UserCount người dùng</div>
                            <div class="d-flex flex-column text-gray-600 fs-7">
                                @foreach (var p in role.KeyPermissions)
                                {
                                    <div class="d-flex align-items-center py-1">
                                        <span class="bullet bg-primary me-3"></span>@p
                                    </div>
                                }
                                @if (role.TotalPerms > role.KeyPermissions.Count)
                                {
                                    <div class="d-flex align-items-center py-1">
                                        <span class="bullet bg-primary me-3"></span>
                                        <em>và @(role.TotalPerms - role.KeyPermissions.Count) quyền khác...</em>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer flex-wrap pt-0 pb-7">
                            <button type="button" class="btn btn-light btn-active-light-primary btn-sm me-2 fw-bold" @onclick="() => openRoleDetail(role)">
                                <i class="ki-outline ki-information-5 fs-5 me-1"></i>Thông tin & Gán
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!--begin::Add new card-->
            <div class="col-md-4">
                <div class="card h-md-100 shadow-sm border-dashed border-primary bg-light-light hover-elevate">
                    <div class="card-body d-flex flex-center">
                        <button type="button" class="btn btn-clear d-flex flex-column flex-center w-100 h-100" @onclick="openAddRole">
                            <i class="ki-outline ki-plus fs-3tx text-primary mb-3"></i>
                            <div class="fw-bolder fs-4 text-gray-800">Tạo vai trò mới</div>
                            <span class="fs-8 text-muted mt-2">Thiết lập nhóm quyền truy cập mới</span>
                        </button>
                    </div>
                </div>
            </div>
            <!--end::Add new card-->
        </div>
        <!--end::Row-->

    </div>
</div>

<!-- DRAWER TẠO VAI TRÒ MỚI -->
<div class="bg-white drawer drawer-end @(_showAddRoleDrawer ? "drawer-on" : "")" 
     style="width: 500px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showAddRoleDrawer ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <div class="card-header pe-5 py-6">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Thiết lập vai trò mới</span>
                    <span class="fs-8 fw-bold text-muted mt-2">Cấu hình tên nhóm và các quyền cơ bản ban đầu</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeAddRole">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <div class="card-body hover-scroll-overlay-y py-8 px-10">
            <div class="mb-10">
                <label class="required fs-7 fw-bold mb-3">Tên vai trò / Nhóm</label>
                <input type="text" class="form-control form-control-solid fs-7" placeholder="VD: Giám sát ATTT" @bind="_newRoleName" />
            </div>
            
            <div class="mb-10">
                <label class="fs-7 fw-bold mb-5">Danh sách quyền cơ bản (Chọn nhanh)</label>
                <div class="d-flex flex-column gap-3">
                    @foreach (var p in _availablePerms)
                    {
                        <div class="form-check form-check-custom form-check-solid">
                            <input class="form-check-input w-20px h-20px" type="checkbox" @bind="p.IsSelected" id="perm_@p.Name" />
                            <label class="form-check-label" for="perm_@p.Name">
                                <span class="fw-bold text-gray-800 fs-7">@p.Name</span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card-footer py-6 px-10 border-0 bg-light-light d-flex gap-3 justify-content-end">
            <button type="button" class="btn btn-sm btn-light fw-bold px-6" @onclick="closeAddRole">Hủy bỏ</button>
            <button type="button" class="btn btn-sm btn-primary fw-bold px-6" @onclick="confirmCreateRole">Tạo vai trò</button>
        </div>
    </div>
</div>

<!-- DRAWER CHI TIẾT VAI TRÒ & GÁN NHÂN VIÊN -->
<div class="bg-white drawer drawer-end @(_showRoleDetailDrawer ? "drawer-on" : "")" 
     style="width: 800px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showRoleDetailDrawer ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <div class="card-header pe-5 py-6">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Quản lý Vai trò: @(_selectedRole?.Name)</span>
                    <span class="fs-8 fw-bold text-muted mt-2">Thông tin quyền hạn và danh sách nhân viên được gán</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeRoleDetail">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <div class="card-body hover-scroll-overlay-y py-8 px-10">
            <!-- Thông tin quyền -->
            <div class="mb-10">
                <div class="d-flex flex-stack mb-5">
                    <span class="fw-bolder text-gray-800 fs-6">Danh sách quyền hạn</span>
                    <span class="badge badge-light-primary fs-7 fw-bold">Tổng: @(_selectedRole?.TotalPerms) quyền</span>
                </div>
                <div class="row row-cols-2 g-3">
                    @if (_selectedRole != null)
                    {
                        @foreach (var p in _selectedRole.KeyPermissions)
                        {
                            <div class="col">
                                <div class="d-flex align-items-center p-3 rounded bg-light-light border border-dashed border-gray-300">
                                    <span class="bullet bg-primary me-3"></span>
                                    <span class="text-gray-700 fs-7">@p</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="separator separator-dashed my-8"></div>

            <!-- Quản lý nhân viên -->
            <div class="d-flex flex-stack mb-5">
                <div class="d-flex align-items-center position-relative my-1">
                    <i class="ki-outline ki-magnifier fs-4 position-absolute ms-4"></i>
                    <input type="text" class="form-control form-control-solid w-250px ps-12" placeholder="Tìm thành viên..." @bind="_memberSearchQuery" @bind:event="oninput" />
                </div>
                <button type="button" class="btn btn-primary btn-sm" @onclick="openAddUser">
                    <i class="ki-outline ki-plus fs-3 me-1"></i>Thêm nhân viên
                </button>
            </div>

            <div class="table-responsive">
                <table class="table align-middle table-row-dashed fs-7 gy-4">
                    <thead>
                        <tr class="text-start text-muted fw-bolder text-uppercase gs-0">
                            <th class="min-w-200px">Nhân viên</th>
                            <th class="min-w-100px">Mã NV</th>
                            <th class="text-end min-w-50px"></th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700 fw-bold">
                        @if (FilteredMembers.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center py-10">
                                    <div class="text-muted fs-8">Chưa có nhân viên nào trong vai trò này.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in FilteredMembers)
                            {
                                <tr>
                                    <td class="d-flex align-items-center">
                                        <div class="symbol symbol-circle symbol-35px overflow-hidden me-3">
                                            <div class="symbol-label">
                                                <img src="@user.Avatar" alt="" class="w-100" />
                                            </div>
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="text-gray-800 text-hover-primary mb-1 fs-7">@user.Name</span>
                                            <span class="fs-9 text-gray-500">@user.Department</span>
                                        </div>
                                    </td>
                                    <td><span class="badge badge-light fw-bold">@user.Code</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-icon btn-light-danger btn-sm" @onclick="() => removeUser(user)">
                                            <i class="ki-outline ki-trash fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- DRAWER CHỌN NHÂN VIÊN -->
<div class="bg-white drawer drawer-end @(_showUserPicker ? "drawer-on" : "")" 
     style="width: 500px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showUserPicker ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <div class="card-header pe-5 py-6">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Thêm nhân viên vào vai trò</span>
                    <span class="fs-8 fw-bold text-muted mt-2">Chọn nhân viên để cấp quyền @(_selectedRole?.Name)</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeAddUser">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <div class="card-body hover-scroll-overlay-y py-8 px-10">
            <div class="mb-7">
                <div class="position-relative">
                    <i class="ki-outline ki-magnifier fs-3 position-absolute top-50 translate-middle-y ms-4"></i>
                    <input type="text" class="form-control form-control-solid ps-12" placeholder="Tìm tên hoặc mã NV..." @bind="_employeeSearchQuery" @bind:event="oninput" />
                </div>
            </div>
            
            <div class="separator separator-dashed my-5"></div>

            <div class="d-flex flex-column gap-5">
                @foreach (var emp in FilteredAvailableEmployees)
                {
                    <div class="d-flex flex-stack @(emp.IsSelected ? "bg-light-primary p-3 rounded" : "")">
                        <div class="d-flex align-items-center me-3">
                            <div class="symbol symbol-45px symbol-circle me-3">
                                <img src="@emp.Avatar" alt="" />
                            </div>
                            <div class="d-flex flex-column">
                                <span class="text-gray-800 fw-bold fs-6">@emp.Name</span>
                                <span class="text-muted fs-8">@emp.Code - @emp.Position</span>
                            </div>
                        </div>
                        <div class="form-check form-check-custom form-check-solid">
                            <input class="form-check-input" type="checkbox" @bind="emp.IsSelected" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card-footer py-6 px-10 border-0 bg-light-light d-flex gap-3 justify-content-end">
            <button type="button" class="btn btn-sm btn-light fw-bold px-6" @onclick="closeAddUser">Hủy bỏ</button>
            <button type="button" class="btn btn-sm btn-primary fw-bold px-6" @onclick="confirmAddUsers">Xác nhận thêm</button>
        </div>
    </div>
</div>

@if (_showUserPicker || _showAddRoleDrawer || _showRoleDetailDrawer)
{
    <div class="drawer-overlay" style="z-index: 105; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="() => { closeAddUser(); closeAddRole(); closeRoleDetail(); }"></div>
}

@code {
    private RoleItem? _selectedRole;
    private bool _showUserPicker = false;
    private bool _showAddRoleDrawer = false;
    private bool _showRoleDetailDrawer = false;
    private string _memberSearchQuery = "";
    private string _employeeSearchQuery = "";

    private List<UserRoleData> FilteredMembers => _usersInRole
        .Where(x => string.IsNullOrWhiteSpace(_memberSearchQuery) || 
                   x.Name.Contains(_memberSearchQuery, StringComparison.OrdinalIgnoreCase) || 
                   x.Code.Contains(_memberSearchQuery, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private List<EmployeePickerItem> FilteredAvailableEmployees => _availableEmployees
        .Where(x => string.IsNullOrWhiteSpace(_employeeSearchQuery) || 
                   x.Name.Contains(_employeeSearchQuery, StringComparison.OrdinalIgnoreCase) || 
                   x.Code.Contains(_employeeSearchQuery, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private string _newRoleName = "";
    private List<SelectedPerm> _availablePerms = new() {
        new("Xem hồ sơ nhân sự"), new("Phê duyệt đơn từ"), new("Quản lý bảng lương"), 
        new("Cấu hình hệ thống"), new("Báo cáo thống kê"), new("Quản lý hợp đồng")
    };

    private void openAddRole() => _showAddRoleDrawer = true;
    private void closeAddRole() {
        _showAddRoleDrawer = false;
        _newRoleName = "";
        _availablePerms.ForEach(x => x.IsSelected = false);
    }

    private void confirmCreateRole() {
        if (string.IsNullOrWhiteSpace(_newRoleName)) return;
        
        var selected = _availablePerms.Where(x => x.IsSelected).Select(x => x.Name).Take(3).ToList();
        if (selected.Count == 0) selected.Add("Quyền cơ bản");

        _roles.Insert(0, new RoleItem(_newRoleName, 0, _availablePerms.Count(x => x.IsSelected), selected));
        closeAddRole();
    }

    private void openRoleDetail(RoleItem role) {
        _selectedRole = role;
        _usersInRole = _allUsersInRoles.Where(x => x.RoleName == role.Name).ToList();
        _showRoleDetailDrawer = true;
    }

    private void closeRoleDetail() => _showRoleDetailDrawer = false;

    private void openAddUser() => _showUserPicker = true;
    private void closeAddUser() => _showUserPicker = false;

    private void confirmAddUsers() {
        var selected = _availableEmployees.Where(x => x.IsSelected).ToList();
        foreach(var s in selected) {
            var newUser = new UserRoleData { 
                Name = s.Name, 
                Code = s.Code, 
                Email = s.Code.ToLower() + "@ttl.com.vn",
                Avatar = s.Avatar,
                Department = "Phòng Kỹ thuật",
                AssignedDate = DateTime.Now.ToString("dd/MM/yyyy"),
                RoleName = _selectedRole?.Name ?? ""
            };
            _usersInRole.Add(newUser);
            _allUsersInRoles.Add(newUser);
            s.IsSelected = false;
        }
        if (_selectedRole != null) _selectedRole.UserCount += selected.Count;
        closeAddUser();
    }

    private void removeUser(UserRoleData user) {
        _usersInRole.Remove(user);
        if (_selectedRole != null) _selectedRole.UserCount--;
    }

    private List<RoleItem> _roles = new()
    {
        new("Quản trị hệ thống", 5, 45, new() { "Toàn quyền cấu hình", "Quản lý người dùng", "Thiết lập quy trình tuyển dụng" }),
        new("Quản lý Nhân sự", 12, 38, new() { "Xem chuyên cần", "Phê duyệt nghỉ phép", "Theo dõi Kanban Tuyển dụng" }),
        new("Chuyên viên Tuyển dụng", 4, 25, new() { "Đăng tin tuyển dụng", "Đặt lịch phỏng vấn", "Quản lý nguồn ứng viên" }),
        new("Giảng viên nội bộ", 6, 20, new() { "Tạo khóa đào tạo", "Đăng ký học viên", "Cấp chứng chỉ hoàn thành" }),
        new("Kế toán tiền lương", 8, 30, new() { "Tính toán bảng lương", "Quản lý thuế & bảo hiểm", "Phụ cấp & phúc lợi" }),
        new("Quản lý trực tiếp", 32, 18, new() { "Phê duyệt đơn từ", "Đánh giá thử việc", "Đề xuất đào tạo nhóm" }),
        new("IT Support", 3, 22, new() { "Hỗ trợ kỹ thuật", "Quản lý thiết bị", "Cài đặt phần mềm" }),
        new("Thanh tra nội bộ", 2, 18, new() { "Kiểm tra quy trình", "Báo cáo tuân thủ", "Giám sát kỷ luật" }),
        new("Nhân viên chính thức", 115, 8, new() { "Xem lịch công cá nhân", "Gửi đơn nghỉ phép", "Nhận phiếu lương" })
    };

    private List<UserRoleData> _usersInRole = new();

    private List<UserRoleData> _allUsersInRoles = new() {
        new() { Name = "Nguyễn Văn An", Code = "NV001", Email = "an.nv@ttl.com.vn", Avatar = "assets/media/avatars/300-1.jpg", Department = "Ban Giám đốc", AssignedDate = "10/01/2024", RoleName = "Quản trị hệ thống" },
        new() { Name = "Trần Thị Bình", Code = "NV005", Email = "binh.tt@ttl.com.vn", Avatar = "assets/media/avatars/300-2.jpg", Department = "Hành chính Nhân sự", AssignedDate = "15/01/2024", RoleName = "Quản lý Nhân sự" },
        new() { Name = "Lê Văn Cường", Code = "NV008", Email = "cuong.lv@ttl.com.vn", Avatar = "assets/media/avatars/300-3.jpg", Department = "Kế toán", AssignedDate = "20/01/2024", RoleName = "Kế toán tiền lương" },
        new() { Name = "Phan Thanh Tùng", Code = "NV010", Email = "tung.pt@ttl.com.vn", Avatar = "assets/media/avatars/300-5.jpg", Department = "Tuyển dụng", AssignedDate = "01/02/2025", RoleName = "Chuyên viên Tuyển dụng" },
        new() { Name = "Đặng Quang Hải", Code = "NV020", Email = "hai.dq@ttl.com.vn", Avatar = "assets/media/avatars/300-6.jpg", Department = "Kỹ thuật", AssignedDate = "10/02/2025", RoleName = "Giảng viên nội bộ" }
    };

    private List<EmployeePickerItem> _availableEmployees = new() {
        new() { Name = "Phạm Đức Minh", Code = "NV012", Position = "Lập trình viên", Avatar = "assets/media/avatars/300-11.jpg" },
        new() { Name = "Hoàng Thanh Thảo", Code = "NV015", Position = "Tester", Avatar = "assets/media/avatars/300-12.jpg" },
        new() { Name = "Nguyễn Phi Hùng", Code = "NV018", Position = "Team Lead", Avatar = "assets/media/avatars/300-15.jpg" },
        new() { Name = "Vũ Thị Mai", Code = "NV025", Position = "Content Marketing", Avatar = "assets/media/avatars/300-7.jpg" },
        new() { Name = "Lý Văn Phát", Code = "NV030", Position = "Business Analyst", Avatar = "assets/media/avatars/300-9.jpg" },
        new() { Name = "Bùi Văn Nam", Code = "NV035", Position = "UI/UX Designer", Avatar = "assets/media/avatars/300-8.jpg" }
    };

    private class RoleItem {
        public string Name { get; set; }
        public int UserCount { get; set; }
        public int TotalPerms { get; set; }
        public List<string> KeyPermissions { get; set; }
        public RoleItem(string name, int count, int perms, List<string> keys) {
            Name = name; UserCount = count; TotalPerms = perms; KeyPermissions = keys;
        }
    }

    private class UserRoleData {
        public string Name { get; set; } = "";
        public string Code { get; set; } = "";
        public string Email { get; set; } = "";
        public string Avatar { get; set; } = "";
        public string Department { get; set; } = "";
        public string AssignedDate { get; set; } = "";
        public string RoleName { get; set; } = "";
    }

    private class EmployeePickerItem {
        public string Name { get; set; } = "";
        public string Code { get; set; } = "";
        public string Position { get; set; } = "";
        public string Avatar { get; set; } = "";
        public bool IsSelected { get; set; } = false;
    }

    private class SelectedPerm {
        public string Name { get; set; }
        public bool IsSelected { get; set; }
        public SelectedPerm(string name) => Name = name;
    }
}
