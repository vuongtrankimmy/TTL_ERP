@page "/permissions"
@using TTL.HR.Application.Modules.Common.Models
@using TTL.HR.Application.Modules.Common.Interfaces

<PageTitle>Ma trận Phân quyền - TTL.HR</PageTitle>

<!--begin::Toolbar-->
<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
        <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
            <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">Ma trận Phân quyền</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                <li class="breadcrumb-item text-muted"> <a href="/" class="text-muted text-hover-primary">Trang chủ</a> </li>
                <li class="breadcrumb-item"> <span class="bullet bg-gray-400 w-5px h-2px"></span> </li>
                <li class="breadcrumb-item text-muted">Quản trị</li>
                <li class="breadcrumb-item"> <span class="bullet bg-gray-400 w-5px h-2px"></span> </li>
                <li class="breadcrumb-item text-dark">Ma trận Phân quyền</li>
            </ul>
        </div>
    </div>
</div>

<!--begin::Content-->
<div id="kt_app_content" class="app-content flex-column-fluid">
    <!--begin::Content container-->
    <div id="kt_app_content_container" class="app-container container-fluid">
        <!-- Summary Cards -->
        <div class="row g-5 mb-8">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-light-primary">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-40px bg-white me-3">
                                <span class="symbol-label"><i class="ki-outline ki-shield-tick fs-2 text-primary"></i></span>
                            </span>
                            <span class="text-gray-800 fw-bolder fs-6">Tổng số vai trò</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2 fw-bolder text-dark">@(_roles.Count.ToString("D2"))</span>
                            <span class="text-muted fs-8 fw-bold">@string.Join(", ", _roles.Take(5).Select(r => r.Name))</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-light-success">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-40px bg-white me-3">
                                <span class="symbol-label"><i class="ki-outline ki-key fs-2 text-success"></i></span>
                            </span>
                            <span class="text-gray-800 fw-bolder fs-6">Tổng quyền hạn</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2 fw-bolder text-dark">@_allPermissionsCount</span>
                            <span class="text-muted fs-8 fw-bold">Đã phân phối cho các nhóm</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-light-warning">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-40px bg-white me-3">
                                <span class="symbol-label"><i class="ki-outline ki-people fs-2 text-warning"></i></span>
                            </span>
                            <span class="text-gray-800 fw-bolder fs-6">Người dùng được gán</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2 fw-bolder text-dark">@_totalUsersWithRoles</span>
                            <span class="text-muted fs-8 fw-bold">Nhân viên đang hoạt động</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!--begin::Card-->
        <div class="card shadow-sm">
            <!--begin::Card header-->
            <div class="card-header border-0 pt-6">
                <div class="card-title flex-column">
                    <h3 class="fw-bold mb-1">Ma trận phân quyền</h3>
                    <span class="text-muted fs-7">Thiết lập chi tiết quyền hạn cho từng nhóm người dùng</span>
                </div>
                <!--begin::Card toolbar-->
                <div class="card-toolbar">
                    <div class="d-flex justify-content-end gap-3">
                        <button type="button" class="btn btn-light btn-sm fw-bold" @onclick="LoadDataAsync">
                            <i class="ki-outline ki-arrows-circle fs-3 me-1"></i>Làm mới
                        </button>
                        <a href="/administration/roles" class="btn btn-light-primary btn-sm fw-bold">
                            <i class="ki-outline ki-setting-4 fs-3 me-1"></i>Quản lý vai trò
                        </a>
                        <button type="button" class="btn btn-primary btn-sm fw-bold px-6" @onclick="SaveAllChanges">
                            <i class="ki-outline ki-check-circle fs-3 me-1"></i>Lưu thay đổi
                        </button>
                    </div>
                </div>
                <!--end::Card toolbar-->
            </div>
            <!--end::Card header-->

            <!--begin::Card body-->
            <div class="card-body py-4 px-0">
                <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-300 align-middle gs-7 gy-5">
                        <thead>
                            <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0 bg-light">
                                <th class="min-w-250px rounded-start align-middle">Danh mục quyền hạn</th>
                                @foreach (var role in _roles)
                                {
                                    <th class="text-center min-w-100px">
                                        <div class="d-flex flex-column align-items-center">
                                            <i class="ki-outline ki-shield-tick fs-2 text-primary mb-2"></i>
                                            <span>@role.Name</span>
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (_isLoading)
                            {
                                <tr>
                                    <td colspan="@(1 + _roles.Count)" class="text-center py-10">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var p in _permissions)
                                {
                                    <tr class="hover-elevate cursor-pointer" @onclick="() => openPermissionDetail(p)">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="symbol symbol-45px me-4">
                                                    <span class="symbol-label @p.IconBg">
                                                        <i class="@p.Icon fs-2 @p.IconColor"></i>
                                                    </span>
                                                </div>
                                                <div class="d-flex flex-column">
                                                    <span class="text-gray-800 fw-bolder text-hover-primary fs-6">@p.Name</span>
                                                    <span class="text-muted fs-8">@p.Description</span>
                                                </div>
                                            </div>
                                        </td>
                                        @for (int i = 0; i < _roles.Count; i++)
                                        {
                                            var roleIndex = i;
                                            <td class="text-center" @onclick:stopPropagation="true">
                                                @{
                                                    var isEnabled = p.AccessDefaults[roleIndex];
                                                    var colorClass = isEnabled ? "text-success" : "text-gray-300";
                                                    var iconClass = isEnabled ? "ki-check-square" : "ki-cross-square";
                                                }
                                                <div class="d-flex justify-content-center cursor-pointer" @onclick="() => ToggleCategory(p, roleIndex)">
                                                    <i class="ki-outline @iconClass fs-1 @colorClass"></i>
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Content container-->
</div>
<!--end::Content-->

<!-- PERMISSION DETAIL DRAWER -->
<div class="bg-white drawer drawer-end @(_showDetailDrawer ? "drawer-on" : "")" 
     style="width: 550px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showDetailDrawer ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        @if (_selectedCategory != null)
        {
            <div class="card-header pe-5 py-8 @(_selectedCategory.IconBg) rounded-0 border-0">
                <div class="card-title">
                    <div class="d-flex align-items-center">
                        <div class="symbol symbol-50px me-5 bg-white bg-opacity-50 p-1 rounded">
                            <span class="symbol-label bg-transparent"><i class="@_selectedCategory.Icon fs-1 @_selectedCategory.IconColor"></i></span>
                        </div>
                        <div class="d-flex justify-content-center flex-column">
                            <span class="fs-3 fw-bolder text-white lh-1">@_selectedCategory.Name</span>
                            <span class="fs-8 fw-bold text-white opacity-75 mt-2">Chi tiết các hành động được phép thực hiện</span>
                        </div>
                    </div>
                </div>
                <div class="card-toolbar">
                    <div class="btn btn-sm btn-icon btn-active-color-primary bg-white bg-opacity-20" @onclick="closeDetailDrawer">
                        <i class="ki-outline ki-cross fs-4 text-white"></i>
                    </div>
                </div>
            </div>

            <div class="card-body hover-scroll-overlay-y py-8 px-10">
                <div class="notice d-flex bg-light-primary rounded border-primary border border-dashed mb-9 p-6">
                    <i class="ki-outline ki-information fs-2tx text-primary me-4"></i>
                    <div class="d-flex flex-stack flex-grow-1">
                        <div class="fw-semibold">
                            <div class="fs-7 text-gray-700">Dưới đây là danh sách chi tiết các quyền hạn nguyên tử của <strong>@_selectedCategory.Name</strong>. Bạn có thể bật/tắt quyền cho từng vai trò cụ thể.</div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-row-bordered table-row-gray-300 align-middle gs-0 gy-5">
                        <thead>
                            <tr class="fw-bold text-muted fs-9 text-uppercase">
                                <th class="min-w-150px px-2">Hành động khả dụng</th>
                                @foreach (var role in _roles)
                                {
                                    <th class="text-center min-w-80px px-2">@role.Name</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in _selectedCategory.SubPermissions)
                            {
                                <tr>
                                    <td class="px-2">
                                        <div class="d-flex flex-column">
                                            <span class="text-gray-800 fw-bold fs-7">@sub.Action</span>
                                            <span class="text-muted fs-9">@sub.Key</span>
                                        </div>
                                    </td>
                                    @for (int i = 0; i < _roles.Count; i++)
                                    {
                                        var roleIndex = i;
                                        var roleId = _roles[roleIndex].Id;
                                        <td class="text-center px-2">
                                            <div class="form-check form-switch form-check-custom form-check-solid justify-content-center">
                                                <input class="form-check-input h-20px w-35px" type="checkbox" 
                                                       checked="@sub.IsEnabled(roleId)" 
                                                       @onclick="() => ToggleSinglePermission(sub, roleIndex)" />
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer py-6 px-10 border-0 bg-light d-flex gap-3 justify-content-end">
                <button type="button" class="btn btn-sm btn-light fw-bold px-6" @onclick="closeDetailDrawer">Đóng</button>
                <button type="button" class="btn btn-sm btn-primary fw-bold px-6" @onclick="SaveAllChanges">
                    <i class="ki-outline ki-check-circle fs-4 me-1"></i>Lưu thay đổi
                </button>
            </div>
        }
    </div>
</div>



@if (_showDetailDrawer)
{
    <div class="drawer-overlay" style="z-index: 105; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="closeDetailDrawer"></div>
}


