@page "/leave/requests"
@using TTL.HR.Shared.Components.Common

<PageTitle>Quản lý đơn nghỉ - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        <!-- Header & Tabs -->
        <div class="card mb-8 shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <div class="d-flex flex-stack flex-wrap p-8">
                    <div class="d-flex flex-column">
                        <h1 class="text-gray-900 fw-bolder fs-2 mb-1">Quản lý nghỉ phép</h1>
                        <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 pt-1">
                            <li class="breadcrumb-item text-muted">Quản lý nhân sự</li>
                            <li class="breadcrumb-item"><span class="bullet bg-gray-300 w-5px h-2px"></span></li>
                            <li class="breadcrumb-item text-gray-900">Danh sách đơn nghỉ</li>
                        </ul>
                    </div>
                    <div class="d-flex align-items-center gap-3 mt-4 mt-md-0">
                        <button class="btn btn-light-primary fw-bold px-6 py-3 shadow-sm hover-elevate-up" @onclick="LoadData" disabled="@_isLoading">
                            <i class="ki-outline ki-arrows-loop fs-3 me-2"></i>Cập nhật dữ liệu
                        </button>
                        <button class="btn btn-primary fw-bold px-6 py-3 shadow-sm hover-elevate-up" @onclick="openCreate">
                            <i class="ki-outline ki-plus-square fs-3 me-2"></i>Tạo đơn mới
                        </button>
                    </div>
                </div>

                <div class="px-8 border-top bg-light-light bg-opacity-50">
                    <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "All" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("All")'>
                                Tất cả <span class="badge badge-light-dark ms-2">@(_summary.TotalCount)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "Pending" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("Pending")'>
                                Chờ duyệt <span class="badge badge-light-warning ms-2">@_summary.PendingCount</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "Approved" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("Approved")'>
                                Đã duyệt <span class="badge badge-light-success ms-2">@_summary.ApprovedCount</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-active-primary py-5 me-10 @(_activeTab == "Rejected" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("Rejected")'>
                                Từ chối <span class="badge badge-light-danger ms-2">@_summary.RejectedCount</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Filter Bar -->
        <div class="card mb-6 shadow-xs border-0 rounded-3">
            <div class="card-body py-4 px-8">
                <div class="d-flex flex-wrap align-items-center">
                    <div class="position-relative w-md-300px me-auto my-1">
                        <i class="ki-outline ki-magnifier fs-2 position-absolute top-50 translate-middle-y ms-4 text-gray-500"></i>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm theo tên NV, mã NV, lý do..." @oninput="Search" value="@_searchTerm" />
                    </div>
                </div>
            </div>
        </div>


        <!-- Table -->
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-10">
            <div class="card-body p-0">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="8">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-200 align-middle gs-8 gy-5 mb-0">
                            <thead class="bg-light-light">
                                <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
                                    <th class="w-10px pe-2">
                                        <div class="form-check form-check-sm form-check-custom form-check-solid">
                                            <input class="form-check-input" type="checkbox" />
                                        </div>
                                    </th>
                                    <th class="min-w-200px">Nhân viên / Đối tượng</th>
                                    <th class="min-w-150px text-center">Loại đơn</th>
                                    <th class="min-w-150px">Thời gian dự kiến</th>
                                    <th class="min-w-250px">Lý do cụ thể</th>
                                    <th class="min-w-150px text-center">Trạng thái</th>
                                    <th class="min-w-150px text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in _leaveRequests)
                                {
                                    <tr class="hover-elevate cursor-pointer" @onclick="() => openDetail(req)">
                                        <td>
                                            <div class="form-check form-check-sm form-check-custom form-check-solid">
                                                <input class="form-check-input" type="checkbox" @onclick:stopPropagation />
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="symbol symbol-circle symbol-45px me-3">
                                                    @if (!string.IsNullOrEmpty(req.Avatar))
                                                    {
                                                        <img src="@req.Avatar" alt="" />
                                                    }
                                                    else
                                                    {
                                                        <div class="symbol-label @req.AvatarBg bg-opacity-10 text-primary fw-bold fs-6">@(!string.IsNullOrEmpty(req.Name) ? req.Name.Substring(0, 1) : "N")</div>
                                                    }
                                                </div>
                                                <div class="d-flex flex-column">
                                                    <span class="text-gray-900 fw-bold fs-6 mb-1">@req.Name</span>
                                                    <span class="text-muted fw-semibold fs-8">@req.EmployeeCode • @req.Department</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @req.TypeColor fw-bold px-4 py-3 rounded-pill">@req.Type</span>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <div class="d-flex align-items-center mb-1">
                                                    <i class="ki-outline ki-calendar-8 fs-7 text-primary me-2"></i>
                                                    <span class="text-gray-800 fw-bold fs-7">@req.DateRange</span>
                                                </div>
                                                <div class="d-flex align-items-center">
                                                    <i class="ki-outline ki-time fs-7 text-muted me-2"></i>
                                                    <span class="text-muted fw-semibold fs-8">@req.Duration</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="text-gray-700 fs-7 text-truncate d-inline-block" style="max-width: 250px;" title="@req.Reason">
                                                @req.Reason
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @req.StatusColor fw-bold px-4 py-2 d-inline-flex align-items-center">
                                                <span class="bullet bullet-dot @((req.StatusColor ?? "badge-light-secondary").Replace("badge-light-", "bg-")) w-6px h-6px me-2 @(req.Status == "Chờ duyệt" ? "pulse pulse-warning" : "")"></span>@req.Status
                                            </span>
                                        </td>
                                        <td class="text-end pe-8">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm shadow-sm" @onclick="() => openDetail(req)" @onclick:stopPropagation title="Xem chi tiết">
                                                    <i class="ki-outline ki-eye fs-3"></i>
                                                </button>
                                                @if (IsHR && (req.Status == "Chờ duyệt" || req.Status == "Pending"))
                                                {
                                                    <button class="btn btn-icon btn-bg-light btn-active-color-success btn-sm shadow-sm" @onclick="() => requestApprove(req)" @onclick:stopPropagation title="Duyệt">
                                                        <i class="ki-outline ki-check fs-2"></i>
                                                    </button>
                                                    <button class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm shadow-sm" @onclick="() => requestReject(req)" @onclick:stopPropagation title="Từ chối">
                                                        <i class="ki-outline ki-cross fs-2"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!_leaveRequests.Any() && !_isLoading)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-20">
                                            <div class="d-flex flex-column align-items-center">
                                                <i class="ki-outline ki-notification-on fs-5x text-gray-200 mb-5"></i>
                                                <span class="text-muted fs-6 fw-bold">Hiện không có đơn nghỉ nào trong danh sách.</span>
                                                @if (!string.IsNullOrEmpty(_searchTerm))
                                                {
                                                    <span class="text-muted fs-7 mt-2">Thử thay đổi từ khóa tìm kiếm: "@_searchTerm"</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination -->
                    <div class="d-flex flex-stack flex-wrap px-8 py-6 bg-light-light bg-opacity-30 border-top">
                        <div class="fs-7 fw-bold text-gray-700">
                            Hiển thị <span class="text-gray-900 fw-bolder">@_leaveRequests.Count</span> của tổng số <span class="text-gray-900 fw-bolder">@_totalCount</span> yêu cầu
                        </div>
                        <ul class="pagination pagination-outline">
                            <li class="page-item previous @(_pageIndex <= 1 ? "disabled" : "")">
                                <a href="javascript:;" class="page-link" @onclick="() => ChangePage(_pageIndex - 1)"><i class="ki-outline ki-left fs-6"></i></a>
                            </li>
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                var p = i;
                                <li class="page-item @(_pageIndex == p ? "active" : "")">
                                    <a href="javascript:;" class="page-link" @onclick="() => ChangePage(p)">@p</a>
                                </li>
                            }
                            <li class="page-item next @(_pageIndex >= TotalPages ? "disabled" : "")">
                                <a href="javascript:;" class="page-link" @onclick="() => ChangePage(_pageIndex + 1)"><i class="ki-outline ki-right fs-6"></i></a>
                            </li>
                        </ul>
                    </div>
                </SkeletonLoading>
            </div>
        </div>
    </div>
</div>






<!-- LEAVE DETAIL DRAWER -->
<div class="bg-white drawer drawer-end @(_showDetail ? "drawer-on" : "")" 
     style="width: 500px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showDetail ? "translateX(0)" : "translateX(100%)"); display: block;">
    <!-- ... existing Detail Drawer content ... -->
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <div class="card-header pe-5">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column me-3">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Chi tiết yêu cầu</span>
                    <span class="fs-7 fw-bold text-muted mt-2">Mã yêu cầu: #LR-@(_selectedRequest?.Id.Substring(2) ?? "000")</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeDetail">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>
        <div class="card-body hover-scroll-overlay-y">
            @if (_selectedRequest != null)
            {
                <div class="d-flex flex-stack bg-light-primary rounded p-6 mb-8 border border-primary border-dashed">
                    <div class="d-flex align-items-center">
                        <div class="symbol symbol-60px symbol-circle me-5 border border-white border-3 shadow-sm">
                            @if (!string.IsNullOrEmpty(_selectedRequest.Avatar))
                            {
                                <img src="@_selectedRequest.Avatar" alt="" />
                            }
                            else
                            {
                                <div class="symbol-label fs-2 fw-bold @_selectedRequest.AvatarBg text-white">@(_selectedRequest.Name.Length > 0 ? _selectedRequest.Name.Substring(0, 1) : "N")</div>
                            }
                        </div>
                        <div class="d-flex flex-column">
                            <span class="text-gray-900 fw-bolder fs-5">@_selectedRequest.Name</span>
                            <span class="text-muted fw-bold fs-7">@_selectedRequest.Department</span>
                            <div class="d-flex align-items-center mt-1">
                                <span class="badge @_selectedRequest.StatusColor fw-bold fs-9 px-2 py-0.5">@_selectedRequest.Status</span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Request Content -->
                <div class="mb-10">
                    <h3 class="fw-bolder fs-6 mb-5 text-gray-800 text-uppercase">Nội dung yêu cầu</h3>
                    <div class="d-flex flex-column gap-5">
                        <div class="bg-light-light p-5 rounded border border-dashed">
                            <div class="d-flex flex-stack mb-3">
                                <span class="text-muted fw-bold">Loại nghỉ:</span>
                                <span class="badge @_selectedRequest.TypeColor fs-8 fw-bold">@_selectedRequest.Type</span>
                            </div>
                            <div class="d-flex flex-stack mb-3">
                                <span class="text-muted fw-bold">Thời gian:</span>
                                <span class="text-gray-800 fw-bolder">@_selectedRequest.DateRange</span>
                            </div>
                            <div class="d-flex flex-stack mb-3">
                                <span class="text-muted fw-bold">Số ngày:</span>
                                <span class="text-gray-800 fw-bolder">@_selectedRequest.Duration</span>
                            </div>
                        </div>
                        <div class="p-5">
                            <label class="text-muted fw-bold d-block mb-3">Lý do nghỉ:</label>
                            <div class="text-gray-800 fs-6 lh-lg p-4 bg-light rounded border">
                                @_selectedRequest.Reason
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(_selectedRequest.ManagerNote))
                        {
                            <div class="p-5 pt-0">
                                <label class="text-muted fw-bold d-block mb-3">Phản hồi từ quản lý:</label>
                                <div class="text-gray-800 fs-6 lh-lg p-4 bg-light-info rounded border border-info border-opacity-25">
                                    @_selectedRequest.ManagerNote
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <!-- ... Balance Summary ... -->
                <div class="card bg-light-warning border-0 mb-8">
                    <div class="card-body p-6 text-center">
                        <h3 class="fw-bolder fs-6 mb-5 text-gray-800 text-uppercase">Quỹ phép 2026</h3>
                        <div class="d-flex flex-stack gap-4">
                            <div class="flex-grow-1 border-end border-warning border-opacity-25">
                                <div class="fs-4 fw-bolder text-gray-800">12</div>
                                <div class="fs-9 fw-bold text-muted">TỔNG</div>
                            </div>
                            <div class="flex-grow-1 border-end border-warning border-opacity-25">
                                <div class="fs-4 fw-bolder text-gray-800">4.5</div>
                                <div class="fs-9 fw-bold text-muted">ĐàDÙNG</div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fs-4 fw-bolder text-primary">7.5</div>
                                <div class="fs-9 fw-bold text-muted">CÒN LẠI</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="card-footer border-0 d-flex gap-3 justify-content-between p-10">
            @if (_selectedRequest?.Status == "Chờ phê duyệt")
            {
                <button type="button" class="btn btn-light-danger flex-grow-1 fs-7 fw-bold" @onclick="() => requestReject(_selectedRequest)">Từ chối</button>
                <button type="button" class="btn btn-primary flex-grow-1 fs-7 fw-bold" @onclick="() => requestApprove(_selectedRequest)">Phê duyệt</button>
            }
            else
            {
                <button type="button" class="btn btn-light flex-grow-1 fs-7 fw-bold w-100" @onclick="closeDetail">Đóng</button>
            }
        </div>
    </div>
</div>

<!-- CREATE REQUEST DRAWER -->
<div class="bg-white drawer drawer-end @(_showCreate ? "drawer-on" : "")" 
     style="width: 550px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showCreate ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <!-- Header -->
        <div class="card-header pe-5">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column me-3">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Tạo yêu cầu mới</span>
                    <span class="fs-7 fw-bold text-muted mt-2">Gửi yêu cầu phê duyệt nghỉ phép / công tác</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeCreate">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="card-body hover-scroll-overlay-y py-10">
            <!-- Form -->
            <div class="d-flex flex-column gap-7">
                @if (IsHR)
                {
                    <!-- Employee -->
                    <div class="fv-row">
                        <label class="required fs-6 fw-bold mb-2">Nhân viên</label>
                        <select class="form-select form-select-solid fw-bolder fs-7" @bind="_createModel.EmployeeId">
                            <option value="">-- Chọn nhân viên --</option>
                            @foreach(var emp in _employees)
                            {
                                <option value="@emp.Id">@emp.FullName (@emp.Code)</option>
                            }
                        </select>
                    </div>
                }

                <!-- Type -->
                <div class="fv-row">
                    <label class="required fs-6 fw-bold mb-2">Loại yêu cầu</label>
                    <select class="form-select form-select-solid fw-bolder fs-7" @bind="_createModel.LeaveTypeId">
                        <option value="">-- Chọn loại yêu cầu --</option>
                        @foreach(var type in _leaveTypes)
                        {
                            <option value="@type.Id">@type.Name</option>
                        }
                    </select>
                </div>

                <!-- Date Range -->
                <div class="row g-9">
                    <div class="col-md-6 fv-row">
                        <label class="required fs-6 fw-bold mb-2">Từ ngày</label>
                        <input type="date" class="form-control form-control-solid fs-7" @bind="_createModel.StartDate" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div class="col-md-6 fv-row">
                        <label class="required fs-6 fw-bold mb-2">Đến ngày</label>
                        <input type="date" class="form-control form-control-solid fs-7" @bind="_createModel.EndDate" @bind:format="yyyy-MM-dd" />
                    </div>
                </div>

                <!-- Duration Info -->
                <div class="notice d-flex bg-light-info rounded border-info border border-dashed p-4">
                    <i class="ki-outline ki-information-5 fs-2 text-info me-3"></i>
                    <div class="d-flex flex-stack flex-grow-1">
                        <div class="fw-bold">
                            @{
                                var diff = (_createModel.EndDate - _createModel.StartDate).TotalDays + 1;
                                if (diff < 0) diff = 0;
                            }
                            <div class="fs-7 text-gray-700">Tổng thời gian dự kiến: <span class="fw-bolder">@diff.ToString("N1") ngày</span></div>
                        </div>
                    </div>
                </div>

                <!-- Reason -->
                <div class="fv-row">
                    <label class="required fs-6 fw-bold mb-2">Lý do cụ thể</label>
                    <textarea class="form-control form-control-solid fs-7" rows="4" placeholder="Vui lòng nhập chi tiết lý do..." @bind="_createModel.Reason"></textarea>
                </div>

                <!-- Attachments -->
                <div class="fv-row">
                    <label class="fs-6 fw-bold mb-2">Tệp đính kèm (nếu có)</label>
                    <div class="dropzone border-dashed border-primary bg-light-primary rounded d-flex flex-column align-items-center justify-content-center p-10 cursor-pointer">
                        <i class="ki-outline ki-file-up fs-2hx text-primary mb-3"></i>
                        <span class="fs-8 fw-bold text-gray-600">Nhấn để tải lên hoặc kéo thả tệp tại đây (PDF, JPG, PNG)</span>
                    </div>
                </div>

                <!-- Handover -->
                <div class="fv-row">
                    <label class="fs-6 fw-bold mb-2">Người bàn giao công việc</label>
                    <select class="form-select form-select-solid fs-7" @bind="_createModel.NextApproverId">
                        <option value="">-- Chọn người thay thế tạm thời --</option>
                        <option value="60f123456789012345678901">Bùi Quang Tuấn (Manager)</option>
                        <option value="60f123456789012345678902">Trần Thị Tuyết (Senior Dev)</option>
                        <option value="60f123456789012345678903">Nguyễn Minh Anh (Accountant)</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="card-footer border-0 d-flex gap-3 justify-content-end p-10 bg-light-light">
            <button type="button" class="btn btn-light fw-bold px-8" @onclick="closeCreate" disabled="@_isSaving">Hủy bỏ</button>
            <button type="button" class="btn btn-primary fw-bold px-8" @onclick="handleSubmitCreate" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="spinner-border spinner-border-sm align-middle me-2"></span>
                    <span>Đang gửi...</span>
                }
                else
                {
                    <i class="ki-outline ki-send fs-5 me-1"></i>
                    <span>Gửi yêu cầu</span>
                }
            </button>
        </div>
    </div>
</div>


<!-- Backdrop -->
@if (_showDetail || _showCreate)
{
    <div class="drawer-overlay" style="z-index: 105; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="() => { closeDetail(); closeCreate(); }"></div>
}

<GenericActionModal IsVisible="_showActionModal"
                    Title="@_modalTitle"
                    Heading="@_modalHeading"
                    Message="@_modalMessage"
                    Color="@_modalColor"
                    Icon="@_modalIcon"
                    ConfirmLabel="@_modalConfirmLabel"
                    ShowReasonInput="_showReasonInput"
                    IsReasonRequired="@(_actionType == "REJECT")"
                    ReasonPlaceholder="@(_actionType == "REJECT" ? "Vui lòng nhập lý do từ chối (bắt buộc)..." : "Nhập lời nhắn gửi nhân viên (không bắt buộc)...")"
                    OnConfirmed="confirmAction"
                    OnCancelled="closeModal" />


