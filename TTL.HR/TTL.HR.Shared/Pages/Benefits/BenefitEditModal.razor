@using TTL.HR.Shared.Components.Common
@using TTL.HR.Application.Modules.Payroll.Models

@if (IsVisible)
{
    <!-- Backdrop -->
    <div class="modal-backdrop fade show overlay-backdrop"></div>
    
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered mw-650px">
            <div class="modal-content rounded-4 shadow-lg border-0">
                <div class="modal-header border-0 pb-0 pt-6 px-8">
                    <h2 class="fw-bolder">@(IsEdit ? "Cập nhật phúc lợi" : "Thêm phúc lợi mới")</h2>
                    <div class="btn btn-sm btn-icon btn-active-color-primary" @onclick="Close">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </div>
                </div>

                <div class="modal-body scroll-y px-8 pt-6 pb-15">
                    <EditForm Model="@Benefit" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        
                        <div class="row g-9 mb-8">
                            <div class="col-md-6 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Tên phúc lợi</label>
                                <InputText class="form-control form-control-solid" @bind-Value="Benefit.Name" placeholder="Vd: Phụ cấp ăn trưa" />
                            </div>
                            <div class="col-md-6 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Mã phúc lợi</label>
                                <InputText class="form-control form-control-solid" @bind-Value="Benefit.Code" placeholder="Vd: LUNCH_ALW" disabled="@IsEdit" />
                            </div>
                        </div>

                        <div class="fv-row mb-8">
                            <label class="required fs-6 fw-bold mb-2">Mô tả chi tiết</label>
                            <InputTextArea class="form-control form-control-solid" rows="3" @bind-Value="Benefit.Description" placeholder="Mục đích, điều kiện áp dụng..." />
                        </div>

                        <div class="row g-9 mb-8">
                            <div class="col-md-4 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Định mức (VNĐ)</label>
                                <InputNumber class="form-control form-control-solid" @bind-Value="Benefit.Amount" />
                            </div>
                            <div class="col-md-4 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Loại định kỳ</label>
                                <InputSelect class="form-select form-select-solid" @bind-Value="Benefit.Type">
                                    <option value="Monthly">Cố định hàng tháng</option>
                                    <option value="Yearly">Định kỳ năm</option>
                                    <option value="OneTime">Một lần</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-4 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Danh mục</label>
                                <InputSelect class="form-select form-select-solid" @bind-Value="Benefit.Category">
                                    <option value="Allowance">Phụ cấp</option>
                                    <option value="Insurance">Bảo hiểm</option>
                                    <option value="Bonus">Thưởng</option>
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row g-9 mb-8">
                            <div class="col-md-12 fv-row">
                                <label class="required fs-6 fw-bold mb-2">Trạng thái áp dụng</label>
                                <div class="form-check form-switch form-check-custom form-check-solid">
                                    <InputCheckbox class="form-check-input" @bind-Value="Benefit.IsActive" />
                                    <label class="form-check-label fw-bold">
                                        @(Benefit.IsActive ? "Đang có hiệu lực" : "Ngừng áp dụng")
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-10">
                            <button type="button" class="btn btn-light fw-bold me-3" @onclick="Close" disabled="@_isSaving">Hủy bỏ</button>
                            <button type="submit" class="btn btn-primary fw-bold" disabled="@_isSaving">
                                @if (_isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm align-middle me-2"></span>
                                    <span>Đang lưu...</span>
                                }
                                else
                                {
                                    <span>Lưu định mức</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}
