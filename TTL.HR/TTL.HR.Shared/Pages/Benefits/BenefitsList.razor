@page "/benefits"
@using TTL.HR.Shared.Components.Common
@using TTL.HR.Application.Modules.Payroll.Models

<PageTitle>Chế độ phúc lợi - TTL.HR</PageTitle>

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        
        <!-- Summary Cards -->
        <div class="row g-5 mb-8">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-primary rounded-4">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-45px bg-white me-3 rounded-3 shadow-xs">
                                <span class="symbol-label">
                                    <i class="ki-outline ki-wallet fs-2 text-primary"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bold fs-6">Dự chi phúc lợi tháng</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2hx fw-bolder text-dark">@_benefits.Sum(x => x.Amount).ToString("N0") đ</span>
                            <span class="text-muted fs-8 fw-bold text-uppercase">Dự chi theo cấu hình</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-success rounded-4">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-45px bg-white me-3 rounded-3 shadow-xs">
                                <span class="symbol-label">
                                    <i class="ki-outline ki-notification-on fs-2 text-success"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bold fs-6">Chế độ đang hiệu lực</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2hx fw-bolder text-dark">@_benefits.Count(x => x.IsActive).ToString("D2")</span>
                            <span class="text-muted fs-8 fw-bold text-uppercase">Trên tổng số @_benefits.Count danh mục</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-info rounded-4">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-45px bg-white me-3 rounded-3 shadow-xs">
                                <span class="symbol-label">
                                    <i class="ki-outline ki-people fs-2 text-info"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bold fs-6">Nhân sự thụ hưởng</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2hx fw-bolder text-dark">@_benefits.Sum(x => x.EmployeeCount).ToString("D2")</span>
                            <span class="text-muted fs-8 fw-bold text-uppercase">Đang được gán phụ cấp</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-warning rounded-4">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-45px bg-white me-3 rounded-3 shadow-xs">
                                <span class="symbol-label">
                                    <i class="ki-outline ki-timer fs-2 text-warning"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bold fs-6">Yêu cầu chờ duyệt</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2hx fw-bolder text-dark">03</span>
                            <span class="text-muted fs-8 fw-bold text-uppercase">Phụ cấp phát sinh mới</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters Bar -->
        <div class="card mb-8 shadow-sm border-0 rounded-4">
            <div class="card-body py-4 px-6">
                <div class="d-flex flex-wrap align-items-center">
                    <div class="position-relative w-md-300px me-4 my-1">
                        <i class="ki-outline ki-magnifier fs-3 position-absolute top-50 translate-middle-y ms-4 text-gray-500"></i>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm kiếm tên, mã phúc lợi..." 
                               @bind="_searchTerm" @bind:event="oninput" />
                    </div>

                    <div class="w-md-200px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold" @bind="_selectedCategory">
                            <option value="">Phân loại: Tất cả</option>
                            <option value="Allowance">Phụ cấp</option>
                            <option value="Insurance">Bảo hiểm</option>
                            <option value="Bonus">Thưởng</option>
                        </select>
                    </div>

                    <div class="ms-auto my-1 d-flex gap-2">
                        <button class="btn btn-light-primary fw-bold fs-7 px-6 shadow-sm" @onclick="ExportExcel"><i class="ki-outline ki-exit-up fs-5 me-1"></i>Xuất Excel</button>
                        <button class="btn btn-primary fw-bold fs-7 px-6 shadow-sm" @onclick="CreateNewBenefit"><i class="ki-outline ki-plus fs-5 me-1"></i>Thêm phúc lợi mới</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="8">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-200 align-middle gs-9 gy-5 mb-0">
                            <thead class="bg-light">
                                <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
                                    <th class="w-10px pe-2 text-center">STT</th>
                                    <th class="min-w-250px">PHÚC LỢI / PHỤ CẤP</th>
                                    <th class="min-w-150px">LOẠI HÌNH</th>
                                    <th class="min-w-150px text-center">ĐỊNH MỨC</th>
                                    <th class="min-w-150px">ĐỐI TƯỢNG</th>
                                    <th class="min-w-120px text-center">TRẠNG THÁI</th>
                                    <th class="min-w-120px text-end pe-7">THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody class="fw-semibold text-gray-700">
                                @if (FilteredBenefits.Any())
                                {
                                    int index = 1;
                                    @foreach (var item in FilteredBenefits)
                                    {
                                        <tr class="hover-elevate cursor-pointer transition-3ms" @onclick="() => openDetail(item)">
                                            <td class="text-center text-muted fs-7">@index</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="symbol symbol-45px symbol-label bg-light-primary me-4 rounded-3">
                                                        <i class="@GetIconByBenefit(item) fs-3 text-primary"></i>
                                                    </div>
                                                    <div class="d-flex justify-content-start flex-column">
                                                        <span class="text-gray-900 fw-bold text-hover-primary fs-6 mb-1">@item.Name</span>
                                                        <span class="text-muted fw-semibold fs-7">@item.Code • @item.Description</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><span class="badge @GetTypeBadgeClass(item.Type) fw-bold px-3 py-2 rounded-pill">@TranslateType(item.Type)</span></td>
                                            <td class="text-center"><span class="text-gray-900 fw-bolder fs-6">@item.Amount.ToString("N0") VNĐ</span></td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="ki-outline ki-people fs-5 text-info me-2"></i>
                                                    <span class="text-gray-700 fw-bold">@item.EmployeeCount.ToString("N0") nhân sự</span>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @(item.IsActive ? "badge-light-success" : "badge-light-warning") fw-bold px-4 py-2">
                                                    @(item.IsActive ? "Đang áp dụng" : "Ngừng áp dụng")
                                                </span>
                                            </td>
                                            <td class="text-end pe-7">
                                                <button class="btn btn-icon btn-light-info btn-sm me-1 shadow-xs border-0" title="Phân công nhân viên" @onclick:stopPropagation @onclick="() => OpenAssignModal(item)">
                                                    <i class="ki-outline ki-people fs-4"></i>
                                                </button>
                                                <button class="btn btn-icon btn-light-primary btn-sm me-1 btn-active-primary shadow-xs border-0" title="Chỉnh sửa" @onclick:stopPropagation @onclick="() => EditBenefit(item)">
                                                    <i class="ki-outline ki-pencil fs-4"></i>
                                                </button>
                                                <button class="btn btn-icon btn-light-danger btn-sm btn-active-danger shadow-xs border-0" title="Xóa" @onclick:stopPropagation @onclick="() => PromptDeleteBenefit(item)">
                                                    <i class="ki-outline ki-trash fs-4"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-20">
                                            <div class="text-muted fs-4">Không tìm thấy danh mục phúc lợi nào.</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </SkeletonLoading>
            </div>
        </div>

    </div>
</div>

<!-- BENEFIT DETAIL DRAWER -->
<div class="bg-white drawer drawer-end @(_showDetail ? "drawer-on" : "") shadow-lg" 
     style="width: 550px; max-width: 90vw; position: fixed; right: 0; top: 0; bottom: 0; z-index: 120; border-left: 1px solid #eff2f5; transition: transform 0.4s cubic-bezier(0, 1, 0, 1); transform: @(_showDetail ? "translateX(0)" : "translateX(100%)");">
    @if (_selectedBenefit != null)
    {
        <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
            <!-- Header -->
            <div class="card-header border-0 pe-5 py-8 ms-4 mt-2">
                <div class="card-title">
                    <div class="d-flex justify-content-center flex-column me-3">
                        <h2 class="fs-2 fw-bolder text-gray-900 mb-1">Cấu hình chi tiết</h2>
                        <span class="fs-7 fw-semibold text-muted text-uppercase">Thiết lập định mức & Đối tượng thụ hưởng</span>
                    </div>
                </div>
                <div class="card-toolbar">
                    <button class="btn btn-sm btn-icon btn-active-light-primary bg-light" @onclick="closeDetail">
                        <i class="ki-outline ki-cross fs-1 text-gray-700"></i>
                    </button>
                </div>
            </div>

            <!-- Body -->
            <div class="card-body hover-scroll-overlay-y py-6 px-12">
                <div class="mb-10 text-center">
                    <div class="symbol symbol-100px symbol-label bg-light-primary mb-5 mx-auto rounded-circle">
                        <i class="@GetIconByBenefit(_selectedBenefit) fs-3x text-primary"></i>
                    </div>
                    <h3 class="fw-bolder fs-3 text-gray-900">@_selectedBenefit.Name</h3>
                    <span class="badge badge-light-primary fw-bold text-uppercase px-4 py-2 mt-2">@_selectedBenefit.Code</span>
                </div>

                <div class="separator separator-dashed border-gray-300 mb-10"></div>

                <div class="d-flex flex-column gap-8">
                    <div class="fv-row">
                        <label class="fs-7 fw-bold text-muted text-uppercase mb-2 d-block">Mô tả khoản chi</label>
                        <p class="text-gray-800 fw-semibold fs-6">@_selectedBenefit.Description</p>
                    </div>

                    <div class="row g-9">
                        <div class="col-md-6">
                            <label class="fs-7 fw-bold text-muted text-uppercase mb-2 d-block">Loại hình</label>
                            <span class="badge @GetTypeBadgeClass(_selectedBenefit.Type) fs-7 fw-bold px-4 py-2">@TranslateType(_selectedBenefit.Type)</span>
                        </div>
                        <div class="col-md-6">
                            <label class="fs-7 fw-bold text-muted text-uppercase mb-2 d-block">Danh mục</label>
                            <span class="text-gray-800 fw-bold fs-6">@_selectedBenefit.Category</span>
                        </div>
                    </div>

                        <div class="fv-row">
                        <label class="fs-7 fw-bold text-muted text-uppercase mb-2 d-block">Định mức chi trả</label>
                        <div class="bg-light-primary p-5 rounded-3 border border-primary border-dashed">
                            <span class="fs-2hx fw-bolder text-primary">@_selectedBenefit.Amount.ToString("N0") VNĐ</span>
                            <div class="fs-8 text-muted mt-2 fw-bold italic">* Hệ thống tự động tính vào bảng lương hàng tháng</div>
                        </div>
                    </div>

                    <div class="fv-row">
                        <label class="fs-7 fw-bold text-muted text-uppercase mb-2 d-block">Đối tượng áp dụng</label>
                        <div class="d-flex align-items-center">
                            <i class="ki-outline ki-people fs-2 text-info me-3"></i>
                            <span class="text-gray-800 fw-bold fs-6">@_selectedBenefit.TargetPerson</span>
                        </div>
                    </div>

                    <div class="fv-row bg-light rounded-4 p-6 border border-gray-200">
                         <label class="fs-8 fw-bold text-gray-600 text-uppercase mb-4 d-block">Quy tắc nâng cao</label>
                         <div class="form-check form-check-custom form-check-solid mb-4">
                            <input class="form-check-input h-20px w-20px" type="checkbox" checked disabled />
                            <label class="form-check-label text-gray-800 fw-bold ms-3 fs-7">Tính theo tỷ lệ ngày công thực tế</label>
                        </div>
                        <div class="form-check form-check-custom form-check-solid">
                            <input class="form-check-input h-20px w-20px" type="checkbox" checked disabled />
                            <label class="form-check-label text-gray-800 fw-bold ms-3 fs-7">Miễn trừ thuế TNCN (trong hạn mức)</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="card-footer py-8 px-12 border-0 d-flex gap-3 justify-content-end bg-light-light">
                <button type="button" class="btn btn-light fw-bold px-10" @onclick="closeDetail">Đóng</button>
                <button type="button" class="btn btn-primary fw-bold px-12 shadow-sm" @onclick="() => { closeDetail(); EditBenefit(_selectedBenefit); }">
                    <i class="ki-outline ki-pencil fs-5 me-1"></i>Chỉnh sửa
                </button>
            </div>
        </div>
    }
</div>

<!-- Backdrop -->
@if (_showDetail)
{
    <div class="drawer-overlay" style="z-index: 119; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="closeDetail"></div>
}

<BenefitEditModal @ref="_editModal" OnSaved="LoadData" />

<DeleteConfirmationModal 
    IsVisible="@IsDeleteModalOpen"
    Title="Xóa phúc lợi"
    Message="Bạn có chắc chắn muốn xóa danh mục phúc lợi này?"
    ItemName="@(BenefitToDelete?.Name ?? "")"
    OnConfirmed="ConfirmDelete"
    OnCancelled="CloseDeleteModal" />

@* ── ASSIGN EMPLOYEES MODAL ─────────────────────────────────────────────── *@
@if (_showAssignModal && _benefitToAssign != null)
{
    <div class="modal-backdrop fade show" style="z-index: 1040"></div>
    <div class="modal fade show d-block" style="z-index: 1050" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
            <div class="modal-content rounded-4 shadow-lg border-0">
                <div class="modal-header border-0 pb-0 pt-6 px-8 bg-light-info">
                    <div>
                        <h2 class="fw-bolder mb-1">
                            <i class="ki-outline ki-people fs-2 text-info me-2"></i>
                            Phân công: @_benefitToAssign.Name
                        </h2>
                        <span class="text-muted fs-7">Chọn nhân viên sẽ được hưởng phụ cấp này &bull; Định mức: <strong class="text-info">@_benefitToAssign.Amount.ToString("N0") VNĐ</strong></span>
                    </div>
                    <button class="btn btn-sm btn-icon btn-active-light-primary" @onclick="CloseAssignModal">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </button>
                </div>

                <div class="modal-body px-8 pt-6 pb-4">
                    <div class="row g-6">
                        <div class="col-md-4">
                            <div class="card border border-gray-200 h-100 shadow-xs">
                                <div class="card-header border-0 pt-5 min-h-auto">
                                    <h5 class="card-title fw-bolder text-dark fs-6 text-uppercase">1. Cấu hình chung</h5>
                                </div>
                                <div class="card-body pt-2">
                                    <div class="fv-row mb-5">
                                        <label class="form-label fs-7 fw-bold">Mức phụ cấp riêng (VNĐ)</label>
                                        <input type="number" class="form-control form-control-solid" placeholder="Mặc định: @_benefitToAssign.Amount.ToString("N0")" @bind="_assignRequest.OverrideAmount" />
                                    </div>
                                    <div class="row g-5 mb-5">
                                        <div class="col-6">
                                            <label class="form-label fs-7 fw-bold required">Ngày bắt đầu</label>
                                            <input type="date" class="form-control form-control-solid" @bind="_assignRequest.StartDate" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label fs-7 fw-bold">Ngày kết thúc</label>
                                            <input type="date" class="form-control form-control-solid" @bind="_assignRequest.EndDate" />
                                        </div>
                                    </div>
                                    <div class="fv-row mb-5">
                                        <label class="form-label fs-7 fw-bold">Ghi chú</label>
                                        <textarea class="form-control form-control-solid" rows="2" placeholder="Lý do áp dụng..." @bind="_assignRequest.Note"></textarea>
                                    </div>
                                    <div class="separator separator-dashed my-5"></div>
                                    <div class="alert alert-light-info border border-info border-dashed d-flex align-items-center p-4 fs-8">
                                        <i class="ki-outline ki-information-5 fs-4 text-info me-3"></i>
                                        Cấu hình trên sẽ áp dụng cho tất cả nhân viên được thêm mới trong lần lưu này.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="card border border-gray-200 h-100 shadow-xs">
                                <div class="card-header border-0 pt-5 flex-wrap">
                                    <div class="d-flex align-items-center flex-grow-1">
                                        <ul class="nav nav-pills nav-pills-custom gap-3">
                                            <li class="nav-item">
                                                <a class="nav-link btn btn-sm btn-color-muted btn-active-light-primary fw-bold px-4 py-2 @(_allocationTab == "unassigned" ? "active" : "")" @onclick='() => _allocationTab = "unassigned"'>
                                                    Chưa chọn (@(_allEmployees.Count - _currentAssignedIds.Count))
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link btn btn-sm btn-color-muted btn-active-light-success fw-bold px-4 py-2 @(_allocationTab == "assigned" ? "active" : "")" @onclick='() => _allocationTab = "assigned"'>
                                                    Đã chọn (@_currentAssignedIds.Count)
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="position-relative w-250px my-1">
                                        <i class="ki-outline ki-magnifier fs-4 position-absolute top-50 translate-middle-y ms-3 text-gray-500"></i>
                                        <input type="text" class="form-control form-control-sm form-control-solid ps-10" placeholder="Tìm nhân viên..." @bind="_employeeSearchTerm" @bind:event="oninput" />
                                    </div>
                                </div>
                                <div class="card-body pt-2 scroll-y" style="max-height: 400px; overflow-y: auto">
                                    <SkeletonLoading IsLoading="_isAllocationLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="5">
                                        @if (FilteredEmployees.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-row-dashed table-hover align-middle gy-3">
                                                    <thead class="bg-light sticky-top" style="top: -1px; z-index: 1">
                                                        <tr class="fw-bold text-muted fs-8 text-uppercase">
                                                            <th class="ps-4">NHÂN VIÊN</th>
                                                            <th>PHÒNG BAN</th>
                                                            <th class="text-end pe-4">THAO TÁC</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var emp in FilteredEmployees)
                                                        {
                                                            <tr>
                                                                <td class="ps-4">
                                                                    <div class="d-flex align-items-center">
                                                                        <div class="symbol symbol-30px symbol-circle me-3">
                                                                            @if (!string.IsNullOrEmpty(emp.AvatarUrl))
                                                                            {
                                                                                <img src="@emp.AvatarUrl" alt="" />
                                                                            }
                                                                            else
                                                                            {
                                                                                <div class="symbol-label bg-light-primary text-primary fw-bold fs-8">@(emp.FullName?.Length > 0 ? emp.FullName.Substring(0, 1) : "N")</div>
                                                                            }
                                                                        </div>
                                                                        <div class="d-flex flex-column">
                                                                            <span class="fw-bold text-gray-800 fs-7">@emp.FullName</span>
                                                                            <span class="text-muted fs-9">@emp.Code</span>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td><span class="text-gray-700 fs-7">@emp.DepartmentName</span></td>
                                                                <td class="text-end pe-4">
                                                                    @if (_currentAssignedIds.Contains(emp.Id))
                                                                    {
                                                                        <button class="btn btn-sm btn-light-danger btn-icon-start fw-bold px-3 py-1" @onclick="() => ToggleEmployeeAssignment(emp.Id)">
                                                                            <i class="ki-outline ki-trash fs-6"></i> Bỏ chọn
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <button class="btn btn-sm btn-light-success btn-icon-start fw-bold px-3 py-1" @onclick="() => ToggleEmployeeAssignment(emp.Id)">
                                                                            <i class="ki-outline ki-plus fs-6"></i> Chọn
                                                                        </button>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-center py-15 text-muted">
                                                <i class="ki-outline ki-face-blank fs-3x mb-3 d-block"></i>
                                                Không có dữ liệu hiển thị
                                            </div>
                                        }
                                    </SkeletonLoading>
                                </div>
                                <div class="card-footer py-4 px-6 border-0 bg-light-light d-flex justify-content-between align-items-center">
                                    <div class="text-muted fs-8">
                                        Đang có <span class="fw-bold text-dark">@(_currentAssignedIds.Count - _initiallyAssignedIds.Intersect(_currentAssignedIds).Count())</span> thay đổi mới
                                    </div>
                                    @if (_allocationTab == "unassigned")
                                    {
                                        <button class="btn btn-sm btn-light-primary fw-bold" @onclick="AssignToAllEmployees">Chọn tất cả trang này</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 pt-4 pb-8 px-12 justify-content-end bg-light">
                    <button class="btn btn-light fw-bold px-10 h-45px" @onclick="CloseAssignModal" disabled="@_isAssignLoading">Hủy bỏ</button>
                    <button class="btn btn-primary fw-bold px-15 h-45px shadow-sm" @onclick="SaveAssignments" disabled="@(_isAssignLoading || (_currentAssignedIds.OrderBy(x => x).SequenceEqual(_initiallyAssignedIds.OrderBy(x => x))))">
                        @if (_isAssignLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Đang lưu...</span>
                        }
                        else
                        {
                            <i class="ki-outline ki-check fs-4 me-2"></i>
                            <span>Lưu thay đổi</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}
