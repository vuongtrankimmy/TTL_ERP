@page "/benefits"

<div class="post d-flex flex-column-fluid pt-8" id="kt_post">
    <div id="kt_content_container" class="container-fluid">
        
        <!-- Summary Cards -->
        <div class="row g-5 mb-8">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-primary">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-40px bg-white me-3">
                                <span class="symbol-label">
                                    <i class="bi bi-wallet2 fs-2 text-primary"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bolder fs-6">Tổng ngân sách tháng</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2 fw-bolder text-dark">450,000,000 đ</span>
                            <span class="text-muted fs-8 fw-bold">+12% so với tháng trước</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-success">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-40px bg-white me-3">
                                <span class="symbol-label">
                                    <i class="bi bi-check-circle fs-2 text-success"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bolder fs-6">Chế độ đang áp dụng</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2 fw-bolder text-dark">15</span>
                            <span class="text-muted fs-8 fw-bold">Trên tổng số 18 danh mục</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-info">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-40px bg-white me-3">
                                <span class="symbol-label">
                                    <i class="bi bi-people fs-2 text-info"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bolder fs-6">Nhân viên thụ hưởng</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2 fw-bolder text-dark">124</span>
                            <span class="text-muted fs-8 fw-bold">98% tổng nhân sự</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-light-warning">
                    <div class="card-body p-6">
                        <div class="d-flex align-items-center mb-2">
                            <span class="symbol symbol-40px bg-white me-3">
                                <span class="symbol-label">
                                    <i class="bi bi-hourglass-split fs-2 text-warning"></i>
                                </span>
                            </span>
                            <span class="text-gray-800 fw-bolder fs-6">Chờ phê duyệt</span>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fs-2 fw-bolder text-dark">03</span>
                            <span class="text-muted fs-8 fw-bold">Yêu cầu phúc lợi mới</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters Bar -->
        <div class="card mb-8 shadow-sm">
            <div class="card-body py-4 px-6">
                <div class="d-flex flex-wrap align-items-center">
                    <div class="position-relative w-md-250px me-4 my-1">
                        <span class="svg-icon svg-icon-3 position-absolute top-50 translate-middle-y ms-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"></path>
                            </svg>
                        </span>
                        <input type="text" class="form-control form-control-solid ps-12 fs-7" placeholder="Tìm tên phúc lợi..." />
                    </div>

                    <div class="w-md-175px me-4 my-1">
                        <select class="form-select form-select-solid fs-7 fw-bold">
                            <option>Loại: Tất cả</option>
                            <option>Phụ cấp cố định</option>
                            <option>Thưởng & Phúc lợi</option>
                            <option>Bảo hiểm & Y tế</option>
                        </select>
                    </div>

                    <div class="ms-auto my-1 d-flex gap-2">
                        <button class="btn btn-light-primary fw-bold fs-7 px-6"><i class="bi bi-download me-1"></i>Xuất báo cáo</button>
                        <button class="btn btn-primary fw-bold fs-7 px-6"><i class="bi bi-plus-lg me-1"></i>Thêm mới</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-200 align-middle gs-7 gy-5">
                        <thead>
                            <tr class="fw-bold text-muted text-uppercase fs-8 border-bottom-0">
                                <th class="w-10px pe-2"></th>
                                <th class="min-w-200px">PHÚC LỢI / PHỤ CẤP</th>
                                <th class="min-w-150px">LOẠI HÌNH</th>
                                <th class="min-w-150px">ĐỊNH MỨC</th>
                                <th class="min-w-150px">ĐỐI TƯỢNG</th>
                                <th class="min-w-100px text-center">TRẠNG THÁI</th>
                                <th class="min-w-100px text-end pe-7">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _benefits)
                            {
                                <tr class="hover-elevate cursor-pointer" @onclick="() => openDetail(item)">
                                    <td>
                                        <div class="form-check form-check-sm form-check-custom form-check-solid">
                                            <input class="form-check-input" type="checkbox" @onclick:stopPropagation />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="symbol symbol-40px @item.IconBg me-4">
                                                <span class="symbol-label"><i class="@item.Icon fs-4 @item.IconColor"></i></span>
                                            </div>
                                            <div class="d-flex justify-content-start flex-column">
                                                <span class="text-dark fw-bolder text-hover-primary fs-6">@item.Name</span>
                                                <span class="text-muted fw-bold fs-7">@item.Description</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge @item.TypeColor fw-bold">@item.Type</span></td>
                                    <td><span class="text-dark fw-bolder">@item.Rate</span></td>
                                    <td><span class="text-gray-800 fw-bold">@item.Target</span></td>
                                    <td class="text-center">
                                        <span class="badge @(item.Status == "Đang áp dụng" ? "badge-light-success" : "badge-light-primary") fw-bold">@item.Status</span>
                                    </td>
                                    <td class="text-end pe-7">
                                        <button class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1 border" @onclick:stopPropagation @onclick="() => openDetail(item)"><i class="bi bi-pencil-fill fs-6"></i></button>
                                        <button class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm border" @onclick:stopPropagation><i class="bi bi-trash-fill fs-6"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Pagination -->
                <div class="px-7 py-5">
                    <div class="d-flex flex-stack flex-wrap">
                        <div class="fs-7 fw-bold text-gray-700">Hiển thị @_benefits.Count đến @_benefits.Count của 18 danh mục</div>
                        <ul class="pagination">
                            <li class="page-item previous disabled"><a href="#" class="page-link"><i class="next"></i></a></li>
                            <li class="page-item active"><a href="#" class="page-link">1</a></li>
                            <li class="page-item next disabled"><a href="#" class="page-link"><i class="next"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- BENEFIT DETAIL DRAWER -->
<div class="bg-white drawer drawer-end @(_showDetail ? "drawer-on" : "")" 
     style="width: 600px; position: fixed; right: 0; top: 0; bottom: 0; z-index: 106; box-shadow: -10px 0 30px rgba(0,0,0,0.1); border-left: 1px solid #eff2f5; transition: transform 0.3s ease; transform: @(_showDetail ? "translateX(0)" : "translateX(100%)"); display: block;">
    <div class="card w-100 rounded-0 border-0 h-100 overflow-hidden">
        <!-- Header -->
        <div class="card-header pe-5 py-6">
            <div class="card-title">
                <div class="d-flex justify-content-center flex-column me-3">
                    <span class="fs-4 fw-bolder text-gray-900 lh-1">Cấu hình chi tiết khoản chi</span>
                    <span class="fs-8 fw-bold text-muted mt-2">Thiết lập định mức, công thức và điều kiện hưởng phụ cấp</span>
                </div>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-sm btn-icon btn-active-light-primary" @onclick="closeDetail">
                    <i class="ki-outline ki-cross fs-4"></i>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="card-body hover-scroll-overlay-y py-8 px-10">
            @if (_selectedBenefit != null)
            {
                <div class="d-flex flex-column gap-10">
                    <!-- Section 1: Thông tin định danh -->
                    <div class="fv-row">
                        <div class="d-flex align-items-center mb-5">
                            <span class="badge badge-circle badge-primary fw-bold me-3">1</span>
                            <h3 class="fw-bolder fs-6 text-uppercase text-gray-800 mb-0">Thông tin định danh</h3>
                        </div>
                        <div class="row g-9 mb-6">
                            <div class="col-md-8">
                                <label class="required fs-7 fw-bold mb-2">Tên khoản chi</label>
                                <input type="text" class="form-control form-control-solid fs-7" value="@_selectedBenefit.Name" />
                            </div>
                            <div class="col-md-4">
                                <label class="required fs-7 fw-bold mb-2">Mã khoản chi</label>
                                <input type="text" class="form-control form-control-solid fs-7" value="@_selectedBenefit.Code" />
                            </div>
                        </div>
                        <div class="row g-9">
                            <div class="col-12">
                                <label class="required fs-7 fw-bold mb-2">Nhóm khoản chi</label>
                                <select class="form-select form-select-solid fs-7 fw-bold">
                                    <option>Phúc lợi nhân viên</option>
                                    <option>Phụ cấp cố định</option>
                                    <option>Bảo hiểm & Y tế</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: Công thức tính -->
                    <div class="fv-row">
                        <div class="d-flex align-items-center mb-5">
                            <span class="badge badge-circle badge-primary fw-bold me-3">2</span>
                            <h3 class="fw-bolder fs-6 text-uppercase text-gray-800 mb-0">Công thức tính</h3>
                        </div>
                        <div class="nav-group nav-group-outline mb-6">
                            <a href="#" class="btn btn-sm btn-color-muted btn-active btn-active-primary px-6 py-3 fw-bold active">Số tiền cố định</a>
                            <a href="#" class="btn btn-sm btn-color-muted btn-active btn-active-primary px-6 py-3 fw-bold">Tính theo % lương</a>
                        </div>
                        <div class="fv-row">
                            <label class="fs-7 fw-bold mb-2">Số tiền ($/VNĐ)</label>
                            <div class="position-relative">
                                <input type="text" class="form-control form-control-solid fs-5 fw-bolder text-primary" value="@_selectedBenefit.RateValue.ToString("N0")" />
                                <span class="position-absolute top-50 end-0 translate-middle-y me-4 text-gray-500 fw-bold">đ</span>
                            </div>
                            <div class="fs-8 text-muted mt-2">Hệ thống sẽ cộng trực tiếp khoản này vào mỗi kỳ lương hàng tháng.</div>
                        </div>
                    </div>

                    <!-- Section 3: Quy tắc áp dụng -->
                    <div class="fv-row">
                        <div class="d-flex align-items-center mb-5">
                            <span class="badge badge-circle badge-primary fw-bold me-3">3</span>
                            <h3 class="fw-bolder fs-6 text-uppercase text-gray-800 mb-0">Quy tắc áp dụng</h3>
                        </div>
                        <div class="d-flex flex-column gap-5">
                            <div class="form-check form-check-custom form-check-solid">
                                <input class="form-check-input" type="radio" value="1" name="rule" id="rule1" checked />
                                <label class="form-check-label" for="rule1">
                                    <span class="fw-bolder text-gray-800 fs-7 d-block">Tính theo ngày công thực tế</span>
                                    <span class="text-muted fs-8">Lương = (Định mức / Ngày công chuẩn) * Ngày công đi làm thực tế</span>
                                </label>
                            </div>
                            <div class="form-check form-check-custom form-check-solid">
                                <input class="form-check-input" type="radio" value="2" name="rule" id="rule2" />
                                <label class="form-check-label" for="rule2">
                                    <span class="fw-bolder text-gray-800 fs-7 d-block">Tính trọn tháng</span>
                                    <span class="text-muted fs-8">Chỉ áp dụng các khi nhân viên có thực lãnh lương trong tháng.</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Section 4: Điều kiện hưởng -->
                    <div class="fv-row">
                        <div class="d-flex align-items-center mb-5">
                            <span class="badge badge-circle badge-primary fw-bold me-3">4</span>
                            <h3 class="fw-bolder fs-6 text-uppercase text-gray-800 mb-0">Điều kiện hưởng</h3>
                        </div>
                        <div class="mb-5">
                            <label class="fs-7 fw-bold mb-2">Cấp bậc áp dụng</label>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge badge-light-primary fw-bold px-3 py-2 cursor-pointer border border-primary border-opacity-20 active">Nhân viên chính thức</span>
                                <span class="badge badge-light fw-bold px-3 py-2 cursor-pointer border">Thử việc</span>
                                <span class="badge badge-light fw-bold px-3 py-2 cursor-pointer border">Quản lý</span>
                                <span class="badge badge-light-primary fw-bold px-3 py-2 cursor-pointer border border-primary border-opacity-20 active">Trưởng phòng</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="card-footer py-6 px-10 border-0 d-flex gap-3 justify-content-end bg-light-light">
            <button type="button" class="btn btn-light fw-bold px-8" @onclick="closeDetail">Hủy bỏ</button>
            <button type="button" class="btn btn-primary fw-bold px-8">Lưu cấu hình</button>
        </div>
    </div>
</div>

<!-- Backdrop -->
@if (_showDetail)
{
    <div class="drawer-overlay" style="z-index: 105; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);" @onclick="closeDetail"></div>
}

@code {
    private bool _showDetail = false;
    private BenefitItem? _selectedBenefit;

    private void openDetail(BenefitItem item)
    {
        _selectedBenefit = item;
        _showDetail = true;
    }

    private void closeDetail() => _showDetail = false;

    private List<BenefitItem> _benefits = new()
    {
        new() { Code = "PC-001", Name = "Phụ cấp xăng xe", Description = "Phụ cấp di chuyển hàng tháng", Icon = "bi-fuel-pump", IconBg = "bg-light-primary", IconColor = "text-primary", Type = "Cố định hàng tháng", TypeColor = "badge-light-primary", Rate = "500,000 đ", RateValue = 500000, Target = "Toàn bộ nhân viên", Status = "Đang áp dụng" },
        new() { Code = "PL-01-02", Name = "Quà sinh nhật", Description = "Phúc lợi cho nhân viên", Icon = "bi-balloon", IconBg = "bg-light-info", IconColor = "text-info", Type = "Sự kiện", TypeColor = "badge-light-info", Rate = "1,000,000 đ", RateValue = 1000000, Target = "Chính thức", Status = "Đang áp dụng" },
        new() { Code = "PC-02-03", Name = "Phụ cấp ăn trưa", Description = "Tiền bữa trưa hàng tháng", Icon = "bi-egg-fried", IconBg = "bg-light-warning", IconColor = "text-warning", Type = "Cố định", TypeColor = "badge-light-primary", Rate = "30,000 đ/ngày", RateValue = 730000, Target = "Toàn bộ công ty", Status = "Đang áp dụng" },
        new() { Code = "PC-01-04", Name = "Phụ cấp điện thoại", Description = "Dành cho khối phòng doanh kinh", Icon = "bi-telephone", IconBg = "bg-light-info", IconColor = "text-info", Type = "Cố định", TypeColor = "badge-light-primary", Rate = "300,000 đ", RateValue = 300000, Target = "Phòng Kinh doanh, CSKH", Status = "Đang áp dụng" },
        new() { Code = "PL-10-05", Name = "Bảo hiểm sức khỏe", Description = "PVI Care cao cấp", Icon = "bi-shield-plus", IconBg = "bg-light-danger", IconColor = "text-danger", Type = "Số lượng", TypeColor = "badge-light-warning", Rate = "5,000,000 VNĐ/năm", RateValue = 5000000, Target = "Cấp quản lý", Status = "Đang áp dụng" },
        new() { Code = "PL-11-06", Name = "Hỗ trợ học tập", Description = "Chứng chỉ chuyên môn", Icon = "bi-book", IconBg = "bg-light-dark", IconColor = "text-dark", Type = "Sự kiện", TypeColor = "badge-light-info", Rate = "100% lệ phí", RateValue = 2000000, Target = "Toàn bộ nhân viên", Status = "Mới ban hành" }
    };

    private class BenefitItem
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public string IconBg { get; set; } = "";
        public string IconColor { get; set; } = "";
        public string Type { get; set; } = "";
        public string TypeColor { get; set; } = "";
        public string Rate { get; set; } = "";
        public decimal RateValue { get; set; }
        public string Target { get; set; } = "";
        public string Status { get; set; } = "";
    }
}
