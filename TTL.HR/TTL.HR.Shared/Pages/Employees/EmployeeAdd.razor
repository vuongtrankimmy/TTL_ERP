@page "/employees/add"
@page "/employees/edit/{Id}"
@using TTL.HR.Shared.Components.Common

<CccdScanner @ref="cccdScanner" />

<div class="d-flex flex-stack mb-6">
    <div class="d-flex align-items-center">
        <button class="btn btn-icon btn-sm btn-light-primary me-4" @onclick='() => Navigation.NavigateTo("/employees")' title="Quay lại">
            <i class="ki-outline ki-arrow-left fs-2"></i>
        </button>
        <div class="d-flex flex-column">
            <h1 class="fs-3 fw-bold text-gray-900 mb-1">
                @(IsEditMode ? $"CHỈNH SỬA: {newEmployee.FullName}" : "THÊM MỚI NHÂN VIÊN")
            </h1>
            <div class="d-flex align-items-center gap-2">
                <span class="badge badge-light-primary fw-bold">ID: @(IsEditMode ? newEmployee.Code : "TỰ ĐỘNG SINH")</span>
                @if (IsEditMode)
                {
                    <span class="badge @(newEmployee.IsActive ? "badge-light-success" : "badge-light-danger") fw-bold">
                        @(newEmployee.IsActive ? "Đang hoạt động" : "Ngừng hoạt động")
                    </span>
                }
            </div>
        </div>
    </div>
    <div class="d-flex gap-2">
        @if (IsReadOnly)
        {
            <div class="alert alert-dismissible bg-light-warning d-flex flex-column flex-sm-row p-3 border border-warning border-dashed rounded-3 m-0">
                <i class="ki-outline ki-shield-search fs-2hx text-warning me-4 mb-5 mb-sm-0"></i>
                <div class="d-flex flex-column pe-0 pe-sm-10">
                    <h5 class="mb-1 text-warning fw-bolder fs-7 text-uppercase">Chế độ xem (Read-only)</h5>
                    <span class="fs-9 text-gray-600">Bạn đang ở chế độ xem hồ sơ. Các tính năng chỉnh sửa đã được tạm khóa.</span>
                </div>
            </div>
        }
    </div>
</div>


<div class="card card-flush mb-6 shadow-sm border-0">
    <div class="card-body p-0">
        <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-6 fw-bold px-10">
            <li class="nav-item">
                <a class="nav-link text-active-primary active py-5 d-flex align-items-center" data-bs-toggle="tab" href="#tab_basic">
                    <span class="symbol symbol-20px me-3">
                        <i class="bi bi-person-check-fill fs-4 text-primary"></i>
                    </span>HỒ SƠ CƠ BẢN
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-active-primary py-5 d-flex align-items-center" data-bs-toggle="tab" href="#tab_personal">
                    <span class="symbol symbol-20px me-3">
                        <i class="bi bi-person-lines-fill fs-4 text-success"></i>
                    </span>LÝ LỊCH CHI TIẾT
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-active-primary py-5 d-flex align-items-center" data-bs-toggle="tab" href="#tab_competence">
                    <span class="symbol symbol-20px me-3">
                        <i class="bi bi-mortarboard fs-4 text-warning"></i>
                    </span>NĂNG LỰC & GIA ĐÌNH
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-active-primary py-5 d-flex align-items-center" data-bs-toggle="tab" href="#tab_account_finance">
                    <span class="symbol symbol-20px me-3">
                        <i class="bi bi-shield-lock-fill fs-4 text-danger"></i>
                    </span>TÀI KHOẢN & TÀI CHÍNH
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-active-primary py-5 d-flex align-items-center" data-bs-toggle="tab" href="#tab_documents">
                    <span class="symbol symbol-20px me-3">
                        <i class="bi bi-paperclip fs-4 text-info"></i>
                    </span>TÀI LIỆU
                </a>
            </li>
        </ul>
    </div>
</div>

<div class="tab-content border-0 p-0 m-0 position-relative">
    @if (_isLoading)
    {
        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center z-index-3 bg-white bg-opacity-75 rounded-3 border border-gray-200" style="min-height: 400px; z-index: 1000;">
            <div class="spinner-border text-primary w-60px h-60px border-4 mb-4" role="status"></div>
            <div class="fw-bold fs-5 text-gray-700">@(_currentLoadingStage ?? "Đang tải hồ sơ nhân viên...")</div>
            <div class="text-muted fs-8 mt-1 italic">Hệ thống đang đồng bộ dữ liệu với máy chủ CRM.</div>
            @if (!string.IsNullOrEmpty(_loadingError))
            {
                <div class="alert alert-danger mt-4 mx-10 p-4 border-dashed">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill fs-3 text-danger me-3"></i>
                        <div class="fw-bold">@_loadingError</div>
                    </div>
                    <button class="btn btn-sm btn-light-danger mt-3 w-100" @onclick="LoadAllDataAsync">Thử lại ngay</button>
                    <a href="/employees" class="btn btn-sm btn-link mt-1 w-100">Quay lại danh sách</a>
                </div>
            }
        </div>
    }
    
    <!-- TAB 1: THÔNG TIN CƠ BẢN & CÔNG VIỆC -->
    <div class="tab-pane fade show active" id="tab_basic" role="tabpanel">
        <EmployeeStepBasic 
            Model="newEmployee" 
            IsProcessing="_isProcessing" 
            IsReadOnly="@IsReadOnly"
            Errors="errorsMap"
            Departments="departments"
            Positions="positions"
            WorkplaceLookups="workplaceLookups"
            StatusLookups="employeeStatusLookups"
            ContractTypeLookups="contractTypeLookups"
            OnSave="Submit"
            OnAvatarUpload="UploadAvatar"
            OnScanRequested="ScanCCCD" />
    </div>
<!-- TAB 2: LÝ LỊCH CHI TIẾT -->
<div class="tab-pane fade" id="tab_personal" role="tabpanel">
    <EmployeeStepPersonal 
        Model="newEmployee" 
        IsProcessing="_isProcessing" 
        IsReadOnly="@IsReadOnly"
        Errors="errorsMap"
        GenderLookups="genderLookups"
        MaritalStatusLookups="maritalStatusLookups"
        EthnicityLookups="ethnicityLookups"
        ReligionLookups="religionLookups"
        NationalityLookups="nationalityLookups"
        ProvinceLookups="provinceLookups"
        OnSave="Submit" />
</div>

    <!-- TAB 3: NĂNG LỰC & GIA ĐÌNH -->
    <div class="tab-pane fade" id="tab_competence" role="tabpanel">
        <EmployeeStepCompetence 
            Model="newEmployee" 
            IsProcessing="_isProcessing" 
            IsReadOnly="@IsReadOnly"
            Errors="errorsMap"
            SchoolLookups="schoolLookups"
            DegreeLookups="degreeLookups"
            MajorLookups="majorLookups"
            OnSave="Submit" />
    </div>

    <!-- TAB 4: TÀI KHOẢN & TÀI CHÍNH -->
    <div class="tab-pane fade" id="tab_account_finance" role="tabpanel">
        <EmployeeStepFinance 
            Model="newEmployee" 
            IsProcessing="_isProcessing" 
            IsReadOnly="@IsReadOnly"
            Errors="errorsMap"
            IsEditMode="IsEditMode"
            AvailableRoles="availableRoles"
            OnSave="Submit"
            OnToggleRole="ToggleRole"
            OnPasswordResetRequested="RequestPasswordReset" />
    </div>

    <!-- TAB 5: TÀI LIỆU -->
    <div class="tab-pane fade" id="tab_documents" role="tabpanel">
        <EmployeeStepDocuments 
            Model="newEmployee"
            IsProcessing="_isProcessing"
            IsReadOnly="@IsReadOnly"
            UploadedDocuments="uploadedDocuments"
            OnSave="Submit"
            OnDocumentUpload='(val) => UploadDocument(val.Args, val.DocType)' />
    </div>
</div>




