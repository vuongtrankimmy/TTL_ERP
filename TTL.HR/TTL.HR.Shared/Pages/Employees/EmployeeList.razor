@page "/employees"

<div class="card card-flush shadow-sm">
	<div class="card-header border-0 pt-6">
		<div class="card-title">
			<div class="d-flex align-items-center position-relative my-1">
				<span class="svg-icon svg-icon-1 position-absolute ms-6">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
						<rect opacity="0.5" x="17.0365" y="15.1223" width="8.15546" height="2" rx="1" transform="rotate(45 17.0365 15.1223)" fill="currentColor" />
						<path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor" />
					</svg>
				</span>
				<input type="text" value="@searchQuery" @oninput="HandleSearch" class="form-control form-control-solid w-250px ps-14" placeholder="Tìm kiếm nhân viên..." />
			</div>
		</div>
		<div class="card-toolbar">
			<!-- VIEW MODE TOGGLE -->
			<div class="d-flex justify-content-end align-items-center me-4 border rounded shadow-xs overflow-hidden">
				<button type="button" class="btn btn-icon btn-sm btn-active-color-primary @(_viewMode == "table" ? "bg-light-primary text-primary" : "bg-white text-gray-400")" 
						@onclick='() => ToggleViewMode("table")' title="Xem dạng bảng">
					<i class="ki-outline ki-row-horizontal fs-2"></i>
				</button>
				<button type="button" class="btn btn-icon btn-sm btn-active-color-primary @(_viewMode == "card" ? "bg-light-primary text-primary" : "bg-white text-gray-400")" 
						@onclick='() => ToggleViewMode("card")' title="Xem dạng lưới">
					<i class="ki-outline ki-element-11 fs-2"></i>
				</button>
			</div>
			<button type="button" class="btn btn-light-primary me-3" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
				<i class="ki-outline ki-filter fs-2"></i> Lọc
			</button>
			<div class="menu menu-sub menu-sub-dropdown w-300px w-md-325px" data-kt-menu="true">
				<div class="px-7 py-5">
					<div class="fs-5 text-dark fw-bolder">Tùy chọn lọc nâng cao</div>
				</div>
				<div class="separator border-gray-200"></div>
				<div class="px-7 py-5">
					<div class="mb-5">
						<label class="form-label fs-6 fw-bold">Phòng ban:</label>
						<select class="form-select form-select-solid" @bind="filterDept">
							<option value="">Tất cả phòng ban</option>
							@foreach (var dept in CachedDepartments)
							{
								<option value="@dept.Name">@dept.Name</option>
							}
						</select>
					</div>
					<div class="mb-5">
						<label class="form-label fs-6 fw-bold">Nơi làm việc:</label>
						<select class="form-select form-select-solid" @bind="filterWorkplace">
							<option value="">Tất cả địa điểm</option>
							@foreach (var wp in CachedWorkplaces)
							{
								<option value="@wp.LookupID">@wp.Name</option>
							}
						</select>
					</div>
					<div class="d-flex justify-content-end">
						<button type="reset" class="btn btn-light btn-active-light-primary fw-bold me-2 px-6" @onclick="ResetFilters">Reset</button>
						<button type="submit" class="btn btn-primary fw-bold px-6" @onclick="ApplyFilters">Áp dụng</button>
					</div>
				</div>
			</div>

			<button type="button" class="btn btn-light-success me-3" @onclick="ExportExcel">
				<i class="ki-outline ki-exit-up fs-2"></i> Xuất Excel
			</button>

			<button type="button" class="btn btn-light-info me-3" @onclick="OpenImportWizard">
				<i class="ki-outline ki-file-up fs-2"></i> Nhập Excel
			</button>

			<a href="/employees/add" class="btn btn-primary">
				<i class="ki-outline ki-plus fs-2"></i> Thêm nhân viên
			</a>
		</div>
	</div>

	<div class="card-body pt-0">
		<!-- TABS -->
		<ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bolder px-5 mb-5">
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(string.IsNullOrEmpty(filterStatus) ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("")'>
					Tất cả <span class="badge badge-light-primary ms-2">@_counts.All</span>
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(filterStatus == "Active" ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("Active")'>
					Chính thức <span class="badge badge-light-success ms-2">@_counts.Active</span>
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(filterStatus == "Probation" ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("Probation")'>
					Thử việc <span class="badge badge-light-warning ms-2">@_counts.Probation</span>
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(filterStatus == "Resigned" ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("Resigned")'>
					Đã thôi việc <span class="badge badge-light-danger ms-2">@_counts.Resigned</span>
				</a>
			</li>
		</ul>

		@if (_loadFailed)
		{
			<div class="alert alert-danger d-flex align-items-center p-5 mb-10 transition-all animate__animated animate__shakeX">
				<i class="ki-outline ki-information-5 fs-2hx text-danger me-4"></i>
				<div class="d-flex flex-column">
					<h4 class="mb-1 text-danger fw-bolder">Có lỗi xảy ra khi tải dữ liệu</h4>
					<span class="fs-6 text-gray-700">@_errorMessage</span>
					<div class="mt-3">
						<button class="btn btn-sm btn-danger fw-boldest px-6" @onclick="ReloadData">
							<i class="ki-outline ki-arrows-circle fs-3 me-2"></i> Thử lại ngay
						</button>
					</div>
				</div>
			</div>
		}
		<SkeletonLoading IsLoading="_isLoading" Type='@(_viewMode == "card" ? SkeletonLoading.SkeletonType.CardGrid : SkeletonLoading.SkeletonType.Table)' Rows="10" Columns="8">
			@if (_viewMode == "card")
			{
				<!-- CARD GRID VIEW -->
				<div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 row-cols-xxl-4 g-9 animate__animated animate__fadeIn">
					@if (FilteredEmployees != null && FilteredEmployees.Any())
					{
						@foreach (var emp in FilteredEmployees)
						{
							<div class="col">
								<div class="card h-100 shadow-xs border-0 rounded-4 overflow-hidden position-relative hover-elevate-up transition-all hover-shadow-sm">
									<div class="card-body p-8">
										<!-- Card Header: Status & Actions -->
										<div class="d-flex flex-stack mb-5">
											<div class="badge badge-light-@(string.IsNullOrEmpty(emp.StatusColor) ? "warning" : emp.StatusColor) fw-boldest fs-9 px-3 py-2 rounded-pill shadow-xs">@emp.StatusName</div>

											<div class="dropdown">
												<button class="btn btn-icon btn-sm btn-light btn-active-light-primary rounded-circle" data-bs-toggle="dropdown" aria-expanded="false">
													<i class="ki-outline ki-dots-horizontal fs-3"></i>
												</button>
												<ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3">
													<li><a class="dropdown-item py-3 cursor-pointer kt_drawer_employee_detail_toggle" @onclick="() => SelectEmployeeByObj(emp)"><i class="ki-outline ki-eye fs-5 me-3 text-primary"></i>Xem hồ sơ</a></li>
													<li><a class="dropdown-item py-3 cursor-pointer" href="/employees/edit/@emp.Id"><i class="ki-outline ki-pencil fs-5 me-3 text-warning"></i>Cập nhật thông tin</a></li>
													<li><a class="dropdown-item py-3 cursor-pointer" @onclick="async () => { selectedEmployee = emp; await GenerateQR(); }"><i class="ki-outline ki-barcode fs-5 me-3 text-success"></i>Tạo mã QR</a></li>
													<li><hr class="dropdown-divider bg-gray-200"></li>
													<li><a class="dropdown-item py-3 cursor-pointer text-danger" @onclick="async () => { selectedEmployee = emp; await Offboarding(); }"><i class="ki-outline ki-trash fs-5 me-3 text-danger"></i>Xóa nhân sự</a></li>
												</ul>
											</div>
										</div>

										<!-- Card Content: Identity -->
										<div class="d-flex flex-column align-items-center mb-7">
											<div class="symbol symbol-70px symbol-circle mb-4 shadow-sm border border-2 border-white cursor-pointer kt_drawer_employee_detail_toggle" @onclick="() => SelectEmployeeByObj(emp)">
												@if (!string.IsNullOrEmpty(emp.Avatar))
												{
													<img src="@emp.Avatar" alt="@emp.Name" />
												}
												else
												{
													<div class="symbol-label fs-2 bg-light-primary text-primary fw-boldest">@(emp.DisplayInitials ?? "??")</div>
												}
											</div>
											<a href="javascript:;" class="kt_drawer_employee_detail_toggle text-gray-900 text-hover-primary fw-boldest fs-5 mb-1" @onclick="() => SelectEmployeeByObj(emp)">@emp.Name</a>
											<span class="text-muted fw-bold fs-7">@emp.Role</span>
										</div>

										<!-- Card Stats: Practical Info -->
										<div class="bg-light rounded-4 p-5 mb-0 border border-dashed border-gray-300">
											<div class="d-flex flex-stack mb-3">
												<span class="text-gray-600 fw-bold fs-8 text-uppercase">Phòng ban:</span>
												<span class="text-gray-800 fw-boldest fs-8 text-end text-truncate ms-2" title="@emp.Dept">@emp.Dept</span>
											</div>
											<div class="d-flex flex-stack mb-3">
												<span class="text-gray-600 fw-bold fs-8 text-uppercase">Mã NV:</span>
												<span class="text-gray-800 fw-boldest fs-8 text-end">@emp.Code</span>
											</div>
											<div class="d-flex flex-stack mb-0">
												<span class="text-gray-600 fw-bold fs-8 text-uppercase">Ngày vào:</span>
												<span class="text-gray-800 fw-boldest fs-8 text-end">@emp.JoinDate?.ToString("dd/MM/yyyy")</span>
											</div>
										</div>
									</div>
									
									<!-- Hover decoration -->
									<div class="position-absolute end-0 bottom-0 opacity-5 pe-3 pb-3">
										<i class="ki-outline ki-user-square fs-1 text-primary"></i>
									</div>
								</div>
							</div>
						}
					}
					else
					{
						<div class="col-12 py-10">
							<div class="text-center bg-light rounded-4 p-10 border border-dashed border-gray-300">
								<i class="ki-outline ki-users fs-3x text-gray-400 mb-5"></i>
								<div class="text-gray-500 fw-bold fs-6">Không tìm thấy nhân viên nào trong danh sách.</div>
							</div>
						</div>
					}
				</div>
			}
			else
			{
				<!-- TABLE VIEW (Default) -->
				<table class="table align-middle table-row-dashed fs-7 gy-5 animate__animated animate__fadeIn" id="kt_table_users">
					<thead>
						<tr class="text-start text-muted fw-bold fs-8 text-uppercase gs-0">
							<th class="w-10px pe-2">
								<div class="form-check form-check-sm form-check-custom form-check-solid me-3">
									<input class="form-check-input" type="checkbox" @onchange="ToggleSelectAll" checked="@isAllSelected" />
								</div>
							</th>
							<th class="min-w-200px cursor-pointer" @onclick='() => ToggleSort("name")'>Nhân viên <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "name" ? "text-primary" : "text-muted")"></i></th>
							<th class="min-w-100px cursor-pointer" @onclick='() => ToggleSort("code")'>Mã NV <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "code" ? "text-primary" : "text-muted")"></i></th>
							<th class="min-w-150px cursor-pointer" @onclick='() => ToggleSort("dept")'>Phòng ban <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "dept" ? "text-primary" : "text-muted")"></i></th>
							<th class="min-w-150px cursor-pointer" @onclick='() => ToggleSort("role")'>Vị trí <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "role" ? "text-primary" : "text-muted")"></i></th>
							<th class="min-w-125px cursor-pointer" @onclick='() => ToggleSort("joindate")'>Ngày vào làm <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "joindate" ? "text-primary" : "text-muted")"></i></th>
							<th class="min-w-150px cursor-pointer" @onclick='() => ToggleSort("workplace")'>Nơi làm việc <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "workplace" ? "text-primary" : "text-muted")"></i></th>
							<th class="min-w-125px text-center cursor-pointer" @onclick='() => ToggleSort("status")'>Trạng thái <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "status" ? "text-primary" : "text-muted")"></i></th>
							<th class="text-end min-w-100px">Thao tác</th>
						</tr>
					</thead>
					<tbody class="text-gray-600 fw-bold" id="kt_table_users_body">
						@if (FilteredEmployees != null && FilteredEmployees.Any())
						{
							@foreach (var emp in FilteredEmployees)
							{
								<tr class="@(selectedIds.Contains(emp.Id) ? "bg-light-primary" : "")">
									<td><div class="form-check form-check-sm form-check-custom form-check-solid"><input class="form-check-input" type="checkbox" checked="@selectedIds.Contains(emp.Id)" @onchange="(e) => ToggleSelection(emp.Id, e.Value ?? false)" /></div></td>
									<td class="d-flex align-items-center">
										<div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
											<a href="javascript:;" class="kt_drawer_employee_detail_toggle" @onclick="() => SelectEmployeeByObj(emp)">
												@if (!string.IsNullOrEmpty(emp.Avatar))
												{
													<div class="symbol-label"><img src="@emp.Avatar" alt="@emp.Name" class="w-100" /></div>
												}
												else
												{
													<div class="symbol-label bg-light-primary text-primary fw-bolder">@(emp.DisplayInitials ?? "??")</div>
												}
											</a>
										</div>
										<div class="d-flex flex-column">
											<a href="javascript:;" class="kt_drawer_employee_detail_toggle text-gray-900 fw-bold text-hover-primary mb-1 fs-6" @onclick="() => SelectEmployeeByObj(emp)">@emp.Name</a>
											<span class="text-muted fw-semibold fs-7">@emp.Code • @emp.Role</span>
										</div>
									</td>
									<td>@emp.Code</td>
									<td>@emp.Dept</td>
									<td>@emp.Role</td>
									<td>@emp.JoinDate?.ToString("dd/MM/yyyy")</td>
									<td>@emp.Workplace</td>
									<td class="text-center">
										<div class="badge badge-light-@(string.IsNullOrEmpty(emp.StatusColor) ? "warning" : emp.StatusColor) fw-bolder">@emp.StatusName</div>
									</td>
									<td class="text-end">
										<div class="d-flex justify-content-end flex-shrink-0">
											<a href="javascript:;" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1 kt_drawer_employee_detail_toggle" title="Xem chi tiết" @onclick="() => SelectEmployeeByObj(emp)">
												<i class="ki-outline ki-eye fs-3"></i>
											</a>
											<a href="/employees/edit/@emp.Id" class="btn btn-icon btn-bg-light btn-active-color-warning btn-sm me-1" title="Cập nhật thông tin">
												<i class="ki-outline ki-pencil fs-3"></i>
											</a>
											<button type="button" class="btn btn-icon btn-bg-light btn-active-color-success btn-sm me-1" title="Tạo thẻ QR" @onclick="async () => { selectedEmployee = emp; await GenerateQR(); }">
												<i class="ki-outline ki-barcode fs-3"></i>
											</button>
											<button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm" title="Xóa nhân viên" @onclick="async () => { selectedEmployee = emp; await Offboarding(); }">
												<i class="ki-outline ki-trash fs-3"></i>
											</button>
										</div>
									</td>
								</tr>
							}
						}
						else
						{
							<tr>
								<td colspan="9" class="text-center py-10">
									<div class="d-flex flex-column align-items-center">
										<i class="ki-outline ki-users fs-3x text-gray-300 mb-3"></i>
										<span class="text-gray-400">Không có dữ liệu nhân viên để hiển thị.</span>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}
			<div class="mt-10">
				<Pagination PageIndex="@currentPage" PageSize="@pageSize" TotalCount="@totalCount" OnPageChanged="GoToPage" />
			</div>
		</SkeletonLoading>

		<!-- INFO BARS: Block 1 (Search & Details) + Block 2 (Statistics) -->
		<div class="row g-5 mt-5">
			<div class="col-md-8">
				<div class="row g-5 h-100">
					<!-- GUIDANCE BLOCK -->
					<div class="col-md-6">
						<div class="card bg-light-danger border border-dashed border-danger p-5 h-100 hover-elevate-up">
							<div class="d-flex align-items-center">
								<i class="ki-outline ki-notification-on fs-2hx text-danger me-4"></i>
								<div>
									<div class="fs-6 fw-bolder text-gray-800">Tra cứu nhanh hồ sơ</div>
									<div class="fs-8 text-muted mt-1">Sử dụng bộ lọc thông minh để tìm kiếm nhân sự theo phòng ban hoặc địa điểm.</div>
								</div>
							</div>
						</div>
					</div>
					<div class="col-md-6">
						<div class="card bg-light-dark border border-dashed border-dark p-5 h-100 hover-elevate-up">
							<div class="d-flex align-items-center">
								<i class="ki-outline ki-information-2 fs-2hx text-dark me-4"></i>
								<div>
									<div class="fs-6 fw-bolder text-gray-800">Mô tả chi tiết</div>
									<div class="fs-8 text-muted mt-1">Click vào tên nhân viên hoặc icon mắt để xem chi tiết hồ sơ toàn diện.</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<!-- STATISTICS BLOCK -->
				<div class="card bg-light-primary border border-dashed border-primary p-5 h-100 hover-elevate-up">
					<div class="d-flex align-items-center h-100">
						<i class="ki-outline ki-chart-line-4 fs-2hx text-primary me-4"></i>
						<div>
							<div class="fs-6 fw-bolder text-gray-800">Thống kê nội dung</div>
							<div class="fs-8 text-muted mt-1">Dữ liệu nhân sự được cập nhật và đồng bộ liên tục theo thời gian thực.</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<ImportWizard @ref="importWizard" OnImportCompleted="ReloadData" />

<EmployeeDetailDrawer 
    Employee="@selectedEmployee" 
    IsLoading="@_isLoading" 
    IsReadOnly="@_isReadOnlyDetail"
    Departments="@CachedDepartments"
    Positions="@CachedPositions"
    Managers="@CachedEmployees"
    Roles="@CachedRoles"
    Workplaces="@CachedWorkplaces"
    OnSave="SaveChanges"
    OnScanCCCD="ScanCCCD"
    OnViewContract="ViewCurrentContract"
    OnPrintContract="PrintContract" />



<CccdScanner @ref="cccdScanner" />

<!-- CONTRACT PREVIEW MODAL -->
<div class="modal fade" id="preview_modal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-scrollable">
		<div class="modal-content border-0 shadow-lg">
			<div class="modal-header bg-white border-0 py-5 px-10 flex-stack">
				<h2 class="modal-title fs-4 fw-bolder text-gray-900">Xem trước hợp đồng</h2>
				<div class="d-flex align-items-center gap-2">
					<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
				</div>
			</div>
			<div class="modal-body p-0 bg-light position-relative">
				<!-- Floating Print Button (Sticky) -->
				<div class="d-print-none" style="position: sticky; top: 20px; right: 40px; float: right; z-index: 100; margin-bottom: -60px; pointer-events: none;">
					<button type="button" class="btn btn-primary shadow-lg fw-bold px-6 py-4 rounded-pill d-flex align-items-center gap-2 hover-elevate-up m-5" onclick="window.print()" style="pointer-events: auto;">
						<i class="bi bi-printer fs-3"></i>
						<span>In ngay</span>
					</button>
				</div>

				<div class="p-10">
					<div class="contract-paper mx-auto shadow-sm" style="background: #fff; width: 210mm; min-height: 297mm; padding: 25mm 20mm; font-family: 'Times New Roman', Times, serif; font-size: 16px; line-height: 1.6; color: black;">
						@((MarkupString)PreviewContent)
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Dedicated Print Container (Hidden on screen) -->
<div id="print_only_area" class="d-none d-print-block">
	<div style="width: 210mm; padding: 20mm; background: white; font-family: 'Times New Roman', Times, serif; font-size: 16px; line-height: 1.6; color: black;">
		@((MarkupString)PreviewContent)
	</div>
</div>


<style>
	.hover-border-primary:hover {
		border-color: var(--kt-primary) !important;
		background-color: var(--kt-primary-light) !important;
		color: var(--kt-primary) !important;
	}
	/* Đảm bảo grid hiển thị chuẩn trên mọi màn hình */
	.calendar-grid {
		min-width: 100%;
	}

	/* Contract Paper Print Styles */
	.contract-paper {
		box-shadow: 0 0.5rem 1.5rem 0.5rem rgba(0, 0, 0, 0.075);
	}

	@@media print {
		/* Hide ALL screen elements */
