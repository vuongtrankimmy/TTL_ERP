                                                <tr><td>Chấm công</td><td class="text-center"><input class="form-check-input" type="checkbox" checked /></td><td class="text-center"><input class="form-check-input" type="checkbox" checked /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td></tr>
