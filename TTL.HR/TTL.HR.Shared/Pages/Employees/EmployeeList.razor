@page "/employees"

    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div class="d-flex align-items-center position-relative my-1">
                <span class="svg-icon svg-icon-1 position-absolute ms-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <rect opacity="0.5" x="17.0365" y="15.1223" width="8.15546" height="2" rx="1" transform="rotate(45 17.0365 15.1223)" fill="currentColor" />
                        <path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor" />
                    </svg>
                </span>
                <input type="text" @bind="searchQuery" @bind:event="oninput" class="form-control form-control-solid w-250px ps-14" placeholder="Tìm kiếm nhân viên" />
            </div>
        </div>
        <div class="card-toolbar">
            <button type="button" class="btn btn-light-primary me-3" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                <span class="svg-icon svg-icon-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M19.0759 3H4.72777C3.95892 3 3.47768 3.83148 3.86067 4.49814L8.56967 12.6949C9.17923 13.7559 9.5 14.9582 9.5 16.1819V19.5072C9.5 20.2189 10.2223 20.7028 10.8805 20.432L13.8805 19.1977C14.2553 19.0435 14.5 18.6783 14.5 18.273V13.8372C14.5 12.8089 14.8171 11.8056 15.408 10.964L19.8943 4.57465C20.3596 3.912 19.8856 3 19.0759 3Z" fill="currentColor" />
                    </svg>
                </span>
                Lọc
            </button>
            <div class="menu menu-sub menu-sub-dropdown w-300px w-md-325px" data-kt-menu="true">
                <div class="px-7 py-5">
                    <div class="fs-5 text-dark fw-bolder">Tùy chọn lọc</div>
                </div>
                <div class="separator border-gray-200"></div>
                <div class="px-7 py-5" data-kt-user-table-filter="form">
                    <div class="mb-10">
                        <label class="form-label fs-6 fw-bold">Phòng ban:</label>
                        <select class="form-select form-select-solid fw-bolder" @bind="filterDept">
                            <option value="">Tất cả phòng ban</option>
                            @foreach(var dept in CachedDepartments)
                            {
                                <option value="@dept.Name">@dept.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-10">
                        <label class="form-label fs-6 fw-bold">Trạng thái:</label>
                        <select class="form-select form-select-solid fw-bolder" @bind="filterStatus">
                            <option value="">Tất cả trạng thái</option>
                            @foreach(var status in CachedStatuses)
                            {
                                <option value="@status.Name">@status.Name</option>
                            }
                        </select>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="reset" class="btn btn-light btn-active-light-primary fw-bold me-2 px-6" @onclick="ResetFilters">Reset</button>
                        <button type="submit" class="btn btn-primary fw-bold px-6" @onclick="ApplyFilters">Áp dụng</button>
                    </div>
                </div>
            </div>
            <button type="button" class="btn btn-light-success me-3" @onclick="ExportExcel">
                <span class="svg-icon svg-icon-2"><i class="bi bi-file-earmark-spreadsheet"></i></span> Xuất Excel
            </button>
            <a href="/employees/add" class="btn btn-primary">
                <span class="svg-icon svg-icon-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <rect opacity="0.5" x="11.364" y="20.364" width="16" height="2" rx="1" transform="rotate(-90 11.364 20.364)" fill="currentColor" />
                        <rect x="4.36396" y="11.364" width="16" height="2" rx="1" fill="currentColor" />
                    </svg>
                </span>
                Thêm nhân viên
            </a>
        </div>
    </div>
    <div class="card-body py-4">
        <SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10" Columns="8">
            <table class="table align-middle table-row-dashed fs-7 gy-5" id="kt_table_users">
                <thead>
                    <tr class="text-start text-muted fw-bold fs-8 text-uppercase gs-0">
                        <th class="w-10px pe-2">
                            <div class="form-check form-check-sm form-check-custom form-check-solid me-3">
                                <input class="form-check-input" type="checkbox" @onchange="ToggleSelectAll" checked="@isAllSelected" />
                            </div>
                        </th>
                        <th class="min-w-125px">Nhân viên</th>
                        <th class="min-w-125px">Mã NV</th>
                        <th class="min-w-125px">Phòng ban</th>
                        <th class="min-w-125px">Chức vụ</th>
                        <th class="min-w-125px">Ngày vào làm</th>
                        <th class="min-w-125px">Trạng thái</th>
                        <th class="text-end min-w-100px">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-bold" id="kt_table_users_body">
                    @foreach(var emp in FilteredEmployees)
                    {
                        <tr class="@(selectedIds.Contains(emp.Id) ? "bg-light-primary" : "")">
                            <td><div class="form-check form-check-sm form-check-custom form-check-solid"><input class="form-check-input" type="checkbox" checked="@selectedIds.Contains(emp.Id)" @onchange="(e) => ToggleSelection(emp.Id, e.Value ?? false)" /></div></td>
                            <td class="d-flex align-items-center">
                                <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                                    <a href="javascript:;" class="kt_drawer_employee_detail_toggle" @onclick="() => SelectEmployeeByObj(emp)">
                                        @if(!string.IsNullOrEmpty(emp.Avatar)) {
                                            <div class="symbol-label"><img src="@emp.Avatar" alt="@emp.Name" class="w-100" /></div>
                                        } else {
                                            <div class="symbol-label bg-light-primary text-primary fw-bolder">@emp.Name.Substring(0,2).ToUpper()</div>
                                        }
                                    </a>
                                </div>
                                <div class="d-flex flex-column">
                                    <a href="javascript:;" class="kt_drawer_employee_detail_toggle text-gray-800 text-hover-primary mb-1" @onclick="() => SelectEmployeeByObj(emp)">@emp.Name</a>
                                    <span>@emp.CompanyEmail</span>
                                </div>
                            </td>
                            <td>@emp.Code</td>
                            <td>@emp.Dept</td>
                            <td>@emp.Role</td>
                            <td>@emp.JoinDate?.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="badge @(emp.Status == "Chính thức" ? "badge-light-success" : emp.Status == "Nghỉ việc" ? "badge-light-danger" : "badge-light-warning") fw-bolder">@emp.Status</div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end flex-shrink-0">
                                    <a href="javascript:;" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1 kt_drawer_employee_detail_toggle" title="Xem chi tiết" @onclick="() => SelectEmployeeByObj(emp)">
                                        <i class="ki-outline ki-eye fs-3"></i>
                                    </a>
                                    <button type="button" class="btn btn-icon btn-bg-light btn-active-color-success btn-sm me-1" title="Tạo thẻ QR" @onclick="async () => { selectedEmployee = emp; await GenerateQR(); }">
                                        <i class="ki-outline ki-barcode fs-3"></i>
                                    </button>
                                    <button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm" title="Quy trình nghỉ việc" @onclick="async () => { selectedEmployee = emp; await Offboarding(); }">
                                        <i class="ki-outline ki-trash fs-3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="d-flex flex-stack flex-wrap pt-10">
                <div class="fs-6 fw-bold text-gray-700">Hiển thị @FilteredEmployees.Count() của @employees.Count() nhân viên</div>
                <ul class="pagination">
                    <li class="page-item previous disabled"><a href="javascript:;" class="page-link" @onclick="() => GoToPage(currentPage - 1)"><i class="previous"></i></a></li>
                    @for (int i = 1; i <= 3; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")"><a href="javascript:;" class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</a></li>
                    }
                    <li class="page-item next"><a href="javascript:;" class="page-link" @onclick="() => GoToPage(currentPage + 1)"><i class="next"></i></a></li>
                </ul>
            </div>
        </SkeletonLoading>
    </div>

<!-- DRAWER: EMPLOYEE DETAIL -->
<div id="kt_drawer_employee_detail" class="bg-white" data-kt-drawer="true" data-kt-drawer-name="employee-detail" data-kt-drawer-activate="true" data-kt-drawer-overlay="true" data-kt-drawer-width="{default:'300px', 'md': '650px'}" data-kt-drawer-direction="end" data-kt-drawer-toggle=".kt_drawer_employee_detail_toggle" data-kt-drawer-close="#kt_drawer_employee_detail_close">
    <div class="card shadow-none rounded-0 w-100 h-100">
        <div class="card-header border-0 pt-7 pb-5">
            <div class="d-flex align-items-center">
                <div class="symbol symbol-70px symbol-2by3 me-5">
                    <img src="@(selectedEmployee?.Avatar ?? "assets/media/avatars/300-1.jpg")" alt="@selectedEmployee?.Name" class="rounded-3" />
                </div>
                <div class="d-flex flex-column">
                    <h2 class="fs-1 fw-bolder text-gray-900 mb-1">@(selectedEmployee?.Name ?? "N/A")</h2>
                    <div class="text-primary fw-bold fs-6 mb-2">@(selectedEmployee?.Role ?? "N/A")</div>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge badge-light-secondary text-gray-600 fw-bold px-3 py-2">Mã NV: @(selectedEmployee?.Code ?? "---")</span>
                        <span class="badge badge-light-secondary text-gray-600 fw-bold px-3 py-2">Phòng @(selectedEmployee?.Dept ?? "---")</span>
                    </div>
                </div>
            </div>
            <div class="card-toolbar">
                <button type="button" class="btn btn-sm btn-icon btn-active-light-primary" id="kt_drawer_employee_detail_close">
                    <i class="bi bi-x-lg fs-2"></i>
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bolder px-10 mb-5">
                <li class="nav-item">
                    <a class="nav-link text-active-primary @(activeTab == "profile" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "profile"'>Thông tin hồ sơ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-active-primary @(activeTab == "account" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "account"'>Tài khoản & Phân quyền</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-active-primary @(activeTab == "calendar" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "calendar"'>Lịch & Chấm công</a>
                </li>
            </ul>
            <div class="tab-content px-10">
                @if (activeTab == "profile")
                {
                    <div class="tab-pane fade show active">
                        <div class="py-5">
                            <div class="d-flex flex-stack mb-5">
                                <h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="bi bi-person-badge text-primary me-2"></i>Thông tin cá nhân</h3>
                                <button type="button" class="btn btn-sm btn-light-primary border border-primary border-dashed" @onclick="ScanCCCD">
                                    <i class="bi bi-qr-code-scan me-2"></i>Quét thẻ căn cước (CCCD) chip
                                </button>
                            </div>
                            <div class="row g-6 mb-8">
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Họ và tên</label>
                                    <input type="text" class="form-control form-control-solid" @bind="selectedEmployee.Name" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Số CCCD / CMND</label>
                                    <div class="position-relative">
                                        <input type="text" class="form-control form-control-solid" value="@(isIdCardVisible ? selectedEmployee?.IdCard : "********" + selectedEmployee?.IdCard?.Substring(Math.Max(0, (selectedEmployee?.IdCard?.Length ?? 0) - 4)))" readonly />
                                        <button type="button" class="btn btn-icon btn-sm btn-active-color-primary position-absolute top-50 end-0 translate-middle-y me-2" @onclick="() => isIdCardVisible = !isIdCardVisible">
                                            <i class="bi @(isIdCardVisible ? "bi-eye" : "bi-eye-slash") fs-6"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Ngày sinh</label>
                                    <input type="date" class="form-control form-control-solid" @bind="selectedEmployee.DOB" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Giới tính</label>
                                    <select class="form-select form-select-solid" @bind="selectedEmployee.Gender">
                                        <option value="Nam">Nam</option>
                                        <option value="Nữ">Nữ</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Số điện thoại</label>
                                    <div class="position-relative">
                                        <input type="text" class="form-control form-control-solid" value="@(isPhoneVisible ? selectedEmployee?.Phone : selectedEmployee?.Phone?.Substring(0, Math.Min(4, selectedEmployee?.Phone?.Length ?? 0)) + "***-***")" readonly />
                                        <button type="button" class="btn btn-icon btn-sm btn-active-color-primary position-absolute top-50 end-0 translate-middle-y me-2" @onclick="() => isPhoneVisible = !isPhoneVisible">
                                            <i class="bi @(isPhoneVisible ? "bi-eye" : "bi-eye-slash") fs-6"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Email cá nhân</label>
                                    <input type="text" class="form-control form-control-solid" @bind="selectedEmployee.Email" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Email công ty</label>
                                    <input type="text" class="form-control form-control-solid" @bind="selectedEmployee.CompanyEmail" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Địa chỉ thường trú (theo CCCD)</label>
                                    <textarea class="form-control form-control-solid" rows="2" @bind="selectedEmployee.Address"></textarea>
                                </div>
                            </div>

                            <div class="card bg-light border-0 mb-8">
                                <div class="card-body p-6">
                                    <div class="d-flex flex-stack mb-5">
                                        <h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="bi bi-file-earmark-text text-primary me-2"></i>Hợp đồng lao động</h3>
                                        <span class="badge badge-light-success fs-8 fw-bolder">ĐANG HIỆU LỰC</span>
                                    </div>
                                    <div class="row g-4 mb-6">
                                        <div class="col-4">
                                            <div class="bg-white rounded p-4 border border-dashed text-center">
                                                <div class="fs-8 text-muted fw-bold mb-1">LOẠI HỢP ĐỒNG</div>
                                                <div class="fs-7 fw-bolder text-gray-800">@selectedEmployee?.ContractType</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="bg-white rounded p-4 border border-dashed text-center">
                                                <div class="fs-8 text-muted fw-bold mb-1">MỨC LƯƠNG ĐÓNG BH</div>
                                                <div class="fs-7 fw-bolder text-gray-900">@(isSalaryVisible ? selectedEmployee?.Salary : "********** VNĐ")</div>
                                                <button type="button" class="btn btn-link btn-xs p-0 fs-10 text-primary" @onclick="() => isSalaryVisible = !isSalaryVisible">@(isSalaryVisible ? "Ẩn" : "Hiển thị")</button>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="bg-white rounded p-4 border border-dashed text-center">
                                                <div class="fs-8 text-muted fw-bold mb-1">NGÀY HẾT HẠN HD</div>
                                                <div class="fs-7 fw-bolder text-danger">@selectedEmployee?.ContractExpiry</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-3">
                                        <button class="btn btn-sm btn-outline btn-outline-primary bg-white flex-grow-1"><i class="bi bi-printer me-2"></i>In hợp đồng</button>
                                        <button class="btn btn-sm btn-primary flex-grow-1"><i class="bi bi-eye me-2"></i>Xem hiện tại</button>
                                        <button class="btn btn-sm btn-light flex-grow-1 border border-dashed"><i class="bi bi-upload me-2"></i>Tải lên (đã ký)</button>
                                    </div>
                                </div>
                            </div>

                            <h3 class="fw-bolder m-0 fs-5 text-uppercase mb-5"><i class="bi bi-clock-history text-gray-600 me-2"></i>Nhật ký thay đổi (Audit Log)</h3>
                            <div class="timeline-label">
                                <div class="timeline-item">
                                    <div class="timeline-label fw-bolder text-gray-800 fs-8 w-75px">14:30</div>
                                    <div class="timeline-badge"><i class="fa fa-genderless text-warning fs-1"></i></div>
                                    <div class="timeline-content fw-bold text-gray-800 ps-3">Cập nhật số điện thoại bởi <span class="text-primary">Admin (Trần Nam)</span></div>
                                </div>
                                <div class="timeline-item">
                                    <div class="timeline-label fw-bolder text-gray-800 fs-8 w-75px">10:15</div>
                                    <div class="timeline-badge"><i class="fa fa-genderless text-success fs-1"></i></div>
                                    <div class="timeline-content text-muted fs-8 ps-3">Gia hạn hợp đồng (Phụ lục 02)</div>
                                </div>
                                <div class="timeline-item">
                                    <div class="timeline-label fw-bolder text-gray-800 fs-8 w-75px">Hôm qua</div>
                                    <div class="timeline-badge"><i class="fa fa-genderless text-primary fs-1"></i></div>
                                    <div class="timeline-content text-muted fs-8 ps-3">Được thêm vào hệ thống thông qua Onboarding Wizard.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (activeTab == "account")
                {
                    <div class="tab-pane fade show active">
                        <div class="py-5">
                            <div class="bg-light-primary rounded p-6 d-flex flex-stack mb-8 border border-primary border-dashed">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px bg-white rounded me-4 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-power fs-2 text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bolder text-gray-900 fs-6">Kích hoạt tài khoản ERP</div>
                                        <div class="text-muted fs-7">Cho phép nhân viên này truy cập vào hệ thống ERP</div>
                                    </div>
                                </div>
                                <div class="form-check form-switch form-check-custom form-check-solid">
                                    <input class="form-check-input w-45px h-25px" type="checkbox" @bind="selectedEmployee.IsActive" />
                                </div>
                            </div>

                            <h3 class="fw-bolder mb-5 fs-5 text-uppercase"><i class="bi bi-shield-lock text-primary me-2"></i>Thông tin tài khoản</h3>
                            <div class="card border border-gray-300 border-dashed mb-10">
                                <div class="card-body p-6">
                                    <div class="row g-6 mb-6">
                                        <div class="col-md-6">
                                            <label class="form-label text-muted fs-7 text-uppercase fw-bold">Tên đăng nhập (Username)</label>
                                            <input type="text" class="form-control form-control-solid" @bind="selectedEmployee.Username" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted fs-7 text-uppercase fw-bold">Mật khẩu (Password)</label>
                                            <div class="position-relative">
                                                <input type="password" class="form-control form-control-solid" @bind="selectedEmployee.Password" />
                                                <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 cursor-pointer text-muted"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-end">
                                        <button class="btn btn-sm btn-light"><i class="bi bi-arrow-repeat me-2"></i>Tạo mới / Reset mật khẩu</button>
                                    </div>
                                </div>
                            </div>

                            <h3 class="fw-bolder mb-5 fs-5 text-uppercase"><i class="bi bi-diagram-3 text-primary me-2"></i>Cấu hình phân quyền</h3>
                            <div class="card border border-gray-300 border-dashed">
                                <div class="card-body p-6">
                                    <div class="nav-group nav-group-outline justify-content-center mb-8">
                                        <button class="btn btn-sm btn-color-gray-400 btn-active btn-active-secondary px-6 py-2 active">Phân quyền theo vai trò</button>
                                        <button class="btn btn-sm btn-color-gray-400 btn-active btn-active-secondary px-6 py-2">Tùy chỉnh quyền chi tiết</button>
                                    </div>
                                    
                                    <label class="form-label text-muted fs-8 text-uppercase fw-bold">Chọn vai trò hệ thống</label>
                                    <select class="form-select form-select-solid mb-4">
                                        <option value="1" selected>Nhân viên (Staff)</option>
                                        <option value="2">Quản lý (Manager)</option>
                                    </select>
                                    <div class="text-muted fs-8 italic mb-8">* Vai trò này sẽ tự động áp dụng bộ quyền mặc định cho các module.</div>

                                    <div class="table-responsive">
                                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-3">
                                            <thead>
                                                <tr class="fw-bold fs-8 text-muted text-uppercase">
                                                    <th class="min-w-150px">Module</th>
                                                    <th class="text-center">Xem</th>
                                                    <th class="text-center">Thêm</th>
                                                    <th class="text-center">Sửa</th>
                                                    <th class="text-center">Xóa</th>
                                                </tr>
                                            </thead>
                                            <tbody class="fs-7 fw-bold">
                                                <tr><td>Nhân sự</td><td class="text-center"><input class="form-check-input" type="checkbox" checked /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td></tr>
                                                <tr><td>Chấm công</td><td class="text-center"><input class="form-check-input" type="checkbox" checked /></td><td class="text-center"><input class="form-check-input" type="checkbox" checked /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td></tr>
                                                <tr><td>Tiền lương</td><td class="text-center"><input class="form-check-input" type="checkbox" checked /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td><td class="text-center"><input class="form-check-input" type="checkbox" /></td></tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (activeTab == "calendar")
                {
                    <div class="tab-pane fade show active">
                        <div class="py-5">
                            <div class="d-flex flex-stack mb-5">
                                <h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="bi bi-calendar-check text-primary me-2"></i>Lịch chấm công chi tiết</h3>
                                <div class="d-flex align-items-center gap-4">
                                    <button class="btn btn-icon btn-sm btn-light"><i class="bi bi-chevron-left"></i></button>
                                    <span class="fw-bolder fs-6">Tháng 02/2026</span>
                                    <button class="btn btn-icon btn-sm btn-light"><i class="bi bi-chevron-right"></i></button>
                                </div>
                            </div>

                            <div class="bg-light-info rounded p-4 mb-8 border border-info border-dashed">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-info-circle-fill text-info me-3 fs-3"></i>
                                    <span class="fs-7 fw-bold text-gray-700">Ghi chú: Dữ liệu này được cập nhật tự động từ hệ thống máy chấm công khuôn mặt FaceID tại cổng chính.</span>
                                </div>
                            </div>

                            <div class="card border border-gray-300 border-dashed mb-8">
                                <div class="card-body p-4 text-center">
                                    <div class="calendar-grid mb-4" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;">
                                        @foreach(var day in new[]{"CN","T2","T3","T4","T5","T6","T7"}) { 
                                            <div class="text-muted fs-8 fw-bold p-2 text-center">@day</div> 
                                        }
                                        @for(int i=1; i<=31; i++) {
                                            <div class="p-1 text-center">
                                                <div class="rounded-circle w-30px h-30px d-flex align-items-center justify-content-center fs-8 fw-bold @(i % 7 == 0 ? "bg-light-danger text-danger" : i % 5 == 0 ? "bg-light-warning text-warning" : "bg-light-success text-success") mx-auto cursor-pointer border border-transparent hover-border-primary">@i</div>
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex justify-content-center gap-6">
                                        <div class="d-flex align-items-center fs-8 fw-bold text-muted"><span class="w-8px h-8px rounded-circle bg-success me-2"></span>Đúng giờ</div>
                                        <div class="d-flex align-items-center fs-8 fw-bold text-muted"><span class="w-8px h-8px rounded-circle bg-warning me-2"></span>Đi muộn</div>
                                        <div class="d-flex align-items-center fs-8 fw-bold text-muted"><span class="w-8px h-8px rounded-circle bg-danger me-2"></span>Nghỉ/Không phép</div>
                                    </div>
                                </div>
                            </div>
                            
                            <h3 class="fw-bolder mb-5 fs-5 text-uppercase"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Thống kê nhanh tháng</h3>
                            <div class="row g-4 mb-8">
                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">SỐ CÔNG CHUẨN</div>
                                                <div class="fs-4 fw-bolder text-gray-900">20 <span class="fs-8 fw-normal">ngày</span></div>
                                            </div>
                                            <i class="bi bi-calendar4-week fs-1 text-gray-400"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">SỐ CÔNG THỰC TẾ</div>
                                                <div class="fs-4 fw-bolder text-gray-900">18.5 <span class="fs-8 fw-normal">ngày</span></div>
                                            </div>
                                            <i class="bi bi-patch-check fs-1 text-success"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">TĂNG CA (OT)</div>
                                                <div class="fs-4 fw-bolder text-gray-900">4.5 <span class="fs-8 fw-normal">giờ</span></div>
                                            </div>
                                            <i class="bi bi-clock-history fs-1 text-primary"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">ĐI MUỘN (Lần)</div>
                                                <div class="fs-4 fw-bolder text-gray-900">02 <span class="fs-8 fw-normal">lần</span></div>
                                            </div>
                                            <i class="bi bi-exclamation-triangle fs-1 text-warning"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="card-footer border-0 d-flex gap-3 justify-content-between p-10">
            @if (activeTab == "profile")
            {
                <button type="button" class="btn btn-primary flex-grow-1" @onclick="SaveChanges">
                    <span class="indicator-label"><i class="bi bi-save me-2"></i>Lưu thay đổi</span>
                </button>
            }
            else if (activeTab == "account")
            {
                <button type="button" class="btn btn-primary flex-grow-1" @onclick='() => JSRuntime.InvokeVoidAsync("Swal.fire", "Thành công", "Đã cập nhật cấu hình phân quyền", "success")'>
                    <i class="bi bi-check2-circle me-2"></i>Cập nhật cấu hình
                </button>
            }
            else if (activeTab == "calendar")
            {
                <button type="button" class="btn btn-primary flex-grow-1" @onclick='() => JSRuntime.InvokeVoidAsync("Swal.fire", "Thông báo", "Hệ thống đang xuất file báo cáo PDF...", "info")'>
                    <i class="bi bi-file-earmark-pdf me-2"></i>Xuất báo cáo cá nhân
                </button>
            }
            <button type="button" class="btn btn-light flex-grow-1" id="kt_drawer_employee_detail_close">@(activeTab == "account" ? "Hủy" : "Đóng")</button>
        </div>
    </div>
</div>



<CccdScanner @ref="cccdScanner" />


<style>
    .hover-border-primary:hover {
        border-color: var(--kt-primary) !important;
        background-color: var(--kt-primary-light) !important;
        color: var(--kt-primary) !important;
    }
    /* Đảm bảo grid hiển thị chuẩn trên mọi màn hình */
    .calendar-grid {
        min-width: 100%;
    }
</style>
