@page "/employees"

<div class="card card-flush shadow-sm">
	<div class="card-header border-0 pt-6">
		<div class="card-title">
			<div class="d-flex align-items-center position-relative my-1">
				<span class="svg-icon svg-icon-1 position-absolute ms-6">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
						<rect opacity="0.5" x="17.0365" y="15.1223" width="8.15546" height="2" rx="1" transform="rotate(45 17.0365 15.1223)" fill="currentColor" />
						<path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor" />
					</svg>
				</span>
				<input type="text" value="@searchQuery" @oninput="HandleSearch" class="form-control form-control-solid w-250px ps-14" placeholder="Tìm kiếm nhân viên..." />
			</div>
		</div>
		<div class="card-toolbar">
			<button type="button" class="btn btn-light-primary me-3" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
				<i class="ki-outline ki-filter fs-2"></i> Lọc
			</button>
			<div class="menu menu-sub menu-sub-dropdown w-300px w-md-325px" data-kt-menu="true">
				<div class="px-7 py-5">
					<div class="fs-5 text-dark fw-bolder">Tùy chọn lọc nâng cao</div>
				</div>
				<div class="separator border-gray-200"></div>
				<div class="px-7 py-5">
					<div class="mb-5">
						<label class="form-label fs-6 fw-bold">Phòng ban:</label>
						<select class="form-select form-select-solid" @bind="filterDept">
							<option value="">Tất cả phòng ban</option>
							@foreach (var dept in CachedDepartments)
							{
								<option value="@dept.Name">@dept.Name</option>
							}
						</select>
					</div>
					<div class="mb-5">
						<label class="form-label fs-6 fw-bold">Nơi làm việc:</label>
						<select class="form-select form-select-solid" @bind="filterWorkplace">
							<option value="">Tất cả địa điểm</option>
							@foreach (var wp in CachedWorkplaces)
							{
								<option value="@wp.Name">@wp.Name</option>
							}
						</select>
					</div>
					<div class="d-flex justify-content-end">
						<button type="reset" class="btn btn-light btn-active-light-primary fw-bold me-2 px-6" @onclick="ResetFilters">Reset</button>
						<button type="submit" class="btn btn-primary fw-bold px-6" @onclick="ApplyFilters">Áp dụng</button>
					</div>
				</div>
			</div>

			<button type="button" class="btn btn-light-success me-3" @onclick="ExportExcel">
				<i class="ki-outline ki-exit-up fs-2"></i> Xuất Excel
			</button>

			<button type="button" class="btn btn-light-info me-3" @onclick="OpenImportWizard">
				<i class="ki-outline ki-file-up fs-2"></i> Nhập Excel
			</button>

			<a href="/employees/add" class="btn btn-primary">
				<i class="ki-outline ki-plus fs-2"></i> Thêm nhân viên
			</a>

			<a href="/employees/add" class="btn btn-primary">
				<i class="ki-outline ki-plus fs-2"></i> Thêm nhân viên
			</a>
		</div>
	</div>

	<div class="card-body pt-0">
		<!-- TABS -->
		<ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bolder px-5 mb-5">
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(string.IsNullOrEmpty(filterStatus) ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("")'>
					Tất cả <span class="badge badge-light-primary ms-2">@_counts.All</span>
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(filterStatus == "Active" ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("Active")'>
					Chính thức <span class="badge badge-light-success ms-2">@_counts.Active</span>
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(filterStatus == "Probation" ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("Probation")'>
					Thử việc <span class="badge badge-light-warning ms-2">@_counts.Probation</span>
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link text-active-primary py-4 @(filterStatus == "Resigned" ? "active" : "")" href="javascript:;" @onclick='() => ChangeStatusFilter("Resigned")'>
					Đã thôi việc <span class="badge badge-light-danger ms-2">@_counts.Resigned</span>
				</a>
			</li>
		</ul>
		<SkeletonLoading IsLoading="_isLoading" Type="SkeletonLoading.SkeletonType.Table" Rows="10" Columns="8">
			<table class="table align-middle table-row-dashed fs-7 gy-5" id="kt_table_users">
				<thead>
					<tr class="text-start text-muted fw-bold fs-8 text-uppercase gs-0">
						<th class="w-10px pe-2">
							<div class="form-check form-check-sm form-check-custom form-check-solid me-3">
								<input class="form-check-input" type="checkbox" @onchange="ToggleSelectAll" checked="@isAllSelected" />
							</div>
						</th>
						<th class="min-w-200px cursor-pointer" @onclick='() => ToggleSort("name")'>Nhân viên <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "name" ? "text-primary" : "text-muted")"></i></th>
						<th class="min-w-100px cursor-pointer" @onclick='() => ToggleSort("code")'>Mã NV <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "code" ? "text-primary" : "text-muted")"></i></th>
						<th class="min-w-150px cursor-pointer" @onclick='() => ToggleSort("dept")'>Phòng ban <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "dept" ? "text-primary" : "text-muted")"></i></th>
						<th class="min-w-150px cursor-pointer" @onclick='() => ToggleSort("role")'>Vị trí <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "role" ? "text-primary" : "text-muted")"></i></th>
						<th class="min-w-125px cursor-pointer" @onclick='() => ToggleSort("joindate")'>Ngày vào làm <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "joindate" ? "text-primary" : "text-muted")"></i></th>
						<th class="min-w-150px cursor-pointer" @onclick='() => ToggleSort("workplace")'>Nơi làm việc <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "workplace" ? "text-primary" : "text-muted")"></i></th>
						<th class="min-w-125px text-center cursor-pointer" @onclick='() => ToggleSort("status")'>Trạng thái <i class="ki-outline ki-arrow-up-down fs-8 ms-1 @(sortBy == "status" ? "text-primary" : "text-muted")"></i></th>
						<th class="text-end min-w-100px">Thao tác</th>
					</tr>
				</thead>
				<tbody class="text-gray-600 fw-bold" id="kt_table_users_body">
					@foreach (var emp in FilteredEmployees)
					{
						<tr class="@(selectedIds.Contains(emp.Id) ? "bg-light-primary" : "")">
							<td><div class="form-check form-check-sm form-check-custom form-check-solid"><input class="form-check-input" type="checkbox" checked="@selectedIds.Contains(emp.Id)" @onchange="(e) => ToggleSelection(emp.Id, e.Value ?? false)" /></div></td>
							<td class="d-flex align-items-center">
								<div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
									<a href="javascript:;" class="kt_drawer_employee_detail_toggle" @onclick="() => SelectEmployeeByObj(emp)">
										@if (!string.IsNullOrEmpty(emp.Avatar))
										{
											<div class="symbol-label"><img src="@emp.Avatar" alt="@emp.Name" class="w-100" /></div>
										}
										else
										{
											<div class="symbol-label bg-light-primary text-primary fw-bolder">@emp.DisplayInitials</div>
										}
									</a>
								</div>
								<div class="d-flex flex-column">
									<a href="javascript:;" class="kt_drawer_employee_detail_toggle text-gray-900 fw-bold text-hover-primary mb-1 fs-6" @onclick="() => SelectEmployeeByObj(emp)">@emp.Name</a>
									<span class="text-muted fw-semibold fs-7">@emp.Code • @emp.Role</span>
								</div>
							</td>
							<td>@emp.Code</td>
							<td>@emp.Dept</td>
							<td>@emp.Role</td>
							<td>@emp.JoinDate?.ToString("dd/MM/yyyy")</td>
							<td>@emp.Workplace</td>
							<td class="text-center">
								<div class="badge @(emp.StatusName == "Chính thức" ? "badge-light-success" : emp.StatusName == "Nghỉ việc" || emp.StatusName == "Đã thôi việc" ? "badge-light-danger" : "badge-light-warning") fw-bolder">@emp.StatusName</div>
							</td>
							<td class="text-end">
								<div class="d-flex justify-content-end flex-shrink-0">
									<a href="javascript:;" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1 kt_drawer_employee_detail_toggle" title="Xem chi tiết" @onclick="() => SelectEmployeeByObj(emp)">
										<i class="ki-outline ki-eye fs-3"></i>
									</a>
									<a href="/employees/edit/@emp.Id" class="btn btn-icon btn-bg-light btn-active-color-warning btn-sm me-1" title="Cập nhật thông tin">
										<i class="ki-outline ki-pencil fs-3"></i>
									</a>
									<button type="button" class="btn btn-icon btn-bg-light btn-active-color-success btn-sm me-1" title="Tạo thẻ QR" @onclick="async () => { selectedEmployee = emp; await GenerateQR(); }">
										<i class="ki-outline ki-barcode fs-3"></i>
									</button>
									<button type="button" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm" title="Xóa nhân viên" @onclick="async () => { selectedEmployee = emp; await Offboarding(); }">
										<i class="ki-outline ki-trash fs-3"></i>
									</button>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
			<div class="d-flex flex-stack flex-wrap pt-10">
				<div class="fs-6 fw-bold text-gray-700">Hiển thị @FromRecord() đến @ToRecord() trong tổng số @totalCount bản ghi</div>
				<Pagination PageIndex="@currentPage" PageSize="@pageSize" TotalCount="@totalCount" OnPageChanged="GoToPage" />
			</div>
		</SkeletonLoading>

		<!-- INFO BARS -->
		<div class="row g-5 mt-5">
			<div class="col-md-4">
				<div class="card bg-light-danger border border-dashed border-danger p-5 hover-elevate-up">
					<div class="d-flex align-items-center">
						<i class="ki-outline ki-notification-on fs-2hx text-danger me-4"></i>
						<div>
							<div class="fs-6 fw-bolder text-gray-800">Tra cứu nhanh hồ sơ</div>
							<div class="fs-8 text-muted mt-1">Sử dụng bộ lọc thông minh để tìm kiếm nhân sự theo phòng ban hoặc địa điểm.</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card bg-light-dark border border-dashed border-dark p-5 hover-elevate-up">
					<div class="d-flex align-items-center">
						<i class="ki-outline ki-information-2 fs-2hx text-dark me-4"></i>
						<div>
							<div class="fs-6 fw-bolder text-gray-800">Mô tả chi tiết</div>
							<div class="fs-8 text-muted mt-1">Click vào tên nhân viên hoặc icon mắt để xem chi tiết hồ sơ toàn diện.</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card bg-light-primary border border-dashed border-primary p-5 hover-elevate-up">
					<div class="d-flex align-items-center">
						<i class="ki-outline ki-chart-line-4 fs-2hx text-primary me-4"></i>
						<div>
							<div class="fs-6 fw-bolder text-gray-800">Thống kê nội dung</div>
							<div class="fs-8 text-muted mt-1">Dữ liệu nhân sự được cập nhật và đồng bộ liên tục theo thời gian thực.</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<ImportWizard @ref="importWizard" OnImportCompleted="ReloadData" />

@code {
    private ImportWizard importWizard;
    
    private async Task OpenImportWizard()
    {
        await JSRuntime.InvokeVoidAsync("showModal", "#import_wizard_modal");
    }

    private async Task ReloadData()
    {
        await LoadEmployeesAsync();
        StateHasChanged();
    }
}

<!-- DRAWER: EMPLOYEE DETAIL -->
<div id="kt_drawer_employee_detail" class="bg-white" data-kt-drawer="true" data-kt-drawer-name="employee-detail" data-kt-drawer-activate="true" data-kt-drawer-overlay="true" data-kt-drawer-width="{default:'300px', 'md': '650px'}" data-kt-drawer-direction="end" data-kt-drawer-toggle=".kt_drawer_employee_detail_toggle" data-kt-drawer-close="#kt_drawer_employee_detail_close">
	<div class="card shadow-none rounded-0 w-100 h-100 d-flex flex-column">
		<div class="card-header border-0 pt-7 pb-5 flex-shrink-0">
			<div class="card-title w-100 d-flex justify-content-between align-items-start">
				<div class="d-flex">
					<div class="symbol symbol-70px symbol-circle me-5">
						<img src="@(selectedEmployee?.Avatar ?? "assets/media/avatars/300-1.jpg")" alt="@selectedEmployee?.Name" style="object-fit: cover;" />
					</div>
					<div class="d-flex flex-column">
						<h2 class="fs-4 fw-bolder text-gray-900 mb-1">@(selectedEmployee?.Name ?? "N/A")</h2>
						<div class="text-primary fw-bold fs-7 mb-2">@(selectedEmployee?.Role ?? "N/A")</div>
						<div class="d-flex flex-wrap gap-2">
							<span class="badge badge-light-secondary text-gray-600 fw-bold px-2 py-1">Mã NV: @(selectedEmployee?.Code ?? "---")</span>
							<span class="badge badge-light-secondary text-gray-600 fw-bold px-2 py-1">Phòng: @(selectedEmployee?.Dept ?? "---")</span>
						</div>
					</div>
				</div>
				<div class="card-toolbar ms-3">
					<button type="button" class="btn btn-sm btn-icon btn-active-light-primary" id="kt_drawer_employee_detail_close">
						<i class="bi bi-x-lg fs-2"></i>
					</button>
				</div>
			</div>
		</div>
		<div class="card-body p-0 flex-grow-1 hover-scroll-y">
			<ul class="nav nav-line-tabs nav-line-tabs-2x border-transparent fs-6 fw-bold px-5 mb-5 flex-nowrap overflow-auto">
				<li class="nav-item">
					<a class="nav-link text-active-primary @(activeTab == "profile" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "profile"'>
						<i class="bi bi-person-lines-fill me-2"></i>Thông tin hồ sơ
					</a>
				</li>
				<li class="nav-item">
					<a class="nav-link text-active-primary @(activeTab == "account" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "account"'>
						<i class="bi bi-shield-lock me-2"></i>Tài khoản & Phân quyền
					</a>
				</li>
				<li class="nav-item">
					<a class="nav-link text-active-primary @(activeTab == "calendar" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "calendar"'>
						<i class="bi bi-calendar-check me-2"></i>Lịch & Chấm công
					</a>
				</li>
			</ul>
			<div class="tab-content px-6">
				@if (activeTab == "profile")
				{
					<div class="tab-pane fade show active">
						<div class="py-5">
							<div class="d-flex flex-stack mb-5">
								<h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="bi bi-person-badge text-primary me-2"></i>Thông tin cá nhân</h3>
								@if (!_isReadOnly)
								{
									<button type="button" class="btn btn-sm btn-light-primary border border-primary border-dashed" @onclick="ScanCCCD">
										<i class="bi bi-qr-code-scan me-2"></i>Quét thẻ căn cước (CCCD) chip
									</button>
								}
							</div>
							<div class="row g-6 mb-8">
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Họ và tên</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.Name" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Số CCCD / CMND</label>
									<div class="position-relative">
										<input type="@(isIdCardVisible ? "text" : "password")" class="form-control form-control-solid" @bind="selectedEmployee.IdCard" placeholder="Nhập số CCCD" readonly="@_isReadOnly" />
										<button type="button" class="btn btn-icon btn-sm btn-active-color-primary position-absolute top-50 end-0 translate-middle-y me-2" @onclick="() => isIdCardVisible = !isIdCardVisible">
											<i class="bi @(isIdCardVisible ? "bi-eye" : "bi-eye-slash") fs-6"></i>
										</button>
									</div>
								</div>
								<div class="col-md-3">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Ngày cấp</label>
									<input type="date" class="form-control form-control-solid" @bind="selectedEmployee.CccdIssueDate" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-3">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Nơi cấp</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.CccdIssuePlace" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Ngày sinh</label>
									<input type="date" class="form-control form-control-solid" @bind="selectedEmployee.DOB" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Giới tính</label>
									<select class="form-select form-select-solid" @bind="selectedEmployee.Gender" disabled="@_isReadOnly">
										<option value="Nam">Nam</option>
										<option value="Nữ">Nữ</option>
									</select>
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Số điện thoại</label>
									<div class="position-relative">
										<input type="@(isPhoneVisible ? "text" : "password")" class="form-control form-control-solid" @bind="selectedEmployee.Phone" placeholder="Nhập số điện thoại" readonly="@_isReadOnly" />
										<button type="button" class="btn btn-icon btn-sm btn-active-color-primary position-absolute top-50 end-0 translate-middle-y me-2" @onclick="() => isPhoneVisible = !isPhoneVisible">
											<i class="bi @(isPhoneVisible ? "bi-eye" : "bi-eye-slash") fs-6"></i>
										</button>
									</div>
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Email cá nhân</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.Email" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Email công ty</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.CompanyEmail" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Địa chỉ thường trú (theo CCCD)</label>
									<textarea class="form-control form-control-solid" rows="2" @bind="selectedEmployee.Address" readonly="@_isReadOnly"></textarea>
								</div>
								<div class="col-md-6">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Nơi ở hiện nay</label>
									<textarea class="form-control form-control-solid" rows="2" @bind="selectedEmployee.Residence" readonly="@_isReadOnly"></textarea>
								</div>
                            
								<div class="col-12 mt-5">
									<div class="separator separator-dashed my-5"></div>
									<h3 class="fw-bolder m-0 fs-5 text-uppercase mb-5"><i class="bi bi-briefcase text-primary me-2"></i>Thông tin công việc</h3>
								</div>
								<div class="col-md-3">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold required">Phòng ban</label>
									<select class="form-select form-select-solid" @bind="selectedEmployee.DepartmentId" disabled="@_isReadOnly">
										<option value="">-- Chọn phòng ban --</option>
										@foreach (var dept in CachedDepartments)
										{
											<option value="@dept.Id">@dept.Name</option>
										}
									</select>
								</div>
								<div class="col-md-3">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold required">Chức vụ</label>
									<select class="form-select form-select-solid" @bind="selectedEmployee.PositionId" disabled="@_isReadOnly">
										<option value="">-- Chọn chức vụ --</option>
										@foreach (var pos in CachedPositions)
										{
											<option value="@pos.Id">@pos.Name</option>
										}
									</select>
								</div>
								<div class="col-md-3">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Người quản lý</label>
									<select class="form-select form-select-solid" @bind="selectedEmployee.ReportToId" disabled="@_isReadOnly">
										<option value="">-- Không có --</option>
										@foreach (var emp in CachedEmployees)
										{
											<option value="@emp.Id">@emp.FullName</option>
										}
									</select>
								</div>
								<div class="col-md-3">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold required">Trạng thái</label>
									<select class="form-select form-select-solid" @bind="selectedEmployee.StatusId" disabled="@_isReadOnly">
