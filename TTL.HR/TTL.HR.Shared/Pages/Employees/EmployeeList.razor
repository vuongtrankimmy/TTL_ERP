							<div class="bg-light-primary rounded p-6 d-flex flex-stack mb-8 border border-primary border-dashed">
								<div class="d-flex align-items-center">
									<div class="symbol symbol-40px bg-white rounded me-4 d-flex align-items-center justify-content-center">
										<i class="bi bi-power fs-2 text-primary"></i>
									</div>
									<div>
										<div class="fw-bolder text-gray-900 fs-6">Kích hoạt tài khoản ERP</div>
										<div class="text-muted fs-7">Cho phép nhân viên này truy cập vào hệ thống ERP</div>
									</div>
								</div>
								<div class="form-check form-switch form-check-custom form-check-solid">
									<input class="form-check-input w-45px h-25px" type="checkbox" @bind="selectedEmployee.IsActive" disabled="@_isReadOnly" />
								</div>
							</div>

							<h3 class="fw-bolder mb-5 fs-5 text-uppercase"><i class="bi bi-shield-lock text-primary me-2"></i>Thông tin tài khoản</h3>
							<div class="card border border-gray-300 border-dashed mb-10">
								<div class="card-body p-6">
									<div class="row g-6 mb-6">
										<div class="col-md-6">
											<label class="form-label text-muted fs-7 text-uppercase fw-bold">Tên đăng nhập (Username)</label>
											<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.Username" readonly="@_isReadOnly" />
										</div>
										<div class="col-md-6">
											<label class="form-label text-muted fs-7 text-uppercase fw-bold">Mật khẩu (Password)</label>
											<div class="position-relative">
												<input type="@(isPasswordVisible ? "text" : "password")" class="form-control form-control-solid" @bind="selectedEmployee.Password" readonly="@_isReadOnly" />
												<i class="bi @(isPasswordVisible ? "bi-eye-slash" : "bi-eye") position-absolute top-50 end-0 translate-middle-y me-3 cursor-pointer text-muted" @onclick="() => isPasswordVisible = !isPasswordVisible"></i>
											</div>
										</div>
									</div>
									@if (!_isReadOnly)
									{
										<div class="d-flex justify-content-end">
											<button class="btn btn-sm btn-light"><i class="bi bi-arrow-repeat me-2"></i>Tạo mới / Reset mật khẩu</button>
										</div>
									}
								</div>
							</div>

							<h3 class="fw-bolder mb-5 fs-5 text-uppercase"><i class="bi bi-diagram-3 text-primary me-2"></i>Cấu hình phân quyền</h3>
							<div class="card border border-gray-300 border-dashed">
								<div class="card-body p-6">
									<div class="nav-group nav-group-outline justify-content-center mb-8">
										<button class="btn btn-sm btn-color-gray-400 btn-active btn-active-secondary px-6 py-2 active">Phân quyền theo vai trò</button>
										<button class="btn btn-sm btn-color-gray-400 btn-active btn-active-secondary px-6 py-2">Tùy chỉnh quyền chi tiết</button>
									</div>
                                    
									<label class="form-label text-muted fs-8 text-uppercase fw-bold">Chọn vai trò hệ thống</label>
									<select class="form-select form-select-solid mb-4" disabled="@_isReadOnly">
										<option value="1" selected>Nhân viên (Staff)</option>
										<option value="2">Quản lý (Manager)</option>
									</select>
									<div class="text-muted fs-8 italic mb-8">* Vai trò này sẽ tự động áp dụng bộ quyền mặc định cho các module.</div>

									<div class="table-responsive">
										<table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-3">
											<thead>
												<tr class="fw-bold fs-8 text-muted text-uppercase">
													<th class="min-w-150px">Module</th>
													<th class="text-center">Xem</th>
													<th class="text-center">Thêm</th>
													<th class="text-center">Sửa</th>
													<th class="text-center">Xóa</th>
												</tr>
											</thead>
											<tbody class="fs-7 fw-bold">
												@if (selectedEmployee?.ModulePermissions != null && selectedEmployee.ModulePermissions.Any())
												{
													@foreach (var perm in selectedEmployee.ModulePermissions)
													{
														<tr>
															<td>@perm.ModuleName</td>
															<td class="text-center"><input class="form-check-input" type="checkbox" checked="@perm.CanView" disabled="@_isReadOnly" /></td>
															<td class="text-center"><input class="form-check-input" type="checkbox" checked="@perm.CanAdd" disabled="@_isReadOnly" /></td>
															<td class="text-center"><input class="form-check-input" type="checkbox" checked="@perm.CanEdit" disabled="@_isReadOnly" /></td>
															<td class="text-center"><input class="form-check-input" type="checkbox" checked="@perm.CanDelete" disabled="@_isReadOnly" /></td>
														</tr>
													}
												}
												else
												{
													<tr><td>Nhân sự</td><td class="text-center"><input class="form-check-input" type="checkbox" checked disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td></tr>
													<tr><td>Chấm công</td><td class="text-center"><input class="form-check-input" type="checkbox" checked disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" checked disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td></tr>
													<tr><td>Tiền lương</td><td class="text-center"><input class="form-check-input" type="checkbox" checked disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td><td class="text-center"><input class="form-check-input" type="checkbox" disabled="@_isReadOnly" /></td></tr>
												}
											</tbody>
										</table>
									</div>
								</div>
							</div>
						</div>
					</div>
				}
				else if (activeTab == "calendar")
				{
					<div class="tab-pane fade show active">
						<div class="py-5">
							<div class="d-flex flex-stack mb-5">
								<h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="bi bi-calendar-check text-primary me-2"></i>Lịch chấm công chi tiết</h3>
								<div class="d-flex align-items-center gap-4">
									<button type="button" class="btn btn-icon btn-sm btn-light" @onclick="PrevMonth"><i class="bi bi-chevron-left"></i></button>
									<span class="fw-bolder fs-6">@($"Tháng {_calendarMonth:D2}/{_calendarYear}")</span>
									<button type="button" class="btn btn-icon btn-sm btn-light" @onclick="NextMonth"><i class="bi bi-chevron-right"></i></button>
								</div>
							</div>

							<div class="bg-light-info rounded p-4 mb-8 border border-info border-dashed">
								<div class="d-flex align-items-center">
									<i class="bi bi-info-circle-fill text-info me-3 fs-3"></i>
									<span class="fs-7 fw-bold text-gray-700">Ghi chú: Dữ liệu này được cập nhật tự động từ hệ thống máy chấm công khuôn mặt FaceID tại cổng chính.</span>
								</div>
							</div>

							<div class="card border border-gray-300 border-dashed mb-8">
								<div class="card-body p-4 text-center">
									<div class="calendar-grid mb-4" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;">
										@foreach (var day in new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" })
										{
											<div class="text-muted fs-8 fw-bold p-2 text-center">@day</div>
										}
										@for (int i = 1; i <= 31; i++)
										{
											<div class="p-1 text-center">
												<div class="rounded-circle w-30px h-30px d-flex align-items-center justify-content-center fs-8 fw-bold @(i % 7 == 0 ? "bg-light-danger text-danger" : i % 5 == 0 ? "bg-light-warning text-warning" : "bg-light-success text-success") mx-auto cursor-pointer border border-transparent hover-border-primary">@i</div>
											</div>
										}
									</div>
									<div class="d-flex justify-content-center gap-6">
										<div class="d-flex align-items-center fs-8 fw-bold text-muted"><span class="w-8px h-8px rounded-circle bg-success me-2"></span>Đúng giờ</div>
										<div class="d-flex align-items-center fs-8 fw-bold text-muted"><span class="w-8px h-8px rounded-circle bg-warning me-2"></span>Đi muộn</div>
										<div class="d-flex align-items-center fs-8 fw-bold text-muted"><span class="w-8px h-8px rounded-circle bg-danger me-2"></span>Nghỉ/Không phép</div>
									</div>
								</div>
							</div>
                            
							<h3 class="fw-bolder mb-5 fs-5 text-uppercase"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Thống kê nhanh tháng</h3>
							<div class="row g-4 mb-8">
								<div class="col-6">
									<div class="card border border-gray-300 border-dashed">
										<div class="card-body p-4 d-flex flex-stack">
											<div>
												<div class="fs-8 text-muted fw-bold">SỐ CÔNG CHUẨN</div>
												<div class="fs-4 fw-bolder text-gray-900">@(selectedEmployee?.AttendanceSummary?.TotalWorkingDays ?? 0) <span class="fs-8 fw-normal">ngày</span></div>
											</div>
											<i class="bi bi-calendar4-week fs-1 text-gray-400"></i>
										</div>
									</div>
								</div>
								<div class="col-6">
									<div class="card border border-gray-300 border-dashed">
										<div class="card-body p-4 d-flex flex-stack">
											<div>
												<div class="fs-8 text-muted fw-bold">PHÉP CÒN LẠI</div>
												<div class="fs-4 fw-bolder text-gray-900">@(selectedEmployee?.AttendanceSummary?.RemainingLeaves ?? 0) <span class="fs-8 fw-normal">ngày</span></div>
											</div>
											<i class="bi bi-patch-check fs-1 text-success"></i>
										</div>
									</div>
								</div>
								<div class="col-6">
									<div class="card border border-gray-300 border-dashed">
										<div class="card-body p-4 d-flex flex-stack">
											<div>
												<div class="fs-8 text-muted fw-bold">TĂNG CA (OT)</div>
												<div class="fs-4 fw-bolder text-gray-900">@(selectedEmployee?.AttendanceSummary?.OvertimeHours ?? 0) <span class="fs-8 fw-normal">giờ</span></div>
											</div>
											<i class="bi bi-clock-history fs-1 text-primary"></i>
										</div>
									</div>
								</div>
								<div class="col-6">
									<div class="card border border-gray-300 border-dashed">
										<div class="card-body p-4 d-flex flex-stack">
											<div>
												<div class="fs-8 text-muted fw-bold">ĐI MUỘN / VỀ SỚM</div>
												<div class="fs-4 fw-bolder text-gray-900">0 <span class="fs-8 fw-normal">lần</span></div>
											</div>
											<i class="bi bi-exclamation-triangle fs-1 text-warning"></i>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				}
			</div>
		</div>
		<div class="card-footer border-0 d-flex gap-3 justify-content-between p-10 flex-shrink-0">
			@if (_isReadOnly)
			{
				<button type="button" class="btn btn-light-success flex-grow-1" @onclick="() => DownloadProfile(selectedEmployee)">
					<i class="bi bi-file-earmark-pdf me-2"></i>In hồ sơ PDF
				</button>
				<button type="button" class="btn btn-light flex-grow-1" id="kt_drawer_employee_detail_close">Đóng</button>
			}
			else
			{
				@if (activeTab == "profile")
				{
					<button type="button" class="btn btn-primary flex-grow-1" @onclick="SaveChanges">
						<span class="indicator-label"><i class="bi bi-save me-2"></i>Lưu thay đổi</span>
					</button>
				}
				else if (activeTab == "account")
				{
					<button type="button" class="btn btn-primary flex-grow-1" @onclick='() => JSRuntime.InvokeVoidAsync("Swal.fire", "Thành công", "Đã cập nhật cấu hình phân quyền", "success")'>
						<i class="bi bi-check2-circle me-2"></i>Cập nhật cấu hình
					</button>
				}
				else if (activeTab == "calendar")
				{
					<button type="button" class="btn btn-light-success flex-grow-1" @onclick="() => DownloadProfile(selectedEmployee)">
						<i class="bi bi-file-earmark-pdf me-2"></i>In hồ sơ PDF
					</button>
				}
				<button type="button" class="btn btn-light flex-grow-1" id="kt_drawer_employee_detail_close">@(activeTab == "account" ? "Hủy" : "Đóng")</button>
			}
		</div>
	</div>
</div>



<CccdScanner @ref="cccdScanner" />

<!-- CONTRACT PREVIEW MODAL -->
<div class="modal fade" id="preview_modal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-scrollable">
		<div class="modal-content border-0 shadow-lg">
			<div class="modal-header bg-white border-0 py-5 px-10 flex-stack">
				<h2 class="modal-title fs-4 fw-bolder text-gray-900">Xem trước hợp đồng</h2>
				<div class="d-flex align-items-center gap-2">
					<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
				</div>
			</div>
			<div class="modal-body p-0 bg-light position-relative">
				<!-- Floating Print Button (Sticky) -->
				<div class="d-print-none" style="position: sticky; top: 20px; right: 40px; float: right; z-index: 100; margin-bottom: -60px; pointer-events: none;">
					<button type="button" class="btn btn-primary shadow-lg fw-bold px-6 py-4 rounded-pill d-flex align-items-center gap-2 hover-elevate-up m-5" onclick="window.print()" style="pointer-events: auto;">
						<i class="bi bi-printer fs-3"></i>
						<span>In ngay</span>
					</button>
				</div>

				<div class="p-10">
					<div class="contract-paper mx-auto shadow-sm" style="background: #fff; width: 210mm; min-height: 297mm; padding: 25mm 20mm; font-family: 'Times New Roman', Times, serif; font-size: 16px; line-height: 1.6; color: black;">
						@((MarkupString)PreviewContent)
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Dedicated Print Container (Hidden on screen) -->
<div id="print_only_area" class="d-none d-print-block">
	<div style="width: 210mm; padding: 20mm; background: white; font-family: 'Times New Roman', Times, serif; font-size: 16px; line-height: 1.6; color: black;">
		@((MarkupString)PreviewContent)
	</div>
</div>


<style>
	.hover-border-primary:hover {
