                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">SỐ CÔNG CHUẨN</div>
                                                <div class="fs-4 fw-bolder text-gray-900">20 <span class="fs-8 fw-normal">ngày</span></div>
                                            </div>
                                            <i class="bi bi-calendar4-week fs-1 text-gray-400"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">SỐ CÔNG THỰC TẾ</div>
                                                <div class="fs-4 fw-bolder text-gray-900">18.5 <span class="fs-8 fw-normal">ngày</span></div>
                                            </div>
                                            <i class="bi bi-patch-check fs-1 text-success"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">TĂNG CA (OT)</div>
                                                <div class="fs-4 fw-bolder text-gray-900">4.5 <span class="fs-8 fw-normal">giờ</span></div>
                                            </div>
                                            <i class="bi bi-clock-history fs-1 text-primary"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card border border-gray-300 border-dashed">
                                        <div class="card-body p-4 d-flex flex-stack">
                                            <div>
                                                <div class="fs-8 text-muted fw-bold">ĐI MUỘN (Lần)</div>
                                                <div class="fs-4 fw-bolder text-gray-900">02 <span class="fs-8 fw-normal">lần</span></div>
                                            </div>
                                            <i class="bi bi-exclamation-triangle fs-1 text-warning"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="card-footer border-0 d-flex gap-3 justify-content-between p-10">
            @if (activeTab == "profile")
            {
                <button type="button" class="btn btn-primary flex-grow-1" @onclick="SaveChanges">
                    <span class="indicator-label"><i class="bi bi-save me-2"></i>Lưu thay đổi</span>
                </button>
            }
            else if (activeTab == "account")
            {
                <button type="button" class="btn btn-primary flex-grow-1" @onclick='() => JSRuntime.InvokeVoidAsync("Swal.fire", "Thành công", "Đã cập nhật cấu hình phân quyền", "success")'>
                    <i class="bi bi-check2-circle me-2"></i>Cập nhật cấu hình
                </button>
            }
            else if (activeTab == "calendar")
            {
                <button type="button" class="btn btn-primary flex-grow-1" @onclick='() => JSRuntime.InvokeVoidAsync("Swal.fire", "Thông báo", "Hệ thống đang xuất file báo cáo PDF...", "info")'>
                    <i class="bi bi-file-earmark-pdf me-2"></i>Xuất báo cáo cá nhân
                </button>
            }
            <button type="button" class="btn btn-light flex-grow-1" id="kt_drawer_employee_detail_close">@(activeTab == "account" ? "Hủy" : "Đóng")</button>
        </div>
    </div>
</div>



