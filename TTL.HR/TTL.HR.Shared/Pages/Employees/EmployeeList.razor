										{
											<option value="@status.Id">@status.Name</option>
										}
									</select>
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold required">Loại hợp đồng</label>
									<select class="form-select form-select-solid" @bind="selectedEmployee.ContractTypeId" disabled="@_isReadOnly">
										@foreach (var ct in CachedContractTypes)
										{
											<option value="@ct.Id">@ct.Name</option>
										}
									</select>
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Ngày vào làm</label>
									<input type="date" class="form-control form-control-solid" @bind="selectedEmployee.JoinDate" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Nơi làm việc</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.Workplace" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Mức lương</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.SalaryDisplay" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Ngày hết hạn HĐ</label>
									<input type="date" class="form-control form-control-solid" @bind="selectedEmployee.ContractExpiry" readonly="@_isReadOnly" />
								</div>
                            
								<div class="col-12 mt-5">
									<div class="separator separator-dashed my-5"></div>
									<h3 class="fw-bolder m-0 fs-5 text-uppercase mb-5"><i class="bi bi-person-heart text-primary me-2"></i>Liên hệ khẩn cấp</h3>
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Người liên hệ</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.EmergencyContactName" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Mối quan hệ</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.EmergencyContactRelation" readonly="@_isReadOnly" />
								</div>
								<div class="col-md-4">
									<label class="form-label text-muted fs-7 text-uppercase fw-bold">Số điện thoại</label>
									<input type="text" class="form-control form-control-solid" @bind="selectedEmployee.EmergencyContactPhone" readonly="@_isReadOnly" />
								</div>
							</div>

							<div class="card bg-light border-0 mb-8">
								<div class="card-body p-6">
									<div class="d-flex flex-stack mb-5">
										<h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="bi bi-file-earmark-text text-primary me-2"></i>Hợp đồng lao động</h3>
										<span class="badge badge-light-success fs-8 fw-bolder">ĐANG HIỆU LỰC</span>
									</div>
									<div class="row g-4 mb-6">
										<div class="col-4">
											<div class="bg-white rounded p-4 border border-dashed text-center">
												<div class="fs-8 text-muted fw-bold mb-1">LOẠI HỢP ĐỒNG</div>
												<div class="fs-7 fw-bolder text-gray-800">@selectedEmployee?.ContractTypeName</div>
											</div>
										</div>
										<div class="col-4">
											<div class="bg-white rounded p-4 border border-dashed text-center">
												<div class="fs-8 text-muted fw-bold mb-1">MỨC LƯƠNG ĐÓNG BH</div>
												<div class="fs-7 fw-bolder text-gray-900">@(isSalaryVisible? selectedEmployee?.SalaryDisplay : "********** VNĐ")</div>
												<button type="button" class="btn btn-link btn-xs p-0 fs-10 text-primary" @onclick="() => isSalaryVisible = !isSalaryVisible">@(isSalaryVisible ? "Ẩn" : "Hiển thị")</button>
											</div>
										</div>
										<div class="col-4">
											<div class="bg-white rounded p-4 border border-dashed text-center">
												<div class="fs-8 text-muted fw-bold mb-1">NGÀY HẾT HẠN HD</div>
												<div class="fs-7 fw-bolder text-danger">@selectedEmployee?.ContractExpiry</div>
											</div>
										</div>
									</div>
									<div class="d-flex gap-3">
										<button class="btn btn-sm btn-outline btn-outline-primary bg-white flex-grow-1" @onclick="PrintContract" disabled="@_isPrintLoading">
