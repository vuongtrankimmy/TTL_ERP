@using TTL.HR.Application.Modules.HumanResource.Models
@using TTL.HR.Application.Modules.HumanResource.Interfaces
@using TTL.HR.Application.Modules.Organization.Models
@using TTL.HR.Application.Modules.Common.Models
@inject IEmployeeService EmployeeService
@inject IContractService ContractService
@inject IJSRuntime JSRuntime

<div id="kt_drawer_employee_detail" class="bg-white" data-kt-drawer="true" data-kt-drawer-name="employee-detail" data-kt-drawer-activate="true" data-kt-drawer-overlay="true" data-kt-drawer-width="{default:'300px', 'md': '650px'}" data-kt-drawer-direction="end" data-kt-drawer-toggle=".kt_drawer_employee_detail_toggle" data-kt-drawer-close="#kt_drawer_employee_detail_close">
	<div class="card shadow-none rounded-0 w-100 h-100 d-flex flex-column">
		<!-- SKELETON LOADING -->
		@if (IsLoading)
		{
            <div class="card-body">
			    <SkeletonLoading IsLoading="true" Type="SkeletonLoading.SkeletonType.Form" Rows="10" />
            </div>
		}
		else if (Employee != null)
		{
			<div class="card-header border-0 pt-7 pb-5 flex-shrink-0">
				<div class="card-title w-100 d-flex justify-content-between align-items-start">
					<div class="d-flex">
						<div class="symbol symbol-70px symbol-circle me-5">
							<img src="@(string.IsNullOrEmpty(Employee.AvatarUrl) ? "assets/media/avatars/300-1.jpg" : Employee.AvatarUrl)" alt="@Employee.FullName" style="object-fit: cover;" />
						</div>
						<div class="d-flex flex-column">
							<h2 class="fs-4 fw-bolder text-gray-900 mb-1">@Employee.FullName</h2>
							<div class="text-primary fw-bold fs-7 mb-2">@Employee.PositionName</div>
							<div class="d-flex flex-wrap gap-2">
								<span class="badge badge-light-secondary text-gray-600 fw-bold px-2 py-1">Mã NV: @Employee.Code</span>
								<span class="badge badge-light-secondary text-gray-600 fw-bold px-2 py-1">Phòng: @Employee.DepartmentName</span>
							</div>
						</div>
					</div>
					<div class="card-toolbar ms-3">
						<button type="button" class="btn btn-sm btn-icon btn-active-light-primary" id="kt_drawer_employee_detail_close">
							<i class="ki-outline ki-cross fs-2"></i>
						</button>
					</div>
				</div>
			</div>
			<div class="card-body p-0 flex-grow-1 hover-scroll-y">
				<ul class="nav nav-line-tabs nav-line-tabs-2x border-transparent fs-6 fw-bold px-5 mb-5 flex-nowrap overflow-auto">
					<li class="nav-item">
						<a class="nav-link text-active-primary @(activeTab == "profile" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "profile"'>
							<i class="ki-outline ki-user me-2"></i>Thông tin hồ sơ
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link text-active-primary @(activeTab == "account" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "account"'>
							<i class="ki-outline ki-lock-2 me-2"></i>Tài khoản & Phân quyền
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link text-active-primary @(activeTab == "calendar" ? "active" : "") py-4" href="javascript:;" @onclick='() => activeTab = "calendar"'>
							<i class="ki-outline ki-calendar-8 me-2"></i>Lịch & Chấm công
						</a>
					</li>
				</ul>
				<div class="tab-content px-6">
					@if (activeTab == "profile")
					{
						<div class="tab-pane fade show active">
							<div class="py-5">
                                <!-- PERSONAL INFO -->
								<div class="d-flex flex-stack mb-5">
									<h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="ki-outline ki-badge text-primary me-2"></i>Thông tin cá nhân</h3>
								</div>
								<div class="row g-6 mb-8">
									<div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Họ và tên</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.FullName</div> }
										else { <input type="text" class="form-control form-control-solid" @bind="Employee.FullName" /> }
									</div>
                                    <div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Ngày sinh</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.DOB?.ToString("dd/MM/yyyy")</div> }
										else { <input type="date" class="form-control form-control-solid" @bind="Employee.DOB" /> }
									</div>
                                    <div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Giới tính</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.Gender</div> }
										else {
											<select class="form-select form-select-solid" @bind="Employee.Gender">
												<option value="">Chọn giới tính</option>
												<option value="Nam">Nam</option>
												<option value="Nữ">Nữ</option>
											</select>
										}
									</div>
                                    <div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Số CCCD</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.IdCard</div> }
										else {
											<div class="position-relative">
												<input type="text" class="form-control form-control-solid" @bind="Employee.IdCard" />
												<button type="button" class="btn btn-icon btn-sm btn-active-color-primary position-absolute end-0 top-0 mt-1 me-1" @onclick="OnScanCCCD">
													<i class="ki-outline ki-scan-barcode fs-3"></i>
												</button>
											</div>
										}
									</div>
                                </div>

                                <!-- WORK INFO -->
                                <div class="d-flex flex-stack mb-5">
									<h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="ki-outline ki-briefcase text-primary me-2"></i>Thông tin công việc</h3>
								</div>
								<div class="row g-6 mb-8">
									<div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Phòng ban</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.DepartmentName</div> }
										else {
											<select class="form-select form-select-solid" @bind="Employee.DepartmentId">
												@foreach (var dept in Departments)
												{
													<option value="@dept.Id">@dept.Name</option>
												}
											</select>
										}
									</div>
                                    <div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Chức vụ</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.PositionName</div> }
										else {
											<select class="form-select form-select-solid" @bind="Employee.PositionId">
												@foreach (var pos in Positions)
												{
													<option value="@pos.Id">@pos.Name</option>
												}
											</select>
										}
									</div>
                                    <div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Người quản lý</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@(string.IsNullOrEmpty(Employee.ReportToName) ? "Không có" : Employee.ReportToName)</div> }
										else {
											<select class="form-select form-select-solid" @bind="Employee.ReportToId">
												<option value="">Không có</option>
												@foreach (var mgr in Managers)
												{
													<option value="@mgr.Id">@mgr.FullName</option>
												}
											</select>
										}
									</div>
                                    <div class="col-md-6">
										<label class="form-label text-muted fs-7 text-uppercase fw-bold">Ngày gia nhập</label>
										@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.JoinDate?.ToString("dd/MM/yyyy")</div> }
										else { <input type="date" class="form-control form-control-solid" @bind="Employee.JoinDate" /> }
									</div>
                                </div>

                                <!-- CONTRACT SECTION (Unified View/Print) -->
								<div class="card bg-light-primary border-0 mb-8">
									<div class="card-body p-6">
										<div class="d-flex flex-stack mb-5">
											<h3 class="fw-bolder m-0 fs-5 text-uppercase text-primary"><i class="ki-outline ki-file-sheet text-primary me-2"></i>Hợp đồng lao động</h3>
											<span class="badge badge-light-success fs-8 fw-bolder">ĐANG HIỆU LỰC</span>
										</div>
										<div class="row g-4 mb-6">
											<div class="col-4">
												<div class="bg-white rounded p-4 border border-dashed text-center">
													<div class="fs-8 text-muted fw-bold mb-1">LOẠI HĐ</div>
													<div class="fs-7 fw-bolder text-gray-800">@Employee.ContractTypeName</div>
												</div>
											</div>
											<div class="col-4">
												<div class="bg-white rounded p-4 border border-dashed text-center">
													<div class="fs-8 text-muted fw-bold mb-1">LƯƠNG CB</div>
													<div class="fs-7 fw-bolder text-gray-900">@Employee.SalaryDisplay</div>
												</div>
											</div>
											<div class="col-4">
												<div class="bg-white rounded p-4 border border-dashed text-center">
													<div class="fs-8 text-muted fw-bold mb-1">HẾT HẠN</div>
													<div class="fs-7 fw-bolder text-danger">@(Employee.ContractExpiry?.ToString("dd/MM/yyyy") ?? "---")</div>
												</div>
											</div>
										</div>
										<div class="d-flex gap-3">
										<button class="btn btn-sm btn-outline btn-outline-primary bg-white flex-grow-1" @onclick="HandlePrintContract" disabled="@_isPrintLoading">
											@if (_isPrintLoading)
											{
												<span class="spinner-border spinner-border-sm me-2"></span>
											}
											else
											{
												<i class="bi bi-printer me-2"></i>
											}
											In hợp đồng
										</button>
										<button class="btn btn-sm btn-primary flex-grow-1" @onclick="HandleViewContract"><i class="bi bi-eye me-2"></i>Xem hiện tại</button>
										@if (!IsReadOnly)
										{
											<button class="btn btn-sm btn-light flex-grow-1 border border-dashed"><i class="bi bi-upload me-2"></i>Tải lên (đã ký)</button>
										}
									</div>
									</div>
								</div>

								<!-- AUDIT LOG TIMELINE -->
								<h3 class="fw-bolder m-0 fs-5 text-uppercase mb-5"><i class="ki-outline ki-time text-gray-600 me-2"></i>Nhật ký thay đổi</h3>
								<div class="timeline-label">
									@if (Employee.AuditLogs != null && Employee.AuditLogs.Any())
									{
										@foreach (var log in Employee.AuditLogs.OrderByDescending(l => l.Timestamp).Take(5))
										{
											<div class="timeline-item">
												<div class="timeline-label fw-bolder text-gray-800 fs-8 w-75px">@log.Timestamp.ToString("HH:mm")</div>
												<div class="timeline-badge"><i class="fa fa-genderless text-primary fs-1"></i></div>
												<div class="timeline-content fw-bold text-gray-800 ps-3">
													@log.Detail bởi <span class="text-primary">@log.UserName</span>
													<div class="text-muted fs-9">@log.Timestamp.ToString("dd/MM/yyyy")</div>
												</div>
											</div>
										}
									}
                                    else
                                    {
                                        <div class="text-muted fs-7">Chưa có nhật ký thay đổi.</div>
                                    }
								</div>
							</div>
						</div>
					}
                    else if (activeTab == "account")
                    {
                        <div class="tab-pane fade show active py-5">
                            <div class="d-flex flex-stack mb-5">
                                <h3 class="fw-bolder m-0 fs-5 text-uppercase"><i class="ki-outline ki-lock-2 text-primary me-2"></i>Cài đặt tài khoản</h3>
                                <div class="form-check form-switch form-check-custom form-check-solid">
                                    <input class="form-check-input" type="checkbox" @bind="Employee.IsAccountActive" id="account_active" />
                                    <label class="form-check-label fw-bold text-gray-600" for="account_active">Đang hoạt động</label>
                                </div>
                            </div>
                            <div class="row g-6 mb-8">
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Email công ty</label>
									@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">@Employee.CompanyEmail</div> }
                                    else { <input type="email" class="form-control form-control-solid" @bind="Employee.CompanyEmail" /> }
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fs-7 text-uppercase fw-bold">Mật khẩu</label>
									@if (IsReadOnly) { <div class="fw-bolder fs-6 text-gray-800 p-3 bg-light rounded">●●●●●●●●●●</div> }
                                    else {
										<div class="position-relative">
											<input type="@(_isPasswordVisible ? "text" : "password")" class="form-control form-control-solid" @bind="Employee.Password" placeholder="Nhập để đổi mật khẩu" />
											<button type="button" class="btn btn-icon btn-sm btn-active-color-primary position-absolute end-0 top-0 mt-1 me-1" @onclick="() => _isPasswordVisible = !_isPasswordVisible">
												<i class="ki-outline @(_isPasswordVisible ? "ki-eye-slash" : "ki-eye") fs-3"></i>
											</button>
										</div>
									}
                                </div>
                            </div>
                        </div>
                    }
				</div>
			</div>
			<div class="card-footer border-0 d-flex gap-3 justify-content-between p-10 flex-shrink-0">
				@if (IsReadOnly)
				{
					<button type="button" class="btn btn-primary flex-grow-1" @onclick="() => IsReadOnly = false">Chỉnh sửa hồ sơ</button>
				}
				else
				{
					<button type="button" class="btn btn-primary flex-grow-1" @onclick="() => OnSave.InvokeAsync(Employee)">Lưu thay đổi</button>
					<button type="button" class="btn btn-light flex-grow-1" @onclick="() => IsReadOnly = true">Hủy</button>
				}
				<button type="button" class="btn btn-light flex-grow-1" id="kt_drawer_employee_detail_close">Đóng</button>
			</div>
		}
	</div>
</div>

@code {
    [Parameter] public EmployeeModel? Employee { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public List<DepartmentModel> Departments { get; set; } = new();
    [Parameter] public List<PositionModel> Positions { get; set; } = new();
    [Parameter] public List<EmployeeDto> Managers { get; set; } = new();
    [Parameter] public EventCallback<EmployeeModel> OnSave { get; set; }
    [Parameter] public EventCallback OnScanCCCD { get; set; }
    [Parameter] public EventCallback<EmployeeModel> OnViewContract { get; set; }
    [Parameter] public EventCallback<EmployeeModel> OnPrintContract { get; set; }

    private string activeTab = "profile";
    private bool _isPasswordVisible = false;
    private bool _isPrintLoading = false;

    private async Task HandlePrintContract()
    {
        _isPrintLoading = true;
        try
        {
            await OnPrintContract.InvokeAsync(Employee);
        }
        finally
        {
            _isPrintLoading = false;
        }
    }

    private async Task HandleViewContract()
    {
        await OnViewContract.InvokeAsync(Employee);
    }
}
