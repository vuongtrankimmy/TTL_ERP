@using Microsoft.AspNetCore.Components
@using TTL.HR.Shared.Components.Common

@if (IsVisible)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1060; opacity: 1;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bolder text-primary">Đăng ký tham gia đào tạo</h5>
                    <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" @onclick="OnCancel">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </div>
                </div>
                
                <div class="modal-body py-5">
                    <div class="mb-5 text-center">
                        <h3 class="fw-bold text-dark mb-1">@CourseTitle</h3>
                        <span class="text-muted fw-bold">Chọn nhân viên để đăng ký tham gia khóa học này</span>
                    </div>

                    <!-- Search Bar -->
                    <div class="position-relative mb-6">
                        <i class="ki-outline ki-magnifier fs-2 position-absolute top-50 translate-middle-y ms-4 text-gray-500"></i>
                        <input type="text" class="form-control form-control-solid ps-12" 
                               placeholder="Tìm kiếm nhân viên theo tên hoặc mã..." 
                               @bind="SearchTerm" @bind:event="oninput" />
                    </div>

                    <!-- Employee List -->
                    <div class="mh-400px scroll-y me-n5 pe-5">
                        <div class="table-responsive">
                            <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-4">
                                <thead>
                                    <tr class="fw-bold text-muted bg-light">
                                        <th class="w-50px ps-4">
                                            <div class="form-check form-check-sm form-check-custom form-check-solid">
                                                <input class="form-check-input" type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected" />
                                            </div>
                                        </th>
                                        <th class="min-w-200px">Nhân viên</th>
                                        <th class="min-w-150px">Phòng ban</th>
                                        <th class="min-w-100px text-end pe-4">Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (_isLoading)
                                    {
                                         <tr>
                                             <td colspan="4" class="text-center py-10">
                                                 <div class="spinner-border text-primary" role="status">
                                                     <span class="visually-hidden">Loading...</span>
                                                 </div>
                                                 <div class="text-muted mt-2">Đang tải danh sách nhân viên...</div>
                                             </td>
                                         </tr>
                                     }
                                     else
                                     {
                                         @foreach (var emp in FilteredEmployees)
                                         {
                                             <tr @onclick="() => ToggleEmployeeSelection(emp)" 
                                                 class="@(emp.IsAlreadyEnrolled ? "" : "cursor-pointer hover-bg-light")"
                                                 style="@(emp.IsAlreadyEnrolled ? "opacity: 0.8;" : "")">
                                                  <td class="ps-4">
                                                      <div class="form-check form-check-sm form-check-custom form-check-solid" @onclick:stopPropagation>
                                                          <input class="form-check-input" type="checkbox" 
                                                                 @bind="emp.IsSelected" 
                                                                 disabled="@emp.IsAlreadyEnrolled" />
                                                      </div>
                                                  </td>
                                                  <td>
                                                      <div class="d-flex align-items-center">
                                                          <div class="symbol symbol-35px me-3">
                                                              <div class="symbol-label bg-light-primary text-primary fw-bold">@(emp.FullName?.Length > 0 ? emp.FullName.Substring(0, 1) : "?")</div>
                                                          </div>
                                                          <div class="d-flex justify-content-start flex-column">
                                                              <span class="text-dark fw-bold text-hover-primary fs-6">@emp.FullName</span>
                                                              <span class="text-muted fw-bold d-block fs-7">@emp.Code</span>
                                                          </div>
                                                      </div>
                                                  </td>
                                                  <td>
                                                      <span class="text-gray-700 fw-bold">@emp.Department</span>
                                                  </td>
                                                  <td class="text-end pe-4">
                                                      @if (emp.IsAlreadyEnrolled)
                                                      {
                                                          <span class="badge badge-light-info fw-bold">Đã tham gia</span>
                                                      }
                                                      else
                                                      {
                                                          <span class="badge @(emp.Status == "Active" ? "badge-light-success" : "badge-light-warning") fw-bold">@emp.Status</span>
                                                      }
                                                  </td>
                                             </tr>
                                         }
                                         @if (!FilteredEmployees.Any())
                                         {
                                             <tr>
                                                 <td colspan="4" class="text-center py-10">
                                                     <span class="text-muted fs-6">Không tìm thấy nhân viên phù hợp</span>
                                                 </td>
                                             </tr>
                                         }
                                     }
                                 </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 pt-0 pb-10 justify-content-center">
                     <div class="bg-light-info rounded p-3 me-5 d-flex align-items-center">
                         <i class="ki-outline ki-information-5 text-info fs-2 me-2"></i>
                         <span class="text-info fw-bold">Đã chọn @(AllEmployees.Count(e => e.IsSelected && !e.IsAlreadyEnrolled)) nhân viên mới</span>
                     </div>
                    <button type="button" class="btn btn-light me-3 fw-bold px-9" @onclick="OnCancel">Hủy bỏ</button>
                     <button type="button" class="btn btn-primary fw-bold px-9 shadow-sm" 
                             disabled="@(!AllEmployees.Any(e => e.IsSelected && !e.IsAlreadyEnrolled))"
                             @onclick="() => OnConfirm.InvokeAsync(AllEmployees.Where(e => e.IsSelected && !e.IsAlreadyEnrolled).ToList())">
                         Tiếp nhận đăng ký
                     </button>
                </div>
            </div>
        </div>
    </div>
}
