@using Microsoft.JSInterop
@using System.Text.Json
@using TTL.HR.Shared.Models

@inject IJSRuntime JSRuntime

@if (isVisible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 1200px;">
            <div class="modal-content rounded-3">
                <div class="modal-body p-10">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-4 mb-5">
                        <div>
                            <h2 class="fw-bold m-0" style="font-size: 1.25rem; color: #181C32;">Xác nhận thông tin quét CCCD</h2>
                            <div class="text-muted fs-7 mt-1">Vui lòng kiểm tra và đối soát thông tin bóc tách từ hình ảnh thẻ căn cước.</div>
                        </div>
                        <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" @onclick="CloseModal">
                            <span class="svg-icon svg-icon-1"><i class="bi bi-x-lg fs-2"></i></span>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="row">
                        <!-- Left Column: Image -->
                        <div class="col-md-5 border-end pe-5">
                            <h6 class="fw-bolder text-gray-800 mb-3"><i class="bi bi-image me-2 text-primary"></i>ẢNH CĂN CƯỚC ĐÃ TẢI LÊN</h6>
                            
                            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center border border-dashed border-gray-300 mb-4 position-relative" style="height: 350px;">
                                    <img src="/assets/media/misc/cccd_sample.jpg" 
                                         onerror="this.onerror=null;this.src='https://upload.wikimedia.org/wikipedia/commons/e/e9/Stylized_Vietnamese_Citizen_Identity_Card_sample.jpg';" 
                                         class="img-fluid rounded" style="max-height: 100%; width: auto; object-fit: contain;" />
                                    <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge badge-success shadow-sm">Đã tải lên</span>
                                    </div>
                            </div>
                            
                            <div class="d-flex justify-content-center gap-3">
                                <button type="button" class="btn btn-sm btn-light-primary w-100"><i class="bi bi-camera me-1"></i> Thử lại</button>
                                <button type="button" class="btn btn-sm btn-light w-100"><i class="bi bi-arrow-repeat me-1"></i> Xoay ảnh</button>
                            </div>

                                <div class="alert alert-dismissible bg-light-primary border border-primary border-dashed d-flex flex-column flex-sm-row w-100 p-3 mt-4 mb-0">
                                <i class="bi bi-info-circle-fill text-primary me-2 fs-5"></i>
                                <div class="d-flex flex-column pe-0 pe-sm-10">
                                    <span class="fw-bold text-primary">Lưu ý</span>
                                    <span class="text-gray-700 fs-8">Độ chính xác đạt 99.8%. Vui lòng kiểm tra kỹ lại các trường thông tin bên phải.</span>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column: Form Data -->
                        <div class="col-md-7 ps-5">
                            <h6 class="fw-bolder text-gray-800 mb-4"><i class="bi bi-file-earmark-text me-2 text-primary"></i>DỮ LIỆU BÓC TÁCH (AI-OCR)</h6>

                            <div class="mb-4">
                                <label class="form-label fs-7 fw-bolder text-gray-600">HỌ VÀ TÊN <span class="text-danger">*</span></label>
                                <div class="position-relative">
                                    <input type="text" class="form-control form-control-solid fw-bolder text-gray-800" style="background-color: #f5f8fa;" value="@scannedData?.Name" readonly />
                                        <i class="bi bi-check-circle-fill text-success position-absolute top-50 end-0 translate-middle-y me-3 fs-3" data-bs-toggle="tooltip" title="Đã xác thực"></i>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fs-7 fw-bolder text-gray-600">SỐ CCCD/CMND <span class="text-danger">*</span></label>
                                <div class="position-relative">
                                    <input type="text" class="form-control form-control-solid fw-bolder text-gray-800" style="background-color: #f5f8fa;" value="@scannedData?.IdCard" readonly />
                                        <span class="position-absolute top-50 end-0 translate-middle-y me-3 badge badge-light-warning fw-bold border border-warning border-dashed">⚠️ Cảnh báo trùng</span>
                                </div>
                                <div class="form-text text-warning fs-9 mt-1"><i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>Số CCCD này đã tồn tại trong hệ thống (Hồ sơ cũ: NV092)</div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-6">
                                    <label class="form-label fs-7 fw-bolder text-gray-600">NGÀY SINH</label>
                                    <input type="text" class="form-control form-control-solid fw-bold text-gray-800" value="@scannedData?.DOB?.ToString("dd/MM/yyyy")" readonly />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fs-7 fw-bolder text-gray-600">GIỚI TÍNH</label>
                                    <select class="form-select form-select-solid fw-bold text-gray-800" disabled>
                                        <option selected>@scannedData?.Gender</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fs-7 fw-bolder text-gray-600">QUÊ QUÁN</label>
                                <input type="text" class="form-control form-control-solid text-gray-800" value="@scannedData?.Hometown" readonly />
                            </div>

                            <div class="mb-0">
                                <label class="form-label fs-7 fw-bolder text-gray-600">NƠI THƯỜNG TRÚ</label>
                                <textarea class="form-control form-control-solid text-gray-800" rows="2" readonly>@scannedData?.Address</textarea>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Footer -->
                <div class="modal-footer border-0 pt-0 pb-10 pe-10">
                    <button type="button" class="btn btn-active-light btn-color-gray-500 fw-bold px-6" @onclick="CloseModal">Hủy, quay lại</button>
                    <button type="button" class="btn btn-primary fw-bold px-6" @onclick="ConfirmScan">Xác nhận & Điền mẫu form</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isVisible = false;
    private CccdData? scannedData;
    private TaskCompletionSource<CccdData?>? tcs;

    public async Task<CccdData?> ScanAsync()
    {
        try 
        {
            // Reset task completion source
            tcs = new TaskCompletionSource<CccdData?>();

            // Bước 1: Hiển thị trạng thái đang quét (vẫn dùng Swal cho loading giả lập vì nó đẹp)
            await JSRuntime.InvokeVoidAsync("Swal.fire", new
            {
                title = "Đang quét CCCD...",
                text = "Hệ thống AI đang kết nối thiết bị và bóc tách dữ liệu thẻ chip. Vui lòng đợi...",
                allowOutsideClick = false,
                showConfirmButton = false,
                timer = 15000, 
                didOpen = new { }
            });
            await JSRuntime.InvokeVoidAsync("Swal.showLoading");
            
            // Bước 2: Giả lập quét dữ liệu
            await Task.Delay(2500); 

            // Initialize fake data matching the user provided sample
            scannedData = new CccdData {
                Name = "LÊ THỊ HƯƠNG", 
                IdCard = "034199008899",
                DOB = new DateTime(1999, 2, 20),
                Gender = "Nữ",
                Hometown = "Phú Lương, Đông Hưng, Thái Bình",
                Address = "Thôn Quảng Hợp, xã Quảng Sơn, huyện Đắk Glong, tỉnh Đắk Nông",
                Nationality = "Việt Nam",
                Ethnicity = "Kinh",
                Religion = "Không",
                IssueDate = "20/01/2021",
                IssuePlace = "Cục Cảnh sát QLHC về TTXH"
            };

            // Close loading alert
            await JSRuntime.InvokeVoidAsync("Swal.close");

            // Bước 3: Show Modal
            isVisible = true;
            StateHasChanged();

            // Wait for user action
            return await tcs.Task;
        } 
        catch (Exception ex) 
        {
            if (ex is TaskCanceledException || ex is JSDisconnectedException) 
                return null;
            
            await JSRuntime.InvokeVoidAsync("Swal.fire", "Thông báo", "Có lỗi xảy ra: " + ex.Message, "error");
            return null;
        }
    }

    private void CloseModal()
    {
        isVisible = false;
        tcs?.TrySetResult(null); // Return null if cancelled
        StateHasChanged();
    }

    private async Task ConfirmScan()
    {
        isVisible = false;
        
        await JSRuntime.InvokeVoidAsync("Swal.fire", new {
            title = "Thành công!",
            text = "Dữ liệu đã được bóc tách và sẵn sàng sử dụng.",
            icon = "success",
            timer = 1500,
            showConfirmButton = false
        });

        tcs?.TrySetResult(scannedData);
        StateHasChanged();
    }
}
