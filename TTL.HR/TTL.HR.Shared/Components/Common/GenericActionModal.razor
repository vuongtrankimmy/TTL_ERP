@using Microsoft.AspNetCore.Components
@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bolder text-@Color">@Title</h5>
                    <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" @onclick="OnCancel">
                        <i class="ki-outline ki-cross fs-1"></i>
                    </div>
                </div>
                <div class="modal-body py-10">
                    <div class="text-center mb-9">
                        <div class="symbol symbol-100px symbol-circle mb-7">
                            <div class="symbol-label bg-light-@Color">
                                <i class="@Icon fs-5x text-@Color"></i>
                            </div>
                        </div>
                        <h2 class="fw-bold text-dark mb-3">@Heading</h2>
                        <div class="text-gray-600 fw-semibold fs-6 px-5">@Message</div>
                    </div>

                    @if (ShowReasonInput)
                    {
                        <div class="mb-5 text-start">
                            <label class="form-label fw-bold text-gray-700 fs-7">@(IsReasonRequired ? "Lý do (Bắt buộc)" : "Lý do")</label>
                            <textarea class="form-control form-control-solid border-gray-200" 
                                      rows="3" 
                                      placeholder="@ReasonPlaceholder" 
                                      @bind="_reasonInput" @bind:event="oninput"></textarea>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(RequiredVerificationText))
                    {
                        <div class="mb-2 text-start">
                            <label class="form-label fw-bold text-gray-700 fs-7">Để xác nhận, vui lòng nhập <span class="badge badge-light-@Color text-@Color fw-bolder">@RequiredVerificationText</span></label>
                            <input type="text" class="form-control form-control-solid border-@Color border-opacity-25" 
                                   placeholder="Nhập yêu cầu xác nhận..." 
                                   @bind="_verificationInput" @bind:event="oninput" />
                        </div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0 pb-10 justify-content-center">
                    <button type="button" class="btn btn-light me-3 fw-bold px-9" @onclick="OnCancel">@CancelLabel</button>
                    <button type="button" class="btn btn-@Color fw-bold px-9 shadow-sm" 
                            disabled="@IsConfirmDisabled" 
                            @onclick="OnConfirm">
                        <span class="indicator-label">@ConfirmLabel</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}
