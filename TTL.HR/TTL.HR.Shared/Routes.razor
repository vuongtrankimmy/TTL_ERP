<Router AppAssembly="typeof(Layout.MainLayout).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            </ChildContent>
            <ErrorContent>
                <div class="m-10">
                    <div class="alert alert-custom alert-light-danger fade show mb-5 p-5" role="alert">
                        <div class="alert-icon"><i class="flaticon-warning"></i></div>
                        <div class="alert-text">
                            <h4 class="alert-heading font-weight-bolder">Hệ thống gặp sự cố tạm thời</h4>
                            <p>Đã xảy ra lỗi không mong muốn trong quá trình xử lý. Vui lòng tải lại trang hoặc quay lại sau.</p>
                            <hr>
                            <button class="btn btn-danger font-weight-bold" onclick="location.reload()">Tải lại trang</button>
                        </div>
                    </div>
                </div>
            </ErrorContent>
        </ErrorBoundary>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    private ErrorBoundary? _errorBoundary;

    protected override void OnParametersSet()
    {
        // Reset error boundary on each navigation
        _errorBoundary?.Recover();
    }
}
