@inject IStringLocalizer<SharedResource> L

<div id="kt_app_sidebar" class="app-sidebar flex-column" data-kt-drawer="true" data-kt-drawer-name="app-sidebar" data-kt-drawer-activate="{default: true, lg: false}" data-kt-drawer-overlay="true" data-kt-drawer-width="225px" data-kt-drawer-direction="start" data-kt-drawer-toggle="#kt_app_sidebar_mobile_toggle">
	<!--begin::Logo-->
	<div class="app-sidebar-logo px-6 d-flex align-items-center justify-content-center border-bottom border-gray-300" id="kt_app_sidebar_logo" style="height: var(--bs-app-header-height, 100px); flex-shrink: 0;">
		<!--begin::Logo image-->
		<a href="/dashboard" class="d-flex align-items-center justify-content-center w-100 h-100">
            @if (!string.IsNullOrEmpty(SettingsService.CachedSettings?.LogoUrl))
            {
                <div class="ttl-logo-default-container">
                    <img alt="Logo" src="@SettingsService.CachedSettings.LogoUrl" class="ttl-logo-default h-45px" style="object-fit: contain;" />
                </div>
                <div class="ttl-logo-minimize-container">
                    <img alt="Logo" src="@SettingsService.CachedSettings.LogoUrl" class="ttl-logo-minimize h-30px" style="object-fit: contain;" />
                </div>
            }
            else
            {
                <div class="ttl-logo-default-container">
                    <img alt="Logo" src="_content/TTL.HR.Shared/assets/media/logos/default.svg" class="ttl-logo-default h-35px" />
                </div>
                <div class="ttl-logo-minimize-container">
                    <img alt="Logo" src="_content/TTL.HR.Shared/assets/media/logos/default-small.svg" class="ttl-logo-minimize h-25px" />
                </div>
            }
		</a>
		<!--end::Logo image-->

		<!--begin::Sidebar toggle-->
		<div id="kt_app_sidebar_toggle" class="sidebar-toggle-btn"
			 data-kt-toggle="true" data-kt-toggle-state="active" data-kt-toggle-target="body" data-kt-toggle-name="app-sidebar-minimize"
			 @onclick="ToggleSidebar"
			 title="Thu gọn / Mở rộng sidebar">
			<i class="ki-outline ki-left fs-5 sidebar-toggle-icon"></i>
		</div>
		<!--end::Sidebar toggle-->
	</div>
	<!--end::Logo-->

	<!--begin::sidebar menu-->
	<div class="app-sidebar-menu flex-column-fluid">
		<!--begin::Menu wrapper-->
		<div id="kt_app_sidebar_menu_wrapper" class="app-sidebar-wrapper hover-scroll-overlay-y my-5" 
             style="height: calc(100vh - 200px);"
             data-kt-scroll="true" data-kt-scroll-activate="true" data-kt-scroll-height="auto" 
             data-kt-scroll-dependencies="#kt_app_sidebar_logo, #kt_app_sidebar_footer" 
             data-kt-scroll-wrappers="#kt_app_sidebar_menu_wrapper" data-kt-scroll-offset="5px">
			<!--begin::Menu-->
			<div class="menu menu-column menu-rounded menu-sub-indention px-3" id="kt_app_sidebar_menu" data-kt-menu="true">
                @foreach (var item in _menuItems)
                {
                    if (item.IsSection)
                    {
                        <div class="menu-item pt-5">
                            <div class="menu-content">
                                <span class="menu-heading fw-bold text-uppercase fs-7">@L[item.Title]</span>
                            </div>
                        </div>
                    }
                    else if (item.HasSubItems)
                    {
                        <div data-kt-menu-trigger="click" class="menu-item menu-accordion">
                            <span class="menu-link py-3" title="@L[item.Title]">
                                <span class="menu-icon">
                                    <i class="@item.Icon fs-2"></i>
                                </span>
                                <span class="menu-title">@L[item.Title]</span>
                                <span class="menu-arrow"></span>
                            </span>
                            <div class="menu-sub menu-sub-accordion">
                                @foreach (var subItem in item.SubItems)
                                {
                                    <div class="menu-item">
                                        <NavLink class="menu-link" href="@subItem.Href" Match="NavLinkMatch.Prefix" title="@L[subItem.Title]">
                                            <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                                            <span class="menu-title">@L[subItem.Title]</span>
                                        </NavLink>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="menu-item">
                            <NavLink class="menu-link py-3" href="@item.Href" Match="NavLinkMatch.All" title="@L[item.Title]">
                                <span class="menu-icon">
                                    <i class="@item.Icon fs-2"></i>
                                </span>
                                <span class="menu-title">@L[item.Title]</span>
                            </NavLink>
                        </div>
                    }
                }
			</div>
			<!--end::Menu-->
		</div>
		<!--end::Menu wrapper-->
	</div>
	<!--end::sidebar menu-->

	<!--begin::Footer-->
	<div class="app-sidebar-footer d-flex align-items-center px-8 pb-10 pt-6 flex-column-auto border-top border-gray-300" id="kt_app_sidebar_footer" style="margin-top: auto;">
		<div class="d-flex flex-stack w-100">
			<!--begin::User info-->
			<div class="d-flex align-items-center cursor-pointer me-3" 
				 id="kt_user_menu_toggle" 
				 data-kt-menu-trigger="{default: 'click', lg: 'hover'}" 
				 data-kt-menu-overflow="true" 
				 data-kt-menu-placement="top-start">
				<div class="symbol symbol-circle symbol-40px">
                    @if (!string.IsNullOrEmpty(_currentEmployee?.AvatarUrl))
                    {
                        <img src="@_currentEmployee.AvatarUrl" alt="user" />
                    }
                    else if (!string.IsNullOrEmpty(_currentUser?.AvatarUrl))
                    {
                        <img src="@_currentUser.AvatarUrl" alt="user" />
                    }
                    else
                    {
                        <img src="https://ui-avatars.com/api/?name=@(System.Uri.EscapeDataString(_currentEmployee?.FullName ?? _currentUser?.FullName ?? "User"))&background=random" alt="user" />
                    }
					<div class="bg-success position-absolute rounded-circle translate-middle start-100 top-10 top-100 border border-white border-2 h-10px w-10px"></div>
				</div>
				<div class="d-flex flex-column ms-3 app-sidebar-user-info">
					<span class="text-gray-900 fw-bold fs-7 mb-1 text-truncate" style="max-width: 100px;">@(_currentEmployee?.FullName ?? _currentUser?.FullName ?? "N/A")</span>
					<span class="text-gray-600 fw-semibold fs-8 text-truncate" style="max-width: 100px;">@(_currentEmployee?.PositionName ?? _currentUser?.Role ?? "User")</span>
				</div>
			</div>
			<!--end::User info-->

			<!--begin::Theme Switcher-->
            <div class="d-flex align-items-center ms-auto">
                <button type="button" class="btn btn-icon btn-sm btn-active-light-primary" @onclick="ToggleTheme">
                    <i class="ki-outline ki-night-day fs-2 text-gray-600 theme-light-show"></i>
                    <i class="ki-outline ki-moon fs-2 text-gray-600 theme-dark-show"></i>
                </button>
            </div>
            <!--end::Theme Switcher-->

			<!--begin::User menu-->
			<div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg menu-state-color fw-semibold py-4 fs-6 w-275px" data-kt-menu="true">
				<div class="menu-item px-3">
					<div class="menu-content d-flex align-items-center px-3">
						<div class="symbol symbol-50px me-5">
                            @if (!string.IsNullOrEmpty(_currentEmployee?.AvatarUrl))
                            {
                                <img src="@_currentEmployee.AvatarUrl" alt="user" />
                            }
                            else if (!string.IsNullOrEmpty(_currentUser?.AvatarUrl))
                            {
                                <img src="@_currentUser.AvatarUrl" alt="user" />
                            }
                            else
                            {
                                <img src="https://ui-avatars.com/api/?name=@(System.Uri.EscapeDataString(_currentEmployee?.FullName ?? _currentUser?.FullName ?? "User"))&background=random" alt="user" />
                            }
						</div>
						<div class="d-flex flex-column">
							<div class="fw-bold d-flex align-items-center fs-5">@(_currentEmployee?.FullName ?? _currentUser?.FullName ?? "N/A")
							<span class="badge badge-light-success fw-bold fs-8 px-2 py-1 ms-2">@L["Status_Active"]</span></div>
							<a href="/user/profile" class="fw-semibold text-muted text-hover-primary fs-7">@(_currentEmployee?.Email ?? _currentUser?.Email ?? _currentUser?.Username ?? "N/A")</a>
						</div>
					</div>
				</div>
				<div class="separator my-2"></div>
				<div class="menu-item px-5">
					<a href="/user/profile" class="menu-link px-5">@L["Label_MyProfile"]</a>
				</div>
				<div class="menu-item px-5">
					<a href="/user/profile?tab=audit" class="menu-link px-5">@L["Label_ActivityLog"]</a>
				</div>
				<div class="separator my-2"></div>
				<div class="menu-item px-5">
					<a href="/auth/logout" class="menu-link px-5">@L["Label_Logout"]</a>
				</div>
			</div>
			<!--end::User menu-->
		</div>
	</div>
	<!--end::Footer-->
</div>

