
<div id="kt_app_header" class="app-header">
	<!--begin::Header container-->
	<div class="app-container container-fluid d-flex align-items-stretch flex-stack" id="kt_app_header_container">
		<!--begin::Sidebar toggle-->
		<div class="d-flex align-items-center d-block d-lg-none ms-n3" title="Show sidebar menu">
			<div class="btn btn-icon btn-active-color-primary w-35px h-35px me-2" id="kt_app_sidebar_mobile_toggle">
				<i class="ki-outline ki-abstract-14 fs-2"></i>
			</div>
			<!--begin::Logo image-->
			<a href="/">
                @if (!string.IsNullOrEmpty(SettingsService.CachedSettings?.LogoUrl))
                {
                    <img alt="Logo" src="@SettingsService.CachedSettings.LogoUrl" style="width: 120px; max-height: 35px; object-fit: contain;" />
                }
                else
                {
                    <img alt="Logo" src="/_content/TTL.HR.Shared/assets/media/logos/demo42.svg" class="h-30px" />
                }
			</a>

			<!--end::Logo image-->
		</div>

		<!--end::Sidebar toggle-->
		<!--begin::Toolbar wrapper-->
		<div class="app-navbar flex-lg-grow-1" id="kt_app_header_navbar">
			<div class="app-navbar-item d-flex align-items-stretch flex-lg-grow-1">
				<!--begin::Page title-->
				<div class="page-title d-flex flex-column justify-content-center flex-wrap me-3 px-4">
					<!--begin::Title-->
					<h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">
						@L[_breadcrumbs.LastOrDefault()?.Title ?? "Dashboard"]
					</h1>
					<!--end::Title-->
					<!--begin::Breadcrumb-->
					<ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
						<li class="breadcrumb-item text-muted">
							<a href="/" class="text-muted text-hover-primary">@L["Label_Home"]</a>
						</li>
						@if (_breadcrumbs != null)
						{
							@foreach (var crumb in _breadcrumbs)
							{
								<li class="breadcrumb-item">
									<span class="bullet bg-gray-500 w-5px h-2px"></span>
								</li>
								<li class="breadcrumb-item text-muted">@L[crumb.Title]</li>
							}
						}
					</ul>
					<!--end::Breadcrumb-->
				</div>
				<!--end::Page title-->
			</div>
			<!--begin::Notifications-->
			<div class="app-navbar-item ms-1 ms-md-3">
				<!--begin::Menu- wrapper-->
				<div class="btn btn-icon btn-custom btn-color-gray-600 btn-active-light btn-active-color-primary w-35px h-35px w-md-40px h-md-40px" data-kt-menu-trigger="{default: 'click', lg: 'hover'}" data-kt-menu-attach="parent" data-kt-menu-placement="bottom-end">
					<i class="ki-outline ki-calendar fs-1"></i>
				</div>
				<!--begin::Menu-->
				<div class="menu menu-sub menu-sub-dropdown menu-column w-350px w-lg-375px" data-kt-menu="true" id="kt_menu_notifications">
					<!--begin::Heading-->
					<div class="d-flex flex-column bgi-no-repeat rounded-top" style="background-image:url('/_content/TTL.HR.Shared/assets/media/misc/menu-header-bg.jpg')">
						<!--begin::Title-->
						<h3 class="text-white fw-semibold px-9 mt-10 mb-6">
							@L["Label_Notifications"]
							<span class="fs-8 opacity-75 ps-3">@_notifications.Count() thông báo</span>
						</h3>
						<!--end::Title-->
						<!--begin::Tabs-->
						<ul class="nav nav-line-tabs nav-line-tabs-2x nav-stretch fw-semibold px-9">
							<li class="nav-item">
								<a class="nav-link text-white opacity-75 opacity-state-100 pb-4 @(_activeNotifyTab == "Notify" ? "active" : "")" href="javascript:;" @onclick='() => _activeNotifyTab = "Notify"'>Notify</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-white opacity-75 opacity-state-100 pb-4 @(_activeNotifyTab == "Email" ? "active" : "")" href="javascript:;" @onclick='() => _activeNotifyTab = "Email"'>Email</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-white opacity-75 opacity-state-100 pb-4 @(_activeNotifyTab == "SMS" ? "active" : "")" href="javascript:;" @onclick='() => _activeNotifyTab = "SMS"'>SMS</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-white opacity-75 opacity-state-100 pb-4 @(_activeNotifyTab == "System" ? "active" : "")" href="javascript:;" @onclick='() => _activeNotifyTab = "System"'>System</a>
							</li>
						</ul>
						<!--end::Tabs-->
					</div>
					<!--end::Heading-->
					<!--begin::Tab content-->
					<div class="tab-content">
						<!--begin::Tab panel-->
						<div class="tab-pane fade show active">
							<!--begin::Items-->
							<div class="scroll-y mh-325px my-5 px-8">
                                @if (_notifications != null && _notifications.Any(n => n.Type == _activeNotifyTab))
                                {
                                    @foreach (var notify in _notifications.Where(n => n.Type == _activeNotifyTab).OrderByDescending(n => n.CreatedAt))
                                    {
                                        <!--begin::Item-->
                                        <div class="d-flex flex-stack py-4 @(notify.IsRead ? "opacity-50" : "")" @onclick="() => MarkAsRead(notify)">
                                            <!--begin::Section-->
                                            <div class="d-flex align-items-center">
                                                <!--begin::Symbol-->
                                                <div class="symbol symbol-35px me-4">
                                                    <span class="symbol-label @(GetNotifyBgClass(notify.Type))">
                                                        <i class="@(notify.Icon ?? "ki-outline ki-notification-on") fs-2 @(GetNotifyTextClass(notify.Type))"></i>
                                                    </span>
                                                </div>
                                                <!--end::Symbol-->
                                                <!--begin::Title-->
                                                <div class="mb-0 me-2">
                                                    <a href="@(notify.Link ?? notify.ActionUrl ?? "javascript:;")" class="fs-6 text-gray-800 text-hover-primary fw-bold">@notify.Title</a>
                                                    <div class="text-gray-500 fs-7 text-truncate w-200px">@notify.Message</div>
                                                </div>
                                                <!--end::Title-->
                                            </div>
                                            <!--end::Section-->
                                            <!--begin::Label-->
                                            <span class="badge badge-light fs-8">@GetTimeAgo(notify.CreatedAt)</span>
                                            <!--end::Label-->
                                        </div>
                                        <!--end::Item-->
                                    }
                                }
                                else
                                {
                                    <div class="d-flex flex-column px-9 py-10">
                                        <div class="text-center text-gray-600 fw-semibold pt-1">Không có thông báo mới</div>
                                    </div>
                                }
							</div>
							<!--end::Items-->
							<!--begin::View more-->
							<div class="py-3 text-center border-top">
								<a href="/notifications" class="btn btn-color-gray-600 btn-active-color-primary">
									@L["Label_ViewAll"]
									<i class="ki-outline ki-arrow-right fs-5"></i>
								</a>
							</div>
							<!--end::View more-->
						</div>
					</div>
					<!--end::Tab content-->
				</div>
				<!--end::Menu-->
				<!--end::Menu wrapper-->
			</div>
			<!--end::Notifications-->
			<!--begin::Quick links-->
			<div class="app-navbar-item ms-1 ms-md-3">
				<!--begin::Menu- wrapper-->
				<div class="btn btn-icon btn-custom btn-color-gray-600 btn-active-light btn-active-color-primary w-35px h-35px w-md-40px h-md-40px" data-kt-menu-trigger="{default: 'click', lg: 'hover'}" data-kt-menu-attach="parent" data-kt-menu-placement="bottom-end">
					<i class="ki-outline ki-abstract-26 fs-1"></i>
				</div>
				<!--begin::Menu-->
				<div class="menu menu-sub menu-sub-dropdown menu-column w-250px w-lg-325px" data-kt-menu="true">
					<!--begin::Heading-->
					<div class="d-flex flex-column flex-center bgi-no-repeat rounded-top px-9 py-10" style="background-image:url('/_content/TTL.HR.Shared/assets/media/misc/menu-header-bg.jpg')">
						<!--begin::Title-->
						<h3 class="text-white fw-semibold mb-3">@L["Label_RecentAccess"]</h3>
						<!--end::Title-->
						<!--begin::Status-->
						<span class="badge bg-primary text-inverse-primary py-2 px-3">Top 5 tương tác gần nhất</span>
						<!--end::Status-->
					</div>
					<!--end::Heading-->
					<!--begin:Nav-->
					<div class="row g-0">
                        @if (_recentMenus != null && _recentMenus.Any())
                        {
                            @foreach (var menu in _recentMenus)
                            {
                                <!--begin:Item-->
                                <div class="col-6">
                                    <a href="@menu.Href" class="d-flex flex-column flex-center h-100 p-6 bg-hover-light border-end border-bottom text-center">
                                        <i class="@(string.IsNullOrEmpty(menu.Icon) ? "ki-outline ki-abstract-26" : menu.Icon) fs-3x text-primary mb-2"></i>
                                        <span class="fs-7 fw-semibold text-gray-800 mb-0">@L[menu.Title]</span>
                                    </a>
                                </div>
                                <!--end:Item-->
                            }
                        }
                        else
                        {
                            <div class="col-12 p-10 text-center">
                                <span class="text-gray-500 fs-7">Chưa có dữ liệu tương tác gần đây</span>
                            </div>
                        }
					</div>
					<!--end:Nav-->
					<!--begin::View more-->
					<div class="py-2 text-center border-top">
						<a href="/" class="btn btn-color-gray-600 btn-active-color-primary">
							Dashboard
							<i class="ki-outline ki-arrow-right fs-5"></i>
						</a>
					</div>
					<!--end::View more-->
				</div>
				<!--end::Menu-->
				<!--end::Menu wrapper-->
			</div>
			<!--end::Quick links-->
			<!--end::Chat-->
			<!--begin::Notifications-->
			<div class="app-navbar-item ms-1 ms-md-3">
				<!--begin::Menu- wrapper-->
				<div class="btn btn-icon btn-custom btn-color-gray-600 btn-active-light btn-active-color-primary w-35px h-35px w-md-40px h-md-40px">
					<i class="ki-outline ki-notification-on fs-1"></i>
				</div>
				<!--end::Menu- wrapper-->
			</div>
			<!--end::Notifications-->
			<!--begin::Header menu toggle-->
			<!--end::Header menu toggle-->
		</div>
		<!--end::Navbar-->
	</div>
	<!--end::Header container-->
</div>

@implements IDisposable

