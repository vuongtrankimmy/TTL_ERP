@inherits LayoutComponentBase
@inject ISettingsService SettingsService

@code {
    protected override async Task OnInitializedAsync()
    {
        try 
        {
            await SettingsService.InitializeAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing settings in AuthLayout: {ex.Message}");
        }
    }
}


<div class="d-flex flex-column flex-root" id="kt_app_root">
    <!--begin::Authentication - Sign-in -->
    <div class="d-flex flex-column flex-column-fluid bgi-size-cover bgi-position-center" style="background-image: url('/_content/TTL.HR.Shared/assets/media/auth/bg1.jpg')">
        <!--begin::Content-->
        <div class="d-flex flex-column flex-center p-10 p-lg-20">
            <!--begin::Logo-->
            <a href="/" class="mb-10">
                @if (!string.IsNullOrEmpty(SettingsService.CachedSettings?.LogoUrl))
                {
                    <img alt="Logo" src="@SettingsService.CachedSettings.LogoUrl" class="w-200px w-lg-250px" style="object-fit: contain;" />
                }
                else
                {
                    <img alt="Logo" src="/_content/TTL.HR.Shared/assets/media/logos/default.svg" class="h-60px" />
                }
            </a>

            <!--end::Logo-->

            <!--begin::Wrapper-->
            <div class="w-lg-500px bg-body shadow-sm rounded p-10 p-lg-15 mx-auto">
                @Body
            </div>
            <!--end::Wrapper-->
        </div>
        <!--end::Content-->
        <!--begin::Footer-->
        <div class="d-flex flex-center flex-column-auto p-10">
            <!--begin::Links-->
            <div class="d-flex align-items-center fw-semibold fs-6">
                <a href="#" class="text-muted text-hover-primary px-2">Điều khoản</a>
                <a href="#" class="text-muted text-hover-primary px-2">Kế hoạch</a>
                <a href="#" class="text-muted text-hover-primary px-2">Liên hệ</a>
            </div>
            <!--end::Links-->
        </div>
        <!--end::Footer-->
    </div>
    <!--end::Authentication - Sign-in-->
</div>
