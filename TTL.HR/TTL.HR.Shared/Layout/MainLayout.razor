@using TTL.HR.Shared.Layout.Component.Footer
@using TTL.HR.Shared.Layout.Component.Header
@using TTL.HR.Shared.Layout.Component.Sidebar
@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject ISettingsService SettingsService

@code {
    private bool _isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            AuthService.InitializeAsync(),
            SettingsService.InitializeAsync()
        );
        _isInitialized = true;
    }
}

<!--begin::Theme mode setup on page load-->
<script>
    // Initialize theme and sidebar state via helper
    if (window.LayoutHelper && typeof window.LayoutHelper.initSidebar === 'function') {
        window.LayoutHelper.initSidebar();
    } else {
        // Fallback for early loading
        const themeMode = localStorage.getItem("data-bs-theme") || "light";
        document.documentElement.setAttribute("data-bs-theme", themeMode);
        
        const savedState = localStorage.getItem('kt_app_sidebar_minimize');
        if (savedState) {
            document.body.setAttribute('data-kt-app-sidebar-minimize', savedState);
        }
    }
</script>

<style>
    /* Sidebar Structural Fixes */
    .app-sidebar {
        height: 100vh !important;
        display: flex !important;
        flex-direction: column !important;
    }

    /* Fixed Layout Fixes */
    [data-kt-app-sidebar-minimize="on"] .app-sidebar-user-info { display: none !important; }
    
    /* Logo Visibility Safeguard */
    [data-kt-app-sidebar-minimize="off"] .app-sidebar-logo-minimize { display: none !important; }
    [data-kt-app-sidebar-minimize="on"] .app-sidebar-logo-default { display: none !important; }
    [data-kt-app-sidebar-minimize="on"] .app-sidebar-logo-minimize { display: block !important; }

    /* Theme visibility helpers */
    [data-bs-theme="light"] .theme-dark-show { display: none !important; }
    [data-bs-theme="dark"] .theme-light-show { display: none !important; }

    /* Button Polish for Dark Mode */
    [data-bs-theme="dark"] .btn-active-light-primary:hover {
        background-color: rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
    }
    
    /* Ensure scrollbar looks good in dark mode */
    [data-bs-theme="dark"] ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.15);
    }
</style>
<!--end::Theme mode setup on page load-->

@if (!_isInitialized)
{
    <div class="d-flex align-items-center justify-content-center vh-100 flex-column">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div class="mt-4 text-gray-600 fw-semibold fs-5">Đang tải dữ liệu...</div>
    </div>
}
else
{
    <!--begin::App-->
    <div class="d-flex flex-column flex-root app-root" id="kt_app_root">
	    <!--begin::Page-->
	    <div class="app-page flex-column flex-column-fluid" id="kt_app_page">
		    <!--begin::Header-->
		    <Header />
		    <!--end::Header-->
		    <!--begin::Wrapper-->
		    <div class="app-wrapper flex-column flex-row-fluid" id="kt_app_wrapper">
			    <!--begin::Sidebar-->
			    <Sidebar />
			    <!--end::Sidebar-->
			    <!--begin::Main-->
			    <div class="app-main flex-column flex-row-fluid" id="kt_app_main">
				    <!--begin::Content wrapper-->
				    <div class="d-flex flex-column flex-column-fluid">
					    <!--begin::Content-->
					    <div id="kt_app_content" class="app-content app-content-stretch">
						    <!--begin::Content container-->
						    <div id="kt_app_content_container" class="app-container container-fluid">
							    @Body
						    </div>
						    <!--end::Content container-->
					    </div>
					    <!--end::Content-->
				    </div>
				    <!--end::Content wrapper-->
				    <!--begin::Footer-->
				    <Footer/>
				    <!--end::Footer-->
			    </div>

			    <!--end:::Main-->
		    </div>
		    <!--end::Wrapper-->
	    </div>
	    <!--end::Page-->
    </div>
    <!--end::App-->
}

<div id="blazor-error-ui" data-nosnippet>
	An unhandled error has occurred.
	<a href="." class="reload">Reload</a>
	<span class="dismiss">🗙</span>
</div>
