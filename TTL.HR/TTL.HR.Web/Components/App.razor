    <script>
        // Resolve conflict between Metronic's internal svg.js and ApexCharts v3+
        // Force ApexCharts to use its own bundled svg.js by clearing global SVG if present
        if (window.SVG) { window._MetronicSVG = window.SVG; window.SVG = undefined; }
    </script>
    <script src="_content/Blazor-ApexCharts/js/apexcharts.esm.js" type="module"></script>
    <script src="_content/Blazor-ApexCharts/js/blazor-apexcharts.js" type="module"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.openEmployeeDetail = () => {
            const drawerElement = document.querySelector('#kt_drawer_employee_detail');
            if (drawerElement) {
                const drawerHandle = KTDrawer.getInstance(drawerElement);
                if (drawerHandle) {
                    drawerHandle.show();
                } else {
                    // Fallback in case instance isn't ready
                    const newHandle = new KTDrawer(drawerElement);
                    newHandle.show();
                }
            }
        };
        window.downloadFile = (fileName, contentType, base64) => {
            const byteCharacters = atob(base64);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray], { type: contentType });
            
            const url = URL.createObjectURL(blob);
            const anchorElement = document.createElement('a');
            anchorElement.href = url;
            anchorElement.download = fileName ?? '';
            anchorElement.click();
            anchorElement.remove();
            URL.revokeObjectURL(url);
        };

        window.printPdf = (base64) => {
            const byteCharacters = atob(base64);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray], { type: 'application/pdf' });
            const url = URL.createObjectURL(blob);
            
            // Create a temporary iframe for printing or open in new tab
            const pdfWindow = window.open(url);
            if (pdfWindow) {
                // Small delay to ensure the PDF is loaded for printing
                setTimeout(() => {
                    pdfWindow.print();
                }, 500);
            }
        };

        window.showModal = (selector) => {
            const el = document.querySelector(selector);
            if (el && typeof bootstrap !== 'undefined') {
                const modal = bootstrap.Modal.getOrCreateInstance(el);
                modal.show();
            } else if (el && typeof $ !== 'undefined') {
                $(el).modal('show');
            } else {
                console.error('Modal element not found or Bootstrap not loaded');
            }
        };
    </script>

</body>

